@using System.Globalization
@using EEMOCantilanSDS.Application.Dtos.Backup
@inject IBackupApiClient BackupApi
@inject IJSRuntime JS
@implements IDisposable

@*
    RestoreWatcher — cross-page "restore complete" popup.
    Mounted once in the Sidebar so it lives on every admin page and survives navigation. When a restore
    is triggered on the Backups page it writes a localStorage marker ("eemo.restore.pending"); this
    watcher then polls the restore-runs feed until the newest run settles, and shows a success/failure
    modal wherever the Head happens to be. The already-notified run id is remembered so it only fires once.
*@

@if (_show)
{
    <div class="rw-overlay" @onclick="Close">
        <div class="rw-modal @(_success ? "rw-ok" : "rw-err")" role="dialog" aria-modal="true"
             aria-label="@(_success ? "Database restored" : "Restore did not complete")"
             @onclick:stopPropagation="true">
            <button class="rw-close" @onclick="Close" aria-label="Close">
                <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
            </button>

            <div class="rw-icon">
                @if (_success)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                }
            </div>

            <div class="rw-title">@(_success ? "Database restored" : "Restore did not complete")</div>
            <div class="rw-body">
                @if (_success)
                {
                    <text>The database was restored from the latest backup (finished @_finishedLabel).</text>
                }
                else
                {
                    <text>The restore failed and was rolled back — your data is unchanged (a safety backup was taken).</text>
                }
            </div>

            <div class="rw-foot">
                <a class="rw-link" href="/settings/backups" @onclick="Close">View details<span class="rw-arrow">→</span></a>
                <button class="rw-btn" @onclick="Close">Close</button>
            </div>
        </div>
    </div>
}

@code {
    private const string PendingKey = "eemo.restore.pending";
    private const string LastNotifiedKey = "eemo.restore.lastNotified";

    private bool _show;
    private bool _success;
    private string _finishedLabel = string.Empty;
    private bool _started;
    private CancellationTokenSource? _cts;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _started) return;
        _started = true;

        string? pending = null;
        try
        {
            pending = await JS.InvokeAsync<string>("localStorage.getItem", PendingKey);
        }
        catch { /* interop not ready / unavailable — nothing to watch */ }

        if (string.IsNullOrWhiteSpace(pending)) return;

        if (!DateTime.TryParse(pending, CultureInfo.InvariantCulture,
                DateTimeStyles.RoundtripKind | DateTimeStyles.AdjustToUniversal, out var pendingTime))
            return;

        _ = PollAsync(pendingTime.ToUniversalTime());
    }

    private async Task PollAsync(DateTime pendingTimeUtc)
    {
        var cts = new CancellationTokenSource();
        _cts = cts;
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(8));
            var ticks = 0;
            while (await timer.WaitForNextTickAsync(cts.Token))
            {
                if (++ticks > 112) break;   // ~15 min safety cap

                var result = await BackupApi.GetRecentRestoreRunsAsync();
                var newest = result.IsSuccess ? result.Value?.FirstOrDefault() : null;
                if (newest is null) continue;

                if (!string.Equals(newest.Status, "completed", StringComparison.OrdinalIgnoreCase))
                    continue;

                if (newest.CreatedAt.ToUniversalTime() < pendingTimeUtc.AddSeconds(-60))
                    continue;

                string? lastNotified = null;
                try { lastNotified = await JS.InvokeAsync<string>("localStorage.getItem", LastNotifiedKey); }
                catch { /* ignore */ }

                if (string.Equals(newest.Id.ToString(), lastNotified, StringComparison.Ordinal))
                    break;   // already shown for this run

                _success = string.Equals(newest.Conclusion, "success", StringComparison.OrdinalIgnoreCase);
                _finishedLabel = PhilippineTime.ToPhilippineTime(newest.CreatedAt).ToString("MMM d, yyyy · h:mm tt");
                _show = true;

                try
                {
                    await JS.InvokeVoidAsync("localStorage.setItem", LastNotifiedKey, newest.Id.ToString());
                    await JS.InvokeVoidAsync("localStorage.removeItem", PendingKey);
                }
                catch { /* ignore */ }

                await InvokeAsync(StateHasChanged);
                break;
            }
        }
        catch (OperationCanceledException) { /* disposed */ }
        catch { /* stop watching quietly */ }
    }

    private void Close() => _show = false;

    public void Dispose()
    {
        _cts?.Cancel();
        _cts?.Dispose();
    }
}
