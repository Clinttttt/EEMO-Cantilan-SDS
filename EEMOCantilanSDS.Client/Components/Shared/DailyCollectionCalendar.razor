@using EEMOCantilanSDS.Application.Dtos.DailyCollections
@inject IDailyCollectionApiClient DailyCollectionApi

<div class="detail-section @SectionClass">
    <div class="detail-section-title">
        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
        Daily Collection — ₱@(DailyRate.ToString("0"))/day@(IsFishSection ? $" + Fish Fee (₱{FishRate.ToString("0")}/kg)" : "")
    </div>

    <div class="cal-nav">
        <button class="cal-nav-btn cal-nav-year" @onclick="PrevYear" title="Previous year">
            <svg viewBox="0 0 24 24"><polyline points="18 18 12 12 18 6" /><polyline points="11 18 5 12 11 6" /></svg>
        </button>
        <button class="cal-nav-btn" @onclick="PrevMonth" title="Previous month">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
        </button>
        <span class="cal-month-label">@CurrentMonth.ToString("MMMM yyyy")</span>
        <button class="cal-nav-btn" @onclick="NextMonth" disabled="@(!CanGoNext)" title="Next month">
            <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
        </button>
        <button class="cal-nav-btn cal-nav-year" @onclick="NextYear" disabled="@(!CanGoNextYear)" title="Next year">
            <svg viewBox="0 0 24 24"><polyline points="6 18 12 12 6 6" /><polyline points="13 18 19 12 13 6" /></svg>
        </button>
    </div>

    <div class="cal-grid-wrap @(IsFishSection ? "cal-grid-fish" : "")">
        <div class="cal-day-hdr">Sun</div>
        <div class="cal-day-hdr">Mon</div>
        <div class="cal-day-hdr">Tue</div>
        <div class="cal-day-hdr">Wed</div>
        <div class="cal-day-hdr">Thu</div>
        <div class="cal-day-hdr">Fri</div>
        <div class="cal-day-hdr">Sat</div>

        @for (int blank = 0; blank < CalendarOffset; blank++)
        {
            <div class="cal-cell cal-empty @(IsFishSection ? "cal-cell-fish" : "")"></div>
        }

        @for (int d = 1; d <= DaysInMonth; d++)
        {
            var day = new DateTime(CurrentMonth.Year, CurrentMonth.Month, d);
            var dayKey = day.ToString("yyyy-MM-dd");
            var today = EEMOCantilanSDS.Domain.Common.PhilippineTime.Today;
            var isFuture = DateOnly.FromDateTime(day) > today;
            var isToday = DateOnly.FromDateTime(day) == today;
            var isBeforeContract = ContractDate.HasValue && day.Date < ContractDate.Value.Date;
            var isMarked = MonthData?.Collections.ContainsKey(dayKey) == true && MonthData.Collections[dayKey].IsPaid;
            var isAbsent = MonthData?.Collections.ContainsKey(dayKey) == true && MonthData.Collections[dayKey].IsAbsent;
            var isClosed = MonthData?.Collections.ContainsKey(dayKey) == true && MonthData.Collections[dayKey].IsMarketClosed;
            // A future day that has already been pre-paid by admin should show as
            // collected (green), not as "Soon". Only unmark future days are out-of-scope.
            var isOutOfScope = (isFuture && !isMarked) || isBeforeContract;
            var cellClass = isBeforeContract ? "cal-before-contract"
                          : (isFuture && !isMarked) ? "cal-future"
                          : isMarked ? "cal-paid"
                          : isClosed ? "cal-closed"
                          : isAbsent ? "cal-absent"
                          : "cal-miss";
            var dailyKilo = MonthData?.Collections.ContainsKey(dayKey) == true ? MonthData.Collections[dayKey].FishKilos ?? 0 : 0;

            <div class="cal-cell @cellClass @(isToday ? "cal-today" : "") @(IsFishSection ? "cal-cell-fish" : "")">

                @if (isFuture && !isMarked)
                {
                    <div class="cal-overlay-label">Soon</div>
                }
                else if (isBeforeContract)
                {
                    <div class="cal-overlay-label cal-overlay-before">N/A</div>
                }

                <div class="cal-cell-header @(isOutOfScope || ReadOnly || isClosed ? "" : "cal-cell-header-clickable")"
                     @onclick="async () => { if (!isOutOfScope && !ReadOnly && !isClosed) await ToggleDay(day); }">
                    <span class="cal-num">@d</span>
                    @if (!isOutOfScope)
                    {
                        <span class="cal-status-icon @(isMarked ? "cal-icon-yes" : isClosed ? "cal-icon-closed" : isAbsent ? "cal-icon-absent" : "cal-icon-no")">
                            @if (isMarked)
                            {
                                <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                            }
                            else if (isClosed)
                            {
                                <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="10" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                            }
                            else if (isAbsent)
                            {
                                <svg viewBox="0 0 24 24"><line x1="6" y1="12" x2="18" y2="12" /></svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                            }
                        </span>
                    }
                </div>

                @if (IsFishSection && !isOutOfScope && isMarked)
                {
                    @if (ReadOnly)
                    {
                        <div class="cal-kilo-bottom">
                            <span class="cal-kilo-input-inline" style="cursor:default;">@((int)dailyKilo)</span>
                            <span class="cal-kilo-label-inline">kg</span>
                        </div>
                    }
                    else
                    {
                        <div class="cal-kilo-bottom" @onclick:stopPropagation="true">
                            <input type="number"
                                   min="0"
                                   step="1"
                                   placeholder="0"
                                   value="@((int)dailyKilo)"
                                   class="cal-kilo-input-inline"
                                   @onclick:stopPropagation="true"
                                   @onchange="@(e => UpdateFishKilo(day, int.TryParse(e.Value?.ToString(), out var k) ? k : 0))" />
                            <span class="cal-kilo-label-inline">kg</span>
                        </div>
                    }
                }
                else if (IsFishSection && !isOutOfScope)
                {
                    <div class="cal-kilo-bottom cal-kilo-placeholder"></div>
                }

            </div>
        }
    </div>

    <div class="cal-footer-stats">
        <div class="cal-sum-item">
            <span class="cal-sum-val cal-sum-green">@(MonthData?.DaysCollected ?? 0)</span>
            <span class="cal-sum-key">Days Collected</span>
        </div>
        @if ((MonthData?.DaysAbsent ?? 0) > 0)
        {
            <div class="cal-sum-item">
                <span class="cal-sum-val cal-sum-amber">@(MonthData?.DaysAbsent ?? 0)</span>
                <span class="cal-sum-key">Days Absent (excused)</span>
            </div>
        }
        @if ((MonthData?.DaysClosed ?? 0) > 0)
        {
            <div class="cal-sum-item">
                <span class="cal-sum-val cal-sum-closed">@(MonthData?.DaysClosed ?? 0)</span>
                <span class="cal-sum-key">Days Closed (market)</span>
            </div>
        }
        <div class="cal-sum-item">
            <span class="cal-sum-val">₱@((MonthData?.TotalDailyFee ?? 0).ToString("N0"))</span>
            <span class="cal-sum-key">Daily Collected @CurrentMonth.ToString("MMM yyyy")</span>
        </div>
        @if (IsFishSection)
        {
            <div class="cal-sum-item fish-fee-item">
                <span class="cal-sum-val">@((int)(MonthData?.TotalFishKilos ?? 0)) kg</span>
                <span class="cal-sum-key">Fish Total</span>
            </div>
            <div class="cal-sum-item fish-fee-item">
                <span class="cal-sum-val">₱@((MonthData?.GrandTotal ?? 0).ToString("N0"))</span>
                <span class="cal-sum-key">Total Fee (@CurrentMonth.ToString("MMM yyyy"))</span>
            </div>
        }
        @if (!IsFishSection)
        {
            <div class="cal-sum-item @(SectionClass)-fee-item">
                <span class="cal-sum-val">₱@((MonthData?.TotalDailyFee ?? 0).ToString("N0"))</span>
                <span class="cal-sum-key">Total Fee (@CurrentMonth.ToString("MMM yyyy"))</span>
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public Guid StallId { get; set; }
    [Parameter] public DateTime? ContractDate { get; set; }
    [Parameter] public bool IsFishSection { get; set; }
    // Tenant-resolved NPM daily + fish rates (₱30 / ₱1 ordinance fallback keeps Cantilan identical).
    [Parameter] public decimal DailyRate { get; set; } = 30m;
    [Parameter] public decimal FishRate { get; set; } = 1m;
    [Parameter] public string SectionClass { get; set; } = "";
    /// <summary>
    /// When true, the calendar is display-only. Day cells are not clickable and
    /// fish-kilo entries are shown as plain text. Set this on the admin/web side;
    /// leave false on the mobile collector side.
    /// </summary>
    [Parameter] public bool ReadOnly { get; set; } = false;

    private DateTime CurrentMonth = new DateTime(
        EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year,
        EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Month,
        1);
    private DailyCollectionMonthDto? MonthData;

    private int DaysInMonth => DateTime.DaysInMonth(CurrentMonth.Year, CurrentMonth.Month);
    private int CalendarOffset => (int)new DateTime(CurrentMonth.Year, CurrentMonth.Month, 1).DayOfWeek;
    private bool CanGoNext => CurrentMonth < new DateTime(
        EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year,
        EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Month,
        1);

    private Guid _loadedStallId;
    private bool _loadedOnce;

    protected override async Task OnParametersSetAsync()
    {
        // Only (re)load when the stall actually changes (or on first render). OnParametersSetAsync fires
        // on every parent re-render, so an unconditional load here re-fetched the month on every render.
        // Month navigation (Prev/Next) reloads on its own, independent of parameters.
        if (!_loadedOnce || _loadedStallId != StallId)
        {
            _loadedOnce = true;
            _loadedStallId = StallId;
            await LoadMonthData();
        }
    }

    private async Task LoadMonthData()
    {
        var result = await DailyCollectionApi.GetDailyCollectionMonthAsync(
            StallId,
            CurrentMonth.Year,
            CurrentMonth.Month);

        if (result.IsSuccess && result.Value != null)
        {
            MonthData = result.Value;
        }
        else
        {
            // If no data or error, ensure MonthData is null
            MonthData = null;
        }
        
        StateHasChanged();
    }

    private async Task PrevMonth()
    {
        CurrentMonth = CurrentMonth.AddMonths(-1);
        await LoadMonthData();
    }

    private async Task NextMonth()
    {
        if (CanGoNext)
        {
            CurrentMonth = CurrentMonth.AddMonths(1);
            await LoadMonthData();
        }
    }

    // Upper bound for navigation: the current (Philippine) month. Never navigate into the future.
    private static DateTime MaxMonth => new DateTime(
        EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year,
        EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Month,
        1);

    private bool CanGoNextYear => CurrentMonth < MaxMonth;

    private async Task PrevYear()
    {
        CurrentMonth = CurrentMonth.AddYears(-1);
        await LoadMonthData();
    }

    private async Task NextYear()
    {
        // Jump forward a year, but cap at the current month so we never land on a future period.
        var candidate = CurrentMonth.AddYears(1);
        if (candidate > MaxMonth) candidate = MaxMonth;
        if (candidate != CurrentMonth)
        {
            CurrentMonth = candidate;
            await LoadMonthData();
        }
    }

    private async Task ToggleDay(DateTime date)
    {
        var dayKey = date.ToString("yyyy-MM-dd");
        var entry = MonthData?.Collections.GetValueOrDefault(dayKey);
        var fishKilos = entry?.FishKilos;

        // Cycle the day's status: Unpaid → Collected → Absent → Unpaid. "Absent" excuses the day
        // (₱0 owed) for a payor who was legitimately not operating.
        bool nextPaid, nextAbsent;
        if (entry?.IsPaid == true)        { nextPaid = false; nextAbsent = true; }   // Collected → Absent
        else if (entry?.IsAbsent == true) { nextPaid = false; nextAbsent = false; }  // Absent → Unpaid
        else                              { nextPaid = true;  nextAbsent = false; }  // Unpaid → Collected

        var command = new Application.Command.DailyCollections.RecordDailyCollection.RecordDailyCollectionCommand(
            StallId: StallId,
            CollectionDate: DateOnly.FromDateTime(date),
            IsPaid: nextPaid,
            FishKilos: nextPaid ? fishKilos : null,
            IsAbsent: nextAbsent
        );

        var result = await DailyCollectionApi.RecordDailyCollectionAsync(command);

        if (result.IsSuccess)
        {
            // Force a fresh reload of the data
            MonthData = null;
            StateHasChanged();
            await LoadMonthData();
            StateHasChanged();
        }
    }

    private async Task UpdateFishKilo(DateTime date, int kilos)
    {
        var dayKey = date.ToString("yyyy-MM-dd");
        var isCollected = MonthData?.Collections.ContainsKey(dayKey) == true && MonthData.Collections[dayKey].IsPaid;

        if (isCollected)
        {
            var command = new Application.Command.DailyCollections.RecordDailyCollection.RecordDailyCollectionCommand(
                StallId: StallId,
                CollectionDate: DateOnly.FromDateTime(date),
                IsPaid: true,
                FishKilos: kilos > 0 ? (decimal)kilos : null
            );

            var result = await DailyCollectionApi.RecordDailyCollectionAsync(command);

            if (result.IsSuccess)
            {
                // Force a fresh reload of the data
                MonthData = null;
                StateHasChanged();
                await LoadMonthData();
                StateHasChanged();
            }
        }
    }
}
