@using EEMOCantilanSDS.Client.Components.Shared

@inject NavigationManager Navigation
@inject ISetupApiClient SetupApi
@* Prerendering is enabled at the interactive root. The setup check is persisted so the static
   prerender and interactive pass don't both call the setup endpoint. *@


<CascadingAuthenticationState>
    <Router AppAssembly="typeof(Program).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated != true)
                    {
                        <RedirectToLogin />
                    }
                    else
                    {
                        <AccessDenied />
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="routeData" Selector="h1" />
        </Found>
    </Router>
</CascadingAuthenticationState>


@code {
    private bool _hasCheckedSetup = false;

    [PersistentState]
    public bool? IsSetupRequired { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (_hasCheckedSetup) return;
        _hasCheckedSetup = true;

        var currentUri = Navigation.Uri;
        if (currentUri.Contains("/account-setup-admin") || currentUri.Contains("/login"))
            return;

        try
        {
            if (IsSetupRequired is null)
            {
                var result = await SetupApi.GetSetupStatusAsync();
                IsSetupRequired = result.IsSuccess && result.Value?.IsSetupRequired == true;
            }

            if (IsSetupRequired == true)
            {
                Navigation.NavigateTo("/account-setup-admin", true);
            }
        }
        catch
        {
            
        }
    }

}
