    private string GetCurrentPeriodLabel()
    {
        return SelectedPeriod switch
        {
            "Weekly" => GetWeeklyDateRangeLabel(),
            "Monthly" => CurrentDate.ToString("MMMM yyyy"),
            "Yearly" => CurrentDate.ToString("yyyy"),
            _ => string.Empty
        };
    }

    private string GetWeeklyDateRangeLabel()
    {
        // Calculate week number based on day of month (same as backend)
        var dayOfMonth = CurrentDate.Day;
        var weekNumber = ((dayOfMonth - 1) / 7) + 1;
        
        // Calculate start and end dates (same logic as backend)
        var startDay = (weekNumber - 1) * 7 + 1;
        var endDay = Math.Min(weekNumber * 7, DateTime.DaysInMonth(CurrentDate.Year, CurrentDate.Month));
        
        var startDate = new DateTime(CurrentDate.Year, CurrentDate.Month, startDay);
        var endDate = new DateTime(CurrentDate.Year, CurrentDate.Month, endDay);
        
        return $"{startDate:MMM dd} – {endDate:MMM dd, yyyy}";
    }

    private void NavigatePrevious()
    {
        if (SelectedPeriod == "Weekly")
        {
            // Calculate current week number
            var dayOfMonth = CurrentDate.Day;
            var currentWeekNumber = ((dayOfMonth - 1) / 7) + 1;
            
            // Move to previous week
            if (currentWeekNumber > 1)
            {
                // Previous week in same month
                var previousWeekNumber = currentWeekNumber - 1;
                var startDay = (previousWeekNumber - 1) * 7 + 1;
                CurrentDate = new DateTime(CurrentDate.Year, CurrentDate.Month, startDay);
            }
            else
            {
                // Previous week is in previous month - go to last week of previous month
                var previousMonth = CurrentDate.AddMonths(-1);
                var daysInPreviousMonth = DateTime.DaysInMonth(previousMonth.Year, previousMonth.Month);
                var lastWeekNumber = ((daysInPreviousMonth - 1) / 7) + 1;
                var startDay = (lastWeekNumber - 1) * 7 + 1;
                CurrentDate = new DateTime(previousMonth.Year, previousMonth.Month, startDay);
            }
        }
        else
        {
            CurrentDate = SelectedPeriod switch
            {
                "Monthly" => CurrentDate.AddMonths(-1),
                "Yearly" => CurrentDate.AddYears(-1),
                _ => CurrentDate
            };
        }
        _ = LoadReportDataAsync();
    }

    private void NavigateNext()
    {
        if (SelectedPeriod == "Weekly")
        {
            // Calculate current week number
            var dayOfMonth = CurrentDate.Day;
            var currentWeekNumber = ((dayOfMonth - 1) / 7) + 1;
            var daysInCurrentMonth = DateTime.DaysInMonth(CurrentDate.Year, CurrentDate.Month);
            var totalWeeksInMonth = ((daysInCurrentMonth - 1) / 7) + 1;
            
            // Move to next week
            if (currentWeekNumber < totalWeeksInMonth)
            {
                // Next week in same month
                var nextWeekNumber = currentWeekNumber + 1;
                var startDay = (nextWeekNumber - 1) * 7 + 1;
                CurrentDate = new DateTime(CurrentDate.Year, CurrentDate.Month, startDay);
            }
            else
            {
                // Next week is in next month - go to first week of next month
                var nextMonth = CurrentDate.AddMonths(1);
                CurrentDate = new DateTime(nextMonth.Year, nextMonth.Month, 1);
            }
        }
        else
        {
            CurrentDate = SelectedPeriod switch
            {
                "Monthly" => CurrentDate.AddMonths(1),
                "Yearly" => CurrentDate.AddYears(1),
                _ => CurrentDate
            };
        }
        _ = LoadReportDataAsync();
    }

