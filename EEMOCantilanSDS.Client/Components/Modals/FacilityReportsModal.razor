    private int MockOccupiedStalls => ReportData?.OccupiedStalls ?? GetMockOccupiedStalls();
    
    private int GetMockOccupiedStalls() => FacilityCode switch
    {
        "NPM" => 28,
        "TCC" => 23,
        "NCC" => 35,
        "BBQ" => 12,
        "ICE" => 8,
