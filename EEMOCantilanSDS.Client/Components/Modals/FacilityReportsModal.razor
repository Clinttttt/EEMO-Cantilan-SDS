@* ══════════════════════════════════════════════════════════════════════════════
   FACILITY REPORTS MODAL
   Displays detailed analytics and reports for a specific facility
   - Weekly/Monthly collection progress
   - Payment trends with graphs
   - Occupancy statistics
   - Revenue breakdown
   ══════════════════════════════════════════════════════════════════════════════ *@

@if (IsOpen)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-container modal-reports" @onclick:stopPropagation="true">

            <!-- ── Header — NPM Hero style ── -->
            <div class="modal-header">
                <div class="modal-title-section">
                    <div class="facility-icon">
                        <svg viewBox="0 0 24 24">
                            <path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z" />
                        </svg>
                    </div>
                    <div class="modal-title-text">
                        <div class="modal-eyebrow">FACILITY · @FacilityCode · REPORTS</div>
                        <h2 class="modal-title">@FacilityName Reports</h2>
                        <p class="modal-subtitle">@GetReportPeriodText()</p>
                    </div>
                </div>
                <button class="modal-close" @onclick="CloseModal" title="Close">
                    <svg viewBox="0 0 24 24">
                        <line x1="18" y1="6" x2="6" y2="18" />
                        <line x1="6" y1="6" x2="18" y2="18" />
                    </svg>
                </button>
                <!-- Gold progress bar at bottom — matches NPM hero -->
                <div class="modal-header-progress">
                    <div class="modal-header-progress-fill" style="width: @ClampPercent(MockCollectionRate)%"></div>
                </div>
            </div>

            <!-- ── Period Selector ── -->
            <div class="report-period-selector">
                <div class="period-tabs">
                    <button class="period-tab @(SelectedPeriod == "Weekly" ? "active" : "")"
                            @onclick='async () => { SelectedPeriod = "Weekly"; await LoadReportDataAsync(); }'>
                        Weekly
                    </button>
                    <button class="period-tab @(SelectedPeriod == "Monthly" ? "active" : "")"
                            @onclick='async () => { SelectedPeriod = "Monthly"; await LoadReportDataAsync(); }'>
                        Monthly
                    </button>
                    <button class="period-tab @(SelectedPeriod == "Yearly" ? "active" : "")"
                            @onclick='async () => { SelectedPeriod = "Yearly"; await LoadReportDataAsync(); }'>
                        Yearly
                    </button>
                </div>
                <div class="period-date-selector">
                    <button class="date-nav-btn" @onclick="NavigatePrevious">
                        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                    </button>
                    <span class="current-period">@GetCurrentPeriodLabel()</span>
                    <button class="date-nav-btn" @onclick="NavigateNext">
                        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                    </button>
                </div>
            </div>

            <!-- ── Modal Body ── -->
            <div class="modal-body">

                @if (IsLoading)
                {
                    <!-- ── Skeleton: 4 KPI Summary Cards ── -->
                    <div class="summary-cards">
                        @for (int i = 0; i < 4; i++)
                        {
                            <div class="summary-card skel-card">
                                <div class="skel skel-icon"></div>
                                <div class="skel-card-body">
                                    <div class="skel skel-label"></div>
                                    <div class="skel skel-value"></div>
                                    <div class="skel skel-change"></div>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- ── Skeleton: Charts (bar + donut) ── -->
                    <div class="charts-section">
                        <div class="chart-card">
                            <div class="skel-chart-header">
                                <div class="skel skel-chart-title"></div>
                                <div class="skel skel-chart-legend"></div>
                            </div>
                            <div class="skel-bar-chart-wrap">
                                @{
                                    var barHeights = new[] { 55, 72, 40, 85, 60, 90 };
                                }
                                @for (int b = 0; b < 6; b++)
                                {
                                    var h = barHeights[b];
                                    <div class="skel-bar-group">
                                        <div class="skel skel-bar" style="height:@(h)%"></div>
                                        <div class="skel skel-bar-label"></div>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="chart-card">
                            <div class="skel-chart-header">
                                <div class="skel skel-chart-title"></div>
                            </div>
                            <div class="skel-donut-wrap">
                                <div class="skel skel-donut"></div>
                                <div class="skel-donut-legend-rows">
                                    <div class="skel skel-legend-row"></div>
                                    <div class="skel skel-legend-row"></div>
                                    <div class="skel skel-legend-row"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ── Skeleton: Breakdown Section ── -->
                    <div class="breakdown-section">
                        <div class="skel skel-section-title"></div>
                        <div class="breakdown-grid">
                            @for (int c = 0; c < 2; c++)
                            {
                                <div class="breakdown-card">
                                    <div class="skel skel-breakdown-title"></div>
                                    @for (int r = 0; r < 3; r++)
                                    {
                                        <div class="skel-breakdown-row">
                                            <div class="skel skel-breakdown-badge"></div>
                                            <div class="skel skel-breakdown-bar"></div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                }
                else if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="error-state">
                        <svg viewBox="0 0 24 24" class="error-icon">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="12" y1="8" x2="12" y2="12" />
                            <line x1="12" y1="16" x2="12.01" y2="16" />
                        </svg>
                        <p>@ErrorMessage</p>
                        <button class="btn btn-primary" @onclick="LoadReportDataAsync">Retry</button>
                    </div>
                }
                else
                {
                    <!-- ── Summary Cards ── -->
                <div class="summary-cards">
                    <div class="summary-card card-revenue">
                        <div class="card-icon">
                            <svg viewBox="0 0 24 24">
                                <line x1="12" y1="1" x2="12" y2="23" />
                                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                            </svg>
                        </div>
                        <div class="card-content">
                            <p class="card-label">@RevenueCardLabel</p>
                            <h3 class="card-value">₱@MockTotalRevenue.ToString("N2")</h3>
                            <p class="card-change @GetChangeClass(MockRevenueGrowth)">@FormatSignedPercentage(MockRevenueGrowth) vs previous @SelectedPeriod.ToLower()</p>
                        </div>
                    </div>

                    <div class="summary-card card-collection">
                        <div class="card-icon">
                            <svg viewBox="0 0 24 24">
                                <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                            </svg>
                        </div>
                        <div class="card-content">
                            <p class="card-label">@CollectionRateLabel</p>
                            <h3 class="card-value">@FormatPercentage(MockCollectionRate)</h3>
                            <p class="card-change @GetChangeClass(MockCollectionGrowth)">@FormatSignedPercentage(MockCollectionGrowth) vs previous @SelectedPeriod.ToLower()</p>
                        </div>
                    </div>

                    <div class="summary-card card-occupancy">
                        <div class="card-icon">
                            <svg viewBox="0 0 24 24">
                                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                        </div>
                        <div class="card-content">
                            <p class="card-label">@OccupancyLabel</p>
                            <h3 class="card-value">@MockOccupiedStalls/@MockTotalStalls</h3>
                            <p class="card-change neutral">@FormatPercentage(MockOccupancyRate) @OccupancySubLabel</p>
                        </div>
                    </div>

                    <div class="summary-card card-pending">
                        <div class="card-icon">
                            <svg viewBox="0 0 24 24">
                                <circle cx="12" cy="12" r="10" />
                                <polyline points="12 6 12 12 16 14" />
                            </svg>
                        </div>
                        <div class="card-content">
                            <p class="card-label">@PendingLabel</p>
                            <h3 class="card-value">@MockPendingCount</h3>
                            <p class="card-change negative">₱@MockPendingAmount.ToString("N2") @PendingAmountLabel</p>
                        </div>
                    </div>
                </div>

                <!-- ── Charts Section ── -->
                <div class="charts-section">

                    <!-- Revenue Trend Bar Chart -->
                    <div class="chart-card">
                        <div class="chart-header">
                            <h3 class="chart-title">Collection Trend</h3>
                            <div class="chart-legend">
                                <span class="legend-item">
                                    <span class="legend-dot revenue"></span>
                                    Collected
                                </span>
                                <span class="legend-item">
                                    <span class="legend-dot target"></span>
                                    Current period
                                </span>
                            </div>
                        </div>
                        <div class="chart-container">
                            @RenderRevenueChart()
                        </div>
                    </div>

                    <!-- Payment Status Donut Chart -->
                    <div class="chart-card">
                        <div class="chart-header">
                            <h3 class="chart-title">@StatusDistributionTitle</h3>
                        </div>
                        <div class="chart-container chart-donut">
                            @RenderPaymentStatusChart()
                        </div>
                    </div>
                </div>

                <!-- ── Detailed Breakdown ── -->
                <div class="breakdown-section">
                    <h3 class="section-title">Audit Breakdown</h3>
                    <div class="breakdown-grid">

                        <!-- By Section (NPM only) -->
                        @if (ShowSectionBreakdown)
                        {
                            <div class="breakdown-card">
                                <h4 class="breakdown-title">Section Revenue</h4>
                                <div class="breakdown-list">
                                    @foreach (var section in MockSectionData)
                                    {
                                        <div class="breakdown-item">
                                            <div class="breakdown-label">
                                                <span class="section-dot" style="background: @section.Color"></span>
                                                @section.Name
                                            </div>
                                            <div class="breakdown-value">₱@section.Revenue.ToString("N2")</div>
                                            <div class="breakdown-bar">
                                                <div class="bar-fill" style="width: @ClampPercent(section.Percentage)%; background: @section.Color"></div>
                                            </div>
                                        </div>
                                    }
                                </div>
                                <div class="section-rate-panel">
                                    <div class="mini-panel-title">Collection Rate by Section</div>
                                    @foreach (var section in MockSectionData)
                                    {
                                        <div class="mini-metric-row">
                                            <span>@GetShortSectionName(section.Name)</span>
                                            <div class="mini-meter">
                                                <div class="mini-meter-fill" style="width: @ClampPercent(section.Percentage)%; background: @section.Color"></div>
                                            </div>
                                            <strong>@FormatPercentage(section.Percentage)</strong>
                                        </div>
                                    }
                                </div>
                                <div class="section-status-panel">
                                    <div class="mini-panel-title">Stall Status per Section</div>
                                    @foreach (var section in MockSectionData)
                                    {
                                        <div class="section-status-row">
                                            <span>@GetShortSectionName(section.Name) - @section.TotalStalls stalls</span>
                                            <strong>@section.ActiveStalls active</strong>
                                            @if (section.ClosedStalls > 0)
                                            {
                                                <small>@section.ClosedStalls closed</small>
                                            }
                                            @if (section.NoContractStalls > 0)
                                            {
                                                <small>@section.NoContractStalls no contract</small>
                                            }
                                        </div>
                                    }
                                </div>
                            </div>
                        }

                        <!-- Collection Performance -->
                        <div class="breakdown-card">
                            <h4 class="breakdown-title">@ComplianceTitle</h4>
                            <div class="breakdown-list">
                                <div class="breakdown-item">
                                    <div class="breakdown-label">
                                        <span class="status-badge paid">Paid</span>
                                    </div>
                                    <div class="breakdown-value">@MockPaidCount @EntityPluralLabel</div>
                                    <div class="breakdown-bar">
                                        <div class="bar-fill paid" style="width: @GetStatusWidth(MockPaidCount)%"></div>
                                    </div>
                                </div>
                                <div class="breakdown-item">
                                    <div class="breakdown-label">
                                        <span class="status-badge partial">Partial</span>
                                    </div>
                                    <div class="breakdown-value">@MockPartialCount @EntityPluralLabel</div>
                                    <div class="breakdown-bar">
                                        <div class="bar-fill partial" style="width: @GetStatusWidth(MockPartialCount)%"></div>
                                    </div>
                                </div>
                                <div class="breakdown-item">
                                    <div class="breakdown-label">
                                        <span class="status-badge unpaid">Unpaid</span>
                                    </div>
                                    <div class="breakdown-value">@MockUnpaidCount @EntityPluralLabel</div>
                                    <div class="breakdown-bar">
                                        <div class="bar-fill unpaid" style="width: @GetStatusWidth(MockUnpaidCount)%"></div>
                                    </div>
                                </div>
                            </div>
                            @if (FeeTypeBreakdown != null)
                            {
                                <div class="fee-breakdown-panel">
                                    <div class="mini-panel-title">Fee Type Breakdown</div>
                                    @foreach (var feeType in GetFeeTypeRows())
                                    {
                                        <div class="fee-type-row">
                                            <span>@feeType.Label</span>
                                            <div class="mini-meter">
                                                <div class="mini-meter-fill @feeType.ClassName" style="width: @feeType.Width%"></div>
                                            </div>
                                            <strong>₱@feeType.Amount.ToString("N0")</strong>
                                        </div>
                                    }
                                </div>
                            }
                            @if (FishKiloTrend.Any())
                            {
                                <div class="fish-trend-panel">
                                    <div class="mini-panel-title">Fish Kilo Volume Trend</div>
                                    <div class="fish-sparkline">
                                        @foreach (var point in GetFishKiloTrendPoints())
                                        {
                                            <span style="height: @point.Height%" title="@($"{point.Label}: {point.Kilos:N1} kg")"></span>
                                        }
                                    </div>
                                    <div class="fish-trend-meta">
                                        <span>@GetFishTrendStartLabel()</span>
                                        <strong>@FishKiloTrend.Sum(p => p.Kilos).ToString("N1") kg total</strong>
                                        <span>@GetFishTrendEndLabel()</span>
                                    </div>
                                    <div class="fish-comparison" style="margin-top: 8px; padding-top: 8px; border-top: 1px solid #e5e7eb; font-size: 0.875rem; color: #6b7280; text-align: center;">
                                        @(FeeTypeBreakdown?.FishKiloComparison ?? "No data available")
                                    </div>
                                </div>
                            }
                        </div>

                        @if (DailyCollectionStreak != null)
                        {
                            <div class="breakdown-card collection-streak-card">
                                <div class="streak-card-header">
                                    <div>
                                        <h4 class="breakdown-title">Daily Collection Streak</h4>
                                        <p class="streak-subtitle">@DailyCollectionStreak.MonthLabel</p>
                                    </div>
                                    <div class="streak-score">
                                        <span>@DailyCollectionStreak.CurrentStreakDays</span>
                                        <small>day streak</small>
                                    </div>
                                </div>

                                <div class="streak-calendar">
                                    <div class="streak-weekdays">
                                        <span>Su</span>
                                        <span>Mo</span>
                                        <span>Tu</span>
                                        <span>We</span>
                                        <span>Th</span>
                                        <span>Fr</span>
                                        <span>Sa</span>
                                    </div>
                                    <div class="streak-grid">
                                        @{
                                            var leadingBlankDays = DailyCollectionStreak.Days.FirstOrDefault()?.DayOfWeek ?? 0;
                                        }
                                        @for (var i = 0; i < leadingBlankDays; i++)
                                        {
                                            <span class="streak-day empty"></span>
                                        }
                                        @foreach (var day in DailyCollectionStreak.Days)
                                        {
                                            <span class="streak-day @GetCollectionDayClass(day.Status)" title="@($"{day.Status} - day {day.DayNumber}")">
                                                @GetCollectionDayLabel(day)
                                            </span>
                                        }
                                    </div>
                                </div>

                                <div class="streak-legend">
                                    <span><i class="legend-swatch collected"></i>Collected (@DailyCollectionStreak.CollectedDays)</span>
                                    <span><i class="legend-swatch missed"></i>Missed (@DailyCollectionStreak.MissedDays)</span>
                                    <span><i class="legend-swatch future"></i>Upcoming</span>
                                    @if (DailyCollectionStreak.Days.Any(day => day.Status.Equals("OutOfScope", StringComparison.OrdinalIgnoreCase)))
                                    {
                                        <span><i class="legend-swatch out-of-scope"></i>Out of scope</span>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="breakdown-card exposure-card">
                                <h4 class="breakdown-title">Collection Exposure</h4>
                                <div class="exposure-stat">
                                    <span class="exposure-value">₱@MockPendingAmount.ToString("N2")</span>
                                    <span class="exposure-label">@ExposureDescription</span>
                                </div>
                                <div class="exposure-grid">
                                    <div>
                                        <span>@FormatPercentage(GetStatusWidth(MockPaidCount))</span>
                                        <small>fully paid</small>
                                    </div>
                                    <div>
                                        <span>@FormatPercentage(GetStatusWidth(MockPartialCount + MockUnpaidCount))</span>
                                        <small>needs follow-up</small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @if (AdditionalCharts != null)
                    {
                        @AdditionalCharts
                    }
                </div>
            }
            </div>

            <!-- ── Footer Actions ── -->
            <div class="modal-footer">
                <button class="btn btn-outline" @onclick="ExportReport">
                    <svg viewBox="0 0 24 24">
                        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                        <polyline points="7 10 12 15 17 10" />
                        <line x1="12" y1="15" x2="12" y2="3" />
                    </svg>
                    Export PDF
                </button>
                <button class="btn btn-outline" @onclick="PrintReport">
                    <svg viewBox="0 0 24 24">
                        <polyline points="6 9 6 2 18 2 18 9" />
                        <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                        <rect x="6" y="14" width="12" height="8" />
                    </svg>
                    Print
                </button>
                <button class="btn btn-primary" @onclick="CloseModal">
                    Close
                </button>
            </div>
        </div>
    </div>
}

@using EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using EEMOCantilanSDS.Application.Dtos.Facilities
@using EEMOCantilanSDS.Domain.Enums
@inject IFacilitiesApiClient FacilitiesApiClient

@code {
    [Parameter]
    public bool IsOpen { get; set; }

    [Parameter]
    public EventCallback<bool> IsOpenChanged { get; set; }

    [Parameter]
    public string FacilityCode { get; set; } = string.Empty;

    [Parameter]
    public string FacilityName { get; set; } = string.Empty;

    [Parameter]
    public bool ShowSectionBreakdown { get; set; } = false;

    [Parameter] public decimal? TotalRevenueOverride { get; set; }
    [Parameter] public decimal? CollectionRateOverride { get; set; }
    [Parameter] public int? OccupiedCountOverride { get; set; }
    [Parameter] public int? TotalCountOverride { get; set; }
    [Parameter] public int? PendingCountOverride { get; set; }
    [Parameter] public decimal? PendingAmountOverride { get; set; }
    [Parameter] public int? PaidCountOverride { get; set; }
    [Parameter] public int? PartialCountOverride { get; set; }
    [Parameter] public int? UnpaidCountOverride { get; set; }
    [Parameter] public IReadOnlyList<ReportTrendPoint>? RevenueTrendOverride { get; set; }
    [Parameter] public IReadOnlyList<ReportVolumeRow>? VolumeRowsOverride { get; set; }
    [Parameter] public IReadOnlyList<ReportBreakdownRow>? FeeBreakdownRowsOverride { get; set; }
    [Parameter] public RenderFragment? AdditionalCharts { get; set; }

    private string SelectedPeriod { get; set; } = "Monthly";
    private DateTime CurrentDate { get; set; } = DateTime.Now;
    
    private bool IsLoading { get; set; } = false;
    private string? ErrorMessage { get; set; }
    private FacilityReportsDto? ReportData { get; set; }
    private bool UsesContextOverrides => FacilityCode is "TRM" or "TPM" or "SLH";

    protected override async Task OnParametersSetAsync()
    {
        if (IsOpen && !string.IsNullOrEmpty(FacilityCode))
        {
            await LoadReportDataAsync();
        }
    }

    private async Task LoadReportDataAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        StateHasChanged();

        try
        {
            if (UsesContextOverrides)
            {
                ReportData = null;
                return;
            }

            // Parse facility code
            if (!Enum.TryParse<FacilityCode>(FacilityCode, out var facilityCodeEnum))
            {
                ErrorMessage = "Invalid facility code";
                return;
            }

            // Parse period
            var period = SelectedPeriod switch
            {
                "Weekly" => ReportPeriod.Weekly,
                "Monthly" => ReportPeriod.Monthly,
                "Yearly" => ReportPeriod.Yearly,
                _ => ReportPeriod.Monthly
            };

            // Calculate week number for weekly reports
            int? weekNumber = null;
            int? month = null;

            if (period == ReportPeriod.Weekly)
            {
                month = CurrentDate.Month;
                weekNumber = GetWeekOfMonth(CurrentDate);
            }
            else if (period == ReportPeriod.Monthly)
            {
                month = CurrentDate.Month;
            }

            // Call API
            var result = await FacilitiesApiClient.GetFacilityReportsAsync(
                facilityCodeEnum,
                period,
                CurrentDate.Year,
                month,
                weekNumber
            );

            if (result.IsSuccess)
            {
                ReportData = result.Value;
            }
            else
            {
                ErrorMessage = result.Error ?? "Failed to load report data";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error loading report: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private int GetWeekOfMonth(DateTime date)
    {
        // Calculate week number based on day of month (same as backend)
        // Week 1 = Days 1-7, Week 2 = Days 8-14, Week 3 = Days 15-21, Week 4 = Days 22-28, Week 5 = Days 29-31
        var dayOfMonth = date.Day;
        var weekNumber = ((dayOfMonth - 1) / 7) + 1;
        return weekNumber;
    }

    // Properties that use API data, caller-provided context, or fallback data.
    private string RevenueCardLabel => FacilityCode switch
    {
        "TRM" => "Terminal Fees Collected",
        "TPM" => "Market Fees Collected",
        "SLH" => "Slaughter Fees Collected",
        _ => "Collected Revenue"
    };

    private string CollectionRateLabel => FacilityCode switch
    {
        "TRM" => "OR Completion Rate",
        "TPM" => "Vendor Collection Rate",
        "SLH" => "OR Completion Rate",
        _ => "Amount Collection Rate"
    };

    private string OccupancyLabel => FacilityCode switch
    {
        "TRM" => "Active Transporters",
        "TPM" => "Vendor Entries",
        "SLH" => "Owners Served",
        _ => "Occupied Payors"
    };

    private string OccupancySubLabel => FacilityCode switch
    {
        "TRM" => "of registered transporters",
        "TPM" => "recorded this period",
        "SLH" => "with slaughter records",
        _ => "of active stalls"
    };

    private string PendingLabel => FacilityCode switch
    {
        "TRM" => "Trips Pending OR",
        "TPM" => "Unpaid Vendors",
        "SLH" => "Pending OR",
        _ => "Payors With Balance"
    };

    private string PendingAmountLabel => FacilityCode switch
    {
        "TRM" => "pending OR value",
        "TPM" => "uncollected",
        "SLH" => "pending OR value",
        _ => "outstanding"
    };

    private string StatusDistributionTitle => FacilityCode switch
    {
        "TRM" => "Trip OR Status Distribution",
        "TPM" => "Vendor Payment Status Distribution",
        "SLH" => "Animal Volume Distribution",
        _ => "Payor Status Distribution"
    };

    private string ComplianceTitle => FacilityCode switch
    {
        "TRM" => "Trip OR Compliance",
        "TPM" => "Vendor Attendance Compliance",
        "SLH" => "Slaughter Volume",
        _ => "Payor Compliance"
    };

