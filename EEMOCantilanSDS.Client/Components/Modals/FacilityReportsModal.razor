                ("NCC", "Weekly") => new[] { 12800m, 14200m, 13500m, 15800m, 16200m, 17100m, 15600m },
                ("NCC", "Monthly") => new[] { 48000m, 52800m, 57600m, 60000m, 64800m, 67200m },
                ("NCC", "Yearly") => new[] { 480000m, 528000m, 576000m, 624000m, 672000m },
                
