    private int MockOccupancyRate => MockTotalStalls > 0 ? (int)((MockOccupiedStalls * 100.0) / MockTotalStalls) : 0;

    private int MockPendingCount => ReportData?.PendingPaymentCount ?? GetMockPendingCount();
    
