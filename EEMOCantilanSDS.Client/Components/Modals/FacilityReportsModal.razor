        if (RevenueTrendOverride?.Any() == true)
        {
            return RevenueTrendOverride.Select(t => t.PeriodLabel).ToArray();
        }

        if (ReportData?.RevenueTrend != null && ReportData.RevenueTrend.Any())
        {
            return ReportData.RevenueTrend.Select(t => t.PeriodLabel).ToArray();
        }

        // Fallback to default labels
        return SelectedPeriod switch
        {
            "Weekly" => new[] { "Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun" },
            "Monthly" => new[] { "Jan", "Feb", "Mar", "Apr", "May", "Jun" },
            "Yearly" => new[] { "2020", "2021", "2022", "2023", "2024" },
            _ => Array.Empty<string>()
        };
    }

