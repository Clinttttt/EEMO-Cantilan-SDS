                ("BBQ", "Weekly") => new[] { 7200m, 8400m, 9600m, 8800m, 10200m, 9800m, 9200m },
                ("BBQ", "Monthly") => new[] { 28800m, 32000m, 33600m, 35200m, 36800m, 38400m },
                ("BBQ", "Yearly") => new[] { 288000m, 320000m, 336000m, 352000m, 384000m },
                
                // ICE - Monthly space rental (stable, lower volume)
                ("ICE", "Weekly") => new[] { 4800m, 5200m, 5600m, 5400m, 6000m, 5800m, 5600m },
                ("ICE", "Monthly") => new[] { 18000m, 19000m, 20000m, 21000m, 22500m, 24000m },
                ("ICE", "Yearly") => new[] { 180000m, 190000m, 200000m, 220000m, 240000m },
                
                _ => Array.Empty<decimal>()
            };
        }

        // Calculate actual max from data
        var dataMax = chartData.Any() && chartData.Max() > 0 ? chartData.Max() : 1;
        
        // Calculate a "nice" scale value by rounding up to the nearest nice number
        // This ensures small values like ₱30 show as small bars, not 100% height
        var maxValue = CalculateNiceScale(dataMax);
        var labels = GetChartLabels();

        // Wrapper with gridlines + bars overlaid
        <div class="bar-chart-wrap">
            <div class="bar-chart-grid">
                <div class="bar-chart-grid-line"></div>
                <div class="bar-chart-grid-line"></div>
                <div class="bar-chart-grid-line"></div>
                <div class="bar-chart-grid-line"></div>
            </div>
            <div class="bar-chart">
                @for (int i = 0; i < chartData.Length; i++)
                {
                    var height = maxValue > 0 ? (chartData[i] / maxValue) * 100 : 0;
                    var isHighlight = i == chartData.Length - 1;
                    <div class="bar-group">
                        <div class="bar-wrapper">
                            <div class="bar @(isHighlight ? "highlight" : "")" style="height: @(height)%">
                                <span class="bar-value">₱@(chartData[i] / 1000)k</span>
                            </div>
                        </div>
                        <span class="bar-label">@(i < labels.Length ? labels[i] : "")</span>
                    </div>
                }
            </div>
        </div>
    };

