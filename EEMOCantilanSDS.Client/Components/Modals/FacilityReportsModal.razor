    private IReadOnlyList<FeeTypeRow> GetFeeTypeRows()
    {
        if (FeeTypeBreakdown == null)
        {
            return Array.Empty<FeeTypeRow>();
        }

        var rows = new[]
        {
            new FeeTypeRow("Daily fee", FeeTypeBreakdown.DailyFeeAmount, "daily"),
            new FeeTypeRow("Fish fee", FeeTypeBreakdown.FishFeeAmount, "fish")
        }
        .ToList();

        var maxAmount = rows.Max(row => row.Amount);
        return rows
            .Select(row => row with { Width = maxAmount > 0 ? ClampPercent((row.Amount / maxAmount) * 100m) : 0m })
            .ToList();
    }

    private string GetShortSectionName(string sectionName)
    {
        // Resolve the tenant's section label (e.g. "Gulayan") first, then trim the generic suffix for the
        // compact chip. sectionName is the canonical key from the server; SectionLabelOf falls back to it.
        var resolved = Enum.TryParse<FacilityCode>(FacilityCode, ignoreCase: true, out var fc)
            ? FacilityCatalog.SectionLabelOf(fc, sectionName)
            : sectionName;
        return resolved
            .Replace(" Section", string.Empty, StringComparison.OrdinalIgnoreCase)
            .Replace(" Area", string.Empty, StringComparison.OrdinalIgnoreCase);
    }

