                    </div>
                }
            </div>
        </div>
    };

    private RenderFragment RenderPaymentStatusChart() => __builder =>
    {
        var total = MockPaidCount + MockPartialCount + MockUnpaidCount;
        var paidPercent = total > 0 ? (MockPaidCount * 100.0m / total) : 0m;
        var partialPercent = total > 0 ? (MockPartialCount * 100.0m / total) : 0m;
        var unpaidPercent = total > 0 ? (MockUnpaidCount * 100.0m / total) : 0m;

        <div class="donut-chart">
            <svg viewBox="0 0 200 200" class="donut-svg">
                <!-- Track ring -->
                <circle cx="100" cy="100" r="75" fill="none" stroke="#eef2f6" stroke-width="32" />
                <!-- Paid segment -->
                <circle cx="100" cy="100" r="75" fill="none" stroke="#2d7a5f" stroke-width="32"
                        stroke-dasharray="@(paidPercent * 4.712m) 471.2"
                        stroke-dashoffset="0"
                        transform="rotate(-90 100 100)" />
                <!-- Partial segment -->
                <circle cx="100" cy="100" r="75" fill="none" stroke="#c8a84b" stroke-width="32"
                        stroke-dasharray="@(partialPercent * 4.712m) 471.2"
                        stroke-dashoffset="@(-paidPercent * 4.712m)"
                        transform="rotate(-90 100 100)" />
                <!-- Unpaid segment -->
                <circle cx="100" cy="100" r="75" fill="none" stroke="#8b3a3a" stroke-width="32"
                        stroke-dasharray="@(unpaidPercent * 4.712m) 471.2"
                        stroke-dashoffset="@(-(paidPercent + partialPercent) * 4.712m)"
                        transform="rotate(-90 100 100)" />
            </svg>
            <div class="donut-center">
                <div class="donut-value">@paidPercent.ToString("0.0")%</div>
                <div class="donut-label">Fully Paid</div>
            </div>
        </div>

        <div class="donut-legend">
            <div class="legend-item">
                <span class="legend-dot" style="background: #2d7a5f"></span>
                <span class="legend-name">Paid</span>
                <span class="legend-percent">@paidPercent.ToString("0.0")%</span>
            </div>
            <div class="legend-item">
                <span class="legend-dot" style="background: #c8a84b"></span>
                <span class="legend-name">Partial</span>
                <span class="legend-percent">@partialPercent.ToString("0.0")%</span>
            </div>
            <div class="legend-item">
                <span class="legend-dot" style="background: #8b3a3a"></span>
                <span class="legend-name">Unpaid</span>
                <span class="legend-percent">@unpaidPercent.ToString("0.0")%</span>
            </div>
        </div>
    };

    private string[] GetChartLabels()
    {
