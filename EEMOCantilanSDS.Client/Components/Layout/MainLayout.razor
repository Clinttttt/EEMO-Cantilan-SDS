@inherits LayoutComponentBase
@inject NavigationManager Navigation
@implements IDisposable

<EEMOCantilanSDS.Client.Components.Shared.GlobalLoadingBar />

@if (showSidebar)
{
    <div class="admin-layout">
        <Sidebar />
        
        <main class="admin-main">
            @Body
        </main>
    </div>
    <EEMOCantilanSDS.Client.Components.Shared.SessionGuard LoginPath="/login" LogoutEndpoint="/api/authproxy/logout" />
}
else
{
    @Body
}

@code {
    private bool showSidebar = true;

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
        UpdateSidebarVisibility();
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        UpdateSidebarVisibility();
        StateHasChanged();
    }

    private void UpdateSidebarVisibility()
    {
        var path = new Uri(Navigation.Uri).AbsolutePath.ToLower();
        showSidebar = !path.Contains("/login") && !path.Contains("/setup") && !path.Contains("account-setup-admin") && !path.Contains("/payor");
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
