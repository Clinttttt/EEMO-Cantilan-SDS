<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="/css/site.min.css" asp-append-version="true" />
    <link rel="stylesheet" href="@Assets["app.css"]" />
    <link rel="stylesheet" href="/css/payor.css" asp-append-version="true" />
    <link rel="stylesheet" href="@Assets["EEMOCantilanSDS.Client.styles.css"]" />
    <link rel="stylesheet" href="/css/print.css" asp-append-version="true" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:wght@400;500;600&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <HeadOutlet />
</head>

<body>
    <div id="stalltrack-splash" class="st-splash" role="status" aria-live="polite">
        <div class="st-splash-ring">
            <img class="st-splash-logo" src="/images/logo_stalltrack.png" alt="StallTrack" />
        </div>
        <div class="st-splash-title">LOADING</div>
        <div class="st-splash-bar"><span></span></div>
        <div class="st-splash-sub" data-splash-status>Please wait…</div>
    </div>
    <Routes @rendermode="@(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: true))" />
    <script src="_framework/blazor.web.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="/js/auth.js"></script>
    <script src="/js/modal.js"></script>
    <script src="/js/payor-hub.js"></script>
    <script src="/js/download.js"></script>
    <script>
        // Branded boot splash: covers the fallback path while the Blazor circuit connects. When
        // prerendered app markup is present, hide it immediately so the static HTML is visible.
        window.hideStallTrackSplash = function () {
            var el = document.getElementById('stalltrack-splash');
            if (!el || el.dataset.hiding) return;
            el.dataset.hiding = '1';
            el.classList.add('st-hide');
            setTimeout(function () { if (el && el.parentNode) el.parentNode.removeChild(el); }, 500);
        };
        if (document.querySelector('.admin-layout, .setup-root, .pp-shell')) {
            window.hideStallTrackSplash();
        }
        setTimeout(function () {
            var el = document.getElementById('stalltrack-splash');
            if (!el || el.dataset.hiding) return;
            var status = el.querySelector('[data-splash-status]');
            if (status) status.textContent = 'Still connecting...';
        }, 15000);

        // Mobile sidebar drawer: lock page scroll while it's open, so scrolling the dimmed backdrop
        // doesn't shift the page underneath (which made the open drawer look "broken" mid-scroll).
        window.stallTrackSetBodyScrollLocked = function (locked) {
            document.body.classList.toggle('st-scroll-locked', !!locked);
        };
    </script>
</body>

</html>
