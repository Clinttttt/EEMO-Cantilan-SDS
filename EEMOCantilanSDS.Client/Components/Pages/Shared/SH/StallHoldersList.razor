@page "/list-stall-holders"

@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>EEMO Admin — List of Stall Holders</PageTitle>

<!-- Topbar -->
<header class="topbar">
            <div class="topbar-left flex gap-2">
                <a href="@BackLink" class="lsh-back-btn">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div>
                    <div class="topbar-title">List of Stall Holders</div>
                    <div class="topbar-breadcrumb">
                        <a href="/menu" class="breadcrumb-link">Dashboard</a>
                        <span class="breadcrumb-sep">/</span>
                        <a href="@BackLink" class="breadcrumb-link">@FacilityName</a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">Stall Holders List</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <AccountChip />
            </div>
        </header>

        <div class="content-area">

            <!-- ── Hero Banner ── -->
            <div class="lsh-hero">
                <div class="lsh-hero-left">
                    <div class="lsh-hero-icon">
                        <svg viewBox="0 0 24 24"><line x1="8" y1="6" x2="21" y2="6" /><line x1="8" y1="12" x2="21" y2="12" /><line x1="8" y1="18" x2="21" y2="18" /><circle cx="3" cy="6" r="1" /><circle cx="3" cy="12" r="1" /><circle cx="3" cy="18" r="1" /></svg>
                    </div>
                    <div>
                        <div class="lsh-hero-eyebrow">@FacilityCode · @FacilityName</div>
                        <div class="lsh-hero-title">List of Stall Holders</div>
                        <div class="lsh-hero-sub">Municipality of Cantilan, Surigao del Sur</div>
                    </div>
                </div>
                <div class="lsh-hero-stats">
                    <div class="lsh-hero-stat">
                        <div class="lsh-hero-val">@AllActiveStalls.Count()</div>
                        <div class="lsh-hero-key">Total Stalls</div>
                    </div>
                    @if (IsFacility("npm"))
                    {
                        <div class="lsh-hero-divider"></div>
                        <div class="lsh-hero-stat">
                            <div class="lsh-hero-val">@VegetableStalls.Count()</div>
                            <div class="lsh-hero-key">Vegetable</div>
                        </div>
                        <div class="lsh-hero-divider"></div>
                        <div class="lsh-hero-stat">
                            <div class="lsh-hero-val">@FishStalls.Count()</div>
                            <div class="lsh-hero-key">Fish</div>
                        </div>
                        <div class="lsh-hero-divider"></div>
                        <div class="lsh-hero-stat">
                            <div class="lsh-hero-val">@MeatStalls.Count()</div>
                            <div class="lsh-hero-key">Meat</div>
                        </div>
                    }
                </div>
                <div class="lsh-hero-progress">
                    <div class="lsh-hero-progress-fill" style="width:100%"></div>
                </div>
            </div>

            <!-- ── Toolbar ── -->
            <div class="page-toolbar">
                <div class="toolbar-left">
                    <div class="search-box">
                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                        <input type="text" placeholder="Search name or stall no…"
                               @bind="SearchQuery" @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(SearchQuery))
                        {
                            <span class="search-clear" @onclick="() => SearchQuery = string.Empty">×</span>
                        }
                    </div>
                    @if (IsFacility("npm"))
                    {
                        <div class="filter-tabs">
                            @foreach (var sec in SectionKeys)
                            {
                                <div class="filter-tab @(ActiveSection == sec ? "active" : "")"
                                     @onclick="() => ActiveSection = sec">
                                    @sec
                                </div>
                            }
                        </div>
                    }
                </div>
                <div style="display:flex;gap:8px;">
                    <button class="btn-outline" onclick="window.print()">
                        <svg viewBox="0 0 24 24" style="width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;vertical-align:middle;margin-right:4px;">
                            <polyline points="6 9 6 2 18 2 18 9" />
                            <path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2" />
                            <rect x="6" y="14" width="12" height="8" />
                        </svg>
                        Print / Export
                    </button>
                    <a href="@BackLink" class="btn-outline">
                        <svg viewBox="0 0 24 24" style="width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;vertical-align:middle;margin-right:4px;">
                            <polyline points="15 18 9 12 15 6" />
                        </svg>
                        Back to @FacilityName
                    </a>
                </div>
            </div>

            <!-- ── Document Panel ── -->
            <div class="lsh-doc-panel">

                <!-- Document Header -->
                <div class="lsh-doc-header">
                    <img class="lsh-doc-logo" src="/images/LGU_CANTILAN_LOGO.jpg" alt="LGU Cantilan logo" />
                    <div class="lsh-doc-republic">Republic of the Philippines</div>
                    <div class="lsh-doc-office">Economic Enterprise &amp; Management Office</div>
                    <div class="lsh-doc-gov">Municipality of Cantilan, Surigao del Sur</div>
                    <div class="lsh-doc-title">List of Stallholders</div>
                    <div class="lsh-doc-facility">@FacilityName.ToUpper()</div>
                </div>

                @if (IsFacility("npm"))
                {
                    @foreach (var sections in VisibleSections)
                    {
                        var sectionStalls = GetSectionStalls(sections).Where(MatchSearch).ToList();
                        if (!sectionStalls.Any()) continue;

                        <div class="lsh-section-block">
                            <div class="lsh-section-label-row">
                                <span class="lsh-section-label">@sections.ToUpper()</span>
                                <span class="lsh-section-count">@sectionStalls.Count stall@(sectionStalls.Count != 1 ? "s" : "")</span>
                            </div>

                            <table class="lsh-table">
                                <thead>
                                    <tr>
                                        <th class="col-no">#</th>
                                        <th class="col-name">Name of Lessee<br /><span class="th-sub">(Actual Occupants)</span></th>
                                        <th class="col-contract">Name of Lessee per<br />Signed Contract</th>
                                        <th class="col-stall">Stall /<br />Space No.</th>
                                        <th class="col-date">Effectivity of<br />Lessee Contract</th>
                                        <th class="col-years">No. of<br />Years</th>
                                        <th class="col-area">Area</th>
                                        <th class="col-rate">Monthly Rentals<br />per Contract</th>
                                        <th class="col-actual">Actual Mo.<br />Rentals</th>
                                        <th class="col-whole">Whole Year<br />Rental</th>

                                    </tr>
                                </thead>
                                <tbody>
                                    @{
                                        int rowNum = 1;
                                    }
                                    @foreach (var s in sectionStalls)
                                    {
                                        <tr class="@(!s.IsActive ? "row-closed" : "")">
                                            <td class="c">@rowNum</td>
                                            <td class="tl fw @(!s.IsActive ? "txt-closed" : "")">@s.ActualOccupant</td>
                                            <td class="tl txt-muted">@(string.IsNullOrEmpty(s.ContractName) ? "—" : s.ContractName)</td>
                                            <td class="c">@s.StallNo</td>
                                            <td class="c">@(s.ContractDate.HasValue? s.ContractDate.Value.ToString("M/d/yyyy") : "—")</td>
                                            <td class="c">3 yrs</td>
                                            <td class="c">@(s.AreaSqm > 0 ? $"{s.AreaSqm} sq.m." : "—")</td>
                                            <td class="r">@(s.IsActive ? $"₱{s.MonthlyRate:N2}" : "—")</td>
                                            <td class="r">@(s.IsActive ? $"₱{s.MonthlyRate:N2}" : "—")</td>
                                            <td class="r">@(s.IsActive ? $"₱{s.MonthlyRate * 12:N2}" : "—")</td>

                                        </tr>
                                        rowNum++;
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="tfoot-row">
                                        <td colspan="7" class="tfoot-label">
                                            Section Total — @sectionStalls.Count(s => s.IsActive) active stall@(sectionStalls.Count(s => s.IsActive) != 1 ? "s" : "")
                                        </td>
                                        <td class="r tfoot-val">₱@sectionStalls.Where(s => s.IsActive).Sum(s => s.MonthlyRate).ToString("N2")</td>
                                        <td class="r tfoot-val">₱@sectionStalls.Where(s => s.IsActive).Sum(s => s.MonthlyRate).ToString("N2")</td>
                                        <td class="r tfoot-val">₱@sectionStalls.Where(s => s.IsActive).Sum(s => s.MonthlyRate * 12).ToString("N2")</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                }
                else
                {
                    <!-- For non-NPM facilities: Simple flat list without sections -->
                    <div class="lsh-section-block">
                        <div class="lsh-section-label-row">
                            <span class="lsh-section-label">ALL STALLS</span>
                            <span class="lsh-section-count">@FilteredNonNpmStalls.Count() stall@(FilteredNonNpmStalls.Count() != 1 ? "s" : "")</span>
                        </div>

                        <table class="lsh-table">
                            <thead>
                                <tr>
                                    <th class="col-no">#</th>
                                    <th class="col-name">Name of Lessee<br /><span class="th-sub">(Actual Occupants)</span></th>
                                    <th class="col-contract">Name of Lessee per<br />Signed Contract</th>
                                    <th class="col-stall">Stall /<br />Space No.</th>
                                    <th class="col-date">Effectivity of<br />Lessee Contract</th>
                                    <th class="col-years">No. of<br />Years</th>
                                    <th class="col-area">Area</th>
                                    <th class="col-rate">Monthly Rentals<br />per Contract</th>
                                    <th class="col-actual">Actual Mo.<br />Rentals</th>
                                    <th class="col-whole">Whole Year<br />Rental</th>
                                    @if (IsFacility("ncc"))
                                    {
                                        <th class="col-arealoc">Area Loc.</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int rowNum = 1;
                                }
                                @foreach (var s in FilteredNonNpmStalls)
                                {
                                    <tr class="@(!s.IsActive ? "row-closed" : "")">
                                        <td class="c">@rowNum</td>
                                        <td class="tl fw @(!s.IsActive ? "txt-closed" : "")">@s.ActualOccupant</td>
                                        <td class="tl txt-muted">@(string.IsNullOrEmpty(s.ContractName) ? "—" : s.ContractName)</td>
                                        <td class="c">@s.StallNo</td>
                                        <td class="c">@(s.ContractDate.HasValue? s.ContractDate.Value.ToString("M/d/yyyy") : "—")</td>
                                        <td class="c">3 yrs</td>
                                        <td class="c">@(s.AreaSqm > 0 ? $"{s.AreaSqm} sq.m." : "—")</td>
                                        <td class="r">@(s.IsActive ? $"₱{s.MonthlyRate:N2}" : "—")</td>
                                        <td class="r">@(s.IsActive ? $"₱{s.MonthlyRate:N2}" : "—")</td>
                                        <td class="r">@(s.IsActive ? $"₱{s.MonthlyRate * 12:N2}" : "—")</td>
                                        @if (IsFacility("ncc"))
                                        {
                                            <td class="c">@(string.IsNullOrEmpty(s.AreaLocation) ? "—" : s.AreaLocation)</td>
                                        }
                                    </tr>
                                    rowNum++;
                                }
                            </tbody>
                            <tfoot>
                                <tr class="tfoot-row">
                                    <td colspan="7" class="tfoot-label">
                                        Total — @FilteredNonNpmStalls.Count(s => s.IsActive) active stall@(FilteredNonNpmStalls.Count(s => s.IsActive) != 1 ? "s" : "")
                                    </td>
                                    <td class="r tfoot-val">₱@FilteredNonNpmStalls.Where(s => s.IsActive).Sum(s => s.MonthlyRate).ToString("N2")</td>
                                    <td class="r tfoot-val">₱@FilteredNonNpmStalls.Where(s => s.IsActive).Sum(s => s.MonthlyRate).ToString("N2")</td>
                                    <td class="r tfoot-val">₱@FilteredNonNpmStalls.Where(s => s.IsActive).Sum(s => s.MonthlyRate * 12).ToString("N2")</td>
                                    @if (IsFacility("ncc"))
                                    {
                                        <td></td>
                                    }
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                }

                @if (ActiveSection == "All" || !IsFacility("npm"))
                {
                    <div class="lsh-grand-total">
                        <div class="lsh-grand-label">Grand Total — @FacilityName</div>
                        <div class="lsh-grand-stats">
                            <div class="lsh-grand-stat">
                                <div class="lsh-grand-val">@AllActiveStalls.Count()</div>
                                <div class="lsh-grand-key">Active Stalls</div>
                            </div>
                            <div class="lsh-grand-stat">
                                <div class="lsh-grand-val">₱@AllActiveStalls.Sum(s => s.MonthlyRate).ToString("N2")</div>
                                <div class="lsh-grand-key">Total Monthly Rate</div>
                            </div>
                            <div class="lsh-grand-stat">
                                <div class="lsh-grand-val">₱@AllActiveStalls.Sum(s => s.MonthlyRate * 12).ToString("N2")</div>
                                <div class="lsh-grand-key">Total Whole Year Rental</div>
                            </div>
                        </div>
                    </div>
                }

            </div>

        </div>

@code {

    [Parameter]
    [SupplyParameterFromQuery]
    public string? Facility { get; set; }

    string SearchQuery = string.Empty;
    string ActiveSection = "All";
    bool IsLoading = true;

    readonly string[] SectionKeys = ["All", "Vegetable Area", "Fish Section", "Meat Section"];

    // Facility detection
    string FacilityCode => Facility?.ToUpper() ?? "NPM";
    string BackLink => $"/facility/{Facility?.ToLower() ?? "npm"}";

    string FacilityName => Facility?.ToLower() switch
    {
        "npm" => "New Public Market",
        "tcc" => "Tampak Commercial Center",
        "ncc" => "New Commercial Center",
        "bbq" => "Barbecue Stand",
        "ice" => "Iceplant",
        "slh" => "Slaughter House",
        _ => "New Public Market"
    };

    bool IsFacility(string code) => Facility?.ToLower() == code || (string.IsNullOrEmpty(Facility) && code == "npm");

    IEnumerable<string> VisibleSections => ActiveSection == "All"
        ? new[] { "Vegetable Area", "Fish Section", "Meat Section" }
        : new[] { ActiveSection };

    IEnumerable<NpmStall> GetSectionStalls(string sec) =>
        Stalls.Where(s => s.Facility == (Facility?.ToLower() ?? "npm") && s.Section == sec).OrderBy(s => s.StallNo);

    IEnumerable<NpmStall> AllActiveStalls => Stalls.Where(s => s.Facility == (Facility?.ToLower() ?? "npm") && s.IsActive);
    IEnumerable<NpmStall> VegetableStalls => Stalls.Where(s => s.Facility == (Facility?.ToLower() ?? "npm") && s.Section == "Vegetable Area");
    IEnumerable<NpmStall> FishStalls => Stalls.Where(s => s.Facility == (Facility?.ToLower() ?? "npm") && s.Section == "Fish Section");
    IEnumerable<NpmStall> MeatStalls => Stalls.Where(s => s.Facility == (Facility?.ToLower() ?? "npm") && s.Section == "Meat Section");

    IEnumerable<NpmStall> FilteredNonNpmStalls => Stalls.Where(s => s.Facility == (Facility?.ToLower() ?? "npm") && MatchSearch(s)).OrderBy(s => s.StallNo);

    bool MatchSearch(NpmStall s) =>
        string.IsNullOrWhiteSpace(SearchQuery) ||
        s.ActualOccupant.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
        s.ContractName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
        s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);

    class NpmStall
    {
        public int Id { get; set; }
        public string Facility { get; set; } = "npm";
        public string StallNo { get; set; } = string.Empty;
        public string Section { get; set; } = string.Empty;
        public string ActualOccupant { get; set; } = string.Empty;
        public string ContractName { get; set; } = string.Empty;
        public double AreaSqm { get; set; }
        public DateTime? ContractDate { get; set; }
        public decimal MonthlyRate { get; set; } = 900;
        public bool IsPaid { get; set; }
        public bool IsPartial { get; set; }
        public decimal PartialAmount { get; set; }
        public bool IsActive { get; set; } = true;
        public string ORNumber { get; set; } = string.Empty;
        public decimal FishKilos { get; set; }
        public string? AreaLocation { get; set; }
    }

    List<NpmStall> Stalls = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadStallsFromApi();
    }

    private async Task LoadStallsFromApi()
    {
        IsLoading = true;
        
        var facilityCode = (Facility?.ToLower() ?? "npm") switch
        {
            "npm" => Domain.Enums.FacilityCode.NPM,
            "tcc" => Domain.Enums.FacilityCode.TCC,
            "ncc" => Domain.Enums.FacilityCode.NCC,
            "bbq" => Domain.Enums.FacilityCode.BBQ,
            "ice" => Domain.Enums.FacilityCode.ICE,
            "slh" => Domain.Enums.FacilityCode.SLH,
            _ => Domain.Enums.FacilityCode.NPM
        };

        var result = await StallsApi.GetStallHoldersListAsync(facilityCode, null, null);
        
        if (result.IsSuccess && result.Value != null)
        {
            Stalls.Clear();
            int id = 1;
            
            foreach (var section in result.Value.Sections)
            {
                foreach (var row in section.Rows)
                {
                    // Map enum section names to display names (NPM only)
                    var sectionName = IsFacility("npm") ? section.SectionName switch
                    {
                        "VegetableArea" => "Vegetable Area",
                        "FishSection" => "Fish Section",
                        "MeatSection" => "Meat Section",
                        _ => section.SectionName
                    } : section.SectionName;
                    
                    Stalls.Add(new NpmStall
                    {
                        Id = id++,
                        Facility = Facility?.ToLower() ?? "npm",
                        StallNo = row.StallNo,
                        Section = sectionName,
                        ActualOccupant = row.ActualOccupant,
                        ContractName = row.NameOnContract,
                        AreaSqm = row.AreaSqm ?? 0,
                        ContractDate = row.EffectivityDate == default ? null : row.EffectivityDate.ToDateTime(TimeOnly.MinValue),
                        MonthlyRate = row.MonthlyRentalRate,
                        IsActive = !row.IsClosed,
                        FishKilos = row.FishFeeTotal ?? 0,
                        AreaLocation = row.AreaLocation
                    });
                }
            }
        }
        
        IsLoading = false;
    }
}
