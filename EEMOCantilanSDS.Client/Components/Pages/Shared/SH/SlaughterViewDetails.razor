@page "/facility/slh/transaction/{OwnerName}"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@inject NavigationManager Navigation
@inject ISlaughterApiClient SlaughterApi
@using EEMOCantilanSDS.Application.Dtos.Slaughterhouse
@using EEMOCantilanSDS.Application.Common.Interface.ApiClients

<!-- Topbar -->
<header class="topbar">
            <div class="topbar-left">
                <button class="back-btn" @onclick="GoBack">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </button>
                <div class="topbar-info">
                    <div class="topbar-title">Transaction Details</div>
                    <div class="topbar-breadcrumb">
                        <span>Dashboard</span>
                        <span class="breadcrumb-sep">/</span>
                        <span>Slaughterhouse</span>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">@OwnerName</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @PhilippineTime.Now.ToString("MMMM d, yyyy")
                </div>
                <AccountChip />
            </div>
        </header>

        <div class="content-area">

            <!-- Hero Banner -->
            <div class="slh-hero">
                <div class="slh-hero-left">
                    <div class="slh-hero-icon">
                        <svg viewBox="0 0 24 24" class="slh-icon-svg">
                            <path d="M12 2L2 7l10 5 10-5-10-5z" />
                            <path d="M2 17l10 5 10-5" />
                            <path d="M2 12l10 5 10-5" />
                        </svg>
                    </div>
                    <div>
                        <div class="slh-hero-eyebrow">Facility · SLH</div>
                        <div class="slh-hero-title">@OwnerName</div>
                        <div class="slh-hero-sub">Slaughterhouse Client · Municipality of Cantilan</div>
                    </div>
                </div>
                <div class="slh-hero-stats">
                    <div class="slh-hero-stat">
                        <div class="slh-hero-val">@TotalTransactions</div>
                        <div class="slh-hero-key">Transactions</div>
                    </div>
                    <div class="slh-hero-divider"></div>
                    <div class="slh-hero-stat">
                        <div class="slh-hero-val">@TotalHeads</div>
                        <div class="slh-hero-key">Total Heads</div>
                    </div>
                    <div class="slh-hero-divider"></div>
                    <div class="slh-hero-stat">
                        <div class="slh-hero-val">₱@TotalCollected.ToString("N0")</div>
                        <div class="slh-hero-key">Total Collected</div>
                    </div>
                </div>
                <div class="slh-hero-progress">
                    <div class="slh-hero-progress-fill" style="width:100%"></div>
                </div>
            </div>

            <!-- Transaction History Table -->
            <div class="panel">
                <div class="panel-header">
                    <div>
                        <div class="panel-title">All Transactions</div>
                        <div class="panel-count">@TotalTransactions records · Sorted by latest date</div>
                    </div>
                    <div class="panel-header-right">
                        <div class="animal-counts">
                            @if (OthersCount > 0)
                            {
                                <div class="animal-count-item">
                                    <div class="animal-count-val">@OthersCount</div>
                                    <div class="animal-count-label">Others</div>
                                </div>
                            }
                            <div class="animal-count-item">
                                <div class="animal-count-val">@HogCount</div>
                                <div class="animal-count-label">Hog</div>
                            </div>
                            <div class="animal-count-item">
                                <div class="animal-count-val">@CarabaoCount</div>
                                <div class="animal-count-label">Carabao</div>
                            </div>
                            <div class="animal-count-item">
                                <div class="animal-count-val">@CowCount</div>
                                <div class="animal-count-label">Cow</div>
                            </div>
                        </div>
                        <button class="btn-print" @onclick="PrintPage">
                            <svg viewBox="0 0 24 24"><polyline points="6 9 6 2 18 2 18 9" /><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" /><rect x="6" y="14" width="12" height="8" /></svg>
                            Print Record
                        </button>
                    </div>
                </div>

                <div class="table-wrap">
                    <table class="txn-table">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>DATE</th>
                                <th>ANIMAL TYPE</th>
                                <th>NO. OF HEADS</th>
                                <th>RATE / HEAD</th>
                                <th>TOTAL AMOUNT</th>
                                <th>OR NUMBER</th>
                                <th>COLLECTOR</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int idx = 1;
                                var groupedByOR = Transactions.GroupBy(t => new { t.TransactionDate, t.ORNumber }).ToList();
                            }
                            @foreach (var orGroup in groupedByOR)
                            {
                                var transactions = orGroup.ToList();
                                var isFirstInGroup = true;
                                
                                @foreach (var txn in transactions)
                                {
                                    var isLastInGroup = txn == transactions.Last();
                                    <tr class="txn-row @(isFirstInGroup ? "group-first" : "") @(isLastInGroup ? "group-last" : "group-middle")">
                                        <td class="row-num">@(isFirstInGroup ? idx.ToString() : "")</td>
                                        <td>@(isFirstInGroup ? txn.TransactionDate.ToString("MMM d, yyyy") : "")</td>
                                        <td>@txn.AnimalTypeDisplay</td>
                                        <td>@txn.NumberOfHeads</td>
                                        <td>₱@txn.RatePerHead.ToString("N0")</td>
                                        <td>₱@txn.TotalAmount.ToString("N0")</td>
                                        <td>@(isFirstInGroup ? txn.ORNumber : "")</td>
                                        <td>@(isFirstInGroup ? txn.CollectorName : "")</td>
                                    </tr>
                                    isFirstInGroup = false;
                                }
                                idx++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Collection Summary Card -->
            <div class="summary-card">
                <div class="summary-header">
                    <div class="summary-title">Collection Summary</div>
                    <div class="summary-period">All Time</div>
                </div>
                <div class="summary-grid">
                    <div class="summary-item">
                        <div class="summary-label">Total Transactions</div>
                        <div class="summary-value">@TotalTransactions</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-label">Total Heads Processed</div>
                        <div class="summary-value">@TotalHeads</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-label">Average per Transaction</div>
                        <div class="summary-value">₱@(Profile?.CollectionSummary.AveragePerTransaction.ToString("N2") ?? "0.00")</div>
                    </div>
                    <div class="summary-item">
                        <div class="summary-label">Total Revenue</div>
                        <div class="summary-value highlight">₱@(Profile?.CollectionSummary.TotalRevenue.ToString("N2") ?? "0.00")</div>
                    </div>
                </div>
            </div>

        </div><!-- end content-area -->

@code {
    [Parameter] public string OwnerName { get; set; } = string.Empty;

    private ClientProfileDto? Profile;
    private bool isLoading = true;

    [PersistentState(AllowUpdates = true)]
    public SlaughterClientProfileState? CachedProfile { get; set; }

    private List<ClientTransactionDto> Transactions => Profile?.Transactions.ToList() ?? new();
    private int TotalTransactions => Profile?.TotalTransactions ?? 0;
    private int TotalHeads => Profile?.TotalHeads ?? 0;
    private decimal TotalCollected => Profile?.TotalCollected ?? 0;
    private int HogCount => Transactions.Count(t => t.AnimalTypeDisplay == "Hog");
    private int CarabaoCount => Transactions.Count(t => t.AnimalTypeDisplay == "Carabao");
    private int CowCount => Transactions.Count(t => t.AnimalTypeDisplay == "Cow");
    private int OthersCount => Transactions.Count(t => t.AnimalTypeDisplay != "Hog" && t.AnimalTypeDisplay != "Carabao" && t.AnimalTypeDisplay != "Cow");

    protected override async Task OnInitializedAsync()
    {
        if (CachedProfile is not null &&
            string.Equals(CachedProfile.OwnerName, OwnerName, StringComparison.OrdinalIgnoreCase))
        {
            Profile = CachedProfile.Profile;
            isLoading = false;
            return;
        }

        await LoadClientProfile();
    }

    private async Task LoadClientProfile()
    {
        isLoading = true;
        var result = await SlaughterApi.GetClientProfileAsync(OwnerName);
        if (result.IsSuccess && result.Value is not null)
        {
            Profile = result.Value;
            CachedProfile = new SlaughterClientProfileState(OwnerName, result.Value);
        }
        isLoading = false;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/facility/slh");
    }
    
    private void PrintPage()
    {
        // TODO: JS interop: window.print()
    }

    public sealed record SlaughterClientProfileState(string OwnerName, ClientProfileDto Profile);
}
