@* ══════════════════════════════════════════════════════════════════════
   FacilityStallsTable.razor  —  Reusable stalls table for all facilities

   USAGE:
       <FacilityStallsTable Facility="ICE"
                            FilteredStalls="FilteredStalls"
                            OnPaymentClick="OpenPayment"
                            OnHistoryClick="OpenHistory"
                            OnEditClick="OpenEdit" />

   PROPERTIES:
     Facility         – string  – facility code (NPM, ICE, TCC, NCC, BBQ)
     FilteredStalls   – IEnumerable  – stalls to display
     OnPaymentClick   – EventCallback – payment record button clicked
     OnHistoryClick   – EventCallback – history button clicked
     OnEditClick      – EventCallback – edit/profile button clicked
══════════════════════════════════════════════════════════════════════ *@

@typeparam TStall

@inject NavigationManager Navigation

<div class="panel">
    @if (!FilteredStalls.Any())
    {
        <div class="empty-state">
            <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
            <div class="empty-title">No Stalls Found</div>
            <div class="empty-sub">Try adjusting the filters or search.</div>
        </div>
    }
    else
    {
        @if (ColumnSet == "Operational")
        {
            <div class="ops-grid">
                @foreach (var s in FilteredStalls)
                {
                    <div class="ops-card @GetRowClass(s)">
                        <div class="ops-card-top">
                            <div class="ops-stall-no">@GetStallNo(s)</div>
                            @if (GetPaidToday(s))
                            {
                                <span class="today-pill today-paid">
                                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                    Paid today
                                </span>
                            }
                            else
                            {
                                <span class="today-pill today-pending">
                                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><line x1="12" y1="7" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                                    Not yet
                                </span>
                            }
                            <div class="action-btns ops-actions">
                                <button class="action-btn" title="View / Record Payment" @onclick="() => OnPaymentClick.InvokeAsync(s)">
                                    <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                                </button>
                                <button class="action-btn" title="Payment History" @onclick="() => OnHistoryClick.InvokeAsync(s)">
                                    <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                                </button>
                                <button class="action-btn" title="View Profile" @onclick="() => NavigateToProfile(s)">
                                    <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                </button>
                            </div>
                        </div>
                        <div class="ops-card-name">@GetActualOccupant(s)</div>
                        <div class="ops-card-meta">
                            <span class="ops-meta-item">
                                <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                <span class="days-paid">@GetDaysPaid(s)</span> days paid
                            </span>
                            <span class="ops-meta-sep">·</span>
                            <span class="ops-meta-item">
                                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                Last: @GetLastPaid(s)
                            </span>
                            @if (!string.IsNullOrEmpty(GetORNumber(s)) && GetORNumber(s) != "—")
                            {
                                <span class="ops-meta-sep">·</span>
                                <span class="ops-meta-item ops-or">OR @GetORNumber(s)</span>
                            }
                        </div>
                    </div>
                }
                @if (ShowFillerSlot) { @FillerSlot }
            </div>
        }
        else if (ColumnSet == "MonthlyCard")
        {
            <div class="ops-grid">
                @foreach (var s in FilteredStalls)
                {
                    var paid = GetIsPaid(s);
                    var partial = GetIsPartial(s);
                    <div class="ops-card @GetRowClass(s)">
                        <div class="ops-card-top">
                            <div class="ops-stall-no">@GetStallNo(s)</div>
                            @if (paid)
                            {
                                <span class="today-pill today-paid">
                                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                    Paid
                                </span>
                            }
                            else if (partial)
                            {
                                <span class="today-pill today-partial">
                                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><path d="M12 3a9 9 0 0 1 0 18z" /></svg>
                                    Partial
                                </span>
                            }
                            else
                            {
                                <span class="today-pill today-pending">
                                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><line x1="12" y1="7" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                                    Unpaid
                                </span>
                            }
                            <div class="action-btns ops-actions">
                                <button class="action-btn" title="View / Record Payment" @onclick="() => OnPaymentClick.InvokeAsync(s)">
                                    <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                                </button>
                                <button class="action-btn" title="Payment History" @onclick="() => OnHistoryClick.InvokeAsync(s)">
                                    <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                                </button>
                                <button class="action-btn" title="View Profile" @onclick="() => NavigateToProfile(s)">
                                    <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                </button>
                            </div>
                        </div>
                        <div class="ops-card-name">@GetActualOccupant(s)</div>
                        <div class="ops-card-meta">
                            <span class="ops-meta-item">
                                <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                                <span class="days-paid">₱@GetMonthlyRate(s).ToString("N0")</span> / month
                            </span>
                            @if (partial)
                            {
                                <span class="ops-meta-sep">·</span>
                                <span class="ops-meta-item">₱@GetPartialAmount(s).ToString("N0") paid</span>
                            }
                            @if (!string.IsNullOrEmpty(GetORNumber(s)) && GetORNumber(s) != "—")
                            {
                                <span class="ops-meta-sep">·</span>
                                <span class="ops-meta-item ops-or">OR @GetORNumber(s)</span>
                            }
                        </div>
                    </div>
                }
                @if (ShowFillerSlot) { @FillerSlot }
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Stall No.</th>
                            <th>Actual Occupant</th>
                            <th>Name on Contract</th>
                            <th>Area (sqm)</th>
                            <th>Contract Date</th>
                            <th>Monthly Rent</th>
                            <th>OR No.</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in FilteredStalls)
                        {
                            <tr class="@GetRowClass(s) data-row">
                                <td>@GetStallNo(s)</td>
                                <td>@GetActualOccupant(s)</td>
                                <td>
                                    @{
                                        var contractName = GetContractName(s);
                                        if (string.IsNullOrEmpty(contractName) || contractName.StartsWith("No contract"))
                                        {
                                            <span>No contract</span>
                                        }
                                        else
                                        {
                                            @contractName
                                        }
                                    }
                                </td>
                                <td>@GetAreaSqm(s)</td>
                                <td>@GetContractDate(s)</td>
                                <td>₱@GetMonthlyRate(s).ToString("N0")</td>
                                <td><span class="mono">@GetORNumber(s)</span></td>
                                <td>
                                    <div class="action-btns">
                                        <button class="action-btn" title="View / Record Payment" @onclick="() => OnPaymentClick.InvokeAsync(s)">
                                            <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                                        </button>
                                        <button class="action-btn" title="Payment History" @onclick="() => OnHistoryClick.InvokeAsync(s)">
                                            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                                        </button>
                                        <button class="action-btn" title="View Profile" @onclick="() => NavigateToProfile(s)">
                                            <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    }
</div>

@code {

    [Parameter] public string Facility { get; set; } = string.Empty;
    [Parameter] public string ColumnSet { get; set; } = "Lease";
    [Parameter] public IEnumerable<TStall> FilteredStalls { get; set; } = new List<TStall>();
    [Parameter] public EventCallback<TStall> OnPaymentClick { get; set; }
    [Parameter] public EventCallback<TStall> OnHistoryClick { get; set; }
    [Parameter] public EventCallback<TStall> OnEditClick { get; set; }

    /// <summary>Optional text shown in the trailing placeholder when the card grid has an odd count.</summary>
    [Parameter] public string EmptySlotLabel { get; set; } = "No other vendors";

    // The 2-per-row card grid leaves one empty cell when the count is odd — fill it with a subtle placeholder.
    private bool ShowFillerSlot => FilteredStalls.Any() && FilteredStalls.Count() % 2 != 0;

    private RenderFragment FillerSlot => @<div class="ops-card ops-card-empty" aria-hidden="true">
        <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /><line x1="4.5" y1="4.5" x2="19.5" y2="19.5" /></svg>
        <span class="ops-empty-label">@EmptySlotLabel</span>
    </div>;

    // Helper methods using reflection to access stall properties generically
    private string GetStallNo(TStall stall) => GetPropertyValue<string>(stall, "StallNo") ?? "";
    private Guid GetStallId(TStall stall) => GetPropertyValue<Guid>(stall, "StallGuid");
    private string GetActualOccupant(TStall stall) => GetPropertyValue<string>(stall, "ActualOccupant") ?? "";
    private string GetContractName(TStall stall) => GetPropertyValue<string>(stall, "ContractName") ?? "";
    private double GetAreaSqm(TStall stall) => GetPropertyValue<double?>(stall, "AreaSqm") ?? 0;
    private string GetORNumber(TStall stall) => GetPropertyValue<string>(stall, "ORNumber") ?? "—";
    private decimal GetMonthlyRate(TStall stall) => GetPropertyValue<decimal?>(stall, "MonthlyRate") ?? 0;

    // ── Operational (NPM daily) accessors ──
    private bool GetPaidToday(TStall stall) => GetPropertyValue<bool?>(stall, "PaidToday") ?? false;
    private int GetDaysPaid(TStall stall) => GetPropertyValue<int?>(stall, "DaysPaidThisMonth") ?? 0;

    // ── Monthly card accessors (TCC/NCC/BBQ/ICE monthly rental) ──
    private bool GetIsPaid(TStall stall) => GetPropertyValue<bool?>(stall, "IsPaid") ?? false;
    private bool GetIsPartial(TStall stall) => GetPropertyValue<bool?>(stall, "IsPartial") ?? false;
    private decimal GetPartialAmount(TStall stall) => GetPropertyValue<decimal?>(stall, "PartialAmount") ?? 0;
    private string GetLastPaid(TStall stall)
    {
        var date = GetPropertyValue<DateOnly?>(stall, "LastPaidDate");
        return date.HasValue ? date.Value.ToString("MMM d") : "—";
    }

    private string GetContractDate(TStall stall)
    {
        var date = GetPropertyValue<DateTime?>(stall, "ContractDate");
        return date.HasValue ? date.Value.ToString("MMM d, yyyy") : "—";
    }

    private string GetAreaSqmDisplay(double area) => area > 0 ? $"{area}" : "—";

    private T GetPropertyValue<T>(TStall stall, string propertyName)
    {
        var property = stall?.GetType().GetProperty(propertyName);
        return property != null ? (T?)property.GetValue(stall) ?? default! : default!;
    }

    private string GetRowClass(TStall stall)
    {
        var isActive = GetPropertyValue<bool?>(stall, "IsActive") ?? true;
        if (!isActive) return "row-inactive";

        // Operational (NPM daily) mode: tint reflects whether today's ₱30 was collected.
        if (ColumnSet == "Operational")
            return GetPaidToday(stall) ? "row-paid" : "row-unpaid";

        var isPaid = GetPropertyValue<bool?>(stall, "IsPaid") ?? false;
        var isPartial = GetPropertyValue<bool?>(stall, "IsPartial") ?? false;

        if (isPaid) return "row-paid";
        if (isPartial) return "row-partial";
        return "row-unpaid";
    }

    /// <summary>
    /// Navigates to the profile page with facility and stall parameters
    /// </summary>
    private void NavigateToProfile(TStall stall)
    {
        var stallId = GetStallId(stall);
        var facilityId = Facility.ToLower();
        // Prefer the unique stall GUID (NPM stall numbers repeat across sections); fall back to number.
        var key = stallId != Guid.Empty ? stallId.ToString() : GetStallNo(stall);
        Navigation.NavigateTo($"/profile/{facilityId}/{key}");
    }
}
