        new() { Id=19, Facility="npm", StallNo="19", Section="Vegetable Area", ActualOccupant="Gonzales, Jonalyn",       ContractName="Retchel R. Estrada",     AreaSqm=4.8, ContractDate=new DateTime(2023,6,7), IsPaid=true  },
        new() { Id=24, Facility="npm", StallNo="24", Section="Vegetable Area", ActualOccupant="Tesado, Ariel",           ContractName="Judianne C. Cahutay",    AreaSqm=4.8, ContractDate=new DateTime(2023,6,7), IsPaid=true  },
