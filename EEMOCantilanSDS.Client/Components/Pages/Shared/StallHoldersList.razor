        // NPM - FISH SECTION
        new() { Id=40, Facility="npm", StallNo="F01", Section="Fish Section", ActualOccupant="Dela Cruz, Maria S.",  ContractName="Dela Cruz, Maria S.",  AreaSqm=4.8, ContractDate=new DateTime(2023,6,7), IsPaid=true,   FishKilos=85  },
        new() { Id=41, Facility="npm", StallNo="F02", Section="Fish Section", ActualOccupant="Santos, Rodrigo T.",   ContractName="Santos, Rodrigo T.",   AreaSqm=4.8, ContractDate=new DateTime(2023,6,7), IsPartial=true, PartialAmount=360, FishKilos=60  },
        new() { Id=42, Facility="npm", StallNo="F03", Section="Fish Section", ActualOccupant="Bautista, Nena L.",    ContractName="Bautista, Nena L.",    AreaSqm=4.8, ContractDate=new DateTime(2023,6,7), IsPartial=true, PartialAmount=270, FishKilos=45  },
        new() { Id=43, Facility="npm", StallNo="F04", Section="Fish Section", ActualOccupant="Reyes, Luzviminda A.", ContractName="Reyes, Luzviminda A.", AreaSqm=4.8, ContractDate=new DateTime(2023,6,7), IsPaid=true,   FishKilos=102 },
        // NPM - MEAT SECTION
        new() { Id=44, Facility="npm", StallNo="M01", Section="Meat Section", ActualOccupant="Garcia, Flordeliza B.", ContractName="Garcia, Flordeliza B.", AreaSqm=4.8, ContractDate=new DateTime(2023,6,7), IsPartial=true, PartialAmount=600 },
