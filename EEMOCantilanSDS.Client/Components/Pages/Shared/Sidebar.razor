<aside class="sidebar @(SidebarCollapsed ? "collapsed" : "")">
    <div class="sidebar-brand">
        <div class="sidebar-seal">
            <img src="/images/LGU_CANTILAN_LOGO.jpg" alt="LGU Cantilan" />
        </div>
        <div class="sidebar-brand-text">
            <div class="sidebar-brand-name">EEMO</div>
            <div class="sidebar-brand-sub">Admin Portal</div>
        </div>
    </div>

    <div class="sidebar-divider"></div>

    <nav class="sidebar-nav">
        <div class="nav-group-label">Main</div>

        <a href="/menu" class="nav-item active">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
            <span>Dashboard</span>
        </a>
        <a href="/collectors" class="nav-item">
            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>
            <span>Collectors</span>
        </a>
        <a href="/vendors" class="nav-item">
            <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" /><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16" /></svg>
            <span>Vendors &amp; Stalls</span>
        </a>

        <div class="nav-group-label" style="margin-top:1rem;">Facilities</div>

        @foreach (var fac in Facilities)
        {
            <a href="/facility/@fac.Code.ToLower()" class="nav-item">
                @((MarkupString)fac.IconSvg)
                <span>@fac.ShortName</span>
                @if (fac.UnpaidCount > 0)
                {
                    <span class="nav-badge">@fac.UnpaidCount</span>
                }
            </a>
        }

        <div class="nav-group-label" style="margin-top:1rem;">Reports</div>

        <a href="/reports" class="nav-item">
            <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
            <span>Financial Reports</span>
        </a>
        <a href="/audit-trail" class="nav-item">
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
            <span>Audit Trail</span>
        </a>
        <a href="/export" class="nav-item">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
            <span>Export Data</span>
        </a>

        <div class="nav-group-label" style="margin-top:1rem;">System</div>

        <a href="/settings" class="nav-item">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" /><path d="M19.07 4.93l-1.41 1.41M19.07 19.07l-1.41-1.41M4.93 19.07l1.41-1.41M4.93 4.93l1.41 1.41M21 12h-2M5 12H3M12 21v-2M12 5V3" /></svg>
            <span>Settings</span>
        </a>
    </nav>

    <button class="sidebar-toggle" @onclick="() => SidebarCollapsed = !SidebarCollapsed">
        <svg viewBox="0 0 24 24"><polyline points="@(SidebarCollapsed ? "9 6 15 12 9 18" : "15 18 9 12 15 6")" /></svg>
    </button>
</aside>
@code{
    bool SidebarCollapsed = false;
    
