@using System.Security.Claims
@using EEMOCantilanSDS.Application.Dtos.Facilities
@inject IFacilitiesApiClient FacilitiesApi
@inject IOnlinePaymentsApiClient OnlinePaymentsApi
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@implements IDisposable

<aside class="sidebar @(SidebarCollapsed ? "collapsed" : "")">
    <div class="sidebar-brand">
        <div class="sidebar-seal">
            <img src="/images/LGU_CANTILAN_LOGO.jpg" alt="LGU Cantilan" />
        </div>
        <div class="sidebar-brand-text">
            <div class="sidebar-brand-name">STALLTRACK</div>
            <div class="sidebar-brand-sub">@_portalLabel</div>
        </div>
    </div>

    <div class="sidebar-divider"></div>

    <nav class="sidebar-nav">
        <div class="nav-group-label">Main</div>

        <NavLink href="/menu" class="@NavItemClass("/menu")" Match="NavLinkMatch.All" @onclick='() => SetPendingPath("/menu")'>
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
            <span>Dashboard</span>
        </NavLink>
        <NavLink href="/collectors" class="@NavItemClass("/collectors")" @onclick='() => SetPendingPath("/collectors")'>
            <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>
            <span>Collectors</span>
        </NavLink>
        <NavLink href="/vendors" class="@NavItemClass("/vendors")" @onclick='() => SetPendingPath("/vendors")'>
            <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" /><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16" /></svg>
            <span>Vendors &amp; Stalls</span>
        </NavLink>
        <NavLink href="/transactions" class="@NavItemClass("/transactions")" @onclick='() => SetPendingPath("/transactions")'>
            <svg viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z" /><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z" /></svg>
            <span>Transactions</span>
        </NavLink>
        <NavLink href="/online-payments" class="@NavItemClass("/online-payments")" @onclick='() => SetPendingPath("/online-payments")'>
            <svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2" /><line x1="2" y1="10" x2="22" y2="10" /></svg>
            <span>Online Payments</span>
            @if (_onlinePaymentsAwaitingOr > 0)
            {
                <span class="nav-badge">@_onlinePaymentsAwaitingOr</span>
            }
        </NavLink>

        <div class="nav-group-label" style="margin-top:1rem;">Facilities</div>

        @foreach (var fc in Enum.GetValues<FacilityCode>())
        {
            if (!Display.TryGetValue(fc, out var display)) { continue; }
            var unpaid = _unpaidByCode.GetValueOrDefault(fc);
            var href = "/facility/" + fc.ToString().ToLower();
            <NavLink href="@href" class="@NavItemClass(href)" @onclick="() => SetPendingPath(href)">
                @((MarkupString)display.Icon)
                <span>@display.Label</span>
                @if (unpaid > 0)
                {
                    <span class="nav-badge">@unpaid</span>
                }
            </NavLink>
        }

        <div class="nav-group-label" style="margin-top:1rem;">Reports</div>

        <NavLink href="/reports" class="@NavItemClass("/reports")" @onclick='() => SetPendingPath("/reports")'>
            <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
            <span>Financial Reports</span>
        </NavLink>
        <NavLink href="/audit-trail" class="@NavItemClass("/audit-trail")" @onclick='() => SetPendingPath("/audit-trail")'>
            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
            <span>Audit Trail</span>
        </NavLink>
        <NavLink href="/export" class="@NavItemClass("/export")" @onclick='() => SetPendingPath("/export")'>
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
            <span>Export Data</span>
        </NavLink>

        <div class="nav-group-label" style="margin-top:1rem;">System</div>

        <NavLink href="/settings" class="@NavItemClass("/settings")" @onclick='() => SetPendingPath("/settings")'>
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" /><path d="M19.07 4.93l-1.41 1.41M19.07 19.07l-1.41-1.41M4.93 19.07l1.41-1.41M4.93 4.93l1.41 1.41M21 12h-2M5 12H3M12 21v-2M12 5V3" /></svg>
            <span>Settings</span>
        </NavLink>
    </nav>

    <button class="sidebar-toggle" @onclick="() => SidebarCollapsed = !SidebarCollapsed">
        <svg viewBox="0 0 24 24"><polyline points="@(SidebarCollapsed ? "9 6 15 12 9 18" : "15 18 9 12 15 6")" /></svg>
    </button>
</aside>

@* Cross-page "restore complete" popup — event-driven (subscribes to the scoped RestoreNotifier); no timer here. *@
<RestoreCompletionToast />

@code {
    private bool SidebarCollapsed;
    private string _portalLabel = "Admin Portal";
    private string? _pendingPath;
    private readonly DateTime _statePeriod = EEMOCantilanSDS.Domain.Common.PhilippineTime.Now;
    private Dictionary<FacilityCode, int> _unpaidByCode = new();
    private int _onlinePaymentsAwaitingOr;

    [PersistentState(AllowUpdates = true)]
    public List<FacilitySidebarSummaryDto>? FacilitySummaries { get; set; }

    [PersistentState(AllowUpdates = true)]
    public int? OnlinePaymentsAwaitingOr { get; set; }

    protected override void OnInitialized()
        => Nav.LocationChanged += OnLocationChanged;

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => _ = InvokeAsync(() =>
        {
            _pendingPath = null;
            StateHasChanged();
        });

    private void SetPendingPath(string href)
    {
        var targetPath = NormalizePath(href);
        _pendingPath = targetPath;
    }

    private string NavItemClass(string href)
    {
        var active = Active(href);
        return string.IsNullOrWhiteSpace(active) ? "nav-item" : $"nav-item {active}";
    }

    // Returns "active" CSS class if the current path matches the given href (exact for /menu,
    // prefix for everything else so /facility/npm and /tcc/reports both light up the facility item).
    private string Active(string href)
    {
        var path = _pendingPath ?? new Uri(Nav.Uri).AbsolutePath;
        href = NormalizePath(href);
        if (href == "/menu")
            return path == "/menu" || path == "/" ? "active" : string.Empty;
        return path.StartsWith(href, StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty;
    }

    private static string NormalizePath(string path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "/";

        path = path.Trim();
        if (!path.StartsWith('/'))
            path = "/" + path;

        return path.TrimEnd('/') is { Length: > 0 } trimmed ? trimmed : "/";
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var isHead = state.User.IsInRole("SuperAdmin")
            || state.User.Claims.Any(c =>
                string.Equals(c.Value, "SuperAdmin", StringComparison.OrdinalIgnoreCase)
                && c.Type.Contains("role", StringComparison.OrdinalIgnoreCase));
        _portalLabel = isHead ? "Head Portal" : "Admin Portal";

        if (FacilitySummaries is not null)
        {
            ApplyFacilitySummaries(FacilitySummaries);
        }
        else
        {
            var result = await FacilitiesApi.GetFacilitySummariesAsync(_statePeriod.Year, _statePeriod.Month);
            if (result.IsSuccess && result.Value is not null)
            {
                ApplyFacilitySummaries(result.Value.ToList());
            }
        }

        if (OnlinePaymentsAwaitingOr is not null)
        {
            _onlinePaymentsAwaitingOr = OnlinePaymentsAwaitingOr.Value;
        }
        else
        {
            var awaitingOr = await OnlinePaymentsApi.GetAwaitingOrAsync();
            if (awaitingOr.IsSuccess && awaitingOr.Value is not null)
            {
                _onlinePaymentsAwaitingOr = awaitingOr.Value.Count;
                OnlinePaymentsAwaitingOr = _onlinePaymentsAwaitingOr;
            }
        }
    }

    private void ApplyFacilitySummaries(IReadOnlyList<FacilitySidebarSummaryDto> summaries)
    {
        FacilitySummaries = summaries as List<FacilitySidebarSummaryDto> ?? summaries.ToList();
        _unpaidByCode = FacilitySummaries.ToDictionary(f => f.Code, f => f.UnpaidCount);
    }

    // Presentation only: short nav label + icon per facility code (data comes from the API).
    private static readonly Dictionary<FacilityCode, (string Label, string Icon)> Display = new()
    {
        [FacilityCode.NPM] = ("Public Market", """<svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>"""),
        [FacilityCode.TCC] = ("Tampak Comm.", """<svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>"""),
        [FacilityCode.NCC] = ("New Comm. Center", """<svg viewBox="0 0 24 24"><path d="M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18"/></svg>"""),
        [FacilityCode.BBQ] = ("BBQ Stand", """<svg viewBox="0 0 24 24"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>"""),
        [FacilityCode.ICE] = ("Iceplant", """<svg viewBox="0 0 24 24"><line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>"""),
        [FacilityCode.SLH] = ("Slaughterhouse", """<svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>"""),
        [FacilityCode.TRM] = ("Transport Terminal", """<svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>"""),
        [FacilityCode.TPM] = ("Tabo-an Market", """<svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>"""),
    };

    public void Dispose()
    {
        Nav.LocationChanged -= OnLocationChanged;
    }
}
