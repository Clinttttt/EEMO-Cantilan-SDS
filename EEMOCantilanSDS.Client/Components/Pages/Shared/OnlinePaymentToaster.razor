@using System.Security.Claims
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@implements IAsyncDisposable
@inject AuthenticationStateProvider AuthState
@inject EEMOCantilanSDS.Client.Securities.TokenService Tokens
@inject IConfiguration Config
@inject IJSRuntime JS

@if (_toasts.Count > 0)
{
    <div class="op-toast-stack">
        @foreach (var t in _toasts)
        {
            <div class="op-toast" @key="t.Id">
                <div class="op-toast-icon">
                    <svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2" /><line x1="2" y1="10" x2="22" y2="10" /></svg>
                </div>
                <div class="op-toast-body">
                    <div class="op-toast-title">Online payment received</div>
                    <div class="op-toast-text">₱@t.Amount.ToString("N2") · @t.Period · awaiting OR</div>
                    <div class="op-toast-ref">@t.Reference</div>
                </div>
                <button class="op-toast-x" type="button" @onclick="() => Dismiss(t.Id)" aria-label="Dismiss">×</button>
            </div>
        }
    </div>
}

@code {
    private sealed record Toast(Guid Id, decimal Amount, string Period, string Reference);

    private readonly List<Toast> _toasts = new();
    private DotNetObjectReference<OnlinePaymentToaster>? _ref;
    private bool _started;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _started) return;

        // Only staff (admin/head) connect to the staff hub.
        var state = await AuthState.GetAuthenticationStateAsync();
        if (!(state.User.IsInRole("SuperAdmin") || state.User.IsInRole("Admin")))
            return;

        var token = Tokens.GetToken();
        if (string.IsNullOrWhiteSpace(token))
            return;

        var baseUrl = (Config["ApiBaseUrl"] ?? string.Empty).TrimEnd('/');
        if (string.IsNullOrEmpty(baseUrl))
            return;

        _started = true;
        _ref = DotNetObjectReference.Create(this);
        try
        {
            await JS.InvokeAsync<bool>("eemoPaymentHub.start", $"{baseUrl}/hubs/online-payments", token, _ref);
        }
        catch
        {
            // Realtime is a non-critical enhancement; the reconciliation page still works without it.
        }
    }

    [JSInvokable]
    public void OnPaymentReceived(decimal amount, string period, string reference)
    {
        var toast = new Toast(Guid.NewGuid(), amount, period ?? string.Empty, reference ?? string.Empty);
        _toasts.Add(toast);
        StateHasChanged();
        _ = AutoDismissAsync(toast.Id);
    }

    private async Task AutoDismissAsync(Guid id)
    {
        await Task.Delay(8000);
        Dismiss(id);
    }

    private void Dismiss(Guid id)
    {
        if (_toasts.RemoveAll(t => t.Id == id) > 0)
            InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        try { await JS.InvokeVoidAsync("eemoPaymentHub.stop"); } catch { /* ignore */ }
        _ref?.Dispose();
    }
}
