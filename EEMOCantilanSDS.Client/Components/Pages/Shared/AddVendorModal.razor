    /// Facility options for the dropdown.
    /// Vendors page  → pass all facilities.
    /// Facility page → pass a single-item list  +  FacilityLocked="true"
    [Parameter] public List<VendorFacilityOption> FacilityOptions { get; set; } = new();

    /// true  → show a read-only facility label   (called from a facility page e.g. NPM)
    /// false → show the full facility dropdown   (called from Vendor.razor)
    [Parameter] public bool FacilityLocked { get; set; } = false;

    /// Fires when Save / Add Vendor is clicked — host runs its own validation + save logic
    [Parameter] public EventCallback OnSave { get; set; }

    /// Fires when Cancel or the ✕ button is clicked
    [Parameter] public EventCallback OnCancel { get; set; }

    /// Fires after the facility dropdown changes — host should call its OnFacilityChanged / AutoPopulateFees
    [Parameter] public EventCallback OnFacilityChanged { get; set; }

    /// Fires after the section dropdown changes — host should call its OnSectionChanged / AutoPopulateFees
    [Parameter] public EventCallback OnSectionChanged { get; set; }

    /// Fires when a fee toggle (Electricity / Water) is clicked — host calls ToggleFee(feeName)
    [Parameter] public EventCallback<string> OnToggleFee { get; set; }

    /// NPM per-LGU custom section names (host-supplied) — shown as selectable options in the Section dropdown.
    [Parameter] public IReadOnlyList<string> CustomSectionNames { get; set; } = Array.Empty<string>();

    // ── Private relay handlers ────────────────────────────────────────────────

    private async Task HandleCancel() => await OnCancel.InvokeAsync();
    private async Task HandleSave() => await OnSave.InvokeAsync();
    private async Task HandleFacilityChanged() => await OnFacilityChanged.InvokeAsync();
    private async Task HandleSectionChanged() => await OnSectionChanged.InvokeAsync();

    // Fee state lives on the shared Form. Toggle it HERE (the modal owns the click) so the checkbox
    // updates immediately and identically on every host — facility pages (NPM/TCC/NCC/BBQ/ICE) and the
    // Vendors registry — without depending on a host round-trip re-render. All hosts' toggles were the
    // same add/remove, so this is authoritative.
    private void HandleToggleFee(string fee)
    {
        if (Form.FeeTypes.Contains(fee))
            Form.FeeTypes.Remove(fee);
        else
            Form.FeeTypes.Add(fee);
        StateHasChanged();
    }

    // Options for the custom Section / Contract-duration dropdowns. NPM custom sections (passed by the host)
    // appear as selectable "existing:{name}" options, followed by the "＋ Custom section…" add-new sentinel.
    private IReadOnlyList<(string Value, string Label)> SectionOptions
    {
        get
        {
            var opts = new List<(string, string)>
            {
                ("Vegetable", "Vegetable Area"), ("Fish", "Fish Area"), ("Meat", "Meat Area"),
            };
            foreach (var name in CustomSectionNames)
                opts.Add(($"existing:{name}", name));
            opts.Add(("__custom__", "＋ Custom section…"));
            return opts;
        }
    }
    private static readonly IReadOnlyList<(string Value, string Label)> ContractYearOptions = new List<(string, string)>
    {
        ("1", "1 year"), ("2", "2 years"), ("3", "3 years"), ("5", "5 years"), ("custom", "Custom…"),
    };

    private async Task OnSectionSelected(string value)
    {
        Form.SelectedSection = value;
        await HandleSectionChanged();
    }

    private void OnContractYearsSelected(string value)
    {
        if (value == "custom")
        {
            _customYears = true;
            // Seed a sensible in-range term if the current value is a standard preset or below the minimum.
            if (Form.ContractYears is < 1 or 1 or 2 or 3 or 5) Form.ContractYears = 4;
        }
        else
        {
            _customYears = false;
            Form.ContractYears = int.TryParse(value, out var years) ? years : 0;
        }
    }

    // Bulk import is offered (Add mode only) for the facilities that have an import page.
    private static readonly HashSet<string> ImportFacilities = new(StringComparer.OrdinalIgnoreCase)
        { "NPM", "TCC", "NCC", "BBQ", "ICE" };
    private bool IsImportSupported => ImportFacilities.Contains(Form.FacilityCode);

    private void HandleImport()
    {
        if (IsImportSupported)
            Navigation.NavigateTo($"/import/{Form.FacilityCode.ToLowerInvariant()}");
    }

