@inject IJSRuntime JS
@inject NavigationManager Navigation

@* ══════════════════════════════════════════════════════════════════════
   AddVendorModal.razor  —  Shared reusable Add / Edit Vendor Modal

   USAGE — Vendors page (facility dropdown is open):
       <AddVendorModal Show="ShowModal"
                       IsEditing="IsEditing"
                       Form="Form"
                       FormError="FormError"
                       FacilityOptions="FacilityTabsAsOptions()"
                       FacilityLocked="false"
                       OnSave="SaveVendor"
                       OnCancel="CloseModal"
                       OnFacilityChanged="OnFacilityChanged"
                       OnSectionChanged="OnSectionChanged"
                       OnToggleFee="ToggleFee" />

   USAGE — Facility page e.g. NPM (facility is fixed / locked):
       <AddVendorModal Show="ShowAddModal"
                       IsEditing="false"
                       Form="AddForm"
                       FormError="AddFormError"
                       FacilityOptions='new(){ new(){ Code="NPM", Name="New Public Market" } }'
                       FacilityLocked="true"
                       OnSave="SaveNewVendor"
                       OnCancel="CloseAddModal"
                       OnFacilityChanged="OnFacilityChanged"
                       OnSectionChanged="OnSectionChanged"
                       OnToggleFee="ToggleFee" />

   PARAMETERS:
     Show              – bool        – controls visibility
     IsEditing         – bool        – true = edit mode, false = add mode
     Form              – VendorModalForm  – two-way bound form data
     FormError         – string      – validation message shown in red
     FacilityOptions   – List<VendorFacilityOption> – dropdown items
     FacilityLocked    – bool        – true = read-only facility label (facility page)
                                       false = full dropdown (vendors page)
     OnSave            – EventCallback      – Save / Add Vendor clicked
     OnCancel          – EventCallback      – Cancel or ✕ clicked
     OnFacilityChanged – EventCallback      – facility select changed
     OnSectionChanged  – EventCallback      – section select changed
     OnToggleFee       – EventCallback<string> – fee toggle clicked (fee name passed)
══════════════════════════════════════════════════════════════════════ *@

<div class="eemo-drawer-overlay @(Show ? "show" : "")" @onclick="HandleCancel"></div>

<div class="eemo-drawer eemo-drawer-right @(Show ? "show" : "")" @onclick:stopPropagation="true">

            <!-- ── Header ──────────────────────────────────────────────── -->
            <div class="eemo-drawer-header">
                <div class="eemo-drawer-header-left">
                    <div class="eemo-drawer-header-icon">
                        <svg viewBox="0 0 24 24">
                            @if (IsEditing)
                            {
                                <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                                <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                            }
                            else
                            {
                                <path d="M9 11l3 3L22 4"/>
                                <path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/>
                            }
                        </svg>
                    </div>
                    <div>
                        <div class="eemo-drawer-header-title">@(IsEditing ? "Edit Vendor / Stall" : "Add New Vendor")</div>
                        <div class="eemo-drawer-header-sub">@(IsEditing ? "Update vendor and stall information." : "Register a new stall vendor in the system.")</div>
                    </div>
                </div>
                <button class="eemo-drawer-header-close" @onclick="HandleCancel">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>

            <!-- ── Body ───────────────────────────────────────────────── -->
            <div class="eemo-modal-body">

                <!-- §1 Leasee Information -->
                <div class="avm-section">
                    <div class="avm-section-label">Leasee Information</div>
                    <div class="avm-row-2">
                        <div class="avm-group">
                            <label class="avm-label">Actual Occupant (Leasee) <span class="avm-req">*</span></label>
                            <input class="avm-input @(GetFieldError("ActualOccupant") != string.Empty ? "form-input-error" : "")" type="text" placeholder="Current stall occupant"
                                   @bind="Form.ActualOccupant" @bind:event="oninput" />
                            @if (GetFieldError("ActualOccupant") != string.Empty)
                            {
                                <span class="form-error">@GetFieldError("ActualOccupant")</span>
                            }
                        </div>
                        <div class="avm-group">
                            <label class="avm-label">Name on Contract (Per Signed Contract)</label>
                            <input class="avm-input @(GetFieldError("NameOnContract") != string.Empty ? "form-input-error" : "")" type="text" placeholder="Leave blank if no contract"
                                   @bind="Form.ContractName" @bind:event="oninput" />
                            @if (GetFieldError("NameOnContract") != string.Empty)
                            {
                                <span class="form-error">@GetFieldError("NameOnContract")</span>
                            }
                        </div>
                    </div>
                </div>

                <!-- §2 Space & Contract Details -->
                <div class="avm-section">
                    <div class="avm-section-label">Space &amp; Contract Details</div>

                    <div class="avm-row-2">
                        <!-- Facility: locked read-only OR full dropdown -->
                        <div class="avm-group">
                            <label class="avm-label">Facility <span class="avm-req">*</span></label>
                            @if (FacilityLocked)
                            {
                                <div class="avm-input avm-input-locked">
                                    @(FacilityOptions.FirstOrDefault()?.Name ?? Form.FacilityCode)
                                </div>
                            }
                            else
                            {
                                <select class="avm-input"
                                        @bind="Form.FacilityCode"
                                        @bind:after="HandleFacilityChanged">
                                    <option value="">-- Select Facility --</option>
                                    @foreach (var f in FacilityOptions)
                                    {
                                        <option value="@f.Code">@f.Name</option>
                                    }
                                </select>
                            }
                        </div>

                        <div class="avm-group">
                            <label class="avm-label">Stall / Space No. <span class="avm-req">*</span></label>
                            <input class="avm-input @(GetFieldError("StallNo") != string.Empty ? "form-input-error" : "")" type="text" placeholder="e.g. 01, T4, B-02"
                                   @bind="Form.StallNo" @bind:event="oninput" />
                            @if (GetFieldError("StallNo") != string.Empty)
                            {
                                <span class="form-error">@GetFieldError("StallNo")</span>
                            }
                            else if (!IsEditing && !string.IsNullOrEmpty(_lastSuggested) && Form.StallNo == _lastSuggested)
                            {
                                <span class="avm-hint-muted">Auto-suggested next number — you can edit it.</span>
                            }
                        </div>
                    </div>

                    <!-- Section dropdown — NPM only -->
                    @if (Form.FacilityCode == "NPM")
                    {
                        <div class="avm-row-2">
                            <div class="avm-group">
                                <label class="avm-label">Section / Category <span class="avm-req">*</span></label>
                                <FhSelect Block="true" Caption="" Value="@Form.SelectedSection"
                                          Options="SectionOptions" ValueChanged="OnSectionSelected" />
                                @if (GetFieldError("Section") != string.Empty)
                                {
                                    <span class="form-error">@GetFieldError("Section")</span>
                                }
                            </div>
                            <div class="avm-group">
                                @if (Form.SelectedSection == "__custom__")
                                {
                                    <label class="avm-label">Custom section name <span class="avm-req">*</span></label>
                                    <input class="avm-input" maxlength="60" placeholder="e.g. Sari-sari Area"
                                           @bind="Form.CustomSectionName" @bind:event="oninput" />
                                    @if (GetFieldError("CustomSectionName") != string.Empty)
                                    {
                                        <span class="form-error">@GetFieldError("CustomSectionName")</span>
                                    }
                                }
                            </div>
                        </div>
                    }

                    <div class="avm-row-2">
                        <div class="avm-group">
                            <label class="avm-label">Contract Effectivity Date</label>
                            @if (IsEditing)
                            {
                                <div class="avm-input avm-input-locked">@(Form.ContractDate?.ToString("MMMM d, yyyy") ?? "—")</div>
                            }
                            else
                            {
                                <input class="avm-input" type="date" @bind="Form.ContractDate" />
                            }
                        </div>
                        <div class="avm-group">
                            <label class="avm-label">Contract Duration (No. of Years)</label>
                            @if (IsEditing)
                            {
                                <div class="avm-input avm-input-locked">@(Form.ContractYears > 0 ? $"{Form.ContractYears} year{(Form.ContractYears > 1 ? "s" : "")}" : "No contract")</div>
                            }
                            else
                            {
                                <FhSelect Block="true" Caption="" Value="@(_customYears ? "custom" : Form.ContractYears.ToString())"
                                          Options="ContractYearOptions" ValueChanged="OnContractYearsSelected" />
                                @if (_customYears)
                                {
                                    <input class="avm-input" style="margin-top:8px;" type="number" min="1" max="10" step="1"
                                           placeholder="Enter years (1–10)" @bind="Form.ContractYears" @bind:event="oninput" />
                                    <span class="avm-hint-muted">Custom contract term — 1 to 10 years.</span>
                                }
                            }
                        </div>
                    </div>
                    @if (IsEditing)
                    {
                        <div class="avm-section-note">Contract effectivity and duration are set at registration — they define the billing history and aren't editable here.</div>
                    }
                </div>

                <!-- §3 Space Information -->
                <div class="avm-section">
                    <div class="avm-section-label">Space Information</div>
                    <div class="avm-row-2">
                        <div class="avm-group">
                            <label class="avm-label">Area (sq.m)</label>
                            <input class="avm-input" type="number" min="0" placeholder="e.g. 4.8"
                                   @bind="Form.AreaSqm" @bind:event="oninput" />
                        </div>
                        <div class="avm-group" style="visibility:hidden;"></div>
                    </div>
                </div>

                <!-- §4 Rental Rates -->
                <div class="avm-section">
                    <div class="avm-section-label">
                        @if (Form.FacilityCode == "SLH")
                        {
                            <text>Fixed Charges</text>
                        }
                        else
                        {

                            <text>Rental Rates</text>
                        }
                    </div>

                    @if (Form.FacilityCode == "SLH")
                    {
                        <div class="avm-info-box">
                            <div class="avm-info-box-title"><strong>Per Head Charges:</strong></div>
                            <div class="avm-info-box-grid">
                                <div>• Slaughter Fee</div><div>• Ante Mortem</div>
                                <div>• Post Mortem</div><div>• Table Charge</div>
                                <div>• Entrance Fee</div><div>• Livestock Fee</div>
                            </div>
                            <div class="avm-info-box-hint">These are fixed per-head charges for slaughterhouse</div>
                        </div>
                    }
                    else
                    {
                        <div class="avm-row-2">
                            <div class="avm-group">
                                <label class="avm-label">Monthly Rental / Rate (₱) <span class="avm-req">*</span></label>
                                <input class="avm-input" type="number" min="0" placeholder="e.g. 900"
                                       @bind="Form.MonthlyRate" @bind:event="oninput" />
                                <div class="avm-hint-muted">Whole Year: ₱@Form.WholeYearRental.ToString("N0")</div>
                                @if (Form.FacilityCode == "NPM")
                                {
                                    <div class="avm-hint-muted">Daily-equivalent ≈ ₱@NpmMonthlyEquivalent.ToString("N0")/mo (₱@NpmDailyRate.ToString("0")/day × @NpmDaysInMonth days). NPM bills per day — this is a reference only.</div>
                                }
                            </div>
                            <div class="avm-group" style="visibility:hidden;"></div>
                        </div>
                    }

                    @if (Form.FacilityCode == "NPM" && Form.SelectedSection == "Vegetable")
                    {
                        <div class="avm-fee-highlight">
                            <div><strong>Daily Collection:</strong> ₱@NpmDailyRate.ToString("0")/day (Vegetable vendors)</div>
                        </div>
                    }
                    @if (Form.FacilityCode == "NPM" && Form.SelectedSection == "Fish")
                    {
                        <div class="avm-fee-highlight">
                            <div><strong>Daily Collection:</strong> ₱@NpmDailyRate.ToString("0")/day (Fish vendors)</div>
                            <div><strong>Fish Fee:</strong> ₱@NpmFishRate.ToString("0.##")/kg (per kilo sold)</div>
                        </div>
                    }
                    @if (Form.FacilityCode == "NPM" && Form.SelectedSection == "Meat")
                    {
                        <div class="avm-fee-highlight">
                            <div><strong>Daily Collection:</strong> ₱@NpmDailyRate.ToString("0")/day (Meat vendors)</div>
                        </div>
                    }
                    @if (Form.FacilityCode == "NPM"
                        && (Form.SelectedSection == "__custom__"
                            || (Form.SelectedSection != null && Form.SelectedSection.StartsWith("existing:", StringComparison.Ordinal))))
                    {
                        <div class="avm-row-2">
                            <div class="avm-group">
                                <label class="avm-label">Daily fee rate (₱/day) <span class="avm-req">*</span></label>
                                <input class="avm-input" type="number" min="1" step="0.01" placeholder="e.g. 30"
                                       @bind="Form.CustomDailyRate" @bind:event="oninput" />
                                <div class="avm-hint-muted">This custom section bills this flat daily fee — no fish/weight. Enable Electricity &amp; Water below if the section is metered.</div>
                                @if (GetFieldError("CustomDailyRate") != string.Empty)
                                {
                                    <span class="form-error">@GetFieldError("CustomDailyRate")</span>
                                }
                            </div>
                            <div class="avm-group" style="visibility:hidden;"></div>
                        </div>
                    }
                </div>

                <!-- §5 Additional Information -->
                <div class="avm-section">
                    <div class="avm-section-label">Additional Information</div>
                    <div class="avm-row-2">
                        @if (Form.FacilityCode == "NCC")
                        {
                            <div class="avm-group">
                                <label class="avm-label">Area Location</label>
                                <input class="avm-input @(GetFieldError("AreaLocation") != string.Empty ? "form-input-error" : "")"
                                       type="text" list="avm-ncc-areas" maxlength="60" autocomplete="off"
                                       placeholder="e.g. Extension, Corner, or your area name"
                                       @bind="Form.AreaLocation" @bind:event="oninput" />
                                <datalist id="avm-ncc-areas">
                                    <option value="Extension" />
                                    <option value="Corner" />
                                    <option value="Standard" />
                                </datalist>
                                @if (GetFieldError("AreaLocation") != string.Empty)
                                {
                                    <span class="form-error">@GetFieldError("AreaLocation")</span>
                                }
                            </div>
                        }
                        else
                        {
                            <div class="avm-group">
                                <label class="avm-label">Area Location / Note</label>
                                <input class="avm-input" type="text" placeholder="e.g. Extension, Corner"
                                       @bind="Form.AreaLocation" @bind:event="oninput" />
                            </div>
                        }
                    </div>
                </div>

                <!-- §6 Applicable Charges — hidden for SLH -->
                @if (!string.IsNullOrEmpty(Form.FacilityCode) && Form.FacilityCode != "SLH")
                {
                    <div class="avm-section">

                        <div class="avm-divider-header">
                            <div class="avm-divider-line"></div>
                            <span class="avm-divider-text">Applicable Charges</span>
                            <div class="avm-divider-line"></div>
                        </div>

                        <!-- Base Rental card -->
                        <div class="avm-sublabel">Base Rental</div>
                        <div class="avm-rental-card">
                            <div class="avm-rental-info">
                                <div class="avm-rental-icon">
                                    <svg viewBox="0 0 24 24">
                                        <rect x="3" y="9" width="18" height="12" rx="2" />
                                        <path d="M3 9l9-6 9 6" />
                                        <line x1="9" y1="21" x2="9" y2="13" />
                                        <line x1="15" y1="21" x2="15" y2="13" />
                                    </svg>
                                </div>
                                <div>
                                    <div class="avm-rental-title">Monthly Rental</div>
                                    <div class="avm-rental-sub">
                                        @if (Form.FacilityCode == "NPM")
                                        {
                                            <text>New Public Market · ₱@NpmDailyRate.ToString("0")/day base</text>
                                        }
                                        else
                                        {
                                            @(FacilityOptions.FirstOrDefault(f => f.Code == Form.FacilityCode)?.Name ?? Form.FacilityCode)
                                        }
                                    </div>
                                </div>
                            </div>

                            <!-- ± Spinner -->
                            <div class="avm-spinner">
                                <button type="button" class="avm-spin-btn avm-spin-left"
                                        @onclick="() => { if (Form.MonthlyRate >= 100) Form.MonthlyRate -= 100; }">
                                    −
                                </button>
                                <div class="avm-spin-inner">
                                    <span class="avm-spin-currency">₱</span>
                                    <input type="number" min="0" class="avm-spin-input"
                                           @bind="Form.MonthlyRate" @bind:event="oninput" />
                                    <span class="avm-spin-freq">/mo</span>
                                </div>
                                <button type="button" class="avm-spin-btn avm-spin-right"
                                        @onclick="() => Form.MonthlyRate += 100">
                                    +
                                </button>
                            </div>
                        </div>

                        <!-- Whole-year hint -->
                        <div class="avm-yearly-hint">
                            <span class="avm-yearly-label">Whole-year equivalent</span>
                            <strong class="avm-yearly-value">₱@Form.WholeYearRental.ToString("N2")</strong>
                        </div>

                        <!-- Utility charges — NPM only -->
                        @if (Form.FacilityCode == "NPM")
                        {
                            @if (!string.IsNullOrEmpty(Form.SelectedSection))
                            {
                                <div class="avm-util-divider"></div>
                                <div class="avm-sublabel">Utility Charges</div>

                                <!-- Electricity -->
                                <div class="avm-fee-toggle @(Form.FeeTypes.Contains("Electricity") ? "active" : "")"
                                     @onclick='() => HandleToggleFee("Electricity")' @onclick:stopPropagation="true">
                                    <div class="avm-fee-icon">
                                        <svg viewBox="0 0 24 24" style="stroke:#d4920a;">
                                            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" />
                                        </svg>
                                    </div>
                                    <div class="avm-fee-text">
                                        <div class="avm-fee-title">Electricity</div>
                                        <div class="avm-fee-sub">Monthly billing — amount varies per reading</div>
                                    </div>
                                    <input type="checkbox" class="avm-fee-checkbox" tabindex="-1"
                                           checked="@Form.FeeTypes.Contains("Electricity")" readonly />
                                </div>

                                <!-- Water -->
                                <div class="avm-fee-toggle avm-fee-toggle-water @(Form.FeeTypes.Contains("Water") ? "active" : "")"
                                     @onclick='() => HandleToggleFee("Water")' @onclick:stopPropagation="true">
                                    <div class="avm-fee-icon">
                                        <svg viewBox="0 0 24 24" style="stroke:#1a7ab5;">
                                            <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z" />
                                        </svg>
                                    </div>
                                    <div class="avm-fee-text">
                                        <div class="avm-fee-title">Water</div>
                                        <div class="avm-fee-sub">Monthly billing — amount varies per reading</div>
                                    </div>
                                    <input type="checkbox" class="avm-fee-checkbox" tabindex="-1"
                                           checked="@Form.FeeTypes.Contains("Water")" readonly />
                                </div>

                                <!-- Fish fee — Fish Area only -->
                                @if (Form.SelectedSection == "Fish")
                                {
                                    <div class="avm-util-divider"></div>
                                    <div class="avm-sublabel">Section-Specific Fees</div>
                                    <div class="avm-fish-fee">
                                        <div class="avm-fish-icon">
                                            <svg viewBox="0 0 24 24">
                                                <path d="M2 12s4-6 10-6 10 6 10 6-4 6-10 6S2 12 2 12z" />
                                                <circle cx="9" cy="12" r="1.5" />
                                            </svg>
                                        </div>
                                        <div class="avm-fish-text">
                                            <div class="avm-fish-title">Fish Fee</div>
                                            <div class="avm-fish-sub">₱@NpmFishRate.ToString("0.00") per kilo of fish sold — Fish Area only</div>
                                        </div>
                                        <span class="avm-fish-badge">✓ Always included</span>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="avm-section-note">Select a section above to configure utility charges.</div>
                            }
                        }

                    </div>
                }

                <!-- Validation error -->
                @if (!string.IsNullOrEmpty(FormError))
                {
                    <div class="avm-error">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                        @FormError
                    </div>
                }

            </div><!-- /eemo-modal-body -->
            <!-- ── Footer ──────────────────────────────────────────────── -->
            <div class="eemo-drawer-footer">
                @if (!IsEditing && IsImportSupported)
                {
                    <button type="button" class="btn-ghost avm-import-btn" @onclick="HandleImport"
                            title="Bulk import stallholders from a file">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" /></svg>
                        Import list
                    </button>
                }
                <button type="button" class="btn-ghost" @onclick="HandleCancel">Cancel</button>
                <button type="button" class="btn-primary" @onclick="HandleSave" @onclick:preventDefault="true">
                    @(IsEditing ? "Save Changes" : "Add Vendor")
                </button>
            </div>

</div>

@code {

    // ── Parameters ────────────────────────────────────────────────────────────

    /// Controls modal visibility
    [Parameter] public bool Show { get; set; }

    /// true = Edit mode   false = Add mode
    [Parameter] public bool IsEditing { get; set; }

    /// Bound form data — mutated directly (class = reference type, no need for two-way EventCallback)
    [Parameter] public VendorModalForm Form { get; set; } = new();

    /// The tenant's resolved NPM daily-stall rate (defaults to the ₱30 ordinance so Cantilan/unset is
    /// unchanged). Drives the NPM daily-collection labels and the daily-equivalent monthly hint, so a
    /// ₱40 LGU never shows ₱30. Display only — nothing here is stored.
    [Parameter] public decimal NpmDailyRate { get; set; } = 30m;

    /// The tenant's resolved NPM fish fee per kilo (defaults to the ₱1 ordinance). Display only.
    [Parameter] public decimal NpmFishRate { get; set; } = 1m;

    // Days in the contract's month (falls back to the current month). Used ONLY for the NPM
    // daily-equivalent reference hint, mirroring how NPM is billed (daily × collectable days).
    private int NpmDaysInMonth
    {
        get { var d = Form.ContractDate ?? PhilippineTime.Now.Date; return DateTime.DaysInMonth(d.Year, d.Month); }
    }

    // Reference figure shown beside the (manual) Monthly Rental field for NPM — the field itself is
    // never auto-filled, so Cantilan admins keep entering their own value.
    private decimal NpmMonthlyEquivalent => NpmDailyRate * NpmDaysInMonth;

    /// Validation error shown at the bottom of the form
    [Parameter] public string FormError { get; set; } = string.Empty;

    /// EventCallback for two-way binding of FormError — enables @bind-FormError in parent
    [Parameter] public EventCallback<string> FormErrorChanged { get; set; }

    /// Field-level validation errors from backend
    [Parameter] public Dictionary<string, string> FieldErrors { get; set; } = new();

    /// Existing stall/space numbers for the CURRENT context (facility, and section for NPM), supplied by
    /// the host from its loaded list. Used only to auto-SUGGEST the next number in add mode — never a
    /// constant; the value stays fully editable.
    [Parameter] public IReadOnlyCollection<string>? ExistingStallNos { get; set; }

    // The last value we auto-suggested; lets us refresh the suggestion when the context (e.g. NPM
    // section) changes — but only while the admin hasn't typed their own number.
    private string _lastSuggested = string.Empty;

    // True when the admin chose "Custom…" for the contract term (or opened an already-custom value),
    // revealing a free numeric input (1–10, the range the backend accepts).
    private bool _customYears;

    protected override void OnParametersSet()
    {
        if (Show && !IsEditing)
        {
            // Suggest on open, and re-suggest when the context list changes — but preserve a value the
            // admin has typed themselves (i.e. only replace an empty field or our own prior suggestion).
            if (string.IsNullOrWhiteSpace(Form.StallNo) || Form.StallNo == _lastSuggested)
            {
                var suggestion = SuggestNextStallNo(ExistingStallNos);
                if (!string.IsNullOrEmpty(suggestion))
                {
                    Form.StallNo = suggestion;
                    _lastSuggested = suggestion;
                }
            }

            // Reflect a non-preset contract term (4, 6–10) as "Custom…" so the input shows and the value
            // is preserved; the standard presets (1/2/3/5) use the dropdown directly. Minimum term is 1 year.
            _customYears = Form.ContractYears is not (1 or 2 or 3 or 5);
        }
        else if (!Show)
        {
            _lastSuggested = string.Empty;
            _customYears = false;
        }
    }

    /// <summary>
    /// Suggests the next stall/space number from the existing ones — dynamically, never a fixed constant.
    /// Takes the numeric part of each existing number, uses (max + 1), preserves a shared non-numeric
    /// prefix (e.g. "F-12" → "F-13") and zero-padding (e.g. "01"…"40" → "41"). Returns empty when there's
    /// no numeric pattern to continue (the admin then types it), so nothing is ever fabricated.
    /// </summary>
    public static string SuggestNextStallNo(IEnumerable<string>? existing)
    {
        if (existing is null) return string.Empty;

        var nums = new List<int>();
        string? sharedPrefix = null;
        var prefixConsistent = true;
        var width = 0;
        var anyEntries = false;

        foreach (var raw in existing)
        {
            if (string.IsNullOrWhiteSpace(raw)) continue;
            anyEntries = true;
            var m = System.Text.RegularExpressions.Regex.Match(raw.Trim(), @"^(.*?)(\d+)\s*$");
            if (!m.Success) continue;

            var prefix = m.Groups[1].Value;
            var digits = m.Groups[2].Value;
            nums.Add(int.Parse(digits));
            width = Math.Max(width, digits.Length);

            if (sharedPrefix is null) sharedPrefix = prefix;
            else if (!string.Equals(sharedPrefix, prefix, StringComparison.OrdinalIgnoreCase)) prefixConsistent = false;
        }

        // No numeric stalls to continue: for a brand-new facility/section (no stalls at all) suggest the
        // first number "1"; for an all-non-numeric scheme (e.g. only "A","B") don't guess — the admin types it.
        if (nums.Count == 0) return anyEntries ? string.Empty : "1";

        var next = (nums.Max() + 1).ToString().PadLeft(Math.Max(width, 1), '0');
        return prefixConsistent && !string.IsNullOrEmpty(sharedPrefix) ? $"{sharedPrefix}{next}" : next;
    }

