@using EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Application.Dtos.Payments
@using EEMOCantilanSDS.Application.Dtos.DailyCollections
@using EEMOCantilanSDS.Application.Command.Payments.RecordPayment
@using EEMOCantilanSDS.Application.Command.DailyCollections.SettleNpmMonth
@using EEMOCantilanSDS.Application.Command.DailyCollections.SettleNpmDays
@inject IPaymentsApiClient PaymentsApi
@inject IDailyCollectionApiClient DailyApi
@inject EEMOCantilanSDS.Client.Services.FacilityState FacilityCatalog

@*
    PayBillModal — full-width, formal "record payment" form opened from a follow-up row.
    Fixed detail sections (account summary, how-to-settle, OR number) sit above ONE clean scrolling
    table so there is never more than one scrollbar. NPM (daily): "Whole month" settles every collectable
    day of a month; "Specific days" is a two-step flow (choose the month, then tick the day(s)) — one OR
    covers the whole transaction. Monthly facilities pick a specific month or all outstanding.
*@

@if (Show)
{
    <div class="pb-modal" @onclick="HandleClose">
        <div class="pb-shell" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div>
                    <div class="eemo-modal-title">Record payment</div>
                    <div class="eemo-modal-sub">@DisplayOccupant · Stall @StallNo · @FacilityCatalog.NameOf(Facility)</div>
                </div>
                <button class="eemo-modal-close" @onclick="HandleClose" aria-label="Close">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>

            <div class="pb-body">
                @if (_loading)
                {
                    <div class="pb-loading">Loading outstanding balance…</div>
                }
                else if (_unpaid.Count == 0)
                {
                    <div class="pb-clear">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                        <span>No outstanding balance — this account is fully paid.</span>
                    </div>
                }
                else
                {
                    <!-- Fixed detail band -->
                    <div class="pb-detail">
                        <div class="pb-statement">
                            <div>
                                <div class="pb-statement-key">Total outstanding</div>
                                <div class="pb-statement-meta">@_unpaid.Count unpaid month@(_unpaid.Count == 1 ? "" : "s")@(string.IsNullOrEmpty(_rangeLabel) ? "" : $" · {_rangeLabel}")</div>
                            </div>
                            <div class="pb-statement-val">₱@_totalOutstanding.ToString("N2")</div>
                        </div>

                        <div class="pb-controls">
                            <div class="pb-control">
                                <span class="pb-label">@(IsNpm ? "How to settle" : "Payment scope")</span>
                                <div class="pb-seg" role="tablist">
                                    @if (IsNpm)
                                    {
                                        <button type="button" class="pb-seg-btn @(_npmMode == "month" ? "on" : "")" @onclick='() => SetNpmMode("month")' disabled="@_submitting">Whole month</button>
                                        <button type="button" class="pb-seg-btn @(_npmMode == "days" ? "on" : "")" @onclick='() => SetNpmMode("days")' disabled="@_submitting">Specific days</button>
                                    }
                                    else
                                    {
                                        <button type="button" class="pb-seg-btn @(_scope == "month" ? "on" : "")" @onclick='() => _scope = "month"' disabled="@_submitting">Specific month</button>
                                        <button type="button" class="pb-seg-btn @(_scope == "all" ? "on" : "")" @onclick='() => _scope = "all"' disabled="@_submitting">All outstanding</button>
                                    }
                                </div>
                            </div>
                            <div class="pb-control pb-control-or">
                                <label class="pb-label" for="pb-or">Official Receipt (OR) No.</label>
                                <input id="pb-or" class="pb-input" type="text" maxlength="50" autocomplete="off" inputmode="numeric"
                                       placeholder="e.g. 1234567" @bind="_or" @bind:event="oninput" disabled="@_submitting" />
                            </div>
                        </div>

                        <div class="pb-caption-row">
                            <span class="pb-caption">@CaptionText()</span>
                            @if (IsNpm && _npmMode == "days" && _dayStep && !_daysLoading && _days.Count > 0)
                            {
                                <span class="pb-caption-actions">
                                    <button type="button" class="pb-linkbtn" @onclick="ChangeMonth" disabled="@_submitting">← Change month</button>
                                    <button type="button" class="pb-linkbtn" @onclick="ToggleSelectAllDays" disabled="@_submitting">@(_daySelected.Count == _days.Count ? "Clear all" : "Select all")</button>
                                </span>
                            }
                        </div>
                    </div>

                    <!-- ONE scrolling table -->
                    <div class="pb-scroll">
                        @if (IsNpm && _npmMode == "days" && _dayStep)
                        {
                            @if (_daysLoading)
                            {
                                <div class="pb-loading">Loading days…</div>
                            }
                            else if (_days.Count == 0)
                            {
                                <div class="pb-clear"><span>No settleable days remain in this month.</span></div>
                            }
                            else
                            {
                                <table class="pb-table">
                                    <thead>
                                        <tr><th class="c"></th><th class="c">#</th><th>Collection day</th><th class="r">Daily fee</th></tr>
                                    </thead>
                                    <tbody>
                                        @{ var dn = 0; }
                                        @foreach (var d in _days)
                                        {
                                            dn++;
                                            var sel = _daySelected.Contains(d.Date);
                                            <tr class="@(sel ? "on" : "")" @onclick="@(() => ToggleDay(d.Date, !sel))">
                                                <td class="c"><input type="checkbox" checked="@sel" @onchange="e => ToggleDay(d.Date, (bool)(e.Value ?? false))" disabled="@_submitting" /></td>
                                                <td class="c pb-muted">@dn</td>
                                                <td>@d.Date.ToString("dddd · MMMM d, yyyy")</td>
                                                <td class="r amt">₱@d.Fee.ToString("N2")</td>
                                            </tr>
                                        }
                                    </tbody>
                                    <tfoot>
                                        <tr><td colspan="3">@_daySelected.Count of @_days.Count day@(_days.Count == 1 ? "" : "s") selected</td><td class="r">₱@_days.Where(x => _daySelected.Contains(x.Date)).Sum(x => x.Fee).ToString("N2")</td></tr>
                                    </tfoot>
                                </table>
                            }
                        }
                        else
                        {
                            var pickMonthForDays = IsNpm && _npmMode == "days";   // step 1: drill into a month
                            var allMode = !IsNpm && _scope == "all";
                            <table class="pb-table">
                                <thead>
                                    <tr><th class="c"></th><th class="c">#</th><th>Billing month</th><th class="r">Outstanding</th></tr>
                                </thead>
                                <tbody>
                                    @{ var mn = 0; }
                                    @foreach (var r in _unpaid)
                                    {
                                        mn++;
                                        var included = allMode || _selectedPeriod == r.Period;
                                        <tr class="@((included && !pickMonthForDays) ? "on" : "")" @onclick="@(() => MonthRowClicked(r.Period))">
                                            <td class="c">
                                                @if (pickMonthForDays)
                                                {
                                                    <svg class="pb-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6" /></svg>
                                                }
                                                else if (allMode)
                                                {
                                                    <svg class="pb-tick" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                                }
                                                else
                                                {
                                                    <input type="radio" name="pb-month" checked="@(_selectedPeriod == r.Period)" @onchange="@(() => _selectedPeriod = r.Period)" disabled="@_submitting" />
                                                }
                                            </td>
                                            <td class="c pb-muted">@mn</td>
                                            <td>@MonthLabel(r.Period)</td>
                                            <td class="r amt due">₱@r.BalanceDue.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                                <tfoot>
                                    <tr><td colspan="3">Total outstanding · @_unpaid.Count month@(_unpaid.Count == 1 ? "" : "s")</td><td class="r">₱@_totalOutstanding.ToString("N2")</td></tr>
                                </tfoot>
                            </table>
                        }
                    </div>

                    @if (_error is not null)
                    {
                        <div class="pb-error">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                            @_error
                        </div>
                    }
                }
            </div>

            <div class="eemo-modal-footer">
                <div class="pb-foot-hint">
                    @if (!_loading && _unpaid.Count > 0)
                    {
                        <text>One receipt covers the whole transaction. Leave OR blank to encode it later via Add OR.</text>
                    }
                </div>
                <button class="btn-ghost" @onclick="HandleClose" disabled="@_submitting">Cancel</button>
                @if (!_loading && _unpaid.Count > 0)
                {
                    <button class="btn-primary" @onclick="Submit" disabled="@(!CanSubmit())">
                        @(_submitting ? "Recording…" : "Record payment")
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public Guid StallId { get; set; }
    [Parameter] public FacilityCode Facility { get; set; }
    [Parameter] public string StallNo { get; set; } = string.Empty;
    [Parameter] public string Occupant { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private bool _loading;
    private bool _submitting;
    private string? _error;
    private string _scope = "month";          // monthly facilities: month | all
    private string _npmMode = "month";         // NPM: month | days
    private bool _dayStep;                      // NPM days: false = choosing month, true = choosing days
    private string _selectedPeriod = string.Empty;
    private string _or = string.Empty;
    private decimal _totalOutstanding;
    private string _rangeLabel = string.Empty;
    private List<PaymentHistoryDto> _unpaid = new();

    private List<SettleableNpmDayDto> _days = new();
    private HashSet<DateOnly> _daySelected = new();
    private bool _daysLoading;

    private Guid _loadedStall;

    private string DisplayOccupant => string.IsNullOrWhiteSpace(Occupant) ? "Unnamed occupant" : Occupant;
    private bool IsNpm => Facility == FacilityCode.NPM;

    private string CaptionText()
    {
        if (IsNpm && _npmMode == "days")
            return _dayStep ? $"Step 2 · Choose day(s) — {MonthLabel(_selectedPeriod)}" : "Step 1 · Choose the month";
        if (!IsNpm && _scope == "all")
            return "Months to be settled";
        return "Select a month to settle";
    }

    private bool CanSubmit()
    {
        if (_submitting) return false;
        if (IsNpm)
            return _npmMode == "days" ? (_dayStep && _daySelected.Count > 0) : !string.IsNullOrEmpty(_selectedPeriod);
        return _scope == "all" || !string.IsNullOrEmpty(_selectedPeriod);
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Show && _loadedStall != StallId)
        {
            _loadedStall = StallId;
            await LoadOutstanding();
        }
    }

    private async Task LoadOutstanding()
    {
        _loading = true;
        _error = null;
        _scope = "month";
        _npmMode = "month";
        _dayStep = false;
        _or = string.Empty;
        _days = new();
        _daySelected = new();

        var result = await PaymentsApi.GetOutstandingMonthsAsync(StallId);
        _unpaid = (result.IsSuccess && result.Value is not null)
            ? result.Value
                .Where(h => !h.IsExcused && h.Status != PaymentStatus.Paid && h.BalanceDue > 0m && !string.IsNullOrWhiteSpace(h.Period))
                .OrderBy(h => h.Period)
                .ToList()
            : new();
        _totalOutstanding = _unpaid.Sum(h => h.BalanceDue);
        _selectedPeriod = _unpaid.FirstOrDefault()?.Period ?? string.Empty;
        _rangeLabel = _unpaid.Count == 0
            ? string.Empty
            : _unpaid.Count == 1
                ? MonthLabelShort(_unpaid[0].Period)
                : $"{MonthLabelShort(_unpaid[0].Period)} – {MonthLabelShort(_unpaid[^1].Period)}";
        _loading = false;
    }

    private void SetNpmMode(string mode)
    {
        _npmMode = mode;
        _dayStep = false;         // always start day-mode at the month step
        _error = null;
    }

    // Clicking a month row: monthly/NPM-whole-month just selects it; NPM-days drills into that month's days.
    private async Task MonthRowClicked(string period)
    {
        _selectedPeriod = period;
        if (IsNpm && _npmMode == "days")
        {
            await LoadDaysForSelectedMonth();
            _dayStep = true;
        }
    }

    private void ChangeMonth()
    {
        _dayStep = false;
        _daySelected = new();
    }

    private async Task LoadDaysForSelectedMonth()
    {
        _days = new();
        _daySelected = new();
        if (!TryParsePeriod(_selectedPeriod, out var year, out var month))
            return;
        _daysLoading = true;
        var res = await DailyApi.GetSettleableNpmDaysAsync(StallId, year, month);
        _days = (res.IsSuccess && res.Value is not null) ? res.Value.ToList() : new();
        _daysLoading = false;
    }

    private void ToggleDay(DateOnly date, bool on)
    {
        if (on) _daySelected.Add(date);
        else _daySelected.Remove(date);
    }

    private void ToggleSelectAllDays()
    {
        if (_daySelected.Count == _days.Count)
            _daySelected = new();
        else
            _daySelected = _days.Select(d => d.Date).ToHashSet();
    }

    private async Task Submit()
    {
        if (!CanSubmit()) return;
        _submitting = true;
        _error = null;

        var or = string.IsNullOrWhiteSpace(_or) ? null : _or.Trim();

        if (IsNpm)
        {
            if (_npmMode == "days")
            {
                var dates = _days.Where(x => _daySelected.Contains(x.Date)).Select(x => x.Date).ToList();
                var r = await DailyApi.SettleNpmDaysAsync(new SettleNpmDaysCommand(StallId, dates, or));
                if (!r.IsSuccess) { _error = r.Error ?? "Could not record the payment. Please try again."; _submitting = false; return; }
            }
            else
            {
                if (!TryParsePeriod(_selectedPeriod, out var year, out var month))
                { _error = "Select a month to settle."; _submitting = false; return; }
                var r = await DailyApi.SettleNpmMonthAsync(new SettleNpmMonthCommand(StallId, year, month, or));
                if (!r.IsSuccess) { _error = r.Error ?? "Could not record the payment. Please try again."; _submitting = false; return; }
            }
        }
        else
        {
            var targets = _scope == "all"
                ? _unpaid.ToList()
                : _unpaid.Where(h => h.Period == _selectedPeriod).ToList();
            if (targets.Count == 0)
            { _error = "Select a month to pay."; _submitting = false; return; }

            // A single OR is one monthly receipt, so only stamp it when paying ONE month; a bulk "all"
            // records the months paid and leaves each month's OR to be encoded later.
            var singleOr = (_scope == "month") ? or : null;

            foreach (var t in targets)
            {
                if (!TryParsePeriod(t.Period, out var year, out var month))
                    continue;
                var r = await PaymentsApi.RecordPaymentAsync(
                    new RecordPaymentCommand(StallId, year, month, PaymentStatus.Paid, null, null, singleOr));
                if (!r.IsSuccess) { _error = r.Error ?? "Could not record the payment. Please try again."; _submitting = false; return; }
            }
        }

        _submitting = false;
        await LoadOutstanding();       // refresh remaining balance (resets to a clean state)
        await OnChanged.InvokeAsync(); // let the host reload its list
    }

    private async Task HandleClose()
    {
        if (_submitting) return;
        _loadedStall = Guid.Empty;     // reload next open
        await OnClose.InvokeAsync();
    }

    private static bool TryParsePeriod(string period, out int year, out int month)
    {
        year = 0; month = 0;
        var parts = period.Split('-');
        return parts.Length == 2 && int.TryParse(parts[0], out year) && int.TryParse(parts[1], out month);
    }

    private static string MonthLabel(string period) =>
        TryParsePeriod(period, out var y, out var m)
            ? new DateTime(y, m, 1).ToString("MMMM yyyy", System.Globalization.CultureInfo.InvariantCulture)
            : period;

    private static string MonthLabelShort(string period) =>
        TryParsePeriod(period, out var y, out var m)
            ? new DateTime(y, m, 1).ToString("MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)
            : period;
}
