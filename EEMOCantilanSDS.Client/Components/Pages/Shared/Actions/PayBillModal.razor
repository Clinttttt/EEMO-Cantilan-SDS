@using EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Application.Dtos.Payments
@using EEMOCantilanSDS.Application.Command.Payments.RecordPayment
@using EEMOCantilanSDS.Application.Command.DailyCollections.SettleNpmMonth
@inject IPaymentsApiClient PaymentsApi
@inject IDailyCollectionApiClient DailyApi
@inject EEMOCantilanSDS.Client.Services.FacilityState FacilityCatalog

@*
    PayBillModal — a formal, structured "record payment" form opened from a follow-up row.
    No calendars: the office picks a SPECIFIC unpaid month or "All outstanding", enters the OR/receipt
    number, and records it. NPM (daily) months are settled server-side as a whole month (SettleNpmMonth);
    monthly facilities record a monthly payment (RecordPayment). Works across every facility.
*@

@if (Show)
{
    <div class="eemo-modal-overlay" @onclick="HandleClose">
        <div class="eemo-modal paybill-modal" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div>
                    <div class="eemo-modal-title">Record payment</div>
                    <div class="eemo-modal-sub">@DisplayOccupant · Stall @StallNo · @FacilityCatalog.ShortNameOf(Facility)</div>
                </div>
                <button class="eemo-modal-close" @onclick="HandleClose" aria-label="Close">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>

            <div class="eemo-modal-body">
                @if (_loading)
                {
                    <div class="pb-loading">Loading outstanding balance…</div>
                }
                else if (_unpaid.Count == 0)
                {
                    <div class="pb-clear">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                        <span>No outstanding balance — this account is fully paid.</span>
                    </div>
                }
                else
                {
                    <div class="pb-statement">
                        <div class="pb-statement-row">
                            <span class="pb-statement-key">Total outstanding</span>
                            <span class="pb-statement-val">₱@_totalOutstanding.ToString("N2")</span>
                        </div>
                        <div class="pb-statement-meta">
                            @_unpaid.Count unpaid month@(_unpaid.Count == 1 ? "" : "s")@(string.IsNullOrEmpty(_rangeLabel) ? "" : $" · {_rangeLabel}")
                        </div>
                    </div>

                    @if (IsNpm)
                    {
                        @* New Public Market is a daily facility: each day carries its own unique Official
                           Receipt, so it is settled ONE MONTH AT A TIME (never in bulk, which would strand
                           hundreds of days without a receipt). Receipts are then encoded per day via Add OR. *@
                        <div class="pb-daily-note">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>
                            <div>
                                <strong>@FacilityCatalog.NameOf(Facility) is collected daily.</strong>
                                Settle one month at a time. Each collectable day is recorded as paid, then its
                                Official Receipt is encoded per day using <em>Add OR</em> — a single OR cannot
                                cover multiple days.
                            </div>
                        </div>

                        <div class="pb-field">
                            <div class="pb-months-head">
                                <span>Select a month to settle</span>
                                <span>Amount</span>
                            </div>
                            <div class="pb-months" role="radiogroup" aria-label="Unpaid months">
                                @foreach (var r in _unpaid)
                                {
                                    <label class="pb-month-row @(_selectedPeriod == r.Period ? "on" : "")">
                                        <input type="radio" name="pb-month" checked="@(_selectedPeriod == r.Period)"
                                               @onchange="@(() => _selectedPeriod = r.Period)" disabled="@_submitting" />
                                        <span class="pb-month-name">@MonthLabel(r.Period)</span>
                                        <span class="pb-month-amt">₱@r.BalanceDue.ToString("N2")</span>
                                    </label>
                                }
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="pb-field">
                            <span class="pb-label">Payment scope</span>
                            <div class="pb-seg" role="tablist">
                                <button type="button" role="tab" aria-selected="@(_scope == "month")"
                                        class="pb-seg-btn @(_scope == "month" ? "on" : "")" @onclick='() => _scope = "month"' disabled="@_submitting">
                                    Specific month
                                </button>
                                <button type="button" role="tab" aria-selected="@(_scope == "all")"
                                        class="pb-seg-btn @(_scope == "all" ? "on" : "")" @onclick='() => _scope = "all"' disabled="@_submitting">
                                    All outstanding
                                </button>
                            </div>
                        </div>

                        <div class="pb-field">
                            <div class="pb-months-head">
                                <span>@(_scope == "all" ? "Months to be settled" : "Select a month")</span>
                                <span>Amount</span>
                            </div>
                            <div class="pb-months @(_scope == "all" ? "all" : "")" role="@(_scope == "all" ? "list" : "radiogroup")" aria-label="Unpaid months">
                                @foreach (var r in _unpaid)
                                {
                                    var included = _scope == "all" || _selectedPeriod == r.Period;
                                    <label class="pb-month-row @(included ? "on" : "")">
                                        @if (_scope == "month")
                                        {
                                            <input type="radio" name="pb-month" checked="@(_selectedPeriod == r.Period)"
                                                   @onchange="@(() => _selectedPeriod = r.Period)" disabled="@_submitting" />
                                        }
                                        else
                                        {
                                            <svg class="pb-month-tick" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                        }
                                        <span class="pb-month-name">@MonthLabel(r.Period)</span>
                                        <span class="pb-month-amt">₱@r.BalanceDue.ToString("N2")</span>
                                    </label>
                                }
                            </div>
                            @if (_scope == "all")
                            {
                                <div class="pb-months-foot">
                                    <span>Total</span>
                                    <span>₱@_totalOutstanding.ToString("N2")</span>
                                </div>
                            }
                        </div>

                        <div class="pb-field">
                            <label class="pb-label" for="pb-or">Official Receipt (OR) No.</label>
                            <input id="pb-or" class="pb-input" type="text" maxlength="50" autocomplete="off" inputmode="numeric"
                                   placeholder="e.g. 1234567" @bind="_or" @bind:event="oninput" disabled="@_submitting" />
                            <div class="pb-hint">
                                @(_scope == "all"
                                    ? "Applied to each settled month. Leave blank to encode receipts individually later."
                                    : "Optional — leave blank to encode the receipt later.")
                            </div>
                        </div>
                    }

                    @if (_error is not null)
                    {
                        <div class="pb-error">
                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                            @_error
                        </div>
                    }
                }
            </div>

            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="HandleClose" disabled="@_submitting">Cancel</button>
                @if (!_loading && _unpaid.Count > 0)
                {
                    <button class="btn-primary" @onclick="Submit" disabled="@(_submitting || (_scope == "month" && string.IsNullOrEmpty(_selectedPeriod)))">
                        @(_submitting ? "Recording…" : "Record payment")
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public Guid StallId { get; set; }
    [Parameter] public FacilityCode Facility { get; set; }
    [Parameter] public string StallNo { get; set; } = string.Empty;
    [Parameter] public string Occupant { get; set; } = string.Empty;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnChanged { get; set; }

    private bool _loading;
    private bool _submitting;
    private string? _error;
    private string _scope = "month";
    private string _selectedPeriod = string.Empty;
    private string _or = string.Empty;
    private decimal _totalOutstanding;
    private string _rangeLabel = string.Empty;
    private List<PaymentHistoryDto> _unpaid = new();
    private Guid _loadedStall;

    private string DisplayOccupant => string.IsNullOrWhiteSpace(Occupant) ? "Unnamed occupant" : Occupant;
    private bool IsNpm => Facility == FacilityCode.NPM;

    protected override async Task OnParametersSetAsync()
    {
        if (Show && _loadedStall != StallId)
        {
            _loadedStall = StallId;
            await LoadOutstanding();
        }
    }

    private async Task LoadOutstanding()
    {
        _loading = true;
        _error = null;
        _scope = "month";
        _or = string.Empty;

        var result = await PaymentsApi.GetOutstandingMonthsAsync(StallId);
        _unpaid = (result.IsSuccess && result.Value is not null)
            ? result.Value
                .Where(h => !h.IsExcused && h.Status != PaymentStatus.Paid && h.BalanceDue > 0m && !string.IsNullOrWhiteSpace(h.Period))
                .OrderBy(h => h.Period)
                .ToList()
            : new();
        _totalOutstanding = _unpaid.Sum(h => h.BalanceDue);
        _selectedPeriod = _unpaid.FirstOrDefault()?.Period ?? string.Empty;
        _rangeLabel = _unpaid.Count == 0
            ? string.Empty
            : _unpaid.Count == 1
                ? MonthLabelShort(_unpaid[0].Period)
                : $"{MonthLabelShort(_unpaid[0].Period)} – {MonthLabelShort(_unpaid[^1].Period)}";
        _loading = false;
    }

    private async Task Submit()
    {
        if (_submitting) return;
        _submitting = true;
        _error = null;

        // NPM is settled one month at a time (daily facility — no bulk "all", which would strand many
        // days without a unique OR). Monthly facilities may pay a single month or all outstanding.
        var payAll = !IsNpm && _scope == "all";
        var targets = payAll
            ? _unpaid.ToList()
            : _unpaid.Where(h => h.Period == _selectedPeriod).ToList();

        if (targets.Count == 0)
        {
            _error = "Select a month to pay.";
            _submitting = false;
            return;
        }

        // A single OR represents one monthly receipt, so only stamp it when paying ONE monthly-billed
        // month. NPM is collected daily — its receipts are encoded per day via Add OR, never as one
        // month-level OR (which could only ever land on a single day), so NPM always settles blank.
        var singleOr = (!IsNpm && _scope == "month" && !string.IsNullOrWhiteSpace(_or)) ? _or.Trim() : null;

        foreach (var t in targets)
        {
            if (!TryParsePeriod(t.Period, out var year, out var month))
                continue;

            var res = Facility == FacilityCode.NPM
                ? await DailyApi.SettleNpmMonthAsync(new SettleNpmMonthCommand(StallId, year, month, singleOr))
                : await PaymentsApi.RecordPaymentAsync(new RecordPaymentCommand(StallId, year, month, PaymentStatus.Paid, null, null, singleOr));

            if (!res.IsSuccess)
            {
                _error = res.Error ?? "Could not record the payment. Please try again.";
                _submitting = false;
                return;
            }
        }

        _submitting = false;
        await LoadOutstanding();       // refresh remaining balance
        await OnChanged.InvokeAsync(); // let the host reload its list
    }

    private async Task HandleClose()
    {
        if (_submitting) return;
        _loadedStall = Guid.Empty;     // reload next open
        await OnClose.InvokeAsync();
    }

    private static bool TryParsePeriod(string period, out int year, out int month)
    {
        year = 0; month = 0;
        var parts = period.Split('-');
        return parts.Length == 2 && int.TryParse(parts[0], out year) && int.TryParse(parts[1], out month);
    }

    private static string MonthLabel(string period) =>
        TryParsePeriod(period, out var y, out var m)
            ? new DateTime(y, m, 1).ToString("MMMM yyyy", System.Globalization.CultureInfo.InvariantCulture)
            : period;

    private static string MonthLabelShort(string period) =>
        TryParsePeriod(period, out var y, out var m)
            ? new DateTime(y, m, 1).ToString("MMM yyyy", System.Globalization.CultureInfo.InvariantCulture)
            : period;
}
