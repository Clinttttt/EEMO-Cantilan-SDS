@* ══════════════════════════════════════════════════════════════════════
   FacilityPaymentModal.razor  —  Smart payment modal for all facilities

   FLOW:
     Collector (Mobile) marks PAID or PARTIAL
         → Admin (Web) opens modal → sees status auto-updated
         → Admin encodes OR Number from physical receipt book
         → Saves OR Number

   OR NUMBER LOGIC:
     UNPAID   → no OR input        (collector hasn't collected yet)
     PAID     → show OR input      (admin encodes OR number)
     PARTIAL  → show OR input      (admin encodes OR number)
     OR already saved → read-only  (already encoded, no more input)

   USAGE:
       <FacilityPaymentModal Facility="NPM"
                             Stall="PaymentStall"
                             Show="ShowPayment"
                             OnClose="ClosePayment"
                             OnSave="HandleSavePayment" />
══════════════════════════════════════════════════════════════════════ *@




@using EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using EEMOCantilanSDS.Application.Command.Payments.SaveOrNumber
@inject IPaymentsApiClient PaymentsApi

@typeparam TStall

@if (Show && Stall is not null)
{
    <div class="eemo-modal-overlay" @onclick="HandleClose">
        <div class="eemo-modal" @onclick:stopPropagation="true">

            <!-- ── Header ── -->
            <div class="eemo-modal-header">
                <div>
                    <div class="eemo-modal-title">Payment Record</div>
                    <div class="eemo-modal-sub">
                        Stall @GetStallNo(Stall) · @GetActualOccupant(Stall) · @DateTime.Now.ToString("MMMM yyyy")
                    </div>
                </div>
                <button class="eemo-modal-close" @onclick="HandleClose">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>

            <div class="eemo-modal-body">

                <!-- ── Status Badge ── -->
                <div class="status-badge @(GetIsPaid(Stall) ? "paid" : GetIsPartial(Stall) ? "partial" : "unpaid")">
                    Status: @GetStatusText(Stall)
                </div>

                <!-- ══════════════════════════════════════════
                     PARTIAL AMOUNT INPUT (when status is Partial)
                ══════════════════════════════════════════ -->
                @if (GetIsPartial(Stall))
                {
                    <div class="partial-amount-section">
                        <label class="partial-label">
                            Partial Amount Paid <span class="required-star">*</span>
                        </label>
                        <div class="partial-input-wrap">
                            <span class="currency-symbol">₱</span>
                            <input @bind="PartialAmountInput"
                                   @bind:event="oninput"
                                   type="number"
                                   min="0"
                                   max="@GetMonthlyRate(Stall)"
                                   step="0.01"
                                   placeholder="0.00"
                                   class="pay-input partial-input @(ShowValidation && PartialAmountInput <= 0 ? "input-error" : "")" />
                        </div>
                        @if (ShowValidation && PartialAmountInput <= 0)
                        {
                            <span class="input-error-msg">Partial amount must be greater than ₱0</span>
                        }
                        @if (PartialAmountInput > 0 && PartialAmountInput < GetMonthlyRate(Stall))
                        {
                            <div class="partial-hint">
                                Balance remaining: ₱@((GetMonthlyRate(Stall) - PartialAmountInput).ToString("N2"))
                            </div>
                        }
                    </div>
                }

                <!-- ══════════════════════════════════════════
                     UNPAID notice — collector hasn't collected yet
                ══════════════════════════════════════════ -->
                @if (!GetIsPaid(Stall) && !GetIsPartial(Stall))
                {
                    <div class="unpaid-notice">
                         Waiting for collector to record payment on mobile.
                        OR Number can be encoded once payment is collected.
                    </div>
                }

                <!-- ══════════════════════════════════════════
                     UNIFIED PAYMENT DETAILS BLOCK
                     OR Number + Monthly Rental + Utilities + Breakdown — all in one
                ══════════════════════════════════════════ -->
                <div class="financial-breakdown">
                    <div class="financial-breakdown-title">Payment Details</div>

                    <!-- OR Number row -->
                    @if (GetIsPaid(Stall) || GetIsPartial(Stall))
                    {
                        @if (!string.IsNullOrWhiteSpace(GetOrNumber(Stall)) && !IsEditingOrNumber)
                        {
                            <!-- OR encoded → read-only + Edit -->
                            <div class="breakdown-item">
                                <span>OR Number</span>
                                <div class="or-encoded-row">
                                    <span class="or-number-display">@GetOrNumber(Stall)</span>
                                    <button class="btn-edit-or" @onclick="StartEditOrNumber" title="Edit OR Number">
                                        <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2">
                                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                        </svg>
                                        Edit
                                    </button>
                                </div>
                            </div>
                        }
                        else
                        {
                            <!-- OR not yet encoded OR editing → input inline -->
                            <div class="breakdown-item breakdown-or-input">
                                <span>
                                    OR Number <span class="required-star">*</span>
                                    @if (IsEditingOrNumber)
                                    {
                                        <span class="editing-tag">editing</span>
                                    }
                                </span>
                                <div class="or-input-col">
                                    <input @bind="OrNumber"
                                           @bind:event="oninput"
                                           type="text"
                                           placeholder="e.g. OR-2026-001"
                                           class="pay-input pay-input-inline @(ShowValidation && string.IsNullOrWhiteSpace(OrNumber) ? "input-error" : "")" />
                                    @if (ShowValidation && string.IsNullOrWhiteSpace(OrNumber))
                                    {
                                        <span class="input-error-msg">OR Number is required</span>
                                    }
                                </div>
                            </div>
                            <div class="breakdown-item breakdown-or-input">
                                <span style="color:var(--text-muted); font-size:12px;">Remarks <span class="optional-tag">(optional)</span></span>
                                <input @bind="Remarks"
                                       type="text"
                                       placeholder="e.g. Late payment..."
                                       class="pay-input pay-input-inline" />
                            </div>
                        }
                    }

                    <!-- Monthly Rental -->
                    <div class="breakdown-item breakdown-section-header">
                        <span>Monthly Rental</span>
                        <span>₱@GetMonthlyRate(Stall).ToString("N0")</span>
                    </div>

                    @if (GetIsPartial(Stall))
                    {
                        <div class="breakdown-item">
                            <span>Amount Paid</span>
                            <span style="color:var(--green);">₱@GetDisplayPartialAmount(Stall).ToString("N0")</span>
                        </div>
                        <div class="breakdown-item">
                            <span>Balance Remaining</span>
                            <span style="color:#b87333;">₱@GetDisplayBalanceRemaining(Stall).ToString("N0")</span>
                        </div>
                    }

                    <!-- NPM: Utilities -->
                    @if (Facility == "NPM")
                    {
                        @if (GetElecAmount(Stall) > 0)
                        {
                            <div class="breakdown-item">
                                <span>Electricity</span>
                                <span>₱@GetElecAmount(Stall).ToString("N0")</span>
                            </div>
                        }
                        @if (GetWaterAmount(Stall) > 0)
                        {
                            <div class="breakdown-item">
                                <span>Water</span>
                                <span>₱@GetWaterAmount(Stall).ToString("N0")</span>
                            </div>
                        }
                        @if (GetSelectedSection(Stall) == "Fish")
                        {
                            <div class="breakdown-item">
                                <span>Fish Fee (₱1/kg)</span>
                                <span>Variable</span>
                            </div>
                        }
                    }

                    <!-- Totals -->
                    <div class="breakdown-item breakdown-total">
                        <span>Total Paid</span>
                        <span>₱@GetTotalPaid(Stall).ToString("N0")</span>
                    </div>

                    <div class="breakdown-item balance-due">
                        <span>Balance Due</span>
                        <span>₱@GetBalanceDue(Stall).ToString("N0")</span>
                    </div>
                </div>

            </div>

            <!-- ── Footer ── -->
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="HandleClose">Close</button>

                @* Show "Save OR Number" only when:
                   - PAID or PARTIAL (collector already collected)
                   - OR Number not yet encoded by admin *@
                @if ((GetIsPaid(Stall!) || GetIsPartial(Stall!))
                                                                                      && string.IsNullOrWhiteSpace(GetOrNumber(Stall!)))
                {
                    <button class="btn-primary @(IsSaving ? "btn-loading" : "")"
                            @onclick="RequestSaveOrNumber"
                            disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="spinner"></span>
                            <span>Saving...</span>
                        }
                        else
                        {
                            <span>Save OR Number</span>
                        }
                    </button>
                }

                @* Show "Update" + "Cancel" when editing existing OR Number *@
                @if (IsEditingOrNumber)
                {
                    <button class="btn-ghost" @onclick="CancelEditOrNumber">Cancel</button>
                    <button class="btn-primary @(IsSaving ? "btn-loading" : "")"
                            @onclick="RequestSaveOrNumber"
                            disabled="@IsSaving">
                        @if (IsSaving)
                        {
                            <span class="spinner"></span>
                            <span>Updating...</span>
                        }
                        else
                        {
                            <span>Update OR Number</span>
                        }
                    </button>
                }
            </div>

        </div>
    </div>
}

@* ══════════════════════════════════════════════════════════════════════
   CONFIRMATION MODAL — Appears on top of payment modal
══════════════════════════════════════════════════════════════════════ *@
@if (ShowConfirmation)
{
    <div class="eemo-modal-overlay confirm-overlay" @onclick="CancelConfirmation">
        <div class="eemo-modal confirm-modal" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div class="eemo-modal-title">Confirm OR Number</div>
            </div>
            <div class="eemo-modal-body">
                <p>You are about to save the following OR Number:</p>
                <div class="confirm-or-display">@OrNumber</div>
                @if (GetIsPartial(Stall!))
                {
                    <p style="margin-top: 1rem;">Partial amount: <strong>₱@PartialAmountInput.ToString("N2")</strong></p>
                }
                <p style="margin-top: 1rem; color: var(--text-muted); font-size: 14px;">
                    This action cannot be undone. Please verify the OR Number is correct.
                </p>
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="CancelConfirmation">Cancel</button>
                <button class="btn-primary" @onclick="ConfirmSaveOrNumber">Confirm & Save</button>
            </div>
        </div>
    </div>
}

@code {

    [Parameter] public string Facility { get; set; } = string.Empty;
    [Parameter] public TStall? Stall { get; set; }
    [Parameter] public bool Show { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<PaymentSubmitDto> OnSave { get; set; }

    // ── Form Fields (admin only encodes OR Number) ──
    private string OrNumber { get; set; } = string.Empty;
    private string Remarks { get; set; } = string.Empty;
    private decimal PartialAmountInput { get; set; } = 0;

    // ── UI State ──
    private bool ShowValidation { get; set; } = false;
    private bool IsSaving { get; set; } = false;
    private bool IsEditingOrNumber { get; set; } = false;
    private bool ShowConfirmation { get; set; } = false;

    // ── Reset form when modal closes ──
    protected override void OnParametersSet()
    {
        if (!Show)
        {
            OrNumber = string.Empty;
            Remarks = string.Empty;
            PartialAmountInput = 0;
            ShowValidation = false;
            IsSaving = false;
            IsEditingOrNumber = false;
            ShowConfirmation = false;
        }
        else if (Show && Stall != null)
        {
            // Pre-fill partial amount if already set
            PartialAmountInput = GetPartialAmount(Stall);
        }
    }

    private async Task HandleClose() => await OnClose.InvokeAsync();

    private void StartEditOrNumber()
    {
        OrNumber = GetOrNumber(Stall!);  // pre-fill with existing value
        IsEditingOrNumber = true;
        ShowValidation = false;
    }

    private void CancelEditOrNumber()
    {
        OrNumber = string.Empty;
        IsEditingOrNumber = false;
        ShowValidation = false;
    }

    private void RequestSaveOrNumber()
    {
        ShowValidation = true;

        if (string.IsNullOrWhiteSpace(OrNumber))
            return;

        if (GetIsPartial(Stall!) && PartialAmountInput <= 0)
            return;

        ShowConfirmation = true;
    }

    private void CancelConfirmation()
    {
        ShowConfirmation = false;
    }

    private async Task ConfirmSaveOrNumber()
    {
        ShowConfirmation = false;
        IsSaving = true;

        var stallGuid = GetStallGuid(Stall!);
        if (stallGuid != Guid.Empty)
        {
            // First, get the payment record to obtain its ID
            var paymentResult = await PaymentsApi.GetPaymentRecordAsync(
                stallGuid,
                DateTime.Now.Year,
                DateTime.Now.Month);

            if (paymentResult.IsSuccess && paymentResult.Value != null)
            {
                var command = new SaveOrNumberCommand(
                    paymentResult.Value.Id,
                    OrNumber.Trim());

                var result = await PaymentsApi.SaveOrNumberAsync(command);
                
                if (result.IsSuccess)
                {
                    await OnSave.InvokeAsync(new PaymentSubmitDto
                    {
                        StallId = GetStallId(Stall!),
                        OrNumber = OrNumber.Trim(),
                        Remarks = Remarks,
                        SavedAt = DateTime.UtcNow
                    });
                }
            }
        }

        IsSaving = false;
    }

    // ── Generic Property Accessors ──
    private Guid GetStallGuid(TStall stall)
    {
        var prop = stall?.GetType().GetProperty("StallGuid",
            System.Reflection.BindingFlags.Public |
            System.Reflection.BindingFlags.Instance |
            System.Reflection.BindingFlags.IgnoreCase);
        if (prop != null)
        {
            var val = prop.GetValue(stall);
            if (val is Guid g && g != Guid.Empty) return g;
        }
        return Guid.Empty;
    }
    private string GetStallNo(TStall stall) => GetPropertyValue<string>(stall, "StallNo") ?? "";
    private string GetActualOccupant(TStall stall) => GetPropertyValue<string>(stall, "ActualOccupant") ?? "";
    private object? GetStallId(TStall stall) => GetPropertyValue<object>(stall, "Id");
    private decimal GetMonthlyRate(TStall stall) => GetPropertyValue<decimal?>(stall, "MonthlyRate") ?? 0;
    private decimal GetPartialAmount(TStall stall) => GetPropertyValue<decimal?>(stall, "PartialAmount") ?? 0;
    private bool GetIsPaid(TStall stall) => GetPropertyValue<bool?>(stall, "IsPaid") ?? false;
    private bool GetIsPartial(TStall stall) => GetPropertyValue<bool?>(stall, "IsPartial") ?? false;
    private decimal GetTotalPaid(TStall stall) => GetPropertyValue<decimal?>(stall, "TotalPaid") ?? 0;
    private decimal GetBalanceDue(TStall stall) => GetPropertyValue<decimal?>(stall, "BalanceDue") ?? 0;
    private decimal GetElecAmount(TStall stall) => GetPropertyValue<decimal?>(stall, "ElecAmount") ?? 0;
    private decimal GetWaterAmount(TStall stall) => GetPropertyValue<decimal?>(stall, "WaterAmount") ?? 0;
    private string GetSelectedSection(TStall stall) => GetPropertyValue<string>(stall, "SelectedSection") ?? "";
    private string GetOrNumber(TStall stall) => GetPropertyValue<string>(stall, "OrNumber") ?? "";

    private T GetPropertyValue<T>(TStall stall, string propertyName)
    {
        var property = stall?.GetType().GetProperty(
            propertyName,
            System.Reflection.BindingFlags.Public |
            System.Reflection.BindingFlags.Instance |
            System.Reflection.BindingFlags.IgnoreCase);  // ← fixes OrNumber vs ORNumber
        return property != null ? (T?)property.GetValue(stall) ?? default! : default!;
    }

    private string GetStatusText(TStall stall)
    {
        if (GetIsPaid(stall)) return "Paid";
        if (GetIsPartial(stall)) return $"Partial — ₱{GetPartialAmount(stall):N0}";
        return "Unpaid";
    }

    // ── Display helpers for partial payment breakdown ──
    private decimal GetDisplayPartialAmount(TStall stall)
    {
        // If user is entering a new partial amount, show the input value
        // Otherwise, show the existing partial amount from database
        if (PartialAmountInput > 0)
            return PartialAmountInput;
        return GetPartialAmount(stall);
    }

    private decimal GetDisplayBalanceRemaining(TStall stall)
    {
        // Calculate balance based on the displayed partial amount
        var monthlyRate = GetMonthlyRate(stall);
        var partialAmount = GetDisplayPartialAmount(stall);
        return monthlyRate - partialAmount;
    }

    // ── DTO ──
    public class PaymentSubmitDto
    {
        public object? StallId { get; set; }
        public string OrNumber { get; set; } = string.Empty;
        public string? Remarks { get; set; }
        public DateTime SavedAt { get; set; } = DateTime.UtcNow;
    }
}
