

@inject IPaymentsApiClient PaymentsApi

@typeparam TStall

@if (Show && Stall is not null)
{
    var history = GetPaymentHistory(Stall);
    var rate = GetMonthlyRate(Stall);
    var stallNo = GetStallNo(Stall);
    var occupant = GetActualOccupant(Stall);
    var contractName = GetContractName(Stall);
    var transactions = GetTransactions(Stall);
    var contractDate = GetContractDate(Stall);
    var now = EEMOCantilanSDS.Domain.Common.PhilippineTime.Now;

    // Calculate experienced months only (from contract start to now)
    var experiencedMonths = new List<DateTime>();
    for (int i = 11; i >= 0; i--)
    {
        var month = now.AddMonths(-i);
        var key = month.ToString("yyyy-MM");
        var hasRecord = PaymentHistory.Any(p => p.Period == key);
        var contractStarts = contractDate.HasValue ? new DateTime(contractDate.Value.Year, contractDate.Value.Month, 1) : (DateTime?)null;
        var beforeContract = !hasRecord && contractStarts.HasValue && month < contractStarts.Value;
        if (!beforeContract)
            experiencedMonths.Add(month);
    }

    int monthsPaid = PaymentHistory.Count(p => p.Status == Domain.Enums.PaymentStatus.Paid);
    int monthsUnpaid = experiencedMonths.Count - monthsPaid;
    decimal collected = PaymentHistory
        .Where(p => p.Status == Domain.Enums.PaymentStatus.Paid || p.Status == Domain.Enums.PaymentStatus.Partial)
        .Sum(p => p.AmountPaid);
    decimal balance = experiencedMonths.Sum(m =>
    {
        var rec = PaymentHistory.FirstOrDefault(p => p.Period == m.ToString("yyyy-MM"));
        return rec is null ? rate
             : rec.Status == Domain.Enums.PaymentStatus.Paid ? 0m
             : rec.Status == Domain.Enums.PaymentStatus.Partial ? rec.BalanceDue
             : rate;
    });
    int compliancePct = experiencedMonths.Count > 0 ? (int)((double)monthsPaid / experiencedMonths.Count * 100) : 0;

    var currentMonthKey = now.ToString("yyyy-MM");
    var currentRecord = PaymentHistory.FirstOrDefault(p => p.Period == currentMonthKey);
    decimal currentPartial = currentRecord?.Status == Domain.Enums.PaymentStatus.Partial ? currentRecord.AmountPaid : 0;

    string statusLabel = monthsUnpaid == 0 ? "Consistent Payer"
                       : monthsUnpaid >= 3 ? "Delinquent"
                                           : "With Arrears";
    string statusClass = monthsUnpaid == 0 ? "ph-badge-consistent"
                       : monthsUnpaid >= 3 ? "ph-badge-delinquent"
                                           : "ph-badge-arrears";

    <div class="eemo-modal-overlay" @onclick="() => OnClose.InvokeAsync()">
        <div class="ph-modal" @onclick:stopPropagation="true">

            <!-- ══ HEADER — matches NCC/NPM hero banner ══ -->
            <div class="ph-header">

                <!-- decorative radial glow -->
                <div class="ph-header-glow"></div>

                <!-- left: icon + identity -->
                <div class="ph-header-left">
                    <div class="ph-header-icon">
                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                    </div>
                    <div class="ph-header-text">
                        <div class="ph-header-eyebrow">
                            @FacilityCode
                            <span class="ph-dot">·</span>
                            Stall @stallNo
                            <span class="ph-dot">·</span>
                            12-Month Payment Record
                        </div>
                        <div class="ph-header-name">@occupant</div>
                        @if (!string.IsNullOrEmpty(contractName) && contractName != occupant)
                        {
                            <div class="ph-header-contract">Contract: @contractName</div>
                        }
                    </div>
                </div>

                <!-- right: stats + badge + close -->
                <div class="ph-header-right">
                    <div class="ph-header-stats">
                        <div class="ph-hstat">
                            <div class="ph-hstat-val">₱@rate.ToString("N0")</div>
                            <div class="ph-hstat-key">Monthly Rate</div>
                        </div>
                        <div class="ph-hstat-div"></div>
                        <div class="ph-hstat">
                            <div class="ph-hstat-val">@monthsPaid<span class="ph-hstat-of">/@experiencedMonths.Count</span></div>
                            <div class="ph-hstat-key">Months Paid</div>
                        </div>
                        <div class="ph-hstat-div"></div>
                        <div class="ph-hstat">
                            <div class="ph-hstat-val @(monthsUnpaid > 0 ? "ph-hstat-red" : "")">@monthsUnpaid<span class="ph-hstat-of">/@experiencedMonths.Count</span></div>
                            <div class="ph-hstat-key">Unpaid</div>
                        </div>
                        <div class="ph-hstat-div"></div>
                        <div class="ph-hstat">
                            <div class="ph-hstat-val">₱@collected.ToString("N0")</div>
                            <div class="ph-hstat-key">Collected</div>
                        </div>
                            <div class="ph-hstat-div"></div>
                            <div class="ph-hstat">
                                <div class="ph-hstat-val @(balance > 0 ? "ph-hstat-red" : "")">₱@balance.ToString("N0")</div>
                                <div class="ph-hstat-key">Balance Due</div>
                            </div>
                            <div class="ph-hstat-div"></div>
                            <div class="ph-hstat">
                                <div class="ph-hstat-val">₱@currentPartial.ToString("N0")</div>
                                <div class="ph-hstat-key">Current Partial</div>
                            </div>
                        </div>
                    <div class="ph-header-right-actions">
                        <span class="ph-status-badge @statusClass">@statusLabel</span>
                        <button class="ph-close-btn" @onclick="() => OnClose.InvokeAsync()">
                            <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                        </button>
                    </div>
                </div>

                <!-- gold progress bar pinned to bottom -->
                <div class="ph-header-progress">
                    <div class="ph-header-progress-fill" style="width:@compliancePct%"></div>
                </div>
            </div>

            <!-- ══ COMPLIANCE ROW ══ -->
            <div class="ph-compliance-row">
                <div class="ph-compliance-label">
                    <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
                    Collection Compliance
                </div>
                <div class="ph-compliance-track">
                    <div class="ph-compliance-fill" style="width:@compliancePct%"></div>
                </div>
                <div class="ph-compliance-pct @(compliancePct == 100 ? "pct-full" : compliancePct < 50 ? "pct-low" : "")">
                    @compliancePct%
                </div>
            </div>

            <!-- ══ LEDGER ══ -->
            <div class="ph-body">

                <div class="ph-ledger-header">
                    <div>Period</div>
                    <div>Status</div>
                    <div>OR Number</div>
                    <div>Payment Date</div>
                    <div>Collector</div>
                    <div>Amount</div>
                    <div>Balance</div>
                </div>

                <div class="ph-ledger-body">
                    @{
                        decimal runningBalance = 0;
                    }
                    @for (int i = 11; i >= 0; i--)
                    {
                        var month = now.AddMonths(-i);
                        var key = month.ToString("yyyy-MM");
                        var contractStart = contractDate.HasValue ? new DateTime(contractDate.Value.Year, contractDate.Value.Month, 1) : (DateTime?)null;
                        var apiRecord = PaymentHistory.FirstOrDefault(p => p.Period == key);
                        var hasRecord = apiRecord != null;
                        var isBeforeContract = !hasRecord && contractStart.HasValue && month < contractStart.Value;
                        var payStatus = hasRecord ? apiRecord!.Status : Domain.Enums.PaymentStatus.Unpaid;
                        var isPaid = payStatus == Domain.Enums.PaymentStatus.Paid;
                        var isPartial = payStatus == Domain.Enums.PaymentStatus.Partial;
                        var tx = transactions.FirstOrDefault(t => t.PeriodKey == key);
                        var isCurr = month.Month == now.Month && month.Year == now.Year;

                        // Calculate balance for this row
                        decimal rowBalance = 0;
                        if (!isBeforeContract)
                        {
                            if (isPaid)
                            {
                                rowBalance = 0; // Fully paid
                            }
                            else if (isPartial && apiRecord != null)
                            {
                                rowBalance = apiRecord.BalanceDue; // Remaining balance after partial
                            }
                            else
                            {
                                rowBalance = rate; // Unpaid full amount
                            }
                        }

                        <div class="ph-ledger-row @(isBeforeContract ? "ph-row-before-contract" : isPaid ? "ph-row-paid" : isPartial ? "ph-row-partial" : "ph-row-unpaid") @(isCurr ? "ph-row-current" : "")">

                            <!-- Period -->
                            <div class="ph-cell-period">
                                <div class="ph-period-dot @(isBeforeContract ? "ph-dot-gray" : isPaid ? "ph-dot-paid" : isPartial ? "ph-dot-partial" : "ph-dot-unpaid")"></div>
                                <div>
                                    <div class="ph-period-month">@month.ToString("MMMM")</div>
                                    <div class="ph-period-year">@month.Year</div>
                                </div>
                                @if (isCurr)
                                {
                                    <span class="ph-current-tag">Current</span>
                                }
                            </div>

                            <!-- Status -->
                            <div>
                                @if (isBeforeContract)
                                {
                                    <span class="ph-pay-pill ph-pill-gray">
                                        <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12" /></svg>
                                        N/A
                                    </span>
                                }
                                else if (isPaid)
                                {
                                    <span class="ph-pay-pill ph-pill-paid">
                                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                        Paid
                                    </span>
                                }
                                else if (isPartial)
                                {
                                    <span class="ph-pay-pill ph-pill-partial">
                                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/><path d="M12 2 A 10 10 0 0 1 12 22 Z" fill="currentColor"/></svg>
                                        Partial
                                    </span>
                                }
                                else
                                {
                                    <span class="ph-pay-pill ph-pill-unpaid">
                                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                                        Unpaid
                                    </span>
                                }
                            </div>

                            <!-- OR Number -->
                            <div>
                                @if (isBeforeContract)
                                {
                                    <span class="ph-cell-empty">—</span>
                                }
                                else if ((isPaid || isPartial) && !string.IsNullOrEmpty(apiRecord?.ORNumber))
                                {
                                    <span class="ph-or-num">@apiRecord!.ORNumber</span>
                                }
                                else
                                {
                                    <span class="ph-cell-empty">—</span>
                                }
                            </div>

                            <!-- Payment Date -->
                            <div>
                                @if (isBeforeContract)
                                {
                                    <span class="ph-cell-empty">—</span>
                                }
                                else if ((isPaid || isPartial) && apiRecord?.PaidAt.HasValue == true)
                                {
                                    <span class="ph-pay-date">@apiRecord!.PaidAt!.Value.ToString("MMM d, yyyy")</span>
                                }
                                else
                                {
                                    <span class="ph-cell-empty">—</span>
                                }
                            </div>

                            <!-- Collector -->
                            <div>
                                @if (isBeforeContract)
                                {
                                    <span class="ph-cell-empty">—</span>
                                }
                                else if ((isPaid || isPartial) && !string.IsNullOrEmpty(apiRecord?.CollectorName))
                                {
                                    <span class="ph-collector-name">@apiRecord!.CollectorName</span>
                                }
                                else
                                {
                                    <span class="ph-cell-empty">—</span>
                                }
                            </div>

                            <!-- Amount -->
                            <div>
                                @if (isBeforeContract)
                                {
                                    <span class="ph-cell-empty">—</span>
                                }
                                else if (isPaid || isPartial)
                                {
                                    <span class="ph-amount-paid">₱@(apiRecord!.AmountPaid.ToString("N0"))</span>
                                }
                                else
                                {
                                    <span class="ph-amount-unpaid">₱@rate.ToString("N0")</span>
                                }
                            </div>

                            <!-- Balance Due (Per Row) -->
                            <div>
                                @if (isBeforeContract)
                                {
                                    <span class="ph-cell-empty">—</span>
                                }
                                else if (rowBalance > 0)
                                {
                                    <span class="ph-balance-due">₱@rowBalance.ToString("N0")</span>
                                }
                                else
                                {
                                    <span class="ph-balance-zero">₱0</span>
                                }
                            </div>

                        </div>
                    }
                </div>
            </div>

            <!-- ══ FOOTER ══ -->
            <div class="ph-footer">
                <div class="ph-footer-meta">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                    Records cover the last 12 rolling months &nbsp;·&nbsp;
                    @now.AddMonths(-11).ToString("MMM yyyy") – @now.ToString("MMM yyyy")
                </div>
                <div class="ph-footer-actions">
                    @if (balance > 0)
                    {
                        <div class="ph-balance-alert">
                            <svg viewBox="0 0 24 24"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                            Outstanding: ₱@balance.ToString("N0") · @monthsUnpaid month@(monthsUnpaid != 1 ? "s" : "") unpaid
                        </div>
                    }
                    <button class="btn-ghost" @onclick="() => OnClose.InvokeAsync()">Close</button>
                </div>
            </div>

        </div>
    </div>
}

@code {
    [Parameter] public bool Show { get; set; }
    [Parameter] public TStall? Stall { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public string FacilityCode { get; set; } = string.Empty;
    [Parameter] public string FacilityName { get; set; } = string.Empty;

    private List<Application.Dtos.Payments.PaymentHistoryDto> PaymentHistory { get; set; } = new();
    private bool IsLoading { get; set; } = false;

    protected override async Task OnParametersSetAsync()
    {
        if (Show && Stall is not null)
        {
            await LoadPaymentHistory();
        }
    }

    private async Task LoadPaymentHistory()
    {
        var stallGuid = GetStallGuid(Stall!);
        if (stallGuid == Guid.Empty)
            return;

        IsLoading = true;
        var result = await PaymentsApi.GetPaymentHistoryAsync(stallGuid);
        if (result.IsSuccess && result.Value != null)
        {
            PaymentHistory = result.Value.ToList();
        }
        IsLoading = false;
    }

    public class PaymentTransaction
    {
        public string PeriodKey { get; set; } = string.Empty;
        public string ORNumber { get; set; } = string.Empty;
        public DateTime? PaidDate { get; set; }
        public string Collector { get; set; } = string.Empty;
        public decimal Amount { get; set; }
    }

    private Guid GetStallGuid(TStall s) => GetProp<Guid>(s, "StallGuid");
    private string GetStallNo(TStall s) => GetProp<string>(s, "StallNo") ?? "—";
    private string GetActualOccupant(TStall s) => GetProp<string>(s, "ActualOccupant") ?? "—";
    private string GetContractName(TStall s) => GetProp<string>(s, "ContractName") ?? string.Empty;
    private decimal GetMonthlyRate(TStall s) => GetProp<decimal?>(s, "MonthlyRate") ?? 0m;
    private decimal GetPartialAmount(TStall s) => GetProp<decimal?>(s, "PartialAmount") ?? 0m;
    private bool GetIsPartial(TStall s) => GetProp<bool?>(s, "IsPartial") ?? false;
    private DateTime? GetContractDate(TStall s) => GetProp<DateTime?>(s, "ContractDate");

    private Dictionary<string, bool> GetPaymentHistory(TStall s)
    {
        // Convert API PaymentHistory to Dictionary for backward compatibility
        var dict = new Dictionary<string, bool>();
        foreach (var payment in PaymentHistory)
        {
            dict[payment.Period] = payment.Status == Domain.Enums.PaymentStatus.Paid;
        }
        return dict;
    }

    private List<PaymentTransaction> GetTransactions(TStall s)
    {
        // Convert API PaymentHistory to PaymentTransaction list
        return PaymentHistory.Select(p => new PaymentTransaction
        {
            PeriodKey = p.Period,
            ORNumber = p.ORNumber ?? string.Empty,
            PaidDate = p.PaidAt,
            Collector = p.CollectorName ?? string.Empty,
            Amount = p.AmountPaid
        }).ToList();
    }

    private T? GetProp<T>(TStall s, string name)
    {
        var prop = s?.GetType().GetProperty(name);
        return prop is not null ? (T?)prop.GetValue(s) : default;
    }
}
