<!-- ----------------------------------------------
     RECORD PAYMENT — removed. Collection (per-day NPM, per-month TCC/NCC/ICE/BBQ,
     Excused, and market closures) is now managed centrally in the Collection Manager
     (/reports/collections). The hero "Manage Collection" button links there.
---------------------------------------------- -->


@code {

    [Parameter]
    public string FacilityId { get; set; } = string.Empty;

    [Parameter]
    public string StallKey { get; set; } = string.Empty;

    bool ShowEditModal = false;
    bool IsSavingEdit = false;
    bool IsLoading = true;
    Guid StallGuid = Guid.Empty;
    string DisplayStallNo = string.Empty;

    private bool IsNpm => FacilityId.ToUpper() == "NPM";

    // GitHub-style daily heatmap (NPM only): last ~12 months of per-day collection status.
    private sealed record HeatCell(DateOnly Date, string Kind);
    private List<List<HeatCell>> _heatWeeks = new();   // each inner list = 7 cells (Sun→Sat)
    private int _heatCollected;
    private int _heatMissed;
    private int _heatYear = EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year;

    // Collection history (transparency log) — cursor-paginated 10/page (NPM days / monthly records).
    private readonly List<StallCollectionHistoryRowDto> _history = new();
    private DateTime? _historyCursor;
    private bool _historyHasMore;
    private bool _historyLoading;
    private bool _historyError;

    private async Task LoadHistory(bool reset)
    {
        if (StallGuid == Guid.Empty || _historyLoading) return;
        if (reset)
        {
            _history.Clear();
            _historyCursor = null;
            _historyHasMore = false;
        }
        _historyLoading = true;
        _historyError = false;
        try
        {
            var result = await StallsApi.GetStallCollectionHistoryAsync(StallGuid, _historyCursor, 10);
            if (result.IsSuccess && result.Value is not null)
            {
                _history.AddRange(result.Value.Items);
                _historyCursor = result.Value.NextCursor;
                _historyHasMore = result.Value.HasMore;
            }
            else
            {
                // Distinguish a failed fetch from a genuinely empty log (don't show "no records").
                _historyError = true;
            }
        }
        finally
        {
            _historyLoading = false;
        }
    }

    private Task LoadMoreHistory() => LoadHistory(reset: false);

    class StallProfile
    {
        public string Facility { get; set; } = string.Empty;
        public string StallNo { get; set; } = string.Empty;
        public string Section { get; set; } = string.Empty;
        public double AreaSqm { get; set; }
        public string AreaNote { get; set; } = string.Empty;
        public string ActualOccupant { get; set; } = string.Empty;
        public string ContractName { get; set; } = string.Empty;
        public DateTime? ContractDate { get; set; }
        public string ContractDuration { get; set; } = string.Empty;
        public int ContractYears { get; set; }
        public DateTime? ContractExpiry { get; set; }
        public decimal MonthlyRate { get; set; }
        public decimal? DailyRate { get; set; }
        public bool HasElectricity { get; set; }
        public decimal ElecReading { get; set; }
        public decimal ElecAmount { get; set; }
        public bool HasWater { get; set; }
        public decimal WaterReading { get; set; }
        public decimal WaterAmount { get; set; }
        public decimal FishKilos { get; set; }
        public decimal FishFee => Section == "Fish Area" ? FishKilos : 0;
        public decimal TotalBill => MonthlyRate + ElecAmount + WaterAmount + FishFee;
        public bool IsPaid { get; set; }
        public bool IsPartial { get; set; }
        public decimal PartialAmount { get; set; }
        public decimal TotalPaid => IsPaid ? TotalBill : IsPartial ? PartialAmount : 0;
        public decimal BalanceDue => TotalBill - TotalPaid;
        public bool IsActive { get; set; } = true;
        public string ORNumber { get; set; } = string.Empty;
        public string Remarks { get; set; } = string.Empty;
        public Dictionary<string, string> PaymentHistory { get; set; } = new();
        // Authoritative daily-aware rolling 12-month ledger totals (from the server).
        public StallLedgerSummaryDto? LedgerSummary { get; set; }
    }

    StallProfile Stall = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadStallData();
    }

    async Task LoadStallData()
    {
        IsLoading = true;
        
        // Parse facility code from URL parameter
        var facilityCode = FacilityId.ToUpper() switch
        {
            "NPM" => Domain.Enums.FacilityCode.NPM,
            "TCC" => Domain.Enums.FacilityCode.TCC,
            "NCC" => Domain.Enums.FacilityCode.NCC,
            "BBQ" => Domain.Enums.FacilityCode.BBQ,
            "ICE" => Domain.Enums.FacilityCode.ICE,
            "SLH" => Domain.Enums.FacilityCode.SLH,
            _ => Domain.Enums.FacilityCode.NPM
        };

        // Load stalls from API
        var stallsResult = await StallsApi.GetStallsByFacilityPaginatedAsync(facilityCode, null, null, 100);
        
        if (stallsResult.IsSuccess && stallsResult.Value != null)
        {
            var stallDto = Guid.TryParse(StallKey, out var keyId)
                ? stallsResult.Value.Items.FirstOrDefault(s => s.Id == keyId)
                : stallsResult.Value.Items.FirstOrDefault(s => s.StallNo == StallKey);
            
            if (stallDto != null)
            {
                StallGuid = stallDto.Id;
                DisplayStallNo = stallDto.StallNo;

                // Fetch all per-stall data concurrently (each is keyed by the stall id and independent),
                // instead of awaiting them one after another. The NPM daily heatmap still runs after the
                // Stall object is built, because it reads the contract date from it.
                var historyTask = PaymentsApi.GetPaymentHistoryAsync(stallDto.Id);
                var currentPaymentTask = PaymentsApi.GetPaymentRecordAsync(stallDto.Id, DateTime.Now.Year, DateTime.Now.Month);
                var ledgerTask = PaymentsApi.GetStallLedgerSummaryAsync(stallDto.Id);
                var reportTask = FacilityId.ToUpper() == "NPM"
                    ? FacilitiesApi.GetFacilityReportsAsync(facilityCode, Domain.Enums.ReportPeriod.Monthly, DateTime.Now.Year, DateTime.Now.Month)
                    : null;
                var pending = new List<Task> { historyTask, currentPaymentTask, ledgerTask };
                if (reportTask is not null) pending.Add(reportTask);
                await Task.WhenAll(pending);

                // Load payment history
                var historyResult = await historyTask;
                var paymentHistory = new Dictionary<string, string>();
                
                if (historyResult.IsSuccess && historyResult.Value != null)
                {
                    foreach (var payment in historyResult.Value)
                    {
                        paymentHistory[payment.Period] = payment.IsExcused ? "Absent"
                            : payment.Status == Domain.Enums.PaymentStatus.Paid ? "Paid" 
                            : payment.Status == Domain.Enums.PaymentStatus.Partial ? "Partial" 
                            : "Unpaid";
                    }
                }

                // Seed the monthly grid's status map for the default (current) year from the rolling history.
                _monthlyStatus = new Dictionary<string, string>(paymentHistory);
                
                // Load current month payment record
                var currentPaymentResult = await currentPaymentTask;
                
                // Handle 404 - no payment record exists yet for current month
                bool isPaid = false;
                bool isPartial = false;
                decimal partialAmount = 0;
                decimal elecAmount = 0;
                decimal waterAmount = 0;
                string orNumber = string.Empty;
                
                if (currentPaymentResult.IsSuccess && currentPaymentResult.Value != null)
                {
                    isPaid = currentPaymentResult.Value.Status == Domain.Enums.PaymentStatus.Paid;
                    isPartial = currentPaymentResult.Value.Status == Domain.Enums.PaymentStatus.Partial;
                    partialAmount = isPartial ? currentPaymentResult.Value.TotalPaid : 0;
                    elecAmount = currentPaymentResult.Value.ElecAmount ?? 0;
                    waterAmount = currentPaymentResult.Value.WaterAmount ?? 0;
                    orNumber = currentPaymentResult.Value.ORNumber ?? string.Empty;
                }

                // NPM is collected daily, so the true status comes from the daily-aware report
                // compliance (a vendor who paid some days is Partial — the monthly PaymentRecord
                // alone would read Unpaid). Mirrors the NPM facility page / payment modal.
                if (FacilityId.ToUpper() == "NPM")
                {
                    var reportResult = await reportTask!;
                    var compliance = reportResult.IsSuccess
                        ? reportResult.Value?.StallCompliance?.FirstOrDefault(c => c.StallId == StallGuid)
                        : null;
                    if (compliance != null)
                    {
                        isPaid = compliance.Status == "Paid";
                        isPartial = compliance.Status == "Partial";
                        partialAmount = compliance.AmountPaid;
                        if (!string.IsNullOrWhiteSpace(compliance.ORNumber))
                            orNumber = compliance.ORNumber!;
                    }
                }
                
                var section = stallDto.Section switch
                {
                    Domain.Enums.MarketSection.VegetableArea => "Vegetable Area",
                    Domain.Enums.MarketSection.FishSection => "Fish Area",
                    Domain.Enums.MarketSection.MeatSection => "Meat Area",
                    _ => stallDto.AreaLocation switch
                    {
                        Domain.Enums.NccAreaLocation.Extension => "Extension",
                        Domain.Enums.NccAreaLocation.Corner => "Corner",
                        _ => "No Location"
                    }
                };
                
                var hasElec = FacilityId.ToUpper() == "NPM";
                var hasWater = FacilityId.ToUpper() == "NPM";
                
                Stall = new()
                {
                    Facility = GetFacilityName(FacilityId),
                    StallNo = stallDto.StallNo,
                    Section = section,
                    AreaSqm = stallDto.AreaSqm ?? 0,
                    AreaNote = stallDto.AreaNote ?? string.Empty,
                    ActualOccupant = stallDto.ActualOccupant ?? "N/A",
                    ContractName = stallDto.NameOnContract ?? "N/A",
                    ContractDate = stallDto.ContractDate,
                    ContractDuration = stallDto.ContractYears > 0 ? $"{stallDto.ContractYears} year{(stallDto.ContractYears > 1 ? "s" : "")}" : "—",
                    ContractYears = stallDto.ContractYears,
                    ContractExpiry = stallDto.ContractYears > 0 ? stallDto.ContractDate?.AddYears(stallDto.ContractYears) : null,
                    MonthlyRate = stallDto.MonthlyRate,
                    DailyRate = stallDto.DailyRate,
                    HasElectricity = hasElec,
                    ElecReading = 0,
                    ElecAmount = elecAmount,
                    HasWater = hasWater,
                    WaterReading = 0,
                    WaterAmount = waterAmount,
                    FishKilos = 0,
                    IsPaid = isPaid,
                    IsPartial = isPartial,
                    PartialAmount = partialAmount,
                    IsActive = stallDto.Status == Domain.Enums.StallStatus.Active,
                    ORNumber = orNumber,
                    Remarks = stallDto.Remarks ?? string.Empty,
                    PaymentHistory = paymentHistory,
                    LedgerSummary = (await ledgerTask).Value
                };

                if (IsNpm) await LoadNpmDailyHeatmap(StallGuid);
            }
            else
            {
                // Stall not found, redirect back
                Navigation.NavigateTo("/facility/" + FacilityId.ToLower());
            }
        }
        
        IsLoading = false;

        // Collection history loads off the first-paint critical path: paint the profile now
        // (StateHasChanged), then fetch page 1 while the card shows its own loading state, so a
        // slow history query never delays the whole page.
        if (StallGuid != Guid.Empty)
        {
            StateHasChanged();
            await LoadHistory(reset: true);
        }
    }

    string GetFacilityName(string facilityId)
    {
        return facilityId.ToLower() switch
        {
            // From Report.razor (lowercase)
            "npm" => "New Public Market",
            "tcc" => "Tampak Commercial Center",
            "ncc" => "New Commercial Center",
            "bbq" => "Barbecue Stand",
            "ice" => "Iceplant",
            "slh" => "Slaughterhouse",

            // From facility pages (uppercase/mixed case)
            "npm-annex" => "New Public Market Annex",
            "public-market-1" => "Public Market 1",
            "public-market-2" => "Public Market 2",
            _ => "Unknown Facility"
        };
    }

    // ── GitHub-style daily collection heatmap (NPM) ──
    async Task LoadNpmDailyHeatmap(Guid stallId)
    {
        var today = EEMOCantilanSDS.Domain.Common.PhilippineTime.Today;
        var year = _heatYear;

        // Window END: today for the current (or a future-picked) year; Dec 31 for a past year. The grid
        // always shows the trailing ~52 weeks ending there — full width, no future cells, and it includes
        // the preceding months ("the passed") so the row spans the whole width instead of half.
        var end = year >= today.Year ? today : new DateOnly(year, 12, 31);
        var start = end.AddDays(-363);
        while (start.DayOfWeek != DayOfWeek.Sunday) start = start.AddDays(-1);

        // Fetch every calendar month the window touches, in parallel.
        var months = new List<(int y, int m)>();
        var mc = new DateOnly(start.Year, start.Month, 1);
        var endMonth = new DateOnly(end.Year, end.Month, 1);
        while (mc <= endMonth) { months.Add((mc.Year, mc.Month)); mc = mc.AddMonths(1); }

        var results = await Task.WhenAll(
            months.Select(mm => DailyCollectionApi.GetDailyCollectionMonthAsync(stallId, mm.y, mm.m)));

        var status = new Dictionary<DateOnly, string>();
        foreach (var r in results)
        {
            if (r.IsSuccess && r.Value is not null)
                foreach (var day in r.Value.Collections.Values)
                    status[day.Date] = day.IsMarketClosed || day.IsAbsent ? "excused" : day.IsPaid ? "collected" : "missed";
        }

        var contractStart = Stall.ContractDate.HasValue ? DateOnly.FromDateTime(Stall.ContractDate.Value) : (DateOnly?)null;

        var weeks = new List<List<HeatCell>>();
        var collected = 0;
        var missed = 0;
        var d = start;
        while (d <= end)
        {
            var week = new List<HeatCell>();
            for (var i = 0; i < 7; i++)
            {
                string kind;
                if (d > today) kind = "future";                                   // only the tail of the final week
                else if (contractStart.HasValue && d < contractStart.Value) kind = "none";
                else if (status.TryGetValue(d, out var st)) kind = st;
                else kind = "missed";
                if (kind == "collected") collected++;
                else if (kind == "missed") missed++;
                week.Add(new HeatCell(d, kind));
                d = d.AddDays(1);
            }
            weeks.Add(week);
        }
        _heatWeeks = weeks;
        _heatCollected = collected;
        _heatMissed = missed;
    }

    // Year navigation for the daily heatmap.
    private bool _heatYearMenuOpen;
    private IEnumerable<int> HeatYearOptions =>
        Enumerable.Range(0, 12).Select(i => EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year - i);

    private void ToggleHeatYearMenu() => _heatYearMenuOpen = !_heatYearMenuOpen;

    private async Task PrevHeatYear()
    {
        _heatYearMenuOpen = false;
        _heatYear--;
        await LoadNpmDailyHeatmap(StallGuid);
    }

    private async Task NextHeatYear()
    {
        if (_heatYear >= EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year) return;
        _heatYearMenuOpen = false;
        _heatYear++;
        await LoadNpmDailyHeatmap(StallGuid);
    }

    private async Task PickHeatYear(int y)
    {
        _heatYearMenuOpen = false;
        if (y == _heatYear) return;
        _heatYear = y;
        await LoadNpmDailyHeatmap(StallGuid);
    }

    private async Task GoToCurrentHeatYear()
    {
        _heatYearMenuOpen = false;
        var cy = EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year;
        if (_heatYear == cy) return;
        _heatYear = cy;
        await LoadNpmDailyHeatmap(StallGuid);
    }

    // Year navigation for the monthly (non-NPM) 12-month payment grid.
    private int _monthlyYear = EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year;
    private bool _monthlyYearMenuOpen;
    private Dictionary<string, string> _monthlyStatus = new();   // "yyyy-MM" → Paid/Partial/Unpaid/Absent

    private void ToggleMonthlyYearMenu() => _monthlyYearMenuOpen = !_monthlyYearMenuOpen;

    private async Task PrevMonthlyYear()
    {
        _monthlyYearMenuOpen = false;
        _monthlyYear--;
        await LoadMonthlyYear(_monthlyYear);
    }

    private async Task NextMonthlyYear()
    {
        if (_monthlyYear >= EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year) return;
        _monthlyYearMenuOpen = false;
        _monthlyYear++;
        await LoadMonthlyYear(_monthlyYear);
    }

    private async Task PickMonthlyYear(int y)
    {
        _monthlyYearMenuOpen = false;
        if (y == _monthlyYear) return;
        _monthlyYear = y;
        await LoadMonthlyYear(y);
    }

    private async Task GoToCurrentMonthlyYear()
    {
        _monthlyYearMenuOpen = false;
        var cy = EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year;
        if (_monthlyYear == cy) return;
        _monthlyYear = cy;
        await LoadMonthlyYear(cy);
    }

    // Populate the monthly grid for a given year. The current year reuses the rolling history already
    // loaded (which preserves Absent/Excused detail); past years fetch each month's record in parallel.
    private async Task LoadMonthlyYear(int year)
    {
        if (year == EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year)
        {
            _monthlyStatus = new Dictionary<string, string>(Stall.PaymentHistory);
            return;
        }

        var tasks = Enumerable.Range(1, 12)
            .Select(m => PaymentsApi.GetPaymentRecordAsync(StallGuid, year, m))
            .ToArray();
        var results = await Task.WhenAll(tasks);

        var dict = new Dictionary<string, string>();
        for (var m = 1; m <= 12; m++)
        {
            var r = results[m - 1];
            if (r.IsSuccess && r.Value is not null)
            {
                dict[$"{year:0000}-{m:00}"] = r.Value.Status switch
                {
                    Domain.Enums.PaymentStatus.Paid => "Paid",
                    Domain.Enums.PaymentStatus.Partial => "Partial",
                    _ => "Unpaid"
                };
            }
        }
        _monthlyStatus = dict;
    }

    // Month abbreviation above the week where the month first changes (skips the clipped left edge).
    private string MonthLabel(int weekIndex)
    {
        if (weekIndex <= 0 || weekIndex >= _heatWeeks.Count) return "";
        var month = _heatWeeks[weekIndex][0].Date.Month;
        var prev = _heatWeeks[weekIndex - 1][0].Date.Month;
        return month != prev ? _heatWeeks[weekIndex][0].Date.ToString("MMM") : "";
    }

    private static string HeatLabel(string kind) => kind switch
    {
        "collected" => "Collected",
        "excused" => "Excused",
        "missed" => "Uncollected",
        "future" => "Upcoming",
        _ => "No obligation"
    };

    async Task SaveEdit()
    {
        IsSavingEdit = true;
        
        var fees = Domain.Enums.ApplicableFees.BaseRental;
        if (Stall.HasElectricity) fees |= Domain.Enums.ApplicableFees.Electricity;
        if (Stall.HasWater) fees |= Domain.Enums.ApplicableFees.Water;
        if (Stall.Section == "Fish Area") fees |= Domain.Enums.ApplicableFees.FishFee;
        
        var command = new UpdateStallCommand(
            StallGuid,
            Stall.MonthlyRate,
            fees,
            Stall.AreaSqm,
            Stall.AreaNote,
            null,
            Stall.ActualOccupant,
            Stall.ContractName,
            Stall.Remarks,
            Stall.ContractDate,
            Stall.ContractYears
        );
        
        var result = await StallsApi.UpdateStallAsync(StallGuid, command);
        
        if (result.IsSuccess)
        {
            ShowEditModal = false;
            await LoadStallData();
        }
        
        IsSavingEdit = false;
    }
}


