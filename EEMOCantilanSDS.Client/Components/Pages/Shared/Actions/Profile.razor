@page "/profile/{FacilityId}/{StallKey}"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using EEMOCantilanSDS.Application.Command.Stalls.UpdateStall
@using EEMOCantilanSDS.Application.Dtos.Stalls
@using EEMOCantilanSDS.Application.Dtos.Payments
@inject IStallsApiClient StallsApi
@inject IPaymentsApiClient PaymentsApi
@inject IFacilitiesApiClient FacilitiesApi
@inject IDailyCollectionApiClient DailyCollectionApi
@inject NavigationManager Navigation

<PageTitle>EEMO Admin — Stall Profile</PageTitle>

<!-- Topbar -->
<header class="topbar">
            <div class="topbar-left flex gap-2">
                <a href="javascript:history.back()" class="prof-back-btn">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div>
                    <div class="topbar-title">Stall Profile</div>
                    <div class="topbar-breadcrumb">
                        <a href="/menu" class="breadcrumb-link">Dashboard</a>
                        <span class="breadcrumb-sep">/</span>
                        <a href="/facility/@FacilityId.ToLower()" class="breadcrumb-link">@GetFacilityName(FacilityId)</a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">Stall @(Stall?.StallNo ?? DisplayStallNo)</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @PhilippineTime.Now.ToString("MMMM d, yyyy")
                </div>
                <AccountChip />
            </div>
        </header>

        <div class="content-area">

            @if (IsLoading)
            {
                <!-- Skeleton loading state (matches the real profile layout) -->
                <div class="prof-hero prof-hero-skel">
                    <div class="skel skel-hero-badge"></div>
                    <div class="prof-hero-identity" style="flex:1;">
                        <div class="skel skel-line" style="width:70px;height:11px;"></div>
                        <div class="skel skel-line" style="width:220px;height:24px;margin-top:10px;"></div>
                        <div class="skel skel-line" style="width:300px;height:14px;margin-top:14px;"></div>
                    </div>
                    <div class="prof-hero-actions">
                        <div class="skel skel-line" style="width:120px;height:38px;border-radius:9px;"></div>
                        <div class="skel skel-line" style="width:160px;height:38px;border-radius:9px;"></div>
                    </div>
                </div>

                <div class="prof-grid">
                    <div class="prof-col">
                        <div class="prof-card">
                            <div class="prof-card-header">
                                <div class="skel skel-chip"></div>
                                <div class="skel skel-line" style="width:140px;height:14px;"></div>
                            </div>
                            <div class="prof-field-list">
                                @for (var i = 0; i < 6; i++)
                                {
                                    <div class="prof-field skel-field">
                                        <div class="skel skel-line" style="width:120px;height:12px;"></div>
                                        <div class="skel skel-line" style="width:90px;height:12px;"></div>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="prof-card">
                            <div class="prof-card-header">
                                <div class="skel skel-chip"></div>
                                <div class="skel skel-line" style="width:160px;height:14px;"></div>
                            </div>
                            <div class="prof-field-list">
                                @for (var i = 0; i < 4; i++)
                                {
                                    <div class="prof-field skel-field">
                                        <div class="skel skel-line" style="width:130px;height:12px;"></div>
                                        <div class="skel skel-line" style="width:100px;height:12px;"></div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                    <div class="prof-col">
                        <div class="prof-card">
                            <div class="prof-card-header">
                                <div class="skel skel-chip"></div>
                                <div class="skel skel-line" style="width:180px;height:14px;"></div>
                                <div class="skel skel-line" style="width:120px;height:28px;border-radius:8px;margin-left:auto;"></div>
                            </div>
                            <div class="skel-body">
                                <div class="skel skel-line" style="width:210px;height:14px;margin-bottom:14px;"></div>
                                <div class="skel-heat">
                                    @for (var i = 0; i < 371; i++)
                                    {
                                        <span class="skel skel-heat-cell"></span>
                                    }
                                </div>
                                <div class="prof-hist-summary" style="margin-top:16px;">
                                    @for (var i = 0; i < 4; i++)
                                    {
                                        <div class="skel skel-line" style="height:58px;border-radius:10px;"></div>
                                    }
                                </div>
                            </div>
                        </div>
                        <div class="prof-card">
                            <div class="prof-card-header">
                                <div class="skel skel-chip"></div>
                                <div class="skel skel-line" style="width:150px;height:14px;"></div>
                            </div>
                            <div class="skel-body">
                                @for (var i = 0; i < 4; i++)
                                {
                                    <div class="skel skel-line" style="height:18px;margin-bottom:14px;"></div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
            else
            {

            <!-- -- Profile Hero -- -->
            <div class="prof-hero">
                <div class="prof-hero-badge">
                    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                </div>
                <div class="prof-hero-identity">
                    <div class="prof-hero-stall-no">Stall @Stall.StallNo</div>
                    <div class="prof-hero-name">@Stall.ActualOccupant</div>
                    <div class="prof-hero-meta">
                        <span class="prof-hero-chip">
                            <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                            @Stall.Facility@(Stall.Section != "No Location" ? " · " + Stall.Section : "")
                        </span>
                        <span class="prof-status-pill @(Stall.IsPaid ? "pill-paid" : Stall.IsPartial ? "pill-partial" : "pill-unpaid")">
                            @(Stall.IsPaid ? "Paid" : Stall.IsPartial ? "Partial" : "Unpaid")
                        </span>
                        <span class="prof-status-pill @(Stall.IsActive ? "pill-active" : "pill-inactive")">
                            @(Stall.IsActive ? "Active" : "Closed")
                        </span>
                    </div>
                </div>
                <div class="prof-hero-actions">
                    <button class="btn-outline" @onclick="() => ShowEditModal = true">
                        <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                        Edit Details
                    </button>
                    <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/reports/collections")'>
                        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /><polyline points="9 16 11 18 15 14" /></svg>
                        Manage Collection
                    </button>
                </div>
            </div>

            <!-- -- Main 2-col grid -- -->
            <div class="prof-grid">

                <!-- LEFT COL -->
                <div class="prof-col">

                    <!-- Stall Information -->
                    <div class="prof-card">
                        <div class="prof-card-header">
                            <div class="prof-card-icon">
                                <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /></svg>
                            </div>
                            <div class="prof-card-title">Stall Information</div>
                        </div>
                        <div class="prof-field-list">
                            <div class="prof-field">
                                <span class="prof-field-label">Facility</span>
                                <span class="prof-field-val">@Stall.Facility</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Stall / Space No.</span>
                                <span class="prof-field-val mono">@Stall.StallNo</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Section / Area</span>
                                <span class="prof-field-val">@Stall.Section</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Area (sq.m)</span>
                                <span class="prof-field-val">@(Stall.AreaSqm > 0 ? $"{Stall.AreaSqm} sqm" : "—")</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Area Location / Note</span>
                                <span class="prof-field-val">@(string.IsNullOrEmpty(Stall.AreaNote) ? "—" : Stall.AreaNote)</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Stall Status</span>
                                <span class="prof-status-pill @(Stall.IsActive ? "pill-active" : "pill-inactive")">
                                    @(Stall.IsActive ? "Active" : "Closed")
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Occupant & Contract -->
                    <div class="prof-card">
                        <div class="prof-card-header">
                            <div class="prof-card-icon">
                                <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                            </div>
                            <div class="prof-card-title">Occupant & Contract</div>
                        </div>
                        <div class="prof-field-list">
                            <div class="prof-field">
                                <span class="prof-field-label">Actual Occupant</span>
                                <span class="prof-field-val bold">@Stall.ActualOccupant</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Name on Contract</span>
                                <span class="prof-field-val">
                                    @if (string.IsNullOrEmpty(Stall.ContractName))
                                    {
                                        <span class="prof-no-contract">No contract on file</span>
                                    }
                                    else
                                    {

                                        @Stall.ContractName
                                    }
                                </span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Contract Effectivity Date</span>
                                <span class="prof-field-val">@(Stall.ContractDate.HasValue? Stall.ContractDate.Value.ToString("MMMM d, yyyy") : "—")</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Contract Duration</span>
                                <span class="prof-field-val">@Stall.ContractDuration</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Contract Expiry</span>
                                <span class="prof-field-val @(Stall.ContractExpiry.HasValue && Stall.ContractExpiry.Value < DateTime.Now.AddMonths(3) ? "text-warn" : "")">
                                    @(Stall.ContractExpiry.HasValue? Stall.ContractExpiry.Value.ToString("MMMM d, yyyy") : "—")
                                    @if (Stall.ContractExpiry.HasValue && Stall.ContractExpiry.Value < DateTime.Now.AddMonths(3))
                                    {
                                        <span class="prof-expiry-warn">Expiring soon</span>
                                    }
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Fees & Utilities -->
                    <div class="prof-card">
                        <div class="prof-card-header">
                            <div class="prof-card-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h7a4 4 0 0 1 0 8H6z" /><line x1="4" y1="9" x2="16" y2="9" /><line x1="4" y1="13" x2="16" y2="13" /><line x1="6" y1="4" x2="6" y2="20" /></svg>
                            </div>
                            <div class="prof-card-title">Fees & Utilities</div>
                        </div>
                        <div class="prof-field-list">
                            <div class="prof-field">
                                <span class="prof-field-label">Monthly Rental Rate</span>
                                <span class="prof-field-val bold gold">₱@Stall.MonthlyRate.ToString("N0")/month</span>
                            </div>
                            @if (FacilityId.ToUpper() == "NPM")
                            {
                                <div class="prof-field">
                                    <span class="prof-field-label">Electricity</span>
                                    <span class="prof-util-badge @(Stall.HasElectricity ? "util-yes" : "util-no")">
                                        @(Stall.HasElectricity ? "Included" : "N/A")
                                    </span>
                                </div>
                                <div class="prof-field">
                                    <span class="prof-field-label">Water</span>
                                    <span class="prof-util-badge @(Stall.HasWater ? "util-yes" : "util-no")">
                                        @(Stall.HasWater ? "Included" : "N/A")
                                    </span>
                                </div>
                            }
                        </div>

                        <!-- Total Bill Banner -->
                        <div class="prof-bill-banner">
                            <div>
                                <div class="prof-bill-label">Total Monthly Bill</div>
                                <div class="prof-bill-sub">
                                    @if (FacilityId.ToUpper() == "NPM")
                                    {
                                        @("Rental + Electricity + Water" + (Stall.Section == "Fish Area" ? " + Fish Fee" : ""))
                                    }
                                    else
                                    {
                                        @("Monthly Rental")
                                    }
                                </div>
                            </div>
                            <div class="prof-bill-val">₱@Stall.TotalBill.ToString("N0")</div>
                        </div>
                    </div>

                </div>

                <!-- RIGHT COL -->
                <div class="prof-col">

                    <!-- Collection history -->
                    <div class="prof-card">
                        <div class="prof-card-header">
                            <div class="prof-card-icon">
                                <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
                            </div>
                            <div class="prof-card-title">@(IsNpm ? "Daily Collection Activity" : "12-Month Payment History")</div>
                            @if (IsNpm)
                            {
                                <div class="ph-year-nav">
                                    <button class="ph-year-arrow" @onclick="PrevHeatYear" title="Previous year">
                                        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                                    </button>
                                    <div class="ph-year-picker">
                                        <button class="ph-year-btn @(_heatYearMenuOpen ? "open" : "")" @onclick="ToggleHeatYearMenu">
                                            <span>@_heatYear</span>
                                            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" /></svg>
                                        </button>
                                        @if (_heatYearMenuOpen)
                                        {
                                            <div class="ph-year-backdrop" @onclick="() => _heatYearMenuOpen = false"></div>
                                            <div class="ph-year-menu">
                                                <div class="ph-year-grid">
                                                    @foreach (var y in HeatYearOptions)
                                                    {
                                                        <button class="ph-year-cell @(y == _heatYear ? "active" : "")" @onclick="() => PickHeatYear(y)">@y</button>
                                                    }
                                                </div>
                                                <button class="ph-year-current" @onclick="GoToCurrentHeatYear">Go to current year</button>
                                            </div>
                                        }
                                    </div>
                                    <button class="ph-year-arrow" @onclick="NextHeatYear" disabled="@(_heatYear >= EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year)" title="Next year">
                                        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                                    </button>
                                </div>
                            }
                            else
                            {
                                <div class="ph-year-nav">
                                    <button class="ph-year-arrow" @onclick="PrevMonthlyYear" title="Previous year">
                                        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                                    </button>
                                    <div class="ph-year-picker">
                                        <button class="ph-year-btn @(_monthlyYearMenuOpen ? "open" : "")" @onclick="ToggleMonthlyYearMenu">
                                            <span>@_monthlyYear</span>
                                            <svg viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" /></svg>
                                        </button>
                                        @if (_monthlyYearMenuOpen)
                                        {
                                            <div class="ph-year-backdrop" @onclick="() => _monthlyYearMenuOpen = false"></div>
                                            <div class="ph-year-menu">
                                                <div class="ph-year-grid">
                                                    @foreach (var y in HeatYearOptions)
                                                    {
                                                        <button class="ph-year-cell @(y == _monthlyYear ? "active" : "")" @onclick="() => PickMonthlyYear(y)">@y</button>
                                                    }
                                                </div>
                                                <button class="ph-year-current" @onclick="GoToCurrentMonthlyYear">Go to current year</button>
                                            </div>
                                        }
                                    </div>
                                    <button class="ph-year-arrow" @onclick="NextMonthlyYear" disabled="@(_monthlyYear >= EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year)" title="Next year">
                                        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                                    </button>
                                </div>
                            }
                        </div>

                        @if (IsNpm)
                        {
                            <div class="ph-heat-head">@_heatCollected day@(_heatCollected == 1 ? "" : "s") collected @(_heatYear == EEMOCantilanSDS.Domain.Common.PhilippineTime.Today.Year ? "in the last year" : $"in {_heatYear}")</div>
                            <div class="ph-heat-scroll">
                                <div class="ph-heat-months">
                                    @for (var w = 0; w < _heatWeeks.Count; w++)
                                    {
                                        <span class="ph-heat-mcol">@MonthLabel(w)</span>
                                    }
                                </div>
                                <div class="ph-heat-body">
                                    <div class="ph-heat-dow">
                                        <span></span><span>Mon</span><span></span><span>Wed</span><span></span><span>Fri</span><span></span>
                                    </div>
                                    <div class="ph-heat-grid">
                                        @foreach (var wk in _heatWeeks)
                                        {
                                            @foreach (var cell in wk)
                                            {
                                                <span class="ph-cell ph-@cell.Kind" data-tip="@(HeatLabel(cell.Kind)) · @(cell.Date.ToString("MMMM d, yyyy"))"></span>
                                            }
                                        }
                                    </div>
                                </div>
                            </div>
                            <div class="ph-heat-legend">
                                <span class="ph-legend-item"><i class="ph-cell ph-collected"></i> Collected</span>
                                <span class="ph-legend-item"><i class="ph-cell ph-excused"></i> Excused</span>
                                <span class="ph-legend-item"><i class="ph-cell ph-missed"></i> Uncollected</span>
                                <span class="ph-legend-item"><i class="ph-cell ph-none"></i> No obligation</span>
                            </div>
                        }
                        else
                        {
                            <div class="prof-hist-grid">
                                @{
                                    var mToday = EEMOCantilanSDS.Domain.Common.PhilippineTime.Today;
                                    var contractStart = Stall.ContractDate.HasValue
                                        ? new DateTime(Stall.ContractDate.Value.Year, Stall.ContractDate.Value.Month, 1)
                                        : (DateTime?)null;
                                }
                                @for (int m = 1; m <= 12; m++)
                                {
                                    var month = new DateTime(_monthlyYear, m, 1);
                                    var key = month.ToString("yyyy-MM");
                                    var isFuture = _monthlyYear > mToday.Year || (_monthlyYear == mToday.Year && m > mToday.Month);
                                    var hasRecord = _monthlyStatus.TryGetValue(key, out var recordedStatus);
                                    var isBeforeContract = !hasRecord && contractStart.HasValue && month < contractStart.Value;
                                    var status = isFuture ? "Future" : isBeforeContract ? "N/A" : hasRecord ? recordedStatus : "Unpaid";
                                    var isCurrent = _monthlyYear == mToday.Year && m == mToday.Month;
                                    <div class="prof-hist-month @(isFuture ? "hist-future" : isBeforeContract ? "hist-na" : status == "Paid" ? "hist-paid" : status == "Partial" ? "hist-partial" : status == "Absent" ? "hist-absent" : "hist-unpaid") @(isCurrent ? "hist-current" : "")">
                                        <div class="prof-hist-month-name">@month.ToString("MMM")</div>
                                        <div class="prof-hist-month-year">@month.ToString("yy")</div>
                                        @if (isFuture)
                                        {
                                            <div class="prof-hist-icon">—</div>
                                        }
                                        else if (isBeforeContract)
                                        {
                                            <div class="prof-hist-icon">—</div>
                                        }
                                        else if (status == "Paid")
                                        {
                                            <div class="prof-hist-icon">✓</div>
                                        }
                                        else if (status == "Partial")
                                        {
                                            <div class="prof-hist-icon">
                                                <svg viewBox="0 0 24 24" style="width:14px;height:14px;">
                                                    <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
                                                    <path d="M12 2 A 10 10 0 0 1 12 22 Z" fill="currentColor"/>
                                                </svg>
                                            </div>
                                        }
                                        else if (status == "Absent")
                                        {
                                            <div class="prof-hist-icon">–</div>
                                        }
                                        else
                                        {
                                            <div class="prof-hist-icon">✗</div>
                                        }
                                    </div>
                                }
                            </div>
                        }

                        <div class="prof-hist-summary">
                            @{
                                var paidCount = Stall.LedgerSummary?.MonthsPaid ?? 0;
                                var unpaidCount = Stall.LedgerSummary?.MonthsUnpaid ?? 0;
                                var totalCollected = Stall.LedgerSummary?.TotalCollected ?? 0m;
                                var balanceDue = Stall.LedgerSummary?.TotalOutstanding ?? 0m;
                            }
                            @if (IsNpm)
                            {
                                <div class="prof-hist-stat">
                                    <div class="prof-hist-stat-val green">@_heatCollected</div>
                                    <div class="prof-hist-stat-key">Days Collected</div>
                                </div>
                                <div class="prof-hist-stat">
                                    <div class="prof-hist-stat-val red">@_heatMissed</div>
                                    <div class="prof-hist-stat-key">Days Uncollected</div>
                                </div>
                            }
                            else
                            {
                                <div class="prof-hist-stat">
                                    <div class="prof-hist-stat-val green">@paidCount</div>
                                    <div class="prof-hist-stat-key">Months Paid</div>
                                </div>
                                <div class="prof-hist-stat">
                                    <div class="prof-hist-stat-val red">@unpaidCount</div>
                                    <div class="prof-hist-stat-key">Months Unpaid</div>
                                </div>
                            }
                            <div class="prof-hist-stat">
                                <div class="prof-hist-stat-val">₱@totalCollected.ToString("N0")</div>
                                <div class="prof-hist-stat-key">Total Collected</div>
                            </div>
                            <div class="prof-hist-stat @(balanceDue > 0 ? "stat-warn" : "")">
                                <div class="prof-hist-stat-val red">₱@balanceDue.ToString("N0")</div>
                                <div class="prof-hist-stat-key">Balance Due</div>
                            </div>
                        </div>
                    </div>

                    <!-- Collection History (transparency log, cursor-paginated 10/page) -->
                    <div class="prof-card">
                        <div class="prof-card-header">
                            <div class="prof-card-icon">
                                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                            </div>
                            <div class="prof-card-title">Collection History</div>
                        </div>

                        @if (_historyLoading && _history.Count == 0)
                        {
                            <div class="prof-ch-state">Loading collection history…</div>
                        }
                        else if (_historyError && _history.Count == 0)
                        {
                            <div class="prof-ch-state">
                                Couldn't load collection history.
                                <button type="button" class="prof-ch-retry" @onclick="() => LoadHistory(true)" disabled="@_historyLoading">
                                    @(_historyLoading ? "Retrying…" : "Retry")
                                </button>
                            </div>
                        }
                        else if (_history.Count == 0)
                        {
                            <div class="prof-ch-state">No collections recorded yet.</div>
                        }
                        else
                        {
                            <div class="prof-ch-wrap">
                                <table class="prof-ch-table">
                                    <thead>
                                        <tr>
                                            <th>@(IsNpm ? "Date" : "Period")</th>
                                            <th>Name</th>
                                            <th>Status</th>
                                            <th class="prof-ch-r">Amount</th>
                                            <th>OR No.</th>
                                            <th>Collector</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var row in _history)
                                        {
                                            <tr>
                                                <td class="prof-ch-date">@row.Date.ToString(IsNpm ? "MMM d, yyyy" : "MMM yyyy")</td>
                                                <td>@row.PayorName</td>
                                                <td><span class="prof-ch-pill prof-ch-@row.Status.ToLowerInvariant()">@row.Status</span></td>
                                                <td class="prof-ch-r mono">@(row.Amount > 0 ? $"₱{row.Amount:N0}" : "—")</td>
                                                <td class="mono">@(string.IsNullOrWhiteSpace(row.ORNumber) ? "—" : row.ORNumber)</td>
                                                <td>@(string.IsNullOrWhiteSpace(row.CollectorName) ? "—" : row.CollectorName)</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                            @if (_historyHasMore)
                            {
                                <button type="button" class="prof-ch-more" @onclick="LoadMoreHistory" disabled="@_historyLoading">
                                    @(_historyLoading ? "Loading…" : "Load more")
                                </button>
                            }
                        }
                    </div>

                </div>
            </div>

            }

        </div><!-- end content-area -->


