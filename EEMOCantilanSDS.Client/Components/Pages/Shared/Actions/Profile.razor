@page "/profile/{FacilityId}/{StallKey}"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using EEMOCantilanSDS.Application.Command.Stalls.UpdateStall
@using EEMOCantilanSDS.Application.Dtos.Stalls
@using EEMOCantilanSDS.Application.Dtos.Payments
@inject IStallsApiClient StallsApi
@inject IPaymentsApiClient PaymentsApi
@inject IFacilitiesApiClient FacilitiesApi
@inject NavigationManager Navigation
@rendermode InteractiveServer

<PageTitle>EEMO Admin — Stall Profile</PageTitle>

<!-- Topbar -->
<header class="topbar">
            <div class="topbar-left flex gap-2">
                <a href="javascript:history.back()" class="prof-back-btn">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div>
                    <div class="topbar-title">Stall Profile</div>
                    <div class="topbar-breadcrumb">
                        <a href="/menu" class="breadcrumb-link">Dashboard</a>
                        <span class="breadcrumb-sep">/</span>
                        <a href="/facility/@FacilityId.ToLower()" class="breadcrumb-link">@GetFacilityName(FacilityId)</a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">Stall @(Stall?.StallNo ?? DisplayStallNo)</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <AccountChip />
            </div>
        </header>

        <div class="content-area">

            <!-- -- Profile Hero -- -->
            <div class="prof-hero">
                <div class="prof-hero-badge">
                    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                </div>
                <div class="prof-hero-identity">
                    <div class="prof-hero-stall-no">Stall @Stall.StallNo</div>
                    <div class="prof-hero-name">@Stall.ActualOccupant</div>
                    <div class="prof-hero-meta">
                        <span class="prof-hero-chip">
                            <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13S3 17 3 10a9 9 0 0118 0z" /><circle cx="12" cy="10" r="3" /></svg>
                            @Stall.Facility@(Stall.Section != "No Location" ? " · " + Stall.Section : "")
                        </span>
                        <span class="prof-status-pill @(Stall.IsPaid ? "pill-paid" : Stall.IsPartial ? "pill-partial" : "pill-unpaid")">
                            @(Stall.IsPaid ? "Paid" : Stall.IsPartial ? "Partial" : "Unpaid")
                        </span>
                        <span class="prof-status-pill @(Stall.IsActive ? "pill-active" : "pill-inactive")">
                            @(Stall.IsActive ? "Active" : "Closed")
                        </span>
                    </div>
                </div>
                <div class="prof-hero-actions">
                    <button class="btn-outline" @onclick="() => ShowEditModal = true">
                        <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                        Edit Details
                    </button>
                    <button class="btn-primary" @onclick='() => Navigation.NavigateTo("/reports/collections")'>
                        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /><polyline points="9 16 11 18 15 14" /></svg>
                        Manage Collection
                    </button>
                </div>
            </div>

            <!-- -- Main 2-col grid -- -->
            <div class="prof-grid">

                <!-- LEFT COL -->
                <div class="prof-col">

                    <!-- Stall Information -->
                    <div class="prof-card">
                        <div class="prof-card-header">
                            <div class="prof-card-icon">
                                <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /></svg>
                            </div>
                            <div class="prof-card-title">Stall Information</div>
                        </div>
                        <div class="prof-field-list">
                            <div class="prof-field">
                                <span class="prof-field-label">Facility</span>
                                <span class="prof-field-val">@Stall.Facility</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Stall / Space No.</span>
                                <span class="prof-field-val mono">@Stall.StallNo</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Section / Area</span>
                                <span class="prof-field-val">@Stall.Section</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Area (sq.m)</span>
                                <span class="prof-field-val">@(Stall.AreaSqm > 0 ? $"{Stall.AreaSqm} sqm" : "—")</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Area Location / Note</span>
                                <span class="prof-field-val">@(string.IsNullOrEmpty(Stall.AreaNote) ? "—" : Stall.AreaNote)</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Stall Status</span>
                                <span class="prof-status-pill @(Stall.IsActive ? "pill-active" : "pill-inactive")">
                                    @(Stall.IsActive ? "Active" : "Closed")
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Occupant & Contract -->
                    <div class="prof-card">
                        <div class="prof-card-header">
                            <div class="prof-card-icon">
                                <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                            </div>
                            <div class="prof-card-title">Occupant & Contract</div>
                        </div>
                        <div class="prof-field-list">
                            <div class="prof-field">
                                <span class="prof-field-label">Actual Occupant</span>
                                <span class="prof-field-val bold">@Stall.ActualOccupant</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Name on Contract</span>
                                <span class="prof-field-val">
                                    @if (string.IsNullOrEmpty(Stall.ContractName))
                                    {
                                        <span class="prof-no-contract">No contract on file</span>
                                    }
                                    else
                                    {

                                        @Stall.ContractName
                                    }
                                </span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Contract Effectivity Date</span>
                                <span class="prof-field-val">@(Stall.ContractDate.HasValue? Stall.ContractDate.Value.ToString("MMMM d, yyyy") : "—")</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Contract Duration</span>
                                <span class="prof-field-val">@Stall.ContractDuration</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Contract Expiry</span>
                                <span class="prof-field-val @(Stall.ContractExpiry.HasValue && Stall.ContractExpiry.Value < DateTime.Now.AddMonths(3) ? "text-warn" : "")">
                                    @(Stall.ContractExpiry.HasValue? Stall.ContractExpiry.Value.ToString("MMMM d, yyyy") : "—")
                                    @if (Stall.ContractExpiry.HasValue && Stall.ContractExpiry.Value < DateTime.Now.AddMonths(3))
                                    {
                                        <span class="prof-expiry-warn">Expiring soon</span>
                                    }
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- Fees & Utilities -->
                    <div class="prof-card">
                        <div class="prof-card-header">
                            <div class="prof-card-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h7a4 4 0 0 1 0 8H6z" /><line x1="4" y1="9" x2="16" y2="9" /><line x1="4" y1="13" x2="16" y2="13" /><line x1="6" y1="4" x2="6" y2="20" /></svg>
                            </div>
                            <div class="prof-card-title">Fees & Utilities</div>
                        </div>
                        <div class="prof-field-list">
                            <div class="prof-field">
                                <span class="prof-field-label">Monthly Rental Rate</span>
                                <span class="prof-field-val bold gold">₱@Stall.MonthlyRate.ToString("N0")/month</span>
                            </div>
                            @if (FacilityId.ToUpper() == "NPM")
                            {
                                <div class="prof-field">
                                    <span class="prof-field-label">Electricity</span>
                                    <span class="prof-util-badge @(Stall.HasElectricity ? "util-yes" : "util-no")">
                                        @(Stall.HasElectricity ? "Included" : "N/A")
                                    </span>
                                </div>
                                <div class="prof-field">
                                    <span class="prof-field-label">Water</span>
                                    <span class="prof-util-badge @(Stall.HasWater ? "util-yes" : "util-no")">
                                        @(Stall.HasWater ? "Included" : "N/A")
                                    </span>
                                </div>
                            }
                        </div>

                        <!-- Total Bill Banner -->
                        <div class="prof-bill-banner">
                            <div>
                                <div class="prof-bill-label">Total Monthly Bill</div>
                                <div class="prof-bill-sub">
                                    @if (FacilityId.ToUpper() == "NPM")
                                    {
                                        @("Rental + Electricity + Water" + (Stall.Section == "Fish Area" ? " + Fish Fee" : ""))
                                    }
                                    else
                                    {
                                        @("Monthly Rental")
                                    }
                                </div>
                            </div>
                            <div class="prof-bill-val">₱@Stall.TotalBill.ToString("N0")</div>
                        </div>
                    </div>

                </div>

                <!-- RIGHT COL -->
                <div class="prof-col">

                    <!-- This Month Status -->
                    <div class="prof-card">
                        <div class="prof-card-header">
                            <div class="prof-card-icon">
                                <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                            </div>
                            <div class="prof-card-title">@DateTime.Now.ToString("MMMM yyyy") — Payment Status</div>
                        </div>

                        <div class="prof-month-status @(Stall.IsPaid ? "month-paid" : Stall.IsPartial ? "month-partial" : "month-unpaid")">
                            <div class="prof-month-icon">
                                @if (Stall.IsPaid)
                                {
                                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                }
                                else if (Stall.IsPartial)
                                {
                                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/><path d="M12 2 A 10 10 0 0 1 12 22 Z" fill="currentColor"/></svg>
                                }
                                else
                                {
                                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                                }
                            </div>
                            <div>
                                <div class="prof-month-label">
                                    @(Stall.IsPaid ? "Fully Paid" : Stall.IsPartial ? "Partially Paid" : "Unpaid")
                                </div>
                                <div class="prof-month-sub">
                                    @if (Stall.IsPaid)
                                    {
                                        @($"₱{Stall.TotalBill:N0} settled")
                                    }
                                    else if (Stall.IsPartial)
                                    {
                                        @($"₱{Stall.PartialAmount:N0} paid · ₱{Stall.BalanceDue:N0} remaining")
                                    }
                                    else
                                    {
                                        @($"₱{Stall.TotalBill:N0} outstanding")
                                    }
                                </div>
                            </div>
                        </div>

                        <div class="prof-field-list" style="margin-top:12px;">
                            <div class="prof-field">
                                <span class="prof-field-label">OR Number</span>
                                <span class="prof-field-val mono">@(string.IsNullOrEmpty(Stall.ORNumber) ? "— Not issued" : Stall.ORNumber)</span>
                            </div>
                            <div class="prof-field">
                                <span class="prof-field-label">Assigned Collector</span>
                                <span class="prof-field-val">
                                    <svg viewBox="0 0 24 24" style="width:13px;height:13px;stroke:var(--text-muted);fill:none;stroke-width:2;vertical-align:middle;margin-right:4px;"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                    @(string.IsNullOrEmpty(Stall.CollectorName) ? "—" : Stall.CollectorName)
                                </span>
                            </div>
                        </div>
                    </div>

                    <!-- 12-Month Payment History -->
                    <div class="prof-card">
                        <div class="prof-card-header">
                            <div class="prof-card-icon">
                                <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12" /></svg>
                            </div>
                            <div class="prof-card-title">12-Month Payment History</div>
                        </div>

                        <div class="prof-hist-grid">
                            @for (int i = 11; i >= 0; i--)
                            {
                                var month = DateTime.Now.AddMonths(-i);
                                var key = month.ToString("yyyy-MM");
                                var contractStart = Stall.ContractDate.HasValue
                                    ? new DateTime(Stall.ContractDate.Value.Year, Stall.ContractDate.Value.Month, 1)
                                    : (DateTime?)null;
                                var hasRecord = Stall.PaymentHistory.TryGetValue(key, out var recordedStatus);
                                var isBeforeContract = !hasRecord && contractStart.HasValue && month < contractStart.Value;
                                var status = isBeforeContract ? "N/A" : hasRecord ? recordedStatus : "Unpaid";
                                var isCurrent = i == 0;
                                <div class="prof-hist-month @(isBeforeContract ? "hist-na" : status == "Paid" ? "hist-paid" : status == "Partial" ? "hist-partial" : status == "Absent" ? "hist-absent" : "hist-unpaid") @(isCurrent ? "hist-current" : "")">
                                    <div class="prof-hist-month-name">@month.ToString("MMM")</div>
                                    <div class="prof-hist-month-year">@month.ToString("yy")</div>
                                    @if (isBeforeContract)
                                    {
                                        <div class="prof-hist-icon">—</div>
                                    }
                                    else if (status == "Paid")
                                    {
                                        <div class="prof-hist-icon">✓</div>
                                    }
                                    else if (status == "Partial")
                                    {
                                        <div class="prof-hist-icon">
                                            <svg viewBox="0 0 24 24" style="width:14px;height:14px;">
                                                <circle cx="12" cy="12" r="10" fill="none" stroke="currentColor" stroke-width="2"/>
                                                <path d="M12 2 A 10 10 0 0 1 12 22 Z" fill="currentColor"/>
                                            </svg>
                                        </div>
                                    }
                                    else if (status == "Absent")
                                    {
                                        <div class="prof-hist-icon">–</div>
                                    }
                                    else
                                    {
                                        <div class="prof-hist-icon">✗</div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="prof-hist-summary">
                            @{
                                var paidCount = Stall.LedgerSummary?.MonthsPaid ?? 0;
                                var unpaidCount = Stall.LedgerSummary?.MonthsUnpaid ?? 0;
                                var totalCollected = Stall.LedgerSummary?.TotalCollected ?? 0m;
                                var balanceDue = Stall.LedgerSummary?.TotalOutstanding ?? 0m;
                            }
                            <div class="prof-hist-stat">
                                <div class="prof-hist-stat-val green">@paidCount</div>
                                <div class="prof-hist-stat-key">Months Paid</div>
                            </div>
                            <div class="prof-hist-stat">
                                <div class="prof-hist-stat-val red">@unpaidCount</div>
                                <div class="prof-hist-stat-key">Months Unpaid</div>
                            </div>
                            <div class="prof-hist-stat">
                                <div class="prof-hist-stat-val">₱@totalCollected.ToString("N0")</div>
                                <div class="prof-hist-stat-key">Total Collected</div>
                            </div>
                            <div class="prof-hist-stat @(balanceDue > 0 ? "stat-warn" : "")">
                                <div class="prof-hist-stat-val red">₱@balanceDue.ToString("N0")</div>
                                <div class="prof-hist-stat-key">Balance Due</div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

        </div><!-- end content-area -->


<!-- ----------------------------------------------
     EDIT MODAL (placeholder)
---------------------------------------------- -->
@if (ShowEditModal)
{
    <div class="eemo-modal-overlay" @onclick="() => ShowEditModal = false">
        <div class="eemo-modal eemo-modal-wide" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div>
                    <div class="eemo-modal-title">Edit Stall Details</div>
                    <div class="eemo-modal-sub">Stall @Stall.StallNo · @Stall.ActualOccupant</div>
                </div>
                <button class="eemo-modal-close" @onclick="() => ShowEditModal = false">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="eemo-modal-body">
                <div class="edit-form-grid">
                    <div class="form-group">
                        <label class="form-label">Facility</label>
                        <input class="form-input" type="text" value="@Stall.Facility" readonly title="Facility cannot be changed here" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stall / Space No.</label>
                        <input class="form-input" type="text" value="@Stall.StallNo" readonly title="Stall number cannot be changed here" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Section / Area</label>
                        <input class="form-input" type="text" value="@Stall.Section" readonly title="Section cannot be changed here" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Area (sq.m)</label>
                        <input class="form-input" type="number" @bind="Stall.AreaSqm" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Actual Occupant <span class="req">*</span></label>
                        <input class="form-input" type="text" @bind="Stall.ActualOccupant" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Name on Contract</label>
                        <input class="form-input" type="text" @bind="Stall.ContractName" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contract Effectivity Date</label>
                        <input class="form-input" type="date"
                               value="@Stall.ContractDate?.ToString("yyyy-MM-dd")"
                               @onchange="e => Stall.ContractDate = DateTime.TryParse(e.Value?.ToString(), out var d) ? d : Stall.ContractDate" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contract Duration (years)</label>
                        <select class="form-input" @bind="Stall.ContractYears">
                            <option value="0">No contract</option>
                            <option value="1">1 year</option>
                            <option value="2">2 years</option>
                            <option value="3">3 years</option>
                            <option value="5">5 years</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Monthly Rental Rate (₱) <span class="req">*</span></label>
                        <input class="form-input" type="number" @bind="Stall.MonthlyRate" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Area Location / Note</label>
                        <input class="form-input" type="text" @bind="Stall.AreaNote" placeholder="e.g. Corner slot, near entrance" />
                    </div>
                </div>
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="() => ShowEditModal = false" disabled="@IsSavingEdit">Cancel</button>
                <button class="btn-primary @(IsSavingEdit ? "btn-loading" : "")" @onclick="SaveEdit" disabled="@IsSavingEdit">
                    @if (IsSavingEdit)
                    {
                        <span class="spinner"></span>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <span>Save Changes</span>
                    }
                </button>
            </div>
        </div>
    </div>
}


<!-- ----------------------------------------------
     RECORD PAYMENT — removed. Collection (per-day NPM, per-month TCC/NCC/ICE/BBQ,
     Excused, and market closures) is now managed centrally in the Collection Manager
     (/reports/collections). The hero "Manage Collection" button links there.
---------------------------------------------- -->


@code {

    [Parameter]
    public string FacilityId { get; set; } = string.Empty;

    [Parameter]
    public string StallKey { get; set; } = string.Empty;

    bool ShowEditModal = false;
    bool IsSavingEdit = false;
    bool IsLoading = true;
    Guid StallGuid = Guid.Empty;
    string DisplayStallNo = string.Empty;

    class StallProfile
    {
        public string Facility { get; set; } = string.Empty;
        public string StallNo { get; set; } = string.Empty;
        public string Section { get; set; } = string.Empty;
        public double AreaSqm { get; set; }
        public string AreaNote { get; set; } = string.Empty;
        public string ActualOccupant { get; set; } = string.Empty;
        public string ContractName { get; set; } = string.Empty;
        public DateTime? ContractDate { get; set; }
        public string ContractDuration { get; set; } = string.Empty;
        public int ContractYears { get; set; }
        public DateTime? ContractExpiry { get; set; }
        public decimal MonthlyRate { get; set; }
        public decimal? DailyRate { get; set; }
        public bool HasElectricity { get; set; }
        public decimal ElecReading { get; set; }
        public decimal ElecAmount { get; set; }
        public bool HasWater { get; set; }
        public decimal WaterReading { get; set; }
        public decimal WaterAmount { get; set; }
        public decimal FishKilos { get; set; }
        public decimal FishFee => Section == "Fish Area" ? FishKilos : 0;
        public decimal TotalBill => MonthlyRate + ElecAmount + WaterAmount + FishFee;
        public bool IsPaid { get; set; }
        public bool IsPartial { get; set; }
        public decimal PartialAmount { get; set; }
        public decimal TotalPaid => IsPaid ? TotalBill : IsPartial ? PartialAmount : 0;
        public decimal BalanceDue => TotalBill - TotalPaid;
        public bool IsActive { get; set; } = true;
        public string ORNumber { get; set; } = string.Empty;
        public string CollectorName { get; set; } = string.Empty;
        public string Remarks { get; set; } = string.Empty;
        public Dictionary<string, string> PaymentHistory { get; set; } = new();
        // Authoritative daily-aware rolling 12-month ledger totals (from the server).
        public StallLedgerSummaryDto? LedgerSummary { get; set; }
    }

    StallProfile Stall = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadStallData();
    }

    async Task LoadStallData()
    {
        IsLoading = true;
        
        // Parse facility code from URL parameter
        var facilityCode = FacilityId.ToUpper() switch
        {
            "NPM" => Domain.Enums.FacilityCode.NPM,
            "TCC" => Domain.Enums.FacilityCode.TCC,
            "NCC" => Domain.Enums.FacilityCode.NCC,
            "BBQ" => Domain.Enums.FacilityCode.BBQ,
            "ICE" => Domain.Enums.FacilityCode.ICE,
            "SLH" => Domain.Enums.FacilityCode.SLH,
            _ => Domain.Enums.FacilityCode.NPM
        };

        // Load stalls from API
        var stallsResult = await StallsApi.GetStallsByFacilityPaginatedAsync(facilityCode, null, null, 100);
        
        if (stallsResult.IsSuccess && stallsResult.Value != null)
        {
            var stallDto = Guid.TryParse(StallKey, out var keyId)
                ? stallsResult.Value.Items.FirstOrDefault(s => s.Id == keyId)
                : stallsResult.Value.Items.FirstOrDefault(s => s.StallNo == StallKey);
            
            if (stallDto != null)
            {
                StallGuid = stallDto.Id;
                DisplayStallNo = stallDto.StallNo;
                
                // Load payment history
                var historyResult = await PaymentsApi.GetPaymentHistoryAsync(stallDto.Id);
                var paymentHistory = new Dictionary<string, string>();
                
                if (historyResult.IsSuccess && historyResult.Value != null)
                {
                    foreach (var payment in historyResult.Value)
                    {
                        paymentHistory[payment.Period] = payment.IsExcused ? "Absent"
                            : payment.Status == Domain.Enums.PaymentStatus.Paid ? "Paid" 
                            : payment.Status == Domain.Enums.PaymentStatus.Partial ? "Partial" 
                            : "Unpaid";
                    }
                }
                
                // Load current month payment record
                var currentPaymentResult = await PaymentsApi.GetPaymentRecordAsync(
                    stallDto.Id,
                    DateTime.Now.Year,
                    DateTime.Now.Month);
                
                // Handle 404 - no payment record exists yet for current month
                bool isPaid = false;
                bool isPartial = false;
                decimal partialAmount = 0;
                decimal elecAmount = 0;
                decimal waterAmount = 0;
                string orNumber = string.Empty;
                
                if (currentPaymentResult.IsSuccess && currentPaymentResult.Value != null)
                {
                    isPaid = currentPaymentResult.Value.Status == Domain.Enums.PaymentStatus.Paid;
                    isPartial = currentPaymentResult.Value.Status == Domain.Enums.PaymentStatus.Partial;
                    partialAmount = isPartial ? currentPaymentResult.Value.TotalPaid : 0;
                    elecAmount = currentPaymentResult.Value.ElecAmount ?? 0;
                    waterAmount = currentPaymentResult.Value.WaterAmount ?? 0;
                    orNumber = currentPaymentResult.Value.ORNumber ?? string.Empty;
                }

                // NPM is collected daily, so the true status comes from the daily-aware report
                // compliance (a vendor who paid some days is Partial — the monthly PaymentRecord
                // alone would read Unpaid). Mirrors the NPM facility page / payment modal.
                if (FacilityId.ToUpper() == "NPM")
                {
                    var reportResult = await FacilitiesApi.GetFacilityReportsAsync(
                        facilityCode, Domain.Enums.ReportPeriod.Monthly, DateTime.Now.Year, DateTime.Now.Month);
                    var compliance = reportResult.IsSuccess
                        ? reportResult.Value?.StallCompliance?.FirstOrDefault(c => c.StallId == StallGuid)
                        : null;
                    if (compliance != null)
                    {
                        isPaid = compliance.Status == "Paid";
                        isPartial = compliance.Status == "Partial";
                        partialAmount = compliance.AmountPaid;
                        if (!string.IsNullOrWhiteSpace(compliance.ORNumber))
                            orNumber = compliance.ORNumber!;
                    }
                }
                
                var section = stallDto.Section switch
                {
                    Domain.Enums.MarketSection.VegetableArea => "Vegetable Area",
                    Domain.Enums.MarketSection.FishSection => "Fish Area",
                    Domain.Enums.MarketSection.MeatSection => "Meat Area",
                    _ => stallDto.AreaLocation switch
                    {
                        Domain.Enums.NccAreaLocation.Extension => "Extension",
                        Domain.Enums.NccAreaLocation.Corner => "Corner",
                        _ => "No Location"
                    }
                };
                
                var hasElec = FacilityId.ToUpper() == "NPM";
                var hasWater = FacilityId.ToUpper() == "NPM";
                
                Stall = new()
                {
                    Facility = GetFacilityName(FacilityId),
                    StallNo = stallDto.StallNo,
                    Section = section,
                    AreaSqm = stallDto.AreaSqm ?? 0,
                    AreaNote = stallDto.AreaNote ?? string.Empty,
                    ActualOccupant = stallDto.ActualOccupant ?? "N/A",
                    ContractName = stallDto.NameOnContract ?? "N/A",
                    ContractDate = stallDto.ContractDate,
                    ContractDuration = stallDto.ContractYears > 0 ? $"{stallDto.ContractYears} year{(stallDto.ContractYears > 1 ? "s" : "")}" : "—",
                    ContractYears = stallDto.ContractYears,
                    ContractExpiry = stallDto.ContractYears > 0 ? stallDto.ContractDate?.AddYears(stallDto.ContractYears) : null,
                    MonthlyRate = stallDto.MonthlyRate,
                    DailyRate = stallDto.DailyRate,
                    HasElectricity = hasElec,
                    ElecReading = 0,
                    ElecAmount = elecAmount,
                    HasWater = hasWater,
                    WaterReading = 0,
                    WaterAmount = waterAmount,
                    FishKilos = 0,
                    IsPaid = isPaid,
                    IsPartial = isPartial,
                    PartialAmount = partialAmount,
                    IsActive = stallDto.Status == Domain.Enums.StallStatus.Active,
                    ORNumber = orNumber,
                    CollectorName = string.Empty,
                    Remarks = stallDto.Remarks ?? string.Empty,
                    PaymentHistory = paymentHistory,
                    LedgerSummary = (await PaymentsApi.GetStallLedgerSummaryAsync(stallDto.Id)).Value
                };
            }
            else
            {
                // Stall not found, redirect back
                Navigation.NavigateTo("/facility/" + FacilityId.ToLower());
            }
        }
        
        IsLoading = false;
    }

    string GetFacilityName(string facilityId)
    {
        return facilityId.ToLower() switch
        {
            // From Report.razor (lowercase)
            "npm" => "New Public Market",
            "tcc" => "Tampak Commercial Center",
            "ncc" => "New Commercial Center",
            "bbq" => "Barbecue Stand",
            "ice" => "Iceplant",
            "slh" => "Slaughterhouse",

            // From facility pages (uppercase/mixed case)
            "npm-annex" => "New Public Market Annex",
            "public-market-1" => "Public Market 1",
            "public-market-2" => "Public Market 2",
            _ => "Unknown Facility"
        };
    }

    async Task SaveEdit()
    {
        IsSavingEdit = true;
        
        var fees = Domain.Enums.ApplicableFees.BaseRental;
        if (Stall.HasElectricity) fees |= Domain.Enums.ApplicableFees.Electricity;
        if (Stall.HasWater) fees |= Domain.Enums.ApplicableFees.Water;
        if (Stall.Section == "Fish Area") fees |= Domain.Enums.ApplicableFees.FishFee;
        
        var command = new UpdateStallCommand(
            StallGuid,
            Stall.MonthlyRate,
            fees,
            Stall.AreaSqm,
            Stall.AreaNote,
            null,
            Stall.ActualOccupant,
            Stall.ContractName,
            Stall.Remarks,
            Stall.ContractDate,
            Stall.ContractYears
        );
        
        var result = await StallsApi.UpdateStallAsync(StallGuid, command);
        
        if (result.IsSuccess)
        {
            ShowEditModal = false;
            await LoadStallData();
        }
        
        IsSavingEdit = false;
    }
}


