@page "/collectors"

@using EEMOCantilanSDS.Application.Command.Collectors.CreateCollector
@using EEMOCantilanSDS.Application.Command.Collectors.UpdateCollector
@using EEMOCantilanSDS.Application.Dtos
@using EEMOCantilanSDS.Application.Dtos.Settings
@using EEMOCantilanSDS.Domain.Enums
@using Microsoft.AspNetCore.Authorization
@inject ICollectorsApiClient CollectorsApi
@inject EEMOCantilanSDS.Client.Services.FacilityState FacilityCatalog
@inject Microsoft.JSInterop.IJSRuntime JS
@attribute [Authorize(Roles = "SuperAdmin")]
<PageTitle>@Branding.OfficeAcronym Admin — Collectors</PageTitle>

<header class="topbar">
            <div class="topbar-left">
                <div class="topbar-title">Collectors</div>
                <div class="topbar-breadcrumb">
                    <span>@Branding.OfficeAcronym Admin</span>
                    <span class="breadcrumb-sep">/</span>
                    <span class="breadcrumb-active">Collectors</span>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @_now.ToString("MMMM d, yyyy")
                </div>
                <AccountChip />
            </div>
        </header>

        <div class="content-area">

            <!-- Collector Hero Banner -->
            <div class="vs-hero">

                <div class="vs-hero-left">
                    <div class="vs-hero-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                            <circle cx="9" cy="7" r="4" />
                            <path d="M23 21v-2a4 4 0 00-3-3.87" />
                            <path d="M16 3.13a4 4 0 010 7.75" />
                        </svg>
                    </div>
                    <div>
                        <div class="vs-hero-eyebrow">@Branding.OfficeAcronym Admin · Collectors</div>
                        <div class="vs-hero-title">Revenue Collectors</div>
                        <div class="vs-hero-sub">Collection Period: @_now.ToString("MMMM yyyy")</div>
                    </div>
                </div>
                <div class="vs-hero-stats">
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">@(Collectors?.Count ?? 0)</div>
                        <div class="vs-hero-key">Total Collectors</div>
                        <div class="vs-hero-sub2">@(Collectors?.Count(c => c.IsActive) ?? 0) active</div>
                    </div>
                    <div class="vs-hero-divider"></div>
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">₱@((Collectors?.Sum(c => c.CollectedThisMonth) ?? 0).ToString("N0"))</div>
                        <div class="vs-hero-key">Total Collected</div>
                        <div class="vs-hero-sub2">@_now.ToString("MMMM yyyy")</div>
                    </div>
                    <div class="vs-hero-divider"></div>
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">@(Collectors?.Sum(c => c.AssignedFacilities.Count) ?? 0)</div>
                        <div class="vs-hero-key">Facility Assignments</div>
                        <div class="vs-hero-sub2">Across all collectors</div>
                    </div>
                    <div class="vs-hero-divider"></div>
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">@(Collectors?.Count(c => !c.IsActive) ?? 0)</div>
                        <div class="vs-hero-key">Inactive Accounts</div>
                        <div class="vs-hero-sub2">Deactivated or suspended</div>
                    </div>
                </div>
                <div class="vs-hero-progress">
                    @{
                        var collectorCount = Collectors?.Count ?? 0;
                        var activeRate = collectorCount > 0 ? ((Collectors!.Count(c => c.IsActive) * 100) / collectorCount) : 0;
                    }
                    <div class="vs-hero-progress-fill" style="width: @activeRate%;"></div>
                </div>
            </div>

            <!-- Toolbar -->
            <div class="page-toolbar">
                <div class="toolbar-left">
                    <div class="search-box">
                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                        <input type="text"
                               placeholder="Search name, ID, facility…"
                               @bind="SearchQuery"
                               @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(SearchQuery))
                        {
                            <span class="search-clear" @onclick="() => SearchQuery = string.Empty">×</span>
                        }
                    </div>
                    <div class="filter-tabs">
                        @foreach (var f in StatusFilters)
                        {
                            <div class="filter-tab @(ActiveFilter == f ? "active" : "")"
                                 @onclick="() => ActiveFilter = f">
                                @f
                            </div>
                        }
                    </div>
                </div>
                <div class="toolbar-actions" style="display:flex; gap:10px;">
                    <button class="btn-ghost" @onclick="OpenAppLink">
                        <svg viewBox="0 0 24 24"><rect x="5" y="2" width="14" height="20" rx="2" /><line x1="12" y1="18" x2="12.01" y2="18" /></svg>
                        Collector app link
                    </button>
                    <button class="btn-primary" @onclick="OpenCreate">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Add Collector
                    </button>
                </div>
            </div>

            <!-- Collectors Table -->
            <div class="panel">
                <div class="panel-header">
                    <div class="panel-title">Collector Accounts</div>
                    <div class="panel-count">@(_loading ? "Loading" : $"{FilteredCollectors.Count()} records")</div>
                </div>

                @if (_loading)
                {
                    <div class="table-wrap collector-loading-table" aria-busy="true" aria-label="Loading collector accounts">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Collector</th>
                                    <th>Employee ID</th>
                                    <th>Assigned Facilities</th>
                                    <th>Collected (This Month)</th>
                                    <th>Transactions</th>
                                    <th>Last Active</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (var i = 0; i < 6; i++)
                                {
                                    <tr>
                                        <td>
                                            <div class="collector-cell">
                                                <Skeleton Width="34px" Height="34px" Radius="999px" />
                                                <div class="collector-loading-name">
                                                    <Skeleton Width="130px" Height="12px" Radius="6px" />
                                                    <Skeleton Width="180px" Height="10px" Radius="5px" />
                                                </div>
                                            </div>
                                        </td>
                                        <td><Skeleton Width="76px" Height="12px" Radius="6px" /></td>
                                        <td>
                                            <div class="facility-tags">
                                                <Skeleton Width="42px" Height="18px" Radius="5px" />
                                                <Skeleton Width="42px" Height="18px" Radius="5px" />
                                                <Skeleton Width="42px" Height="18px" Radius="5px" />
                                            </div>
                                        </td>
                                        <td><Skeleton Width="86px" Height="12px" Radius="6px" /></td>
                                        <td><Skeleton Width="44px" Height="12px" Radius="6px" /></td>
                                        <td><Skeleton Width="92px" Height="12px" Radius="6px" /></td>
                                        <td>
                                            <div class="action-btns">
                                                <Skeleton Width="30px" Height="30px" Radius="7px" />
                                                <Skeleton Width="30px" Height="30px" Radius="7px" />
                                                <Skeleton Width="30px" Height="30px" Radius="7px" />
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else if (!FilteredCollectors.Any())
                {
                    <div class="empty-state">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                        <div class="empty-title">No Collectors Found</div>
                        <div class="empty-sub">Try adjusting your search or filter.</div>
                    </div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Collector</th>
                                    <th>Employee ID</th>
                                    <th>Assigned Facilities</th>
                                    <th>Collected (This Month)</th>
                                    <th>Transactions</th>
                                    <th>Last Active</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var c in FilteredCollectors)
                                {
                                    <tr class="@(!c.IsActive ? "row-inactive" : "")">
                                        <td>
                                            <div class="collector-cell">

                                                <div>
                                                    <div>@c.FullName</div>
                                                    <div class="collector-email">@c.Email</div>
                                                </div>
                                            </div>
                                        </td>
                                        <td><span>@c.EmployeeId</span></td>
                                        <td>
                                            <div class="facility-tags">
                                                @foreach (var f in c.AssignedFacilities)
                                                {
                                                    <span>@f</span>
                                                }
                                            </div>
                                        </td>
                                        <td>
                                            <span>₱@c.CollectedThisMonth.ToString("N0")</span>
                                        </td>
                                        <td>@c.Transactions</td>
                                        <td>@(c.LastActiveAt?.ToString("MMM d, yyyy") ?? "Never")</td>
                                        <td>
                                            <div class="action-btns">
                                                <button class="action-btn" title="Edit" @onclick="() => OpenEdit(c)">
                                                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                                                </button>
                                                <button class="action-btn" title="View Activity" @onclick="() => OpenActivity(c)">
                                                    <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                                                </button>
                                                <button class="action-btn" title="Send message" @onclick="() => OpenMessage(c)">
                                                    <svg viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13" /><polygon points="22 2 15 22 11 13 2 9 22 2" /></svg>
                                                </button>
                                                <button class="action-btn @(c.IsActive ? "action-danger" : "action-success")"
                                                        title="@(c.IsActive ? "Deactivate" : "Activate")"
                                                        @onclick="() => ToggleStatus(c)">
                                                    @if (c.IsActive)
                                                    {
                                                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                                                    }
                                                    else
                                                    {
                                                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                                    }
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>


<!-- ══════════════════════════════════════════════
     CREATE / EDIT MODAL (RIGHT-SIDE DRAWER)
══════════════════════════════════════════════ -->
<div class="eemo-drawer-overlay @(ShowModal ? "show" : "")" @onclick="CloseModal"></div>

<div class="eemo-drawer eemo-drawer-right @(ShowModal ? "show" : "")" @onclick:stopPropagation="true">

    <!-- ── Header ──────────────────────────────────────────────── -->
    <div class="eemo-drawer-header">
        <div class="eemo-drawer-header-left">
            <div class="eemo-drawer-header-icon">
                <svg viewBox="0 0 24 24">
                    @if (IsEditing)
                    {
                        <path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
                        <path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
                    }
                    else
                    {
                        <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 00-3-3.87" />
                        <path d="M16 3.13a4 4 0 010 7.75" />
                    }
                </svg>
            </div>
            <div>
                <div class="eemo-drawer-header-title">@(IsEditing ? "Edit Collector" : "Add New Collector")</div>
                <div class="eemo-drawer-header-sub">@(IsEditing ? "Update collector account information." : "Create a new collector account for field collection.")</div>
            </div>
        </div>
        <button class="eemo-drawer-header-close" @onclick="CloseModal">
            <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
        </button>
    </div>

    <!-- ── Body ───────────────────────────────────────────────── -->
    <div class="eemo-modal-body">
                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label">Full Name <span class="req">*</span></label>
                        <input class="form-input" type="text" placeholder="e.g. Juan dela Cruz"
                               @bind="Form.FullName" @bind:event="oninput" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Employee ID <span class="req">*</span></label>
                        <input class="form-input" type="text" placeholder="e.g. EMP-2025-001"
                               @bind="Form.EmployeeId" @bind:event="oninput" />
                    </div>
                </div>

                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label">Contact Number</label>
                        <input class="form-input" type="tel" placeholder="e.g. 09536939296"
                               @bind="Form.ContactNumber" @bind:event="oninput"
                               maxlength="16" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <input class="form-input" type="email" placeholder="collector@lgu.gov.ph"
                               @bind="Form.Email" @bind:event="oninput" />
                    </div>
                </div>

                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label">Username <span class="req">@(IsEditing ? "" : "*")</span></label>
                        <input class="form-input" type="text" placeholder="Login username"
                               @bind="Form.Username" @bind:event="oninput" readonly="@IsEditing" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">
                            @(IsEditing ? "New Password" : "Password") <span class="req">@(IsEditing ? "" : "*")</span>
                        </label>
                        <input class="form-input" type="password"
                               placeholder="@(IsEditing ? "Leave blank to keep current" : "Set initial password")"
                               @bind="Form.Password" @bind:event="oninput" />
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label">Assigned Facilities <span class="req">*</span></label>
                    <div class="facility-checkboxes">
                        @foreach (var fac in AvailableFacilities)
                        {
                            var isChecked = Form.AssignedFacilities.Contains(fac.Code);
                            <div class="fac-checkbox @(isChecked ? "checked" : "")"
                                 @onclick="() => ToggleFacility(fac.Code)">
                                <div class="fac-check-box">
                                    @if (isChecked)
                                    {
                                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                    }
                                </div>
                                <span class="code-badge">@fac.Code</span>
                                <span class="fac-check-name">@fac.Name</span>
                            </div>
                        }
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(FormError))
                {
                    <div class="form-error">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                        @FormError
                    </div>
                }
    </div><!-- /eemo-modal-body -->

    <!-- ── Footer ──────────────────────────────────────────────── -->
    <div class="eemo-drawer-footer">
        <button class="btn-ghost" @onclick="CloseModal">Cancel</button>
        <button class="btn-primary" @onclick="SaveCollector">
            @(IsEditing ? "Save Changes" : "Create Account")
        </button>
    </div>

</div>


<!-- ══════════════════════════════════════════════
     ACTIVITY MODAL
══════════════════════════════════════════════ -->
@if (ShowActivity && ActivityCollector is not null)
{
    <div class="eemo-modal-overlay" @onclick="() => ShowActivity = false">
        <div class="eemo-modal eemo-modal-wide" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div>
                    <div class="eemo-modal-title">@ActivityCollector.FullName</div>
                    <div class="eemo-modal-sub">Activity — @_now.ToString("MMMM yyyy")</div>
                </div>
                <button class="eemo-modal-close" @onclick="() => ShowActivity = false">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="eemo-modal-body">
                @if (ActivityDetails is not null)
                {
                    <div class="activity-stats">
                        <div class="act-stat">
                            <div class="act-stat-val">₱@ActivityDetails.CollectedThisMonth.ToString("N0")</div>
                            <div class="act-stat-key">Collected This Month</div>
                        </div>
                        <div class="act-stat">
                            <div class="act-stat-val">@ActivityDetails.Transactions</div>
                            <div class="act-stat-key">Transactions</div>
                        </div>
                        <div class="act-stat">
                            <div class="act-stat-val">@ActivityDetails.FacilitiesCount</div>
                            <div class="act-stat-key">Facilities</div>
                        </div>
                        <div class="act-stat">
                            <div class="act-stat-val">@(ActivityDetails.LastActiveAt?.ToString("MMM d") ?? "Never")</div>
                            <div class="act-stat-key">Last Active</div>
                        </div>
                    </div>

                    <div class="act-section-label">Recent Transactions</div>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>OR #</th>
                                <th>Payor</th>
                                <th>Facility</th>
                                <th>Nature</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Date &amp; Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in ActivityDetails.RecentTransactions)
                            {
                                <tr>
                                    <td class="mono">#@tx.ORNumber</td>
                                    <td>@tx.PayorName</td>
                                    <td><span class="code-badge">@tx.Facility</span></td>
                                    <td class="td-nature">@tx.Nature</td>
                                    <td class="amount-val">₱@tx.Amount.ToString("N0")</td>
                                    <td><span class="status-pill @(tx.Status == "Paid" ? "pill-active" : "pill-inactive")">@tx.Status</span></td>
                                    <td class="td-date">@PhilippineTime.ToPhilippineTime(tx.TransactionDate).ToString("MMM d · hh:mm tt")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="() => ShowActivity = false">Close</button>
            </div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════
     CONFIRM TOGGLE STATUS
══════════════════════════════════════════════ -->
@if (ShowConfirm && ConfirmTarget is not null)
{
    <div class="eemo-modal-overlay" @onclick="() => ShowConfirm = false">
        <div class="eemo-modal eemo-modal-sm" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div class="eemo-modal-title">@(ConfirmTarget.IsActive ? "Deactivate Collector?" : "Activate Collector?")</div>
            </div>
            <div class="eemo-modal-body">
                <p class="confirm-text">
                    @if (ConfirmTarget.IsActive)
                    {
                        @($"Are you sure you want to deactivate {ConfirmTarget.FullName}? They will no longer be able to log in to the mobile app.")
                    }
                    else
                    {
                        @($"Reactivate {ConfirmTarget.FullName}? They will regain access to the mobile app.")
                    }
                </p>
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="() => ShowConfirm = false">Cancel</button>
                <button class="@(ConfirmTarget.IsActive ? "btn-danger" : "btn-primary")"
                        @onclick="ConfirmToggle">
                    @(ConfirmTarget.IsActive ? "Yes, Deactivate" : "Yes, Activate")
                </button>
            </div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════
     SEND MESSAGE (PUSH NOTIFICATION)
══════════════════════════════════════════════ -->
@if (ShowMessage && MessageTarget is not null)
{
    <div class="eemo-modal-overlay" @onclick="CloseMessage">
        <div class="eemo-modal eemo-modal-sm" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div>
                    <div class="eemo-modal-title">Send Message</div>
                    <div class="eemo-modal-sub">Push a notification to @MessageTarget.FullName's device.</div>
                </div>
                <button class="eemo-modal-close" @onclick="CloseMessage">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="eemo-modal-body">
                <div class="form-group">
                    <label class="form-label">Title <span class="req">*</span></label>
                    <input class="form-input" type="text" placeholder="e.g. Reminder"
                           @bind="MessageTitle" @bind:event="oninput" maxlength="80" />
                </div>
                <div class="form-group">
                    <label class="form-label">Message <span class="req">*</span></label>
                    <textarea class="form-input" rows="3" placeholder="Type your message…"
                              @bind="MessageBody" @bind:event="oninput" maxlength="300"></textarea>
                </div>
                @if (!string.IsNullOrEmpty(MessageError))
                {
                    <div class="form-error">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                        @MessageError
                    </div>
                }
                @if (!string.IsNullOrEmpty(MessageInfo))
                {
                    <p class="confirm-text">@MessageInfo</p>
                }
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="CloseMessage">Close</button>
                <button class="btn-primary" disabled="@IsSending" @onclick="SendMessage">
                    @(IsSending ? "Sending…" : "Send")
                </button>
            </div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════
     COLLECTOR APP LINK
══════════════════════════════════════════════ -->
@if (ShowAppLink)
{
    <div class="eemo-modal-overlay" @onclick="() => ShowAppLink = false">
        <div class="eemo-modal eemo-modal-sm" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div>
                    <div class="eemo-modal-title">Collector App</div>
                    <div class="eemo-modal-sub">Share the bind link with your collectors — their app opens as your LGU.</div>
                </div>
                <button class="eemo-modal-close" @onclick="() => ShowAppLink = false">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="eemo-modal-body">
                @if (AppLinkLoading)
                {
                    <p class="confirm-text">Loading…</p>
                }
                else if (AppLink is not null)
                {
                    <div class="form-group">
                        <label class="form-label">Bind link (share with collectors)</label>
                        <div style="display:flex; gap:8px;">
                            <input class="form-input" readonly value="@AppLink.BindUrl" />
                            <button class="btn-ghost" @onclick="() => CopyAsync(AppLink.BindUrl)">Copy</button>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">App download link</label>
                        <div style="display:flex; gap:8px;">
                            <input class="form-input" readonly value="@AppLink.DownloadUrl" />
                            <button class="btn-ghost" @onclick="() => CopyAsync(AppLink.DownloadUrl)">Copy</button>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(AppLinkNotice))
                    {
                        <p class="confirm-text" style="color:var(--green);">@AppLinkNotice</p>
                    }
                }
                @if (!string.IsNullOrEmpty(AppLinkError))
                {
                    <div class="form-error">@AppLinkError</div>
                }
            </div>
            <div class="eemo-modal-footer">
                @if (RotateConfirm)
                {
                    <span class="confirm-text">Rotating invalidates the old link. Continue?</span>
                    <button class="btn-danger" disabled="@AppLinkLoading" @onclick="RotateConfirmedAsync">Yes, rotate</button>
                    <button class="btn-ghost" @onclick="() => RotateConfirm = false">Cancel</button>
                }
                else
                {
                    <button class="btn-ghost" disabled="@AppLinkLoading" @onclick="() => RotateConfirm = true">Rotate link</button>
                    <button class="btn-primary" @onclick="() => ShowAppLink = false">Done</button>
                }
            </div>
        </div>
    </div>
}


@code {
    private readonly DateTime _now = EEMOCantilanSDS.Domain.Common.PhilippineTime.Now;
    private bool _loading = true;
    string SearchQuery = string.Empty;
    string ActiveFilter = "All";
    readonly List<string> StatusFilters = new() { "All", "Active", "Inactive" };

    [PersistentState(AllowUpdates = true)]
    public List<CollectorListDto>? Collectors { get; set; }
    string? LoadError = null;

    protected override async Task OnInitializedAsync()
    {
        await FacilityCatalog.EnsureLoadedAsync();
        _loading = true;
        if (Collectors is not null)
        {
            _loading = false;
            return;
        }

        await PaintLoadingAsync();
        try { await LoadCollectors(); }
        finally { _loading = false; }
    }

    private async Task PaintLoadingAsync()
    {
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
    }

    async Task LoadCollectors()
    {
        LoadError = null;
        var result = await CollectorsApi.GetAllCollectorsAsync();
        if (result.IsSuccess)
            Collectors = result.Value?.ToList() ?? new();
        else
            LoadError = result.Error;
    }

    IEnumerable<CollectorListDto> FilteredCollectors => (Collectors ?? new()).Where(c =>
    {
        bool matchFilter = ActiveFilter switch
        {
            "Active" => c.IsActive,
            "Inactive" => !c.IsActive,
            _ => true
        };
        bool matchSearch = string.IsNullOrWhiteSpace(SearchQuery)
            || c.FullName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || c.EmployeeId.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || c.AssignedFacilities.Any(f => f.ToString().Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));
        return matchFilter && matchSearch;
    });

    class FacilityOption { public FacilityCode Code { get; set; } public string Name { get; set; } = ""; }
    List<FacilityOption> AvailableFacilities =>
        FacilityCatalog.All.Select(c => new FacilityOption { Code = c, Name = FacilityCatalog.NameOf(c) }).ToList();

    // ── Form ──────────────────────────────────────────────────────────────────
    class CollectorForm
    {
        public string FullName { get; set; } = string.Empty;
        public string EmployeeId { get; set; } = string.Empty;
        public string ContactNumber { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public List<FacilityCode> AssignedFacilities { get; set; } = new();
    }

    bool ShowModal = false;
    bool IsEditing = false;
    CollectorForm Form = new();
    string FormError = string.Empty;
    Guid EditingId = Guid.Empty;

    async Task OpenCreate()
    {
        IsEditing = false;
        Form = new();
        FormError = string.Empty;
        
        await LoadNextEmployeeId();
        
        ShowModal = true;
    }

    async Task LoadNextEmployeeId()
    {
        var result = await CollectorsApi.GetNextEmployeeIdAsync();
        if (result.IsSuccess && !string.IsNullOrEmpty(result.Value))
        {
            Form.EmployeeId = result.Value;
            StateHasChanged();
        }
    }

    async Task OpenEdit(CollectorListDto c)
    {
        IsEditing = true;
        EditingId = c.Id;
        Form = new CollectorForm
        {
            FullName = c.FullName,
            EmployeeId = c.EmployeeId,
            ContactNumber = "",
            Email = c.Email,
            Username = "",
            Password = string.Empty,
            AssignedFacilities = new(c.AssignedFacilities)
        };
        FormError = string.Empty;
        ShowModal = true;

        var details = await CollectorsApi.GetCollectorByIdAsync(c.Id);
        if (details.IsSuccess && details.Value is not null)
        {
            Form.ContactNumber = details.Value.ContactNumber ?? string.Empty;
            Form.Username = details.Value.Username ?? string.Empty;
            StateHasChanged();
        }
    }

    void ToggleFacility(FacilityCode code)
    {
        if (Form.AssignedFacilities.Contains(code))
            Form.AssignedFacilities.Remove(code);
        else
            Form.AssignedFacilities.Add(code);
    }

    async Task SaveCollector()
    {
        if (string.IsNullOrWhiteSpace(Form.FullName)) { FormError = "Full name is required."; return; }
        if (string.IsNullOrWhiteSpace(Form.EmployeeId)) { FormError = "Employee ID is required."; return; }
        if (!IsEditing && string.IsNullOrWhiteSpace(Form.Username)) { FormError = "Username is required."; return; }
        if (!IsEditing && string.IsNullOrWhiteSpace(Form.Password)) { FormError = "Password is required for new accounts."; return; }
        if (!Form.AssignedFacilities.Any()) { FormError = "Assign at least one facility."; return; }

        if (IsEditing)
        {
            var command = new UpdateCollectorCommand(
                EditingId,
                Form.FullName.Trim(),
                Form.ContactNumber.Trim(),
                Form.Email.Trim(),
                Form.AssignedFacilities);

            var result = await CollectorsApi.UpdateCollectorAsync(command);
            if (result.IsSuccess)
            {
                await LoadCollectors();
                CloseModal();
            }
            else
            {
                FormError = result.Error ?? "Failed to update collector.";
            }
        }
        else
        {
            var command = new CreateCollectorCommand(
                Form.FullName.Trim(),
                Form.EmployeeId.Trim(),
                Form.ContactNumber.Trim(),
                Form.Email.Trim(),
                Form.Username.Trim(),
                Form.Password,
                Form.AssignedFacilities);

            var result = await CollectorsApi.CreateCollectorAsync(command);
            if (result.IsSuccess)
            {
                await LoadCollectors();
                CloseModal();
            }
            else
            {
                FormError = result.Error ?? "Failed to create collector.";
            }
        }
    }

    void CloseModal()
    {
        ShowModal = false;
        FormError = string.Empty;
    }

    bool ShowConfirm = false;
    CollectorListDto? ConfirmTarget = null;

    void ToggleStatus(CollectorListDto c) { ConfirmTarget = c; ShowConfirm = true; }

    async Task ConfirmToggle()
    {
        if (ConfirmTarget is null) return;
        var target = ConfirmTarget;
        ShowConfirm = false;
        ConfirmTarget = null;

        var result = await CollectorsApi.ToggleCollectorStatusAsync(target.Id, !target.IsActive);
        if (result.IsSuccess)
            await LoadCollectors();
        else
            FormError = result.Error ?? "Failed to update status.";
    }

    bool ShowActivity = false;
    CollectorListDto? ActivityCollector = null;
    CollectorActivityDto? ActivityDetails = null;

    async Task OpenActivity(CollectorListDto c)
    {
        ActivityCollector = c;
        ActivityDetails = null;
        ShowActivity = true;

        var result = await CollectorsApi.GetCollectorByIdAsync(c.Id);
        if (result.IsSuccess)
            ActivityDetails = result.Value;
    }

    // ── Send message (push notification) ────────────────────────────────────────
    bool ShowMessage = false;
    bool IsSending = false;
    CollectorListDto? MessageTarget = null;
    string MessageTitle = string.Empty;
    string MessageBody = string.Empty;
    string MessageError = string.Empty;
    string MessageInfo = string.Empty;

    void OpenMessage(CollectorListDto c)
    {
        MessageTarget = c;
        MessageTitle = string.Empty;
        MessageBody = string.Empty;
        MessageError = string.Empty;
        MessageInfo = string.Empty;
        ShowMessage = true;
    }

    void CloseMessage()
    {
        ShowMessage = false;
        MessageTarget = null;
    }

    async Task SendMessage()
    {
        if (MessageTarget is null) return;
        if (string.IsNullOrWhiteSpace(MessageTitle)) { MessageError = "Title is required."; return; }
        if (string.IsNullOrWhiteSpace(MessageBody)) { MessageError = "Message is required."; return; }

        IsSending = true;
        MessageError = string.Empty;
        MessageInfo = string.Empty;
        try
        {
            var result = await CollectorsApi.SendNotificationAsync(MessageTarget.Id, MessageTitle.Trim(), MessageBody.Trim());
            if (result.IsSuccess)
            {
                MessageInfo = result.Value > 0
                    ? $"Sent to {result.Value} device(s)."
                    : "This collector has no registered device yet (they haven't signed in to the app).";
                MessageTitle = string.Empty;
                MessageBody = string.Empty;
            }
            else
            {
                MessageError = result.Error ?? "Failed to send the message.";
            }
        }
        catch
        {
            MessageError = "Failed to send the message. Please try again.";
        }
        finally
        {
            IsSending = false;
        }
    }

    // ── Collector app link (bind link) ──────────────────────────────────────────
    bool ShowAppLink;
    bool AppLinkLoading;
    bool RotateConfirm;
    MobileBindLinkDto? AppLink;
    string? AppLinkError;
    string? AppLinkNotice;

    async Task OpenAppLink()
    {
        ShowAppLink = true;
        RotateConfirm = false;
        AppLinkError = null;
        AppLinkNotice = null;
        await LoadAppLinkAsync(rotate: false);
    }

    async Task LoadAppLinkAsync(bool rotate)
    {
        AppLinkLoading = true;
        AppLinkError = null;
        StateHasChanged();
        try
        {
            var result = await CollectorsApi.GetCollectorAppLinkAsync(rotate);
            if (result.IsSuccess && result.Value is not null)
                AppLink = result.Value;
            else
                AppLinkError = result.Error ?? "Couldn't load the collector app link.";
        }
        catch
        {
            AppLinkError = "Couldn't load the collector app link.";
        }
        finally
        {
            AppLinkLoading = false;
        }
    }

    async Task RotateConfirmedAsync()
    {
        RotateConfirm = false;
        AppLinkNotice = null;
        await LoadAppLinkAsync(rotate: true);
        if (AppLinkError is null)
            AppLinkNotice = "Link rotated. The previous link no longer works.";
    }

    async Task CopyAsync(string text)
    {
        AppLinkError = null;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", text);
            AppLinkNotice = "Copied to clipboard.";
        }
        catch
        {
            AppLinkNotice = "Couldn't copy automatically — select the text and copy manually.";
        }
    }
}
