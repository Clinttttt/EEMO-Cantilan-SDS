@page "/online-payments"
@using Microsoft.AspNetCore.Authorization
@using EEMOCantilanSDS.Application.Dtos.Payments
@using EEMOCantilanSDS.Application.Dtos.Settings
@using EEMOCantilanSDS.Client.Components.Shared
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@inject IOnlinePaymentsApiClient OnlinePaymentsApi
@inject ISettingsApiClient SettingsApi
@inject AuthenticationStateProvider AuthState

<PageTitle>@Branding.OfficeAcronym Admin — Online Payments</PageTitle>

<header class="topbar">
    <div class="topbar-left">
        <div class="topbar-title">Online Payments</div>
        <div class="topbar-breadcrumb">
            <span>@Branding.OfficeAcronym Admin</span>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Awaiting OR</span>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @PhilippineTime.Now.ToString("MMMM d, yyyy")
        </div>
        <AccountChip />
    </div>
</header>

<div class="content-area">

    @* Per-LGU online-payment account (Head only): first-time setup, or a compact status once configured. *@
    @if (_isHead && _paymentLoaded && _showSetup)
    {
        <div class="op-setup">
            <div class="op-setup-card">
                <div class="op-setup-head">
                    <div class="op-setup-badge">
                        <svg viewBox="0 0 24 24"><rect x="1" y="4" width="22" height="16" rx="2" /><line x1="1" y1="10" x2="23" y2="10" /></svg>
                    </div>
                    <div class="op-setup-head-text">
                        <div class="op-setup-title">Set up your online payment account</div>
                        <div class="op-setup-sub">Connect your municipality's PayMongo account so collections settle to you.</div>
                    </div>
                    <button type="button" class="op-help-btn" title="How to set this up" @onclick="() => _showHelp = true">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                    </button>
                </div>

                <div class="form-group">
                    <label class="form-label">Secret Key</label>
                    <input class="form-input" type="password" autocomplete="off" placeholder="sk_live_…" @bind="_paySecret" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label class="form-label">Public Key <span class="op-opt">(optional)</span></label>
                    <input class="form-input" type="text" autocomplete="off" placeholder="pk_live_…" @bind="_payPublic" @bind:event="oninput" />
                </div>
                <div class="form-group">
                    <label class="form-label">Webhook Secret <span class="op-opt">(optional)</span></label>
                    <input class="form-input" type="password" autocomplete="off" placeholder="whsk_…" @bind="_payWebhook" @bind:event="oninput" />
                </div>

                @if (!string.IsNullOrEmpty(_payError))
                {
                    <div class="op-banner op-banner-error">@_payError</div>
                }

                <div class="op-setup-actions">
                    <button class="btn-primary" disabled="@_paySaving" @onclick="SavePaymentAsync">@(_paySaving ? "Saving…" : "Save")</button>
                    @if (_payment?.HasOwnAccount == true || _isDefaultTenant)
                    {
                        <button class="btn-ghost" disabled="@_paySaving" @onclick="() => _showSetup = false">Cancel</button>
                    }
                    @if (_payment?.HasOwnAccount == true)
                    {
                        <button class="btn-ghost" disabled="@_paySaving" @onclick="RevertPaymentAsync">Revert to default</button>
                    }
                </div>
            </div>
        </div>

        @if (_showHelp)
        {
            <div class="eemo-modal-overlay" @onclick="() => _showHelp = false">
                <div class="eemo-modal eemo-modal-sm" @onclick:stopPropagation="true">
                    <div class="eemo-modal-header">
                        <div class="eemo-modal-title">Set up online payments</div>
                        <button class="eemo-modal-close" @onclick="() => _showHelp = false">
                            <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                        </button>
                    </div>
                    <div class="eemo-modal-body">
                        <ol class="op-steps">
                            <li class="op-step">
                                <span class="op-step-no">1</span>
                                <div class="op-step-main">
                                    <div class="op-step-title">Sign in to PayMongo</div>
                                    <div class="op-step-text">Log in to your PayMongo dashboard, or create your municipality's account.</div>
                                </div>
                            </li>
                            <li class="op-step">
                                <span class="op-step-no">2</span>
                                <div class="op-step-main">
                                    <div class="op-step-title">Copy your API keys</div>
                                    <div class="op-step-text">In <b>Developers → API Keys</b>, copy your Secret key (and, optionally, your Public key) into the fields on this page.</div>
                                </div>
                            </li>
                            <li class="op-step">
                                <span class="op-step-no">3</span>
                                <div class="op-step-main">
                                    <div class="op-step-title">Add a webhook</div>
                                    <div class="op-step-text">In <b>Developers → Webhooks</b>, add a webhook to <span class="op-mono">…/onlinepayments/webhook/@Branding.TenantCode</span>, then paste its signing secret into Webhook Secret.</div>
                                </div>
                            </li>
                            <li class="op-step">
                                <span class="op-step-no">4</span>
                                <div class="op-step-main">
                                    <div class="op-step-title">Save</div>
                                    <div class="op-step-text">Your online collections then settle straight to your own account.</div>
                                </div>
                            </li>
                        </ol>
                    </div>
                    <div class="eemo-modal-footer">
                        <button class="btn-primary" @onclick="() => _showHelp = false">Got it</button>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        @if (_dashboard is not null)
        {
            <div class="op-kpis">
                <div class="op-kpi">
                    <div class="op-kpi-label">Collected this month</div>
                    <div class="op-kpi-value">₱@_dashboard.CollectedThisMonth.ToString("N2")</div>
                    <div class="op-kpi-sub">@PhilippineTime.Now.ToString("MMMM yyyy") · online</div>
                </div>
                <div class="op-kpi">
                    <div class="op-kpi-label">Collected this year</div>
                    <div class="op-kpi-value">₱@_dashboard.CollectedThisYear.ToString("N2")</div>
                    <div class="op-kpi-sub">@_dashboard.Year · online</div>
                </div>
                <div class="op-kpi">
                    <div class="op-kpi-label">Settled transactions</div>
                    <div class="op-kpi-value">@_dashboard.SettledCountThisYear.ToString("N0")</div>
                    <div class="op-kpi-sub">@_dashboard.Year@(string.IsNullOrEmpty(_dashboard.TopMethod) ? "" : " · mostly " + MethodLabel(_dashboard.TopMethod))</div>
                </div>
                <div class="op-kpi">
                    <div class="op-kpi-label">Awaiting Official Receipt</div>
                    <div class="op-kpi-value @(Items.Count > 0 ? "is-attention" : "")">@Items.Count.ToString("N0")</div>
                    <div class="op-kpi-sub">@(Items.Count == 0 ? "all caught up" : "need OR encoding below")</div>
                </div>
            </div>
        }

        <div class="op-intro op-intro-row">
            <div>
                <div class="op-intro-title">Online payments received — awaiting Official Receipt</div>
                <div class="op-intro-sub">Encode the manually-issued OR number to complete each cleared payment.</div>
            </div>
            @if (_isHead && _paymentLoaded)
            {
                <button class="op-config-btn" type="button"
                        title="@(_payment?.HasOwnAccount == true ? "Settling to your own PayMongo account — click to configure" : "Using the platform default account — click to configure")"
                        @onclick="RequestConfigure">
                    <span class="op-config-status @(_payment?.HasOwnAccount == true ? "is-own" : "")">@(_payment?.HasOwnAccount == true ? "Own account" : "Default account")</span>
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" /><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" /></svg>
                </button>
            }
        </div>

    @if (!string.IsNullOrEmpty(Message))
    {
        <div class="op-banner @(IsError ? "op-banner-error" : "op-banner-ok")">@Message</div>
    }

    <div class="section-card">
        @if (Loading)
        {
            <div class="op-loading" aria-busy="true" aria-label="Checking online payments awaiting Official Receipt">
                <div class="op-loading-icon">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <rect x="3" y="5" width="18" height="14" rx="2" />
                        <path d="M3 9h18" />
                        <path d="M8 15h3" />
                        <path d="M15 15h1" />
                    </svg>
                </div>
                <div class="op-loading-copy">
                    <div class="op-loading-title">Checking online payments</div>
                    <div class="op-loading-sub">Verifying transactions that still need a manually issued Official Receipt.</div>
                </div>
                <div class="op-loading-lines">
                    <span></span>
                    <span></span>
                </div>
            </div>
        }
        else if (Items.Count == 0)
        {
            <div class="op-empty">No online payments are awaiting an OR. You're all caught up.</div>
        }
        else
        {
            <table class="op-table">
                <thead>
                    <tr>
                        <th>Paid</th>
                        <th>Payor</th>
                        <th>Stall / Period</th>
                        <th>Reference</th>
                        <th class="op-amt">Amount</th>
                        <th>OR Number</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Items)
                    {
                        <tr>
                            <td>
                                <div class="op-strong">@(item.PaidAt.HasValue ? PhilippineTime.ToPhilippineTime(item.PaidAt.Value).ToString("MMM d, yyyy") : "—")</div>
                                <div class="op-muted">@(item.PaidAt.HasValue ? PhilippineTime.ToPhilippineTime(item.PaidAt.Value).ToString("h:mm tt") : "")</div>
                            </td>
                            <td>
                                <div class="op-strong">@item.PayorName</div>
                                <div class="op-muted">@(item.Method ?? "PayMongo")</div>
                            </td>
                            <td>
                                <div class="op-strong">@item.Facility · Stall @item.StallNo</div>
                                <div class="op-muted">@item.Period</div>
                            </td>
                            <td class="op-mono">@item.Reference</td>
                            <td class="op-amt op-strong">₱@item.Amount.ToString("N2")</td>
                            <td>
                                <input class="op-input" type="text" maxlength="50" placeholder="e.g. OR-2026-0301"
                                       value="@GetOr(item.TransactionId)"
                                       @oninput="e => SetOr(item.TransactionId, e.Value?.ToString())" />
                            </td>
                            <td>
                                <button class="op-btn" type="button"
                                        disabled="@(Busy || string.IsNullOrWhiteSpace(GetOr(item.TransactionId)))"
                                        @onclick="() => EncodeAsync(item)">
                                    @(BusyId == item.TransactionId ? "Saving…" : "Encode OR")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* ── Recent online payments (received) ── *@
    <div class="op-intro op-history-head">
        <div class="op-intro-title">Recent online payments</div>
        <div class="op-intro-sub">
            The latest online payments received across all facilities — for verification against the treasury report.
        </div>
    </div>
    <div class="section-card">
        @if (_dashboard is null || _dashboard.Recent.Count == 0)
        {
            <div class="op-empty">No online payments have been received yet.</div>
        }
        else
        {
            <table class="op-table">
                <thead>
                    <tr>
                        <th>Paid</th>
                        <th>Payor</th>
                        <th>Facility / Stall</th>
                        <th>Period</th>
                        <th>Method</th>
                        <th class="op-amt">Amount</th>
                        <th>Status</th>
                        <th>OR Number</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var h in _dashboard.Recent)
                    {
                        <tr>
                            <td>
                                <div class="op-strong">@(h.PaidAt.HasValue ? PhilippineTime.ToPhilippineTime(h.PaidAt.Value).ToString("MMM d, yyyy") : "—")</div>
                                <div class="op-muted">@(h.PaidAt.HasValue ? PhilippineTime.ToPhilippineTime(h.PaidAt.Value).ToString("h:mm tt") : "")</div>
                            </td>
                            <td class="op-strong">@h.PayorName</td>
                            <td>
                                <div class="op-strong">@h.Facility</div>
                                <div class="op-muted">Stall @h.StallNo</div>
                            </td>
                            <td class="op-mono">@h.Period</td>
                            <td>@MethodLabel(h.Method)</td>
                            <td class="op-amt op-strong">₱@h.Amount.ToString("N2")</td>
                            <td><span class="op-status @(h.Status == "Completed" ? "is-done" : "is-await")">@h.Status</span></td>
                            <td class="op-mono">@(string.IsNullOrEmpty(h.ORNumber) ? "—" : h.ORNumber)</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>

    @* Re-authentication before changing the online-payment account. *@
    @if (_showPwConfirm)
    {
        <div class="eemo-modal-overlay" @onclick="() => _showPwConfirm = false">
            <div class="eemo-modal eemo-modal-sm op-confirm" @onclick:stopPropagation="true">
                <div class="eemo-modal-header">
                    <div class="eemo-modal-title">Confirm it's you</div>
                    <button class="eemo-modal-close" @onclick="() => _showPwConfirm = false">
                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                    </button>
                </div>
                <div class="eemo-modal-body">
                    <p class="op-pw-note">Enter your password to change the online-payment account.</p>
                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <input class="form-input" type="password" autocomplete="current-password"
                               @bind="_pwInput" @bind:event="oninput"
                               @onkeydown="@(e => { if (e.Key == "Enter") { _ = ConfirmConfigureAsync(); } })" />
                    </div>
                    @if (!string.IsNullOrEmpty(_pwError))
                    {
                        <div class="op-banner op-banner-error">@_pwError</div>
                    }
                </div>
                <div class="eemo-modal-footer">
                    <button class="btn-ghost" disabled="@_pwVerifying" @onclick="() => _showPwConfirm = false">Cancel</button>
                    <button class="btn-primary" disabled="@_pwVerifying" @onclick="ConfirmConfigureAsync">@(_pwVerifying ? "Verifying…" : "Continue")</button>
                </div>
            </div>
        </div>
    }
    }
</div>

@code {
    private bool Loading = true;
    private bool Busy;
    private Guid? BusyId;
    private string? Message;
    private bool IsError;
    private List<OnlinePaymentAwaitingOrDto> Items = new();
    private readonly Dictionary<Guid, string> _orInputs = new();

    // Treasury overview + recent history (all staff).
    private OnlinePaymentDashboardDto? _dashboard;

    // ── Per-LGU online-payment account (Head only) ──────────────────────────────
    private PaymentSettingsDto? _payment;
    private bool _paymentLoaded;
    private bool _isHead;
    private bool _isDefaultTenant;
    private bool _showSetup;
    private bool _showHelp;
    private string _paySecret = string.Empty;
    private string _payPublic = string.Empty;
    private string _payWebhook = string.Empty;
    private bool _paySaving;
    private string? _payMsg;
    private string? _payError;

    // ── Re-authentication before configuring the payment account ────────────────
    private bool _showPwConfirm;
    private string _pwInput = string.Empty;
    private bool _pwVerifying;
    private string? _pwError;

    private void RequestConfigure()
    {
        _pwInput = string.Empty;
        _pwError = null;
        _showPwConfirm = true;
    }

    private async Task ConfirmConfigureAsync()
    {
        if (_pwVerifying) return;
        if (string.IsNullOrWhiteSpace(_pwInput))
        {
            _pwError = "Enter your password.";
            return;
        }

        _pwVerifying = true;
        _pwError = null;
        try
        {
            var result = await SettingsApi.VerifyMyPasswordAsync(_pwInput);
            if (result.IsSuccess && result.Value)
            {
                _pwInput = string.Empty;
                _showPwConfirm = false;
                OpenSetup();
            }
            else
            {
                _pwError = "Incorrect password. Please try again.";
            }
        }
        catch
        {
            _pwError = "Couldn't verify right now. Please try again.";
        }
        finally
        {
            _pwVerifying = false;
        }
    }

    [PersistentState(AllowUpdates = true)]
    public List<OnlinePaymentAwaitingOrDto>? CachedItems { get; set; }

    private string GetOr(Guid id) => _orInputs.TryGetValue(id, out var v) ? v : string.Empty;
    private void SetOr(Guid id, string? v) => _orInputs[id] = v?.Trim() ?? string.Empty;

    protected override async Task OnInitializedAsync()
    {
        // Payment-account section (Head only) — load before the cached-items early return so it always shows.
        await Branding.EnsureLoadedAsync();
        _isDefaultTenant = Branding.IsDefaultTenant;
        var authState = await AuthState.GetAuthenticationStateAsync();
        _isHead = authState.User.IsInRole("SuperAdmin")
            || authState.User.Claims.Any(c =>
                string.Equals(c.Value, "SuperAdmin", StringComparison.OrdinalIgnoreCase)
                && c.Type.Contains("role", StringComparison.OrdinalIgnoreCase));
        if (_isHead)
            await LoadPaymentAsync();

        // Treasury overview + recent history (shown to all staff, independent of the cached awaiting list).
        await LoadDashboardAsync();

        if (CachedItems is not null)
        {
            Items = CachedItems;
            Loading = false;
            return;
        }

        await LoadAsync(paintLoading: true);
    }

    private async Task LoadDashboardAsync()
    {
        var result = await OnlinePaymentsApi.GetDashboardAsync();
        if (result.IsSuccess && result.Value is not null)
            _dashboard = result.Value;
    }

    // PayMongo method codes → friendly labels.
    private static string MethodLabel(string? method) => method?.ToLowerInvariant() switch
    {
        null or "" => "—",
        "gcash" => "GCash",
        "grab_pay" or "grabpay" => "GrabPay",
        "paymaya" or "maya" => "Maya",
        "card" => "Card",
        "dob" or "online_banking" or "brankas" => "Online Banking",
        _ => char.ToUpperInvariant(method[0]) + method[1..]
    };

    private async Task LoadPaymentAsync()
    {
        var result = await SettingsApi.GetPaymentSettingsAsync();
        if (result.IsSuccess && result.Value is not null)
        {
            _payment = result.Value;
            _payPublic = _payment.PublicKey ?? string.Empty;
            // First-time: a non-default LGU that hasn't connected its own account yet.
            _showSetup = !_payment.HasOwnAccount && !_isDefaultTenant;
        }
        _paymentLoaded = true;
    }

    private void OpenSetup()
    {
        _payError = null;
        _payMsg = null;
        _showSetup = true;
    }

    private async Task SavePaymentAsync()
    {
        _payError = null;
        _payMsg = null;
        if (string.IsNullOrWhiteSpace(_paySecret))
        {
            _payError = "Enter your PayMongo secret key — or use ‘Revert to platform default’.";
            return;
        }

        _paySaving = true;
        try
        {
            var result = await SettingsApi.SavePaymentCredentialsAsync(
                _paySecret.Trim(),
                string.IsNullOrWhiteSpace(_payPublic) ? null : _payPublic.Trim(),
                string.IsNullOrWhiteSpace(_payWebhook) ? null : _payWebhook.Trim());

            if (result.IsSuccess)
            {
                _paySecret = string.Empty;
                _payWebhook = string.Empty;
                await LoadPaymentAsync();
                _showSetup = false;
                _payMsg = "Saved. Online payments now settle to your own PayMongo account.";
            }
            else
            {
                _payError = result.Error ?? "Couldn't save the payment account.";
            }
        }
        catch
        {
            _payError = "Couldn't save the payment account. Please try again.";
        }
        finally
        {
            _paySaving = false;
        }
    }

    private async Task RevertPaymentAsync()
    {
        _payError = null;
        _payMsg = null;
        _paySaving = true;
        try
        {
            var result = await SettingsApi.SavePaymentCredentialsAsync(null, null, null);
            if (result.IsSuccess)
            {
                _paySecret = string.Empty;
                _payPublic = string.Empty;
                _payWebhook = string.Empty;
                await LoadPaymentAsync();
                _showSetup = false;
                _payMsg = "Reverted to the platform default account.";
            }
            else
            {
                _payError = result.Error ?? "Couldn't revert to the default account.";
            }
        }
        catch
        {
            _payError = "Couldn't revert. Please try again.";
        }
        finally
        {
            _paySaving = false;
        }
    }

    private async Task LoadAsync(bool paintLoading = false)
    {
        Loading = true;
        if (paintLoading)
            await PaintLoadingAsync();

        var result = await OnlinePaymentsApi.GetAwaitingOrAsync();
        Items = result.IsSuccess && result.Value is not null
            ? result.Value.ToList()
            : new List<OnlinePaymentAwaitingOrDto>();
        CachedItems = Items;
        Loading = false;
    }

    private async Task PaintLoadingAsync()
    {
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
    }

    private async Task EncodeAsync(OnlinePaymentAwaitingOrDto item)
    {
        var orNumber = GetOr(item.TransactionId);
        if (string.IsNullOrWhiteSpace(orNumber)) return;

        Message = null;
        Busy = true;
        BusyId = item.TransactionId;

        var result = await OnlinePaymentsApi.IssueOrNumberAsync(item.TransactionId, orNumber);

        Busy = false;
        BusyId = null;

        if (result.IsSuccess)
        {
            Items.RemoveAll(i => i.TransactionId == item.TransactionId);
            CachedItems = Items.ToList();
            _orInputs.Remove(item.TransactionId);
            IsError = false;
            Message = $"OR {orNumber} encoded — transaction completed.";
        }
        else
        {
            IsError = true;
            Message = result.Error ?? "Could not encode the OR number. It may already be in use.";
        }
    }
}
