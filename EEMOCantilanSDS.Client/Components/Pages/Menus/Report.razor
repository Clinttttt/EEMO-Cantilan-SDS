@page "/reports"
@attribute [Authorize(Roles = "Admin,SuperAdmin")]
@using Microsoft.AspNetCore.Components
@using EEMOCantilanSDS.Application.Dtos.Reports
@using EEMOCantilanSDS.Domain.Common
@using EEMOCantilanSDS.Domain.Enums
@inject IReportsApiClient ReportsApi
@inject IJSRuntime JS

<PageTitle>Financial Reports — EEMO Admin</PageTitle>

<header class="topbar">
    <div class="topbar-left">
        <div class="topbar-title">Financial Reports</div>
        <div class="topbar-breadcrumb">
            <span>EEMO Admin</span>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Reports</span>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            Generated @GeneratedOn.ToString("MMM d, yyyy · h:mm tt")
        </div>
        <AccountChip />
    </div>
</header>

<div class="content-area">

    <!-- REPORT IDENTITY & SCOPE -->
    <div class="rpt-scope">
        <div class="rpt-scope-main">
            <span class="rpt-scope-item">Reporting period <strong>@PeriodLabel</strong></span>
            <span class="rpt-scope-sep"></span>
            <span class="rpt-scope-item">Scope <strong>@ScopeLabel</strong></span>
            <span class="rpt-scope-sep"></span>
            <span class="rpt-scope-item">Frequency <strong>@FrequencyLabel</strong></span>
        </div>
        <div class="rpt-scope-coverage" title="All EEMO facilities are included; collection cycles differ by facility model">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
            <strong>@(Model?.FacilityCount ?? 8) facilities</strong>&nbsp;· mixed collection cycles
        </div>
    </div>

    <!-- FILTER PANEL -->
    <div class="rpt-filter-panel">
        <div class="rfp-top">
            <div class="rfp-ctrl">
                <div class="rfp-label">Period</div>
                <div class="rfp-period-pills">
                    <button class="rpp @(ActiveTab == "Monthly" ? "on" : "")" @onclick='() => SetTab("Monthly")'>Monthly</button>
                    <button class="rpp @(ActiveTab == "Annual" ? "on" : "")" @onclick='() => SetTab("Annual")'>Annual</button>
                </div>
            </div>

            <div class="rfp-ctrl">
                <FhSelect Caption="Year" Value="@SelectedYear" Options="@YearOptions" ValueChanged="OnYearChanged" />
            </div>

            @if (ActiveTab == "Monthly")
            {
                <div class="rfp-ctrl">
                    <FhSelect Caption="Month" Value="@SelectedMonth" Options="@MonthOptions" ValueChanged="OnMonthChanged" />
                </div>
            }

            <div class="rfp-export">
                <button class="rpt-btn-pdf" @onclick="ExportPdf" disabled="@(Model is null)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="9" y1="13" x2="15" y2="13" /><line x1="9" y1="17" x2="15" y2="17" /></svg>
                    Export PDF
                </button>
            </div>
        </div>

        <div class="rfp-divider"></div>

        <div class="rfp-bottom">
            <div class="rfp-fac-row">
                <div class="rfp-label rfp-label-inline">Facility</div>
                <div class="rfp-chips">
                    @foreach (var (codes, label) in FacilityOptions)
                    {
                        var fc = codes;
                        <button class="rfp-chip @(SelectedFacility == fc ? "on" : "")" title="@label" @onclick='() => SelectFacility(fc)'>
                            @(codes == "All" ? "All" : codes)
                        </button>
                    }
                </div>
            </div>
            <div class="rfp-badge">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <strong>@ScopeLabel</strong>&nbsp;·&nbsp;<strong>@PeriodLabel</strong>
            </div>
        </div>
    </div>

    @if (Loading && Model is null)
    {
        <div class="rpt-state">Loading report…</div>
    }
    else if (Model is null)
    {
        <div class="rpt-state rpt-state-error">
            Unable to load the report for @PeriodLabel.
            <button class="rpt-retry" @onclick="Load">Try again</button>
        </div>
    }
    else
    {
        @if (Loading)
        {
            <div class="rpt-refreshing"><span class="rpt-refreshing-dot"></span> Refreshing @PeriodLabel…</div>
        }
        <!-- PRINT / PDF HEADER (only visible when printing) -->
        <div class="rpt-pdf-header pdf-include">
            <img class="rpt-pdf-logo" src="/images/LGU_CANTILAN_LOGO.jpg" alt="LGU Cantilan" />
            <div class="rpt-pdf-republic">Republic of the Philippines</div>
            <div class="rpt-pdf-office">Economic Enterprise &amp; Management Office</div>
            <div class="rpt-pdf-muni">Municipality of Cantilan, Surigao del Sur</div>
            <div class="rpt-pdf-title">Financial Report — @PeriodLabel</div>
            <div class="rpt-pdf-meta">
                <span>Scope: <strong>@ScopeLabel</strong></span>
                <span>Frequency: <strong>@FrequencyLabel</strong></span>
                <span>Generated: <strong>@GeneratedOn.ToString("MMM d, yyyy · h:mm tt")</strong></span>
            </div>
        </div>

        <!-- FINANCIAL POSITION — KPIs -->
        <div class="kpi-row pdf-include">
            <div class="kpi-card">
                <div class="kpi-icon-wrap green">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h7a4 4 0 0 1 0 8H6z" /><line x1="4" y1="9" x2="16" y2="9" /><line x1="4" y1="13" x2="16" y2="13" /><line x1="6" y1="4" x2="6" y2="20" /></svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-value">@Money(Model.Collected)</div>
                    <div class="kpi-label">Collected — @PeriodLabel</div>
                    @if (Model.CollectedPreviousPeriod is decimal prev && Model.PreviousPeriodLabel is not null && prev > 0)
                    {
                        var delta = (Model.Collected - prev) / prev * 100m;
                        <div class="kpi-sub"><span class="@(delta >= 0 ? "up" : "down")">@(delta >= 0 ? "↑" : "↓") @Math.Abs(delta).ToString("0.0")%</span> vs @Model.PreviousPeriodLabel</div>
                    }
                    else
                    {
                        <div class="kpi-sub">Recorded collections this period</div>
                    }
                </div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon-wrap red">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-value">@Money(Model.CurrentPeriodUnpaid)</div>
                    <div class="kpi-label">Current-period unpaid balance</div>
                    <div class="kpi-sub">Billed but uncollected for @PeriodLabel</div>
                </div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon-wrap gold">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2" /></svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-value">@Model.CollectionRatePct%</div>
                    <div class="kpi-label">Collection rate (by amount)</div>
                    <div class="kpi-sub">@Money(Model.Collected) of @Money(Model.Billed) billed</div>
                </div>
            </div>
            <div class="kpi-card">
                <div class="kpi-icon-wrap navy">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4" /><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" /></svg>
                </div>
                <div class="kpi-body">
                    <div class="kpi-value">@Model.PaidRecords</div>
                    <div class="kpi-label">Paid collection records</div>
                    <div class="kpi-sub">@Model.PaidRecords of @Model.ExpectedRecords expected · @Model.FacilityCount facilities</div>
                   
                </div>
            </div>
        </div>

        <!-- ATTENTION & FOLLOW-UP -->
        <div class="section-card rpt-attention-wrap" style="margin-bottom:20px;">
            <div class="section-header">
                <div>
                    <div class="section-title">Attention &amp; Follow-up</div>
                    <div class="section-sub">@(Model.Delinquent.Count + Model.Arrears.Count) accounts need follow-up · @Money(Model.Delinquent.Sum(d => d.Balance) + Model.Arrears.Sum(a => a.Balance)) outstanding</div>
                </div>
            </div>
            <div class="rpt-attention">
                <div class="attn-col">
                    <div class="attn-col-head">
                        <span class="attn-col-title attn-delinquent">Delinquent accounts</span>
                        <span class="attn-count attn-count-red">@Model.Delinquent.Count</span>
                    </div>
                    <div class="attn-col-note">3 or more unpaid months</div>
                    <div class="delinq-list">
                        @if (Model.Delinquent.Count == 0)
                        {
                            <div class="rpt-empty">No delinquent accounts for @PeriodLabel.</div>
                        }
                        @foreach (var d in Model.Delinquent)
                        {
                            <a href="@ProfileUrl(d.FacilityCode, d.StallNo)" class="delinq-item-link">
                                <div class="delinq-item">
                                    <div class="delinq-avatar">@Initials(d.Name)</div>
                                    <div class="delinq-info">
                                        <div class="delinq-name">@d.Name</div>
                                        <div class="delinq-loc">@d.Location</div>
                                    </div>
                                    <div class="delinq-amount">
                                        <div class="delinq-amt-val">@Money(d.Balance)</div>
                                        <div class="delinq-months attn-age-red">@MonthsLabel(d.UnpaidMonths)</div>
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
                <div class="attn-col">
                    <div class="attn-col-head">
                        <span class="attn-col-title attn-arrears">Accounts in arrears</span>
                        <span class="attn-count attn-count-amber">@Model.Arrears.Count</span>
                    </div>
                    <div class="attn-col-note">1–2 unpaid months</div>
                    <div class="delinq-list">
                        @if (Model.Arrears.Count == 0)
                        {
                            <div class="rpt-empty">No accounts in arrears for @PeriodLabel.</div>
                        }
                        @foreach (var d in Model.Arrears)
                        {
                            <a href="@ProfileUrl(d.FacilityCode, d.StallNo)" class="delinq-item-link">
                                <div class="delinq-item">
                                    <div class="delinq-avatar">@Initials(d.Name)</div>
                                    <div class="delinq-info">
                                        <div class="delinq-name">@d.Name</div>
                                        <div class="delinq-loc">@d.Location</div>
                                    </div>
                                    <div class="delinq-amount">
                                        <div class="delinq-amt-val amber">@Money(d.Balance)</div>
                                        <div class="delinq-months attn-age-amber">@MonthsLabel(d.UnpaidMonths)</div>
                                    </div>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- REVENUE TREND -->
        <div class="section-card pdf-include" style="margin-bottom:20px;">
            <div class="section-header">
                <div>
                    <div class="section-title">Revenue Trend</div>
                    <div class="section-sub">@ScopeLabel · amounts in ₱</div>
                </div>
            </div>
            <div class="chart-wrap">
                @if (TrendBars.Count == 0)
                {
                    <div class="rpt-empty">No trend data for @PeriodLabel.</div>
                }
                else
                {
                    <div class="chart-legend">
                        <div class="legend-item"><div class="legend-dot" style="background:var(--navy)"></div> Collected</div>
                        <div class="legend-item"><div class="legend-dot" style="background:var(--gold)"></div> Selected period</div>
                        <div class="legend-item"><div class="legend-dot" style="background:#dde4ea"></div> Current-period unpaid balance</div>
                    </div>
                    <div class="rpt-trend-plot">
                        <div class="rpt-yaxis" aria-hidden="true">
                            @foreach (var lbl in AxisLabels)
                            {
                                <span>@lbl</span>
                            }
                        </div>
                        <div class="rpt-plot">
                            <div class="rpt-grid" aria-hidden="true">
                                @foreach (var _ in AxisLabels)
                                {
                                    <div class="rpt-grid-line"></div>
                                }
                            </div>
                            <div class="bar-chart">
                                @{ var bi = 0; }
                                @foreach (var m in TrendBars)
                                {
                                    var delay = $"{bi * 70}ms";
                                    <div class="bar-group" @key="(_renderEpoch, bi)">
                                        <div class="bar-wrap" aria-label="@m.Label — collected @Money(m.Collected), unpaid @Money(m.Unpaid)">
                                            <div class="bar @(m.IsSelected ? "gold-bar" : "collected")" style="height:@Pct(m.Collected)%;animation-delay:@delay"></div>
                                            <div class="bar unpaid" style="height:@Pct(m.Unpaid)%;animation-delay:@delay"></div>
                                            <div class="bar-tip" role="tooltip">
                                                <div class="bar-tip-title">@m.Label</div>
                                                <div class="bar-tip-row"><span class="bar-tip-dot tip-collected"></span><span class="bar-tip-key">Collected</span><span class="bar-tip-val">@Money(m.Collected)</span></div>
                                                <div class="bar-tip-row"><span class="bar-tip-dot tip-unpaid"></span><span class="bar-tip-key">Unpaid</span><span class="bar-tip-val">@Money(m.Unpaid)</span></div>
                                            </div>
                                        </div>
                                        <div class="bar-month" style="@(m.IsSelected ? "color:var(--gold);font-weight:700" : "")">@m.Label@(m.IsSelected ? " ●" : "")</div>
                                    </div>
                                    bi++;
                                }
                            </div>
                        </div>
                    </div>
                    <div class="rpt-ytd-note">
                        Collected across shown periods: <strong>@Money(Model.YtdCollected)</strong>
                    </div>
                }
            </div>
        </div>

        <!-- REVENUE BY FACILITY -->
        <div class="section-card pdf-include" style="margin-bottom:20px;">
            <div class="section-header">
                <div>
                    <div class="section-title">Revenue by Facility — @PeriodLabel</div>
                    <div class="section-sub">Collection differs by facility model; unpaid/rate apply only to billed cycles</div>
                </div>
            </div>
            <div class="rpt-table-scroll">
                <table class="fac-table">
                    <thead>
                        <tr>
                            <th scope="col">Facility</th>
                            <th scope="col">Collection model</th>
                            <th scope="col">Collected</th>
                            <th scope="col">Unpaid (period)</th>
                            <th scope="col">Paid records</th>
                            <th scope="col">Rate</th>
                            <th scope="col">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var f in Model.Facilities)
                        {
                            var expandable = f.Detail is not null;
                            var open = expandable && _expandedFacilities.Contains(f.Code);
                            <tr class="@(expandable ? "fac-expandable" : "")" @onclick="@(() => ToggleFacility(f.Code, expandable))">
                                <td>
                                    <div class="fac-name">
                                        @if (expandable)
                                        {
                                            <span class="fac-caret @(open ? "open" : "")">&#9654;</span>
                                        }
                                        <span class="fac-code-badge">@f.Code</span> @f.Name
                                    </div>
                                </td>
                                <td><span class="fac-model">@f.Model</span></td>
                                <td class="mono-num">@Money(f.Collected)</td>
                                <td class="mono-num" style="@(f.Unpaid.HasValue && f.Unpaid > 0 ? "color:var(--red);" : "color:var(--text-muted);")">@(f.Unpaid.HasValue ? Money(f.Unpaid.Value) : "—")</td>
                                <td class="mono-num">@f.PaidRecords</td>
                                <td style="font-weight:700;color:@(f.RatePct.HasValue ? "var(--navy)" : "var(--text-muted)");">@(f.RatePct.HasValue ? f.RatePct + "%" : "—")</td>
                                <td><span class="status-pill @StatusClass(f.Status)">@f.Status</span></td>
                            </tr>
                            @if (open && f.Detail is { } nd)
                            {
                                var other = f.Collected - nd.DailyFeeCollected - nd.FishCollected;
                                <tr class="fac-detail-row">
                                    <td colspan="7">
                                        <div class="fac-detail">
                                            <div class="fac-detail-group">
                                                <div class="fac-detail-heading">Collected breakdown</div>
                                                <div class="fac-detail-item"><span>Daily stall fee</span><strong>@Money(nd.DailyFeeCollected)</strong></div>
                                                <div class="fac-detail-item"><span>Fish KG</span><strong>@Money(nd.FishCollected)</strong></div>
                                                @if (other > 0)
                                                {
                                                    <div class="fac-detail-item"><span>Utilities / other</span><strong>@Money(other)</strong></div>
                                                }
                                                <div class="fac-detail-item fac-detail-total"><span>Total collected</span><strong>@Money(f.Collected)</strong></div>
                                            </div>
                                            <div class="fac-detail-group">
                                                <div class="fac-detail-heading">Outstanding</div>
                                                <div class="fac-detail-item"><span>Unpaid this period (assessed − collected)</span><strong class="fac-detail-red">@Money(nd.PeriodBalance)</strong></div>
                                                @if (nd.FullMonthCoverage > 0)
                                                {
                                                    <div class="fac-detail-item"><span>Full-month coverage (₱900/stall, less absent)</span><strong>@Money(nd.FullMonthCoverage)</strong></div>
                                                    @if (nd.ExcusedAmount > 0)
                                                    {
                                                        <div class="fac-detail-item"><span>Excused (absent days)</span><strong class="fac-detail-amber">@Money(nd.ExcusedAmount)</strong></div>
                                                    }
                                                    <div class="fac-detail-item"><span>Full-month coverage balance</span><strong class="fac-detail-red">@Money(nd.FullMonthCoverageBalance)</strong></div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                    <tfoot>
                        <tr class="fac-foot">
                            <td colspan="2"><strong>Total — @ScopeLabel</strong></td>
                            <td class="mono-num"><strong>@Money(Model.Collected)</strong></td>
                            <td class="mono-num" style="color:var(--red);"><strong>@Money(Model.CurrentPeriodUnpaid)</strong></td>
                            <td class="mono-num"><strong>@Model.PaidRecords</strong></td>
                            <td style="font-weight:700;color:var(--navy);"><strong>@Model.CollectionRatePct%</strong></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
            <div class="rpt-legend-note">
                <span class="rpt-legend-dot"></span>
                All EEMO facilities are included regardless of collection model.
                Per-head (SLH), per-trip (TRM) and weekly-market (TPM) facilities are paid on service at the point of collection, so they carry no recurring unpaid balance and show a 100% rate.
            </div>
        </div>

        <!-- RECENT COLLECTION RECORDS -->
        <div class="section-card" style="margin-bottom:20px;">
            <div class="section-header">
                <div>
                    <div class="section-title">Recent Collection Records</div>
                    <div class="section-sub">Latest recorded payments · @ScopeLabel</div>
                </div>
            </div>
            <div class="rpt-table-scroll">
                <table class="tx-table">
                    <thead>
                        <tr>
                            <th scope="col">OR / Ref #</th>
                            <th scope="col">Payor / Stall</th>
                            <th scope="col">Facility</th>
                            <th scope="col">Date</th>
                            <th scope="col">Type</th>
                            <th scope="col">Amount</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.RecentRecords.Count == 0)
                        {
                            <tr><td colspan="6"><div class="rpt-empty">No records for @ScopeLabel.</div></td></tr>
                        }
                        @foreach (var tx in Model.RecentRecords)
                        {
                            <tr>
                                <td class="tx-id">@tx.Reference</td>
                                <td><a href="@ProfileUrl(tx.FacilityCode, tx.StallNo)" class="vendor-link">@tx.Payor</a></td>
                                <td><span class="fac-code-badge">@tx.FacilityCode</span></td>
                                <td style="color:var(--text-muted);font-size:12.5px;">@tx.RecordedAt.ToString("MMM d, yyyy")</td>
                                <td><span class="pay-method">@tx.Method</span></td>
                                <td class="amount-green">@Money(tx.Amount)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

</div>

@code {
    // ── Filter selection ── (defaults to the current Philippine month/year)
    private string ActiveTab = "Monthly";
    private string SelectedYear = PhilippineTime.Today.Year.ToString();
    private string SelectedMonth = PhilippineTime.Today.ToString("MMMM", System.Globalization.CultureInfo.InvariantCulture);
    private string SelectedFacility = "All";

    private FinancialReportDto? Model;
    private bool Loading = true;

    [PersistentState(AllowUpdates = true)]
    public FinancialReportPageState? CachedFinancialReport { get; set; }

    private readonly HashSet<FacilityCode> _expandedFacilities = new();

    private void ToggleFacility(FacilityCode code, bool expandable)
    {
        if (!expandable) return;
        if (!_expandedFacilities.Add(code)) _expandedFacilities.Remove(code);
    }

    private DateTime GeneratedOn => PhilippineTime.Now;

    private static readonly List<string> Months = new()
    {
        "January","February","March","April","May","June",
        "July","August","September","October","November","December"
    };

    // Year options: the current Philippine year and the two prior years. Computed per render so it
    // always includes the current year (the default), even across a year rollover without a restart.
    private List<int> Years => Enumerable.Range(PhilippineTime.Today.Year - 2, 3).ToList();

    // Option lists for the custom Year/Month dropdowns (value == label for both).
    private IReadOnlyList<(string Value, string Label)> YearOptions =>
        Years.OrderByDescending(y => y).Select(y => (y.ToString(), y.ToString())).ToList();
    private IReadOnlyList<(string Value, string Label)> MonthOptions =>
        Months.Select(m => (m, m)).ToList();

    private async Task OnYearChanged(string value) { SelectedYear = value; await Load(); }
    private async Task OnMonthChanged(string value) { SelectedMonth = value; await Load(); }

    private static readonly List<(string Code, string Label)> FacilityOptions = new()
    {
        ("All", "All Facilities"),
        ("NPM", "New Public Market"),
        ("TCC", "Tampak Comm."),
        ("NCC", "New Comm. Center"),
        ("BBQ", "BBQ Stand"),
        ("ICE", "Iceplant"),
        ("SLH", "Slaughterhouse"),
        ("TRM", "Transport Terminal"),
        ("TPM", "Tabo-an Market"),
    };

    // Authoritative scope labels (fall back to selection before/while loading).
    private string PeriodLabel => Model?.PeriodLabel
        ?? (ActiveTab == "Monthly" ? $"{SelectedMonth} {SelectedYear}" : SelectedYear);
    private string ScopeLabel => Model?.ScopeLabel
        ?? (SelectedFacility == "All" ? "All facilities" : FacilityOptions.First(o => o.Code == SelectedFacility).Label);
    private string FrequencyLabel => Model?.Frequency ?? ActiveTab;

    protected override async Task OnInitializedAsync()
    {
        if (TryApplyCachedFinancialReport())
            return;

        await Load();
    }

    private async Task SetTab(string tab)
    {
        ActiveTab = tab;
        await Load();
    }

    private async Task SelectFacility(string code)
    {
        SelectedFacility = code;
        await Load();
    }

    private async Task Load()
    {
        // Keep the currently-shown report visible while the new one loads (a small "Refreshing…" cue
        // shows instead of blanking the page). Only the very first load shows the full loading state.
        Loading = true;
        await PaintLoadingStateAsync();

        var period = ActiveTab == "Annual" ? ReportPeriod.Yearly : ReportPeriod.Monthly;
        var year = int.Parse(SelectedYear);
        int? month = period == ReportPeriod.Monthly ? Months.IndexOf(SelectedMonth) + 1 : null;
        FacilityCode? facility = SelectedFacility == "All" ? null : Enum.Parse<FacilityCode>(SelectedFacility);

        // Cold-start resilience: tolerate the brief window before the circuit attaches the JWT.
        var loaded = false;
        for (var attempt = 0; attempt < 5; attempt++)
        {
            var result = await ReportsApi.GetFinancialReportAsync(period, year, month, facility);
            if (result.IsSuccess)
            {
                Model = result.Value;
                if (Model is not null)
                {
                    CachedFinancialReport = new FinancialReportPageState(
                        ActiveTab,
                        SelectedYear,
                        SelectedMonth,
                        SelectedFacility,
                        Model);
                }

                loaded = true;
                break;
            }
            if (result.StatusCode is not (401 or 403))
                break;
            await Task.Delay(400);
        }

        // The old report stays visible only while a NEW one is loading; if the load definitively
        // fails, clear it so the error state shows for the new selection (never stale data).
        if (!loaded)
            Model = null;

        // Recompute the y-axis scale for the new data and bump the epoch so bars re-animate.
        var trendMax = TrendBars.Count == 0 ? 0m : TrendBars.Max(t => Math.Max(t.Collected, t.Unpaid));
        _scale = ComputeTrendScale(trendMax);
        _renderEpoch++;

        Loading = false;
        StateHasChanged();
    }

    private bool TryApplyCachedFinancialReport()
    {
        if (CachedFinancialReport is not { } state
            || state.ActiveTab != ActiveTab
            || state.SelectedYear != SelectedYear
            || state.SelectedMonth != SelectedMonth
            || state.SelectedFacility != SelectedFacility)
        {
            return false;
        }

        Model = state.Model;
        var trendMax = TrendBars.Count == 0 ? 0m : TrendBars.Max(t => Math.Max(t.Collected, t.Unpaid));
        _scale = ComputeTrendScale(trendMax);
        _renderEpoch++;
        Loading = false;
        return true;
    }

    // ── Trend scaling (nice round axis + tight ceiling so bars stay tall) ──
    private async Task PaintLoadingStateAsync()
    {
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
    }

    private List<ReportTrendPointDto> TrendBars =>
        (Model?.Trend ?? new List<ReportTrendPointDto>()).TakeLast(6).ToList();

    private int _renderEpoch;                                   // bumped each load → bar-grow animation replays
    private (decimal Ceiling, decimal Step) _scale = (1000m, 250m);

    // Smallest "nice" step (1 / 2 / 2.5 / 5 × 10ⁿ) whose ceiling needs ≤ 5 intervals. Produces round
    // labels (₱100k, ₱200k, …) and a ceiling just above the data, so bars stay tall instead of stubby.
    private static (decimal Ceiling, decimal Step) ComputeTrendScale(decimal max)
    {
        if (max <= 0) return (1000m, 250m);
        decimal[] mantissas = { 1m, 2m, 2.5m, 5m };
        for (var e = 0; e <= 12; e++)
        {
            var pow = (decimal)Math.Pow(10, e);
            foreach (var man in mantissas)
            {
                var step = man * pow;
                var intervals = (int)Math.Ceiling(max / step);
                if (intervals <= 5)
                {
                    var ceiling = step * intervals;
                    // Headroom: keep the tallest bar off the top gridline (never above ~90% of the ceiling).
                    while (max > 0.9m * ceiling)
                        ceiling += step;
                    return (ceiling, step);
                }
            }
        }
        return (max, max);
    }

    private int Pct(decimal v)
    {
        var ceiling = _scale.Ceiling;
        if (ceiling <= 0) return 0;
        return Math.Clamp((int)Math.Round(v / ceiling * 100m), 0, 100);
    }

    // Axis labels top → bottom: ceiling, ceiling − step, … , ₱0 (one gridline per label).
    private List<string> AxisLabels
    {
        get
        {
            var (ceiling, step) = _scale;
            if (step <= 0) return new List<string> { AxisFmt(ceiling), "₱0" };
            var labels = new List<string>();
            for (var v = ceiling; v >= 0; v -= step)
                labels.Add(AxisFmt(v));
            return labels;
        }
    }

    private static string AxisFmt(decimal v)
    {
        if (v <= 0) return "₱0";
        if (v >= 1_000_000m) return "₱" + (v / 1_000_000m).ToString("0.##") + "M";
        if (v >= 1_000m) return "₱" + (v / 1_000m).ToString("0.#") + "k";
        return "₱" + v.ToString("0");
    }

    private static string Money(decimal v) => "₱" + v.ToString("N0");

    private static string MonthsLabel(int months) => $"{months} unpaid month{(months == 1 ? "" : "s")}";

    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "—";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return parts.Length == 1
            ? parts[0][..1].ToUpper()
            : (parts[0][..1] + parts[^1][..1]).ToUpper();
    }

    private static string StatusClass(string status) => status switch
    {
        "Good" => "good",
        "On track" => "warn",
        "Behind" => "bad",
        "Paid on service" => "good",
        _ => "muted"
    };

    private static string ProfileUrl(FacilityCode code, string stallNo) =>
        $"/profile/{code.ToString().ToLower()}/{stallNo}";

    public sealed record FinancialReportPageState(
        string ActiveTab,
        string SelectedYear,
        string SelectedMonth,
        string SelectedFacility,
        FinancialReportDto Model);

    // Export PDF = browser print of the report. A scoped @media print stylesheet (Report.razor.css)
    // narrows the printed page to the header + KPIs + Revenue Trend + Revenue by Facility, laid out
    // cleanly on paper. "Save as PDF" in the print dialog produces the PDF.
    private async Task ExportPdf() => await JS.InvokeVoidAsync("print");
}
