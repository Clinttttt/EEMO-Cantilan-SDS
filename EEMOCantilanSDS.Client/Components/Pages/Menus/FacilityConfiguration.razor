@page "/settings/facilities"
@using EEMOCantilanSDS.Application.Dtos.Facilities
@using EEMOCantilanSDS.Application.Command.Facilities.AddFacility
@using EEMOCantilanSDS.Application.Command.Facilities.UpdateFacility
@using EEMOCantilanSDS.Application.Dtos.TaboanMarket
@using EEMOCantilanSDS.Application.Dtos.TransportTerminal
@using EEMOCantilanSDS.Application.Dtos.Slaughterhouse
@using EEMOCantilanSDS.Domain.Enums
@attribute [Authorize(Roles = "SuperAdmin")]
@inject IFacilitiesApiClient FacilitiesApi
@inject ITpmApiClient TpmApi
@inject ITrmApiClient TrmApi
@inject ISlaughterApiClient SlaughterApi

@*
    Facility Configuration. The Head's own municipality only (API scopes every row to the caller's tenant).
    Read: configured facilities with billing model, status, unit count, and current effective rates.
    Write (safe/additive): add a standard type with a custom name; set the LGU's own fixed ordinance rates
    (SetFacilityRate — effective today, never retroactive). No changes to the enum-keyed collection/report
    core, so Cantilan and the Phase-0 goldens are unaffected.
*@

<PageTitle>@Branding.OfficeAcronym Admin — Facility Configuration</PageTitle>

<header class="topbar">
    <div class="topbar-left">
        <div class="topbar-title">Facility Configuration</div>
        <div class="topbar-breadcrumb">
            <span>@Branding.OfficeAcronym Admin</span>
            <span class="breadcrumb-sep">/</span>
            <a class="breadcrumb-link" href="/settings">Settings</a>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Facilities</span>
        </div>
    </div>
    <div class="topbar-right">
        <AccountChip />
    </div>
</header>

<div class="content-area">

    @{
        var loaded = _model is not null;
        var configuredCount = _model?.Configured.Count ?? 0;
        var activeCount = _model?.Configured.Count(f => f.IsActive) ?? 0;
        var availableCount = _model?.Available.Count ?? 0;
    }

    <!-- ── Hero ── -->
    <div class="vs-hero">
        <div class="vs-hero-left">
            <div class="vs-hero-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 21h18" /><path d="M5 21V7l8-4v18" /><path d="M19 21V11l-6-4" />
                    <path d="M9 9v.01M9 12v.01M9 15v.01M9 18v.01" />
                </svg>
            </div>
            <div>
                <div class="vs-hero-eyebrow">@Branding.OfficeAcronym Admin · Facilities</div>
                <div class="vs-hero-title">Facility Configuration</div>
                <div class="vs-hero-sub">Your municipality's facilities &amp; ordinance rates</div>
            </div>
        </div>
        <div class="vs-hero-stats">
            <div class="vs-hero-stat">
                <div class="vs-hero-val">@configuredCount</div>
                <div class="vs-hero-key">Configured</div>
                <div class="vs-hero-sub2">Operating</div>
            </div>
            <div class="vs-hero-divider"></div>
            <div class="vs-hero-stat">
                <div class="vs-hero-val">@activeCount</div>
                <div class="vs-hero-key">Active</div>
                <div class="vs-hero-sub2">Collecting</div>
            </div>
            <div class="vs-hero-divider"></div>
            <div class="vs-hero-stat">
                <div class="vs-hero-val">@availableCount</div>
                <div class="vs-hero-key">Available</div>
                <div class="vs-hero-sub2">To add</div>
            </div>
        </div>
    </div>

    @if (_error is not null)
    {
        <div class="set-state">
            <div class="set-state-title">Couldn't load facilities</div>
            <div class="set-state-text">@_error</div>
            <button class="set-retry" @onclick="LoadAsync">Try again</button>
        </div>
    }
    else
    {
        <!-- ── Configured facilities ── -->
        <section class="set-card">
            <div class="set-card-head">
                <div class="set-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                </div>
                <div class="set-card-titles">
                    <div class="set-card-title">Configured facilities</div>
                    <div class="set-card-sub">@(loaded ? $"{configuredCount} facilit{(configuredCount == 1 ? "y" : "ies")} · select one to configure its rates" : "Select a facility to configure its rates")</div>
                </div>
            </div>

            @if (!loaded)
            {
                <div class="fac-grid">
                    @for (var i = 0; i < 4; i++)
                    {
                        <div class="fac-card fac-card-skeleton">
                            <Skeleton Width="52px" Height="52px" Radius="12px" />
                            <Skeleton Width="70%" Height="14px" Radius="6px" />
                            <Skeleton Width="45%" Height="11px" Radius="6px" />
                            <Skeleton Width="100%" Height="11px" Radius="6px" />
                        </div>
                    }
                </div>
            }
            else if (configuredCount == 0)
            {
                <div class="fac-empty">No facilities are configured yet for this municipality.</div>
            }
            else
            {
                <div class="fac-grid">
                    @foreach (var f in _model!.Configured)
                    {
                        <button type="button" class="fac-card fac-card-btn @(f.IsActive ? "" : "fac-card-inactive")" @onclick="() => OpenConfigure(f)">
                            <div class="fac-card-top">
                                <div class="fac-badge">@f.ShortName</div>
                                <div class="fac-titles">
                                    <div class="fac-name">@f.Name</div>
                                </div>
                                <span class="fac-pill @(f.IsActive ? "fac-pill-on" : "fac-pill-off")">@(f.IsActive ? "Active" : "Inactive")</span>
                            </div>

                            <div class="fac-meta">
                                <span class="fac-meta-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21V8l8-5 8 5v13" /><path d="M9 21v-6h6v6" /></svg>
                                    @f.BillingModel
                                </span>
                                @if (f.StallCount > 0)
                                {
                                    <span class="fac-meta-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                                        @f.StallCount unit@(f.StallCount == 1 ? "" : "s")
                                    </span>
                                }
                            </div>

                            <div class="fac-rates">
                                @if (f.Rates.Count == 0)
                                {
                                    <div class="fac-rate-none">Rents set per stall</div>
                                }
                                else
                                {
                                    @foreach (var r in f.Rates)
                                    {
                                        <div class="fac-rate">
                                            <span class="fac-rate-label">@r.Label</span>
                                            <span class="fac-rate-dots"></span>
                                            <span class="fac-rate-amt">₱@r.Amount.ToString("N2")</span>
                                        </div>
                                    }
                                }
                            </div>
                            <span class="fac-card-cta">Configure <span aria-hidden="true">→</span></span>
                        </button>
                    }
                </div>
            }
        </section>

        <!-- ── Available to add ── -->
        <section class="set-card">
            <div class="set-card-head">
                <div class="set-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                </div>
                <div class="set-card-titles">
                    <div class="set-card-title">Available to add</div>
                    <div class="set-card-sub">Standard facility types not yet configured</div>
                </div>
            </div>

            @if (!loaded)
            {
                <div class="avail-grid">
                    @for (var i = 0; i < 3; i++)
                    {
                        <div class="avail-tile"><Skeleton Width="60%" Height="12px" Radius="6px" /></div>
                    }
                </div>
            }
            else if (availableCount == 0)
            {
                <div class="fac-empty">All standard facility types are already configured.</div>
            }
            else
            {
                <div class="avail-grid">
                    @foreach (var a in _model!.Available)
                    {
                        <button type="button" class="avail-tile avail-tile-btn @(a.IsCustom ? "avail-tile-custom" : "")" @onclick="() => OpenAdd(a)" title="@("Add " + a.Name)">
                            <div class="avail-tile-badge">@(a.IsCustom ? "＋" : a.ShortName)</div>
                            <div class="avail-tile-body">
                                <div class="avail-tile-name">@a.Name</div>
                                <div class="avail-tile-model">@a.BillingModel@(a.IsCustom ? " · your own name" : "")</div>
                            </div>
                            <span class="avail-tile-add">+ Add</span>
                        </button>
                    }
                </div>
            }
        </section>
    }
</div>

@* ── Configuration drawer (slide-over) ── *@
@if (_drawer != DrawerMode.None)
{
    <div class="cfg-scrim" @onclick="CloseDrawer"></div>
    <aside class="cfg-drawer" role="dialog" aria-modal="true">

        @if (_drawer == DrawerMode.Add && _addTarget is not null)
        {
            <div class="cfg-head">
                <div class="cfg-head-eyebrow">Add facility</div>
                <div class="cfg-head-title">@_addTarget.Name</div>
                <div class="cfg-head-sub">@_addTarget.BillingModel@(_addTarget.IsCustom ? "" : " · " + _addTarget.Code)</div>
                <button class="cfg-close" @onclick="CloseDrawer" aria-label="Close">✕</button>
            </div>

            <div class="cfg-body">
                <div class="cfg-section-label">Identity</div>
                <label class="fac-field">
                    <span class="fac-field-label">Facility name</span>
                    <input class="fac-input" @bind="_addName" @bind:event="oninput" maxlength="120" placeholder="@_addTarget.Name" />
                </label>
                <label class="fac-field">
                    <span class="fac-field-label">Short name</span>
                    <input class="fac-input" @bind="_addShortName" @bind:event="oninput" maxlength="16" />
                </label>
                <label class="fac-field">
                    <span class="fac-field-label">Description <span class="fac-field-opt">(optional)</span></span>
                    <input class="fac-input" @bind="_addDescription" @bind:event="oninput" maxlength="400" placeholder="Short note shown on this facility" />
                </label>

                <div class="cfg-hint">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>
                    Fixed fees start at the standard ordinance rates and can be adjusted after adding. Monthly-rental rates are set per stall.
                </div>

                @if (_addError is not null)
                {
                    <div class="cfg-error">@_addError</div>
                }
            </div>

            <div class="cfg-foot">
                <button class="fac-btn fac-btn-ghost" @onclick="CloseDrawer" disabled="@_busy">Cancel</button>
                <button class="fac-btn fac-btn-primary" @onclick="SubmitAdd"
                        disabled="@(_busy || string.IsNullOrWhiteSpace(_addName) || string.IsNullOrWhiteSpace(_addShortName))">
                    @(_busy ? "Adding…" : "Add facility")
                </button>
            </div>
        }
        else if (_drawer == DrawerMode.Configure && _cfgFacility is not null)
        {
            <div class="cfg-head">
                <div class="cfg-head-eyebrow">Configure facility</div>
                <div class="cfg-head-title">@_cfgFacility.Name</div>
                <div class="cfg-head-sub">@_cfgFacility.BillingModel@(IsCustom(_cfgFacility.Code) ? "" : " · " + _cfgFacility.Code)</div>
                <button class="cfg-close" @onclick="CloseDrawer" aria-label="Close">✕</button>
            </div>

            <div class="cfg-body">
                <div class="cfg-summary">
                    <div class="cfg-summary-item"><span>Status</span><strong class="@(_cfgFacility.IsActive ? "cfg-on" : "cfg-off")">@(_cfgFacility.IsActive ? "Active" : "Inactive")</strong></div>
                    <div class="cfg-summary-item"><span>Billing</span><strong>@_cfgFacility.BillingModel</strong></div>
                    @if (_cfgFacility.StallCount > 0)
                    {
                        <div class="cfg-summary-item"><span>Units</span><strong>@_cfgFacility.StallCount</strong></div>
                    }
                </div>

                <div class="cfg-section-label">Identity</div>
                <label class="fac-field">
                    <span class="fac-field-label">Facility name</span>
                    <input class="fac-input" @bind="_cfgName" @bind:event="oninput" maxlength="120" />
                </label>
                <div class="cfg-field-row">
                    <label class="fac-field">
                        <span class="fac-field-label">Short name</span>
                        <input class="fac-input" @bind="_cfgShortName" @bind:event="oninput" maxlength="16" />
                    </label>
                    @if (!IsCustom(_cfgFacility.Code))
                    {
                        <div class="cfg-field-code">
                            <span class="fac-field-label">Code</span>
                            <div class="cfg-code-chip">@_cfgFacility.Code</div>
                        </div>
                    }
                </div>
                <label class="fac-field">
                    <span class="fac-field-label">Description <span class="fac-field-opt">(optional)</span></span>
                    <input class="fac-input" @bind="_cfgDescription" @bind:event="oninput" maxlength="400" placeholder="Short note shown on this facility" />
                </label>

                @if (_cfgFacility is not null && string.Equals(_cfgFacility.Code, "NPM", StringComparison.OrdinalIgnoreCase))
                {
                    <div class="cfg-section-label">Market section names</div>
                    <div class="cfg-hint">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>
                        Rename how your market sections appear across the dashboard and reports (e.g. &ldquo;Gulayan&rdquo; for the vegetable area). Leave blank to use the default label.
                    </div>
                    <label class="fac-field">
                        <span class="fac-field-label">Vegetable area</span>
                        <input class="fac-input" @bind="_cfgVeg" @bind:event="oninput" maxlength="60" placeholder="Vegetable Area" />
                    </label>
                    <label class="fac-field">
                        <span class="fac-field-label">Fish area</span>
                        <input class="fac-input" @bind="_cfgFish" @bind:event="oninput" maxlength="60" placeholder="Fish Area" />
                    </label>
                    <label class="fac-field">
                        <span class="fac-field-label">Meat area</span>
                        <input class="fac-input" @bind="_cfgMeat" @bind:event="oninput" maxlength="60" placeholder="Meat Area" />
                    </label>
                }

                <div class="cfg-section-label">Fixed ordinance rates</div>

                @if (_cfgFacility.Rates.Count == 0)
                {
                    <div class="cfg-hint">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>
                        This facility has no fixed ordinance rate. Monthly rents are set per stall on the Vendors &amp; Stalls page.
                    </div>
                }
                else
                {
                    <div class="cfg-rate-list">
                        @foreach (var r in _cfgFacility.Rates)
                        {
                            <div class="cfg-rate">
                                <div class="cfg-rate-info">
                                    <span class="cfg-rate-label">@r.Label</span>
                                    @if (!r.IsCustom)
                                    {
                                        <span class="cfg-rate-tag">default</span>
                                    }
                                </div>
                                <div class="cfg-rate-input">
                                    <span class="cfg-peso">₱</span>
                                    <input type="number" step="0.01" min="0" inputmode="decimal"
                                           value="@FormatRate(_rateEdits.GetValueOrDefault(r.Key, r.Amount))"
                                           @onchange="e => SetRateEdit(r.Key, e.Value?.ToString())" />
                                </div>
                            </div>
                        }
                    </div>
                    <div class="cfg-hint">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" /></svg>
                        Rate changes take effect today and are never applied retroactively — already-billed periods keep their original amounts.
                    </div>
                }

                <div class="cfg-section-label">Status &amp; history</div>
                <button class="cfg-history-btn" @onclick="() => OpenHistory(_cfgFacility)">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>
                    View collection history
                </button>

                @if (_cfgFacility.IsActive)
                {
                    @if (_confirmDeactivate)
                    {
                        <div class="cfg-danger">
                            <div class="cfg-danger-text">Deactivate <strong>@_cfgFacility.Name</strong>? It will be hidden from the operational menus (sidebar &amp; dashboard). All history is kept and you can reactivate it anytime.</div>
                            <div class="cfg-danger-actions">
                                <button class="fac-btn fac-btn-ghost" @onclick="() => _confirmDeactivate = false" disabled="@_busy">Keep active</button>
                                <button class="fac-btn fac-btn-danger" @onclick="() => SetStatus(false)" disabled="@_busy">@(_busy ? "Working…" : "Deactivate")</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <button class="cfg-deactivate" @onclick="() => _confirmDeactivate = true" disabled="@_busy">Deactivate facility</button>
                    }
                }
                else
                {
                    <div class="cfg-inactive-note">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" /></svg>
                        Hidden from the operational menus. History stays available above; reactivate to resume collections.
                    </div>
                    <button class="fac-btn fac-btn-primary cfg-reactivate" @onclick="() => SetStatus(true)" disabled="@_busy">@(_busy ? "Working…" : "Reactivate facility")</button>
                }

                @if (_cfgError is not null)
                {
                    <div class="cfg-error">@_cfgError</div>
                }
                @if (_cfgSuccess is not null)
                {
                    <div class="cfg-success">@_cfgSuccess</div>
                }
            </div>

            <div class="cfg-foot">
                <button class="fac-btn fac-btn-ghost" @onclick="CloseDrawer" disabled="@_busy">Close</button>
                <button class="fac-btn fac-btn-primary" @onclick="SaveChanges" disabled="@(_busy || !HasChanges())">
                    @(_busy ? "Saving…" : "Save changes")
                </button>
            </div>
        }
    </aside>
}

@* ── Collection history (per-facility per-stall reference table, like the Month-End Report) ── *@
@if (_historyOpen)
{
    <div class="cfg-scrim" @onclick="CloseHistory"></div>
    <div class="hist-modal" role="dialog" aria-modal="true">
        <div class="hist-head">
            <div class="hist-head-titles">
                <div class="cfg-head-eyebrow">Collection history</div>
                <div class="hist-title">@_historyName</div>
            </div>
            <div class="hist-yearnav">
                <button @onclick="() => ChangeMonth(-1)" disabled="@_historyLoading" aria-label="Previous month">‹</button>
                <span>@_historyPeriodLabel</span>
                <button @onclick="() => ChangeMonth(1)" disabled="@(_historyLoading || _isCurrentPeriod)" aria-label="Next month">›</button>
            </div>
            <button class="cfg-close cfg-close-dark" @onclick="CloseHistory" aria-label="Close">✕</button>
        </div>

        @if (_isTxnFacility && _historyError is null)
        {
            <div class="hist-summary">
                <span><strong>₱@_txnCollected.ToString("N2")</strong> collected</span>
                <span class="hist-summary-muted">Per-transaction facility</span>
            </div>
        }
        else if (_report is not null && _historyError is null)
        {
            <div class="hist-summary">
                <span><strong>₱@_report.TotalRevenue.ToString("N2")</strong> collected</span>
                <span><strong class="hist-out">₱@_report.PendingPaymentAmount.ToString("N2")</strong> outstanding</span>
                <span><strong>@_report.CollectionRate.ToString("0.#")%</strong> rate</span>
                <span class="hist-summary-muted">@_report.OccupiedStalls of @_report.TotalStalls occupied</span>
            </div>
        }

        <div class="hist-body">
            @if (_historyError is not null)
            {
                <div class="cfg-error">@_historyError</div>
            }
            else if (_historyLoading)
            {
                <div class="hist-loading"><span class="set-spinner"></span></div>
            }
            else if (_isTxnFacility && _historyCode == FacilityCode.TPM)
            {
                @if (_tpmRows.Count == 0)
                {
                    <div class="fac-empty">No vendor entries for @_historyPeriodLabel.</div>
                }
                else
                {
                    <table class="hist-table">
                        <thead>
                            <tr>
                                <th>#</th><th>Vendor</th><th>Goods / Product</th><th>Market day</th>
                                <th class="hist-r">OR No.</th><th class="hist-r">Fee</th><th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var tpmIdx = 1; }
                            @foreach (var a in _tpmRows.OrderByDescending(x => x.MarketDate).ThenBy(x => x.VendorName))
                            {
                                <tr>
                                    <td>@(tpmIdx++)</td>
                                    <td>@a.VendorName</td>
                                    <td>@(string.IsNullOrWhiteSpace(a.Goods) ? "—" : a.Goods)</td>
                                    <td>@a.MarketDate.ToString("MMM d, yyyy")</td>
                                    <td class="hist-r hist-or">@(string.IsNullOrWhiteSpace(a.ORNumber) ? "—" : a.ORNumber)</td>
                                    <td class="hist-r">₱@a.Fee.ToString("N2")</td>
                                    <td><span class="hist-status hist-@(a.IsPaid ? "paid" : "unpaid")">@(a.IsPaid ? "Paid" : "Unpaid")</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            else if (_isTxnFacility && _historyCode == FacilityCode.TRM)
            {
                @if (_trmRows.Count == 0)
                {
                    <div class="fac-empty">No trips recorded for @_historyPeriodLabel.</div>
                }
                else
                {
                    <table class="hist-table">
                        <thead>
                            <tr>
                                <th>Trip</th><th>Driver</th><th>Organization</th><th>Route</th><th>Date</th>
                                <th class="hist-r">OR No.</th><th class="hist-r">Fee</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var trip in _trmRows.OrderByDescending(x => x.RecordedAt))
                            {
                                <tr>
                                    <td>@trip.TripNumber</td>
                                    <td>@(string.IsNullOrWhiteSpace(trip.DriverName) ? "—" : trip.DriverName)</td>
                                    <td>@(string.IsNullOrWhiteSpace(trip.Organization) ? "—" : trip.Organization)</td>
                                    <td>@(string.IsNullOrWhiteSpace(trip.Route) ? "—" : trip.Route)</td>
                                    <td>@PhilippineTime.ToPhilippineTime(trip.RecordedAt).ToString("MMM d, yyyy")</td>
                                    <td class="hist-r hist-or">@(string.IsNullOrWhiteSpace(trip.ORNumber) ? "—" : trip.ORNumber)</td>
                                    <td class="hist-r">₱@trip.Fee.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            else if (_isTxnFacility && _historyCode == FacilityCode.SLH)
            {
                @if (_slhRows.Count == 0)
                {
                    <div class="fac-empty">No slaughter transactions for @_historyPeriodLabel.</div>
                }
                else
                {
                    <table class="hist-table">
                        <thead>
                            <tr>
                                <th>#</th><th>Owner</th><th>Animal</th><th class="hist-r">Heads</th><th>Date</th>
                                <th class="hist-r">OR No.</th><th class="hist-r">Amount</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{ var slhIdx = 1; }
                            @foreach (var tx in _slhRows.OrderByDescending(x => x.TransactionDate).ThenBy(x => x.OwnerName))
                            {
                                <tr>
                                    <td>@(slhIdx++)</td>
                                    <td>@tx.OwnerName</td>
                                    <td>@(!string.IsNullOrWhiteSpace(tx.CustomAnimalType) ? tx.CustomAnimalType : tx.AnimalType.ToString())</td>
                                    <td class="hist-r">@tx.NumberOfHeads</td>
                                    <td>@tx.TransactionDate.ToString("MMM d, yyyy")</td>
                                    <td class="hist-r hist-or">@(string.IsNullOrWhiteSpace(tx.ORNumber) ? "—" : tx.ORNumber)</td>
                                    <td class="hist-r">₱@tx.TotalAmount.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            }
            else if (_report is null)
            {
                <div class="hist-loading"><span class="set-spinner"></span></div>
            }
            else if (_report.StallCompliance.Count == 0)
            {
                <div class="fac-empty">No stall-level records for @_historyPeriodLabel. This may be a per-transaction facility, or there was no activity in this period.</div>
            }
            else
            {
                <table class="hist-table">
                    <thead>
                        <tr>
                            <th>Stall</th><th>Payor</th><th class="hist-r">Rate</th><th>Status</th>
                            <th class="hist-r">Collected</th><th class="hist-r">Balance</th><th class="hist-r">OR No.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var s in _report.StallCompliance)
                        {
                            <tr>
                                <td class="hist-stall">@s.StallNo</td>
                                <td>@(string.IsNullOrWhiteSpace(s.Occupant) ? "—" : s.Occupant)</td>
                                <td class="hist-r">@(s.MonthlyRate > 0 ? $"₱{s.MonthlyRate:N2}" : s.DailyRate > 0 ? $"₱{s.DailyRate:N2}/day" : "—")</td>
                                <td><span class="hist-status hist-@s.Status.ToLowerInvariant()">@s.Status</span></td>
                                <td class="hist-r">₱@s.AmountPaid.ToString("N2")</td>
                                <td class="hist-r">@(s.Balance > 0 ? $"₱{s.Balance:N2}" : "—")</td>
                                <td class="hist-r hist-or">@(string.IsNullOrWhiteSpace(s.ORNumber) ? "—" : s.ORNumber)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
}

@code {
    private FacilityConfigurationDto? _model;
    private string? _error;

    private enum DrawerMode { None, Add, Configure }
    private DrawerMode _drawer = DrawerMode.None;
    private bool _busy;

    // Add
    private AvailableFacilityDto? _addTarget;
    private string _addName = string.Empty;
    private string _addShortName = string.Empty;
    private string _addDescription = string.Empty;
    private string? _addError;

    // Configure
    private ConfiguredFacilityDto? _cfgFacility;
    private string _cfgName = string.Empty;
    private string _cfgShortName = string.Empty;
    private string _cfgDescription = string.Empty;
    private string _cfgVeg = string.Empty;
    private string _cfgFish = string.Empty;
    private string _cfgMeat = string.Empty;
    private readonly Dictionary<string, decimal> _rateEdits = new();
    private string? _cfgError;
    private string? _cfgSuccess;
    private bool _confirmDeactivate;

    // History modal
    private bool _historyOpen;
    private FacilityCode _historyCode;
    private string _historyName = string.Empty;
    private int _historyYear = PhilippineTime.Now.Year;
    private int _historyMonth = PhilippineTime.Now.Month;
    private FacilityReportsDto? _report;
    private bool _historyLoading;
    private string? _historyError;

    private string _historyPeriodLabel => new DateOnly(_historyYear, _historyMonth, 1).ToString("MMMM yyyy");
    private bool _isCurrentPeriod => _historyYear == PhilippineTime.Now.Year && _historyMonth == PhilippineTime.Now.Month;

    protected override async Task OnInitializedAsync()
    {
        await Branding.EnsureLoadedAsync();
        await LoadAsync();
    }

    // Custom facilities use an internal slot code (Custom1..5) that should never be shown to users — the
    // Head-chosen short name/acronym is displayed instead.
    private static bool IsCustom(string code) => code.StartsWith("Custom", StringComparison.OrdinalIgnoreCase);

    private async Task LoadAsync()
    {
        _error = null;
        _model = null;
        await InvokeAsync(StateHasChanged);

        var result = await FacilitiesApi.GetFacilityConfigurationAsync();
        if (result.IsSuccess && result.Value is not null)
            _model = result.Value;
        else
            _error = string.IsNullOrWhiteSpace(result.Error) ? "The facility configuration could not be retrieved." : result.Error;
    }

    // ── Drawer control ──
    private void OpenAdd(AvailableFacilityDto a)
    {
        _addTarget = a;
        // Custom facilities are Head-named — start blank so they enter their own name.
        _addName = a.IsCustom ? string.Empty : a.Name;
        _addShortName = a.IsCustom ? string.Empty : a.ShortName;
        _addDescription = string.Empty;
        _addError = null;
        _drawer = DrawerMode.Add;
    }

    private void OpenConfigure(ConfiguredFacilityDto f)
    {
        _cfgFacility = f;
        _cfgName = f.Name;
        _cfgShortName = f.ShortName;
        _cfgDescription = f.Description ?? string.Empty;
        _cfgVeg = f.VegetableSectionLabel ?? string.Empty;
        _cfgFish = f.FishSectionLabel ?? string.Empty;
        _cfgMeat = f.MeatSectionLabel ?? string.Empty;
        _rateEdits.Clear();
        foreach (var r in f.Rates) _rateEdits[r.Key] = r.Amount;
        _cfgError = null;
        _cfgSuccess = null;
        _confirmDeactivate = false;
        _drawer = DrawerMode.Configure;
    }

    private void CloseDrawer()
    {
        _drawer = DrawerMode.None;
        _addTarget = null;
        _cfgFacility = null;
        _confirmDeactivate = false;
    }

    // ── Add ──
    private async Task SubmitAdd()
    {
        if (_addTarget is null || _busy) return;
        _busy = true;
        _addError = null;

        var result = await FacilitiesApi.AddFacilityAsync(new AddFacilityCommand(
            _addTarget.Code, _addName.Trim(), _addShortName.Trim(),
            string.IsNullOrWhiteSpace(_addDescription) ? null : _addDescription.Trim()));

        _busy = false;
        if (result.IsSuccess)
        {
            CloseDrawer();
            await LoadAsync();
        }
        else
        {
            _addError = string.IsNullOrWhiteSpace(result.Error) ? "Couldn't add the facility. Please try again." : result.Error;
        }
    }

    // ── Rates ──
    private static string FormatRate(decimal v) => v.ToString("0.##");

    private void SetRateEdit(string key, string? raw)
    {
        if (decimal.TryParse(raw, out var d) && d >= 0m) _rateEdits[key] = decimal.Round(d, 2);
    }

    private bool HasIdentityChanges()
        => _cfgFacility is not null &&
           (!string.Equals(_cfgName.Trim(), _cfgFacility.Name, StringComparison.Ordinal)
            || !string.Equals(_cfgShortName.Trim(), _cfgFacility.ShortName, StringComparison.Ordinal)
            || !string.Equals(_cfgDescription.Trim(), _cfgFacility.Description ?? string.Empty, StringComparison.Ordinal)
            || !string.Equals(_cfgVeg.Trim(), _cfgFacility.VegetableSectionLabel ?? string.Empty, StringComparison.Ordinal)
            || !string.Equals(_cfgFish.Trim(), _cfgFacility.FishSectionLabel ?? string.Empty, StringComparison.Ordinal)
            || !string.Equals(_cfgMeat.Trim(), _cfgFacility.MeatSectionLabel ?? string.Empty, StringComparison.Ordinal));

    private bool HasRateChanges()
        => _cfgFacility is not null && _cfgFacility.Rates.Any(r => _rateEdits.TryGetValue(r.Key, out var v) && v != r.Amount);

    private bool HasChanges()
        => !string.IsNullOrWhiteSpace(_cfgName) && !string.IsNullOrWhiteSpace(_cfgShortName)
           && (HasIdentityChanges() || HasRateChanges());

    private async Task SaveChanges()
    {
        if (_cfgFacility is null || _busy) return;
        _busy = true;
        _cfgError = null;
        _cfgSuccess = null;

        var code = Enum.Parse<FacilityCode>(_cfgFacility.Code);
        var changes = new List<string>();

        // 1) Identity (name / short-name / description).
        if (HasIdentityChanges())
        {
            var res = await FacilitiesApi.UpdateFacilityAsync(new UpdateFacilityCommand(
                _cfgFacility.Code, _cfgName.Trim(), _cfgShortName.Trim(),
                string.IsNullOrWhiteSpace(_cfgDescription) ? null : _cfgDescription.Trim(),
                string.IsNullOrWhiteSpace(_cfgVeg) ? null : _cfgVeg.Trim(),
                string.IsNullOrWhiteSpace(_cfgFish) ? null : _cfgFish.Trim(),
                string.IsNullOrWhiteSpace(_cfgMeat) ? null : _cfgMeat.Trim()));
            if (!res.IsSuccess)
            {
                _cfgError = string.IsNullOrWhiteSpace(res.Error) ? "Couldn't save the facility details." : res.Error;
                _busy = false;
                return;
            }
            changes.Add("details");
        }

        // 2) Changed fixed rates (effective today, never retroactive).
        var changedRates = _cfgFacility.Rates.Where(r => _rateEdits.TryGetValue(r.Key, out var v) && v != r.Amount).ToList();
        foreach (var r in changedRates)
        {
            var key = Enum.Parse<FeeRateKey>(r.Key);
            var res = await FacilitiesApi.SetFacilityRateAsync(code, key, _rateEdits[r.Key]);
            if (!res.IsSuccess)
            {
                _cfgError = string.IsNullOrWhiteSpace(res.Error) ? "Couldn't save a rate. Please try again." : res.Error;
                _busy = false;
                return;
            }
        }
        if (changedRates.Count > 0) changes.Add($"{changedRates.Count} rate{(changedRates.Count == 1 ? "" : "s")}");

        _busy = false;
        await LoadAsync();

        // Re-bind the drawer to the refreshed facility so labels + amounts + default tags update.
        _cfgFacility = _model?.Configured.FirstOrDefault(x => string.Equals(x.Code, code.ToString(), StringComparison.OrdinalIgnoreCase));
        if (_cfgFacility is not null)
        {
            _cfgName = _cfgFacility.Name;
            _cfgShortName = _cfgFacility.ShortName;
            _cfgDescription = _cfgFacility.Description ?? string.Empty;
            _cfgVeg = _cfgFacility.VegetableSectionLabel ?? string.Empty;
            _cfgFish = _cfgFacility.FishSectionLabel ?? string.Empty;
            _cfgMeat = _cfgFacility.MeatSectionLabel ?? string.Empty;
            _rateEdits.Clear();
            foreach (var r in _cfgFacility.Rates) _rateEdits[r.Key] = r.Amount;
            _cfgSuccess = changes.Count > 0 ? $"Saved: {string.Join(" · ", changes)}." : null;
        }
        else
        {
            CloseDrawer();
        }
    }

    // ── Activate / deactivate ──
    private async Task SetStatus(bool active)
    {
        if (_cfgFacility is null || _busy) return;
        _busy = true;
        _cfgError = null;
        _cfgSuccess = null;

        var code = _cfgFacility.Code;
        var res = await FacilitiesApi.SetFacilityStatusAsync(code, active);
        _busy = false;
        _confirmDeactivate = false;

        if (!res.IsSuccess)
        {
            _cfgError = string.IsNullOrWhiteSpace(res.Error) ? "Couldn't change the facility status." : res.Error;
            return;
        }

        await LoadAsync();
        _cfgFacility = _model?.Configured.FirstOrDefault(x => string.Equals(x.Code, code, StringComparison.OrdinalIgnoreCase));
        if (_cfgFacility is null) { CloseDrawer(); return; }
        _cfgSuccess = active ? "Facility reactivated." : "Facility deactivated — hidden from the operational menus.";
    }

    // ── Collection history ──
    private async Task OpenHistory(ConfiguredFacilityDto f)
    {
        _historyName = f.Name;
        _historyCode = Enum.Parse<FacilityCode>(f.Code);
        _historyYear = PhilippineTime.Now.Year;
        _historyMonth = PhilippineTime.Now.Month;
        _report = null;
        _historyError = null;
        _historyOpen = true;
        await LoadHistory();
    }

    // TPM/TRM/SLH are per-transaction facilities — their collections live in transaction tables, not in
    // stall payment records, so the stall-based facility report reads ₱0 for them. Detect them and pull the
    // month's collected total from the facility's own collection history instead.
    private static bool IsTransactionFacility(FacilityCode code) =>
        code is FacilityCode.TPM or FacilityCode.TRM or FacilityCode.SLH;

    private bool _isTxnFacility;
    private decimal _txnCollected;
    private IReadOnlyList<TpmVendorAttendanceDto> _tpmRows = Array.Empty<TpmVendorAttendanceDto>();
    private IReadOnlyList<TrmTripDto> _trmRows = Array.Empty<TrmTripDto>();
    private IReadOnlyList<SlaughterTransactionDto> _slhRows = Array.Empty<SlaughterTransactionDto>();

    private async Task LoadHistory()
    {
        _historyLoading = true;
        _historyError = null;
        _report = null;
        _txnCollected = 0m;
        _isTxnFacility = IsTransactionFacility(_historyCode);
        await InvokeAsync(StateHasChanged);

        if (_isTxnFacility)
        {
            await LoadTransactionDataAsync();
            _historyLoading = false;
            return;
        }

        var res = await FacilitiesApi.GetFacilityReportsAsync(_historyCode, ReportPeriod.Monthly, _historyYear, _historyMonth);
        _historyLoading = false;
        if (res.IsSuccess && res.Value is not null)
            _report = res.Value;
        else
            _historyError = string.IsNullOrWhiteSpace(res.Error) ? "Couldn't load the collection history." : res.Error;
    }

    // Loads the selected month's per-transaction rows for a transaction facility and derives the collected
    // total from them (matches what the facility page shows). Fails soft to a zeroed/empty view.
    private async Task LoadTransactionDataAsync()
    {
        _tpmRows = Array.Empty<TpmVendorAttendanceDto>();
        _trmRows = Array.Empty<TrmTripDto>();
        _slhRows = Array.Empty<SlaughterTransactionDto>();
        _txnCollected = 0m;
        try
        {
            switch (_historyCode)
            {
                case FacilityCode.TPM:
                    var t = await TpmApi.GetMonthAttendanceAsync(_historyYear, _historyMonth);
                    if (t.IsSuccess && t.Value is not null)
                    {
                        _tpmRows = t.Value;
                        _txnCollected = _tpmRows.Where(a => a.IsPaid).Sum(a => a.Fee);
                    }
                    break;
                case FacilityCode.TRM:
                    var r = await TrmApi.GetTripsAsync(_historyYear, _historyMonth);
                    if (r.IsSuccess && r.Value is not null)
                    {
                        _trmRows = r.Value;
                        _txnCollected = _trmRows.Sum(x => x.Fee);
                    }
                    break;
                case FacilityCode.SLH:
                    var s = await SlaughterApi.GetTransactionsAsync(_historyYear, _historyMonth);
                    if (s.IsSuccess && s.Value is not null)
                    {
                        _slhRows = s.Value;
                        _txnCollected = _slhRows.Sum(x => x.TotalAmount);
                    }
                    break;
            }
        }
        catch
        {
            // Leave zeroed/empty — the modal shows a "no records" state rather than an error.
        }
    }

    private async Task ChangeMonth(int delta)
    {
        var period = new DateOnly(_historyYear, _historyMonth, 1).AddMonths(delta);
        var now = PhilippineTime.Now;
        if (period.Year > now.Year || (period.Year == now.Year && period.Month > now.Month)) return; // no future
        if (period.Year < 2000) return;
        _historyYear = period.Year;
        _historyMonth = period.Month;
        await LoadHistory();
    }

    private void CloseHistory()
    {
        _historyOpen = false;
        _report = null;
    }
}
