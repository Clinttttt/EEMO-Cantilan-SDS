@page "/settings/facilities"
@using EEMOCantilanSDS.Application.Dtos.Facilities
@using EEMOCantilanSDS.Application.Command.Facilities.AddFacility
@using EEMOCantilanSDS.Domain.Enums
@attribute [Authorize(Roles = "SuperAdmin")]
@inject IFacilitiesApiClient FacilitiesApi

@*
    Facility Configuration. The Head's own municipality only (API scopes every row to the caller's tenant).
    Read: configured facilities with billing model, status, unit count, and current effective rates.
    Write (safe/additive): add a standard type with a custom name; set the LGU's own fixed ordinance rates
    (SetFacilityRate — effective today, never retroactive). No changes to the enum-keyed collection/report
    core, so Cantilan and the Phase-0 goldens are unaffected.
*@

<PageTitle>@Branding.OfficeAcronym Admin — Facility Configuration</PageTitle>

<header class="topbar">
    <div class="topbar-left">
        <div class="topbar-title">Facility Configuration</div>
        <div class="topbar-breadcrumb">
            <span>@Branding.OfficeAcronym Admin</span>
            <span class="breadcrumb-sep">/</span>
            <a class="breadcrumb-link" href="/settings">Settings</a>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Facilities</span>
        </div>
    </div>
    <div class="topbar-right">
        <AccountChip />
    </div>
</header>

<div class="content-area">

    @{
        var loaded = _model is not null;
        var configuredCount = _model?.Configured.Count ?? 0;
        var activeCount = _model?.Configured.Count(f => f.IsActive) ?? 0;
        var availableCount = _model?.Available.Count ?? 0;
    }

    <!-- ── Hero ── -->
    <div class="vs-hero">
        <div class="vs-hero-left">
            <div class="vs-hero-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 21h18" /><path d="M5 21V7l8-4v18" /><path d="M19 21V11l-6-4" />
                    <path d="M9 9v.01M9 12v.01M9 15v.01M9 18v.01" />
                </svg>
            </div>
            <div>
                <div class="vs-hero-eyebrow">@Branding.OfficeAcronym Admin · Facilities</div>
                <div class="vs-hero-title">Facility Configuration</div>
                <div class="vs-hero-sub">Your municipality's facilities &amp; ordinance rates</div>
            </div>
        </div>
        <div class="vs-hero-stats">
            <div class="vs-hero-stat">
                <div class="vs-hero-val">@configuredCount</div>
                <div class="vs-hero-key">Configured</div>
                <div class="vs-hero-sub2">Operating</div>
            </div>
            <div class="vs-hero-divider"></div>
            <div class="vs-hero-stat">
                <div class="vs-hero-val">@activeCount</div>
                <div class="vs-hero-key">Active</div>
                <div class="vs-hero-sub2">Collecting</div>
            </div>
            <div class="vs-hero-divider"></div>
            <div class="vs-hero-stat">
                <div class="vs-hero-val">@availableCount</div>
                <div class="vs-hero-key">Available</div>
                <div class="vs-hero-sub2">To add</div>
            </div>
        </div>
    </div>

    @if (_error is not null)
    {
        <div class="set-state">
            <div class="set-state-title">Couldn't load facilities</div>
            <div class="set-state-text">@_error</div>
            <button class="set-retry" @onclick="LoadAsync">Try again</button>
        </div>
    }
    else
    {
        <!-- ── Configured facilities ── -->
        <section class="set-card">
            <div class="set-card-head">
                <div class="set-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                </div>
                <div class="set-card-titles">
                    <div class="set-card-title">Configured facilities</div>
                    <div class="set-card-sub">@(loaded ? $"{configuredCount} facilit{(configuredCount == 1 ? "y" : "ies")} · select one to configure its rates" : "Select a facility to configure its rates")</div>
                </div>
            </div>

            @if (!loaded)
            {
                <div class="fac-grid">
                    @for (var i = 0; i < 4; i++)
                    {
                        <div class="fac-card fac-card-skeleton">
                            <Skeleton Width="52px" Height="52px" Radius="12px" />
                            <Skeleton Width="70%" Height="14px" Radius="6px" />
                            <Skeleton Width="45%" Height="11px" Radius="6px" />
                            <Skeleton Width="100%" Height="11px" Radius="6px" />
                        </div>
                    }
                </div>
            }
            else if (configuredCount == 0)
            {
                <div class="fac-empty">No facilities are configured yet for this municipality.</div>
            }
            else
            {
                <div class="fac-grid">
                    @foreach (var f in _model!.Configured)
                    {
                        <button type="button" class="fac-card fac-card-btn @(f.IsActive ? "" : "fac-card-inactive")" @onclick="() => OpenConfigure(f)">
                            <div class="fac-card-top">
                                <div class="fac-badge">@f.ShortName</div>
                                <div class="fac-titles">
                                    <div class="fac-name">@f.Name</div>
                                    <div class="fac-code">@f.Code</div>
                                </div>
                                <span class="fac-pill @(f.IsActive ? "fac-pill-on" : "fac-pill-off")">@(f.IsActive ? "Active" : "Inactive")</span>
                            </div>

                            <div class="fac-meta">
                                <span class="fac-meta-item">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M4 21V8l8-5 8 5v13" /><path d="M9 21v-6h6v6" /></svg>
                                    @f.BillingModel
                                </span>
                                @if (f.StallCount > 0)
                                {
                                    <span class="fac-meta-item">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                                        @f.StallCount unit@(f.StallCount == 1 ? "" : "s")
                                    </span>
                                }
                            </div>

                            <div class="fac-rates">
                                @if (f.Rates.Count == 0)
                                {
                                    <div class="fac-rate-none">Rents set per stall</div>
                                }
                                else
                                {
                                    @foreach (var r in f.Rates)
                                    {
                                        <div class="fac-rate">
                                            <span class="fac-rate-label">@r.Label</span>
                                            <span class="fac-rate-dots"></span>
                                            <span class="fac-rate-amt">₱@r.Amount.ToString("N2")</span>
                                        </div>
                                    }
                                }
                            </div>
                            <span class="fac-card-cta">Configure <span aria-hidden="true">→</span></span>
                        </button>
                    }
                </div>
            }
        </section>

        <!-- ── Available to add ── -->
        <section class="set-card">
            <div class="set-card-head">
                <div class="set-card-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                </div>
                <div class="set-card-titles">
                    <div class="set-card-title">Available to add</div>
                    <div class="set-card-sub">Standard facility types not yet configured</div>
                </div>
            </div>

            @if (!loaded)
            {
                <div class="avail-grid">
                    @for (var i = 0; i < 3; i++)
                    {
                        <div class="avail-tile"><Skeleton Width="60%" Height="12px" Radius="6px" /></div>
                    }
                </div>
            }
            else if (availableCount == 0)
            {
                <div class="fac-empty">All standard facility types are already configured.</div>
            }
            else
            {
                <div class="avail-grid">
                    @foreach (var a in _model!.Available)
                    {
                        <button type="button" class="avail-tile avail-tile-btn" @onclick="() => OpenAdd(a)" title="@("Add " + a.Name)">
                            <div class="avail-tile-badge">@a.ShortName</div>
                            <div class="avail-tile-body">
                                <div class="avail-tile-name">@a.Name</div>
                                <div class="avail-tile-model">@a.BillingModel</div>
                            </div>
                            <span class="avail-tile-add">+ Add</span>
                        </button>
                    }
                </div>
            }
        </section>
    }
</div>

@* ── Configuration drawer (slide-over) ── *@
@if (_drawer != DrawerMode.None)
{
    <div class="cfg-scrim" @onclick="CloseDrawer"></div>
    <aside class="cfg-drawer" role="dialog" aria-modal="true">

        @if (_drawer == DrawerMode.Add && _addTarget is not null)
        {
            <div class="cfg-head">
                <div class="cfg-head-eyebrow">Add facility</div>
                <div class="cfg-head-title">@_addTarget.Name</div>
                <div class="cfg-head-sub">@_addTarget.BillingModel · @_addTarget.Code</div>
                <button class="cfg-close" @onclick="CloseDrawer" aria-label="Close">✕</button>
            </div>

            <div class="cfg-body">
                <div class="cfg-section-label">Identity</div>
                <label class="fac-field">
                    <span class="fac-field-label">Facility name</span>
                    <input class="fac-input" @bind="_addName" @bind:event="oninput" maxlength="120" placeholder="@_addTarget.Name" />
                </label>
                <label class="fac-field">
                    <span class="fac-field-label">Short name</span>
                    <input class="fac-input" @bind="_addShortName" @bind:event="oninput" maxlength="16" />
                </label>
                <label class="fac-field">
                    <span class="fac-field-label">Description <span class="fac-field-opt">(optional)</span></span>
                    <input class="fac-input" @bind="_addDescription" @bind:event="oninput" maxlength="400" placeholder="Short note shown on this facility" />
                </label>

                <div class="cfg-hint">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>
                    Fixed fees start at the standard ordinance rates and can be adjusted after adding. Monthly-rental rates are set per stall.
                </div>

                @if (_addError is not null)
                {
                    <div class="cfg-error">@_addError</div>
                }
            </div>

            <div class="cfg-foot">
                <button class="fac-btn fac-btn-ghost" @onclick="CloseDrawer" disabled="@_busy">Cancel</button>
                <button class="fac-btn fac-btn-primary" @onclick="SubmitAdd"
                        disabled="@(_busy || string.IsNullOrWhiteSpace(_addName) || string.IsNullOrWhiteSpace(_addShortName))">
                    @(_busy ? "Adding…" : "Add facility")
                </button>
            </div>
        }
        else if (_drawer == DrawerMode.Configure && _cfgFacility is not null)
        {
            <div class="cfg-head">
                <div class="cfg-head-eyebrow">Configure facility</div>
                <div class="cfg-head-title">@_cfgFacility.Name</div>
                <div class="cfg-head-sub">@_cfgFacility.BillingModel · @_cfgFacility.Code</div>
                <button class="cfg-close" @onclick="CloseDrawer" aria-label="Close">✕</button>
            </div>

            <div class="cfg-body">
                <div class="cfg-summary">
                    <div class="cfg-summary-item"><span>Status</span><strong class="@(_cfgFacility.IsActive ? "cfg-on" : "cfg-off")">@(_cfgFacility.IsActive ? "Active" : "Inactive")</strong></div>
                    <div class="cfg-summary-item"><span>Billing</span><strong>@_cfgFacility.BillingModel</strong></div>
                    @if (_cfgFacility.StallCount > 0)
                    {
                        <div class="cfg-summary-item"><span>Units</span><strong>@_cfgFacility.StallCount</strong></div>
                    }
                </div>

                <div class="cfg-section-label">Fixed ordinance rates</div>

                @if (_cfgFacility.Rates.Count == 0)
                {
                    <div class="cfg-hint">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>
                        This facility has no fixed ordinance rate. Monthly rents are set per stall on the Vendors &amp; Stalls page.
                    </div>
                }
                else
                {
                    <div class="cfg-rate-list">
                        @foreach (var r in _cfgFacility.Rates)
                        {
                            <div class="cfg-rate">
                                <div class="cfg-rate-info">
                                    <span class="cfg-rate-label">@r.Label</span>
                                    @if (!r.IsCustom)
                                    {
                                        <span class="cfg-rate-tag">default</span>
                                    }
                                </div>
                                <div class="cfg-rate-input">
                                    <span class="cfg-peso">₱</span>
                                    <input type="number" step="0.01" min="0" inputmode="decimal"
                                           value="@FormatRate(_rateEdits.GetValueOrDefault(r.Key, r.Amount))"
                                           @onchange="e => SetRateEdit(r.Key, e.Value?.ToString())" />
                                </div>
                            </div>
                        }
                    </div>
                    <div class="cfg-hint">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" /></svg>
                        Rate changes take effect today and are never applied retroactively — already-billed periods keep their original amounts.
                    </div>
                }

                @if (_cfgError is not null)
                {
                    <div class="cfg-error">@_cfgError</div>
                }
                @if (_cfgSuccess is not null)
                {
                    <div class="cfg-success">@_cfgSuccess</div>
                }
            </div>

            <div class="cfg-foot">
                <button class="fac-btn fac-btn-ghost" @onclick="CloseDrawer" disabled="@_busy">Close</button>
                @if (_cfgFacility.Rates.Count > 0)
                {
                    <button class="fac-btn fac-btn-primary" @onclick="SaveRates" disabled="@(_busy || !HasRateChanges())">
                        @(_busy ? "Saving…" : "Save rates")
                    </button>
                }
            </div>
        }
    </aside>
}

@code {
    private FacilityConfigurationDto? _model;
    private string? _error;

    private enum DrawerMode { None, Add, Configure }
    private DrawerMode _drawer = DrawerMode.None;
    private bool _busy;

    // Add
    private AvailableFacilityDto? _addTarget;
    private string _addName = string.Empty;
    private string _addShortName = string.Empty;
    private string _addDescription = string.Empty;
    private string? _addError;

    // Configure
    private ConfiguredFacilityDto? _cfgFacility;
    private readonly Dictionary<string, decimal> _rateEdits = new();
    private string? _cfgError;
    private string? _cfgSuccess;

    protected override async Task OnInitializedAsync()
    {
        await Branding.EnsureLoadedAsync();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        _model = null;
        await InvokeAsync(StateHasChanged);

        var result = await FacilitiesApi.GetFacilityConfigurationAsync();
        if (result.IsSuccess && result.Value is not null)
            _model = result.Value;
        else
            _error = string.IsNullOrWhiteSpace(result.Error) ? "The facility configuration could not be retrieved." : result.Error;
    }

    // ── Drawer control ──
    private void OpenAdd(AvailableFacilityDto a)
    {
        _addTarget = a;
        _addName = a.Name;
        _addShortName = a.ShortName;
        _addDescription = string.Empty;
        _addError = null;
        _drawer = DrawerMode.Add;
    }

    private void OpenConfigure(ConfiguredFacilityDto f)
    {
        _cfgFacility = f;
        _rateEdits.Clear();
        foreach (var r in f.Rates) _rateEdits[r.Key] = r.Amount;
        _cfgError = null;
        _cfgSuccess = null;
        _drawer = DrawerMode.Configure;
    }

    private void CloseDrawer()
    {
        _drawer = DrawerMode.None;
        _addTarget = null;
        _cfgFacility = null;
    }

    // ── Add ──
    private async Task SubmitAdd()
    {
        if (_addTarget is null || _busy) return;
        _busy = true;
        _addError = null;

        var result = await FacilitiesApi.AddFacilityAsync(new AddFacilityCommand(
            _addTarget.Code, _addName.Trim(), _addShortName.Trim(),
            string.IsNullOrWhiteSpace(_addDescription) ? null : _addDescription.Trim()));

        _busy = false;
        if (result.IsSuccess)
        {
            CloseDrawer();
            await LoadAsync();
        }
        else
        {
            _addError = string.IsNullOrWhiteSpace(result.Error) ? "Couldn't add the facility. Please try again." : result.Error;
        }
    }

    // ── Rates ──
    private static string FormatRate(decimal v) => v.ToString("0.##");

    private void SetRateEdit(string key, string? raw)
    {
        if (decimal.TryParse(raw, out var d) && d >= 0m) _rateEdits[key] = decimal.Round(d, 2);
    }

    private bool HasRateChanges()
        => _cfgFacility is not null && _cfgFacility.Rates.Any(r => _rateEdits.TryGetValue(r.Key, out var v) && v != r.Amount);

    private async Task SaveRates()
    {
        if (_cfgFacility is null || _busy) return;
        _busy = true;
        _cfgError = null;
        _cfgSuccess = null;

        var code = Enum.Parse<FacilityCode>(_cfgFacility.Code);
        var changed = _cfgFacility.Rates.Where(r => _rateEdits.TryGetValue(r.Key, out var v) && v != r.Amount).ToList();

        foreach (var r in changed)
        {
            var key = Enum.Parse<FeeRateKey>(r.Key);
            var res = await FacilitiesApi.SetFacilityRateAsync(code, key, _rateEdits[r.Key]);
            if (!res.IsSuccess)
            {
                _cfgError = string.IsNullOrWhiteSpace(res.Error) ? "Couldn't save a rate. Please try again." : res.Error;
                _busy = false;
                return;
            }
        }

        _busy = false;
        await LoadAsync();

        // Re-bind the drawer to the refreshed facility so the saved amounts + "default→custom" tags update.
        _cfgFacility = _model?.Configured.FirstOrDefault(x => string.Equals(x.Code, code.ToString(), StringComparison.OrdinalIgnoreCase));
        if (_cfgFacility is not null)
        {
            _rateEdits.Clear();
            foreach (var r in _cfgFacility.Rates) _rateEdits[r.Key] = r.Amount;
            _cfgSuccess = changed.Count > 0 ? $"{changed.Count} rate{(changed.Count == 1 ? "" : "s")} updated." : null;
        }
        else
        {
            CloseDrawer();
        }
    }
}
