@page "/menu"

  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      background: #e8ecef;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 100vh;
      font-family: 'DM Sans', sans-serif;
    }

    /* Mobile Frame */
    .phone-frame {
      width: 390px;
      height: 844px;
      background: #f4f6f8;
      border-radius: 48px;
      box-shadow:
        0 0 0 10px #1a1a2e,
        0 0 0 12px #2d2d44,
        0 40px 80px rgba(0,0,0,0.35);
      overflow: hidden;
      position: relative;
      display: flex;
      flex-direction: column;
    }

    /* Notch */
    .notch {
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 126px;
      height: 34px;
      background: #1a1a2e;
      border-radius: 0 0 20px 20px;
      z-index: 10;
    }

    /* Header */
    .header {
      background: #0d2137;
      padding: 54px 24px 20px;
      position: relative;
      flex-shrink: 0;
    }

    .header::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 3px;
      background: linear-gradient(90deg, #c8a84b, #e8cc76, #c8a84b);
    }

    .gov-label {
      font-family: 'DM Sans', sans-serif;
      font-size: 9px;
      font-weight: 500;
      letter-spacing: 3px;
      color: #c8a84b;
      text-transform: uppercase;
      margin-bottom: 10px;
    }

    .header-logo-row {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .seal {
      width: 52px;
      height: 52px;
      border-radius: 50%;
      background: linear-gradient(145deg, #1e3a5f, #0d2137);
      border: 1.5px solid #c8a84b;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .seal svg {
      width: 30px;
      height: 30px;
      opacity: 0.9;
    }

    .header-text { flex: 1; }

    .org-name {
      font-family: 'EB Garamond', serif;
      font-size: 15px;
      font-weight: 600;
      color: #ffffff;
      line-height: 1.2;
      letter-spacing: 0.2px;
    }

    .org-sub {
      font-size: 10px;
      color: #8faabf;
      margin-top: 2px;
      letter-spacing: 0.3px;
    }

    /* Greeting Bar */
    .greeting-bar {
      background: #112d47;
      padding: 12px 24px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-shrink: 0;
    }

    .greeting-text {
      font-size: 11.5px;
      color: #8faabf;
    }

    .greeting-text span {
      color: #e8cc76;
      font-weight: 500;
    }

    .date-badge {
      font-size: 10px;
      color: #6a8aa0;
      background: #0d2137;
      padding: 4px 10px;
      border-radius: 20px;
      border: 1px solid #1e3a5f;
    }

    /* Scrollable Content */
    .content {
      flex: 1;
      overflow-y: auto;
      padding: 20px 20px 100px;
      scrollbar-width: none;
    }
    .content::-webkit-scrollbar { display: none; }

    /* Section Label */
    .section-label {
      font-size: 9.5px;
      font-weight: 600;
      letter-spacing: 2.5px;
      color: #8faabf;
      text-transform: uppercase;
      margin: 0 0 10px 4px;
    }

    /* Menu Cards */
    .menu-card {
      background: #ffffff;
      border-radius: 12px;
      border: 1px solid #dde4ea;
      padding: 16px 18px;
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 10px;
      cursor: pointer;
      transition: all 0.18s ease;
      position: relative;
      overflow: hidden;
    }

    .menu-card::before {
      content: '';
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: transparent;
      transition: background 0.18s;
    }

    .menu-card:active {
      background: #f0f4f8;
      transform: scale(0.985);
    }

    .menu-card:active::before {
      background: #c8a84b;
    }

    .card-icon {
      width: 40px;
      height: 40px;
      border-radius: 10px;
      background: #eef2f6;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }

    .card-icon svg {
      width: 20px;
      height: 20px;
      stroke: #0d2137;
      fill: none;
      stroke-width: 1.6;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    .card-info { flex: 1; }

    .card-title {
      font-size: 13.5px;
      font-weight: 500;
      color: #0d2137;
      letter-spacing: 0.1px;
    }

    .card-sub {
      font-size: 10.5px;
      color: #8faabf;
      margin-top: 2px;
    }

    .card-arrow {
      color: #c8d8e4;
      font-size: 16px;
    }

    /* Divider between groups */
    .group-spacer { margin-top: 18px; }

    /* Summary Strip */
    .summary-strip {
      background: #ffffff;
      border-radius: 12px;
      border: 1px solid #dde4ea;
      padding: 14px 18px;
      margin-bottom: 18px;
      display: flex;
      gap: 0;
    }

    .summary-item {
      flex: 1;
      text-align: center;
    }

    .summary-item + .summary-item {
      border-left: 1px solid #eef2f6;
    }

    .summary-value {
      font-family: 'EB Garamond', serif;
      font-size: 18px;
      font-weight: 600;
      color: #0d2137;
    }

    .summary-key {
      font-size: 9px;
      color: #8faabf;
      letter-spacing: 1px;
      text-transform: uppercase;
      margin-top: 2px;
    }

    /* Bottom Nav */
    .bottom-nav {
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 72px;
      background: #ffffff;
      border-top: 1px solid #dde4ea;
      display: flex;
      align-items: center;
      justify-content: space-around;
      padding: 0 10px 10px;
      flex-shrink: 0;
    }

    .nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      cursor: pointer;
      padding: 8px 16px;
      border-radius: 10px;
    }

    .nav-item.active .nav-icon { color: #0d2137; }
    .nav-item.active .nav-label { color: #0d2137; font-weight: 600; }
    .nav-item .nav-icon { color: #b0c4d4; font-size: 20px; }
    .nav-item .nav-label { font-size: 9px; color: #b0c4d4; letter-spacing: 0.5px; }

    .nav-item svg {
      width: 22px; height: 22px;
      stroke-width: 1.7;
      stroke-linecap: round;
      stroke-linejoin: round;
      fill: none;
    }

    .nav-item.active svg { stroke: #0d2137; }
    .nav-item svg { stroke: #b0c4d4; }
  </style>


