@page "/menu"
<PageTitle>EEMO Admin — Dashboard</PageTitle>

<div class="admin-layout">

    <!-- ═══════════════════════════════════════════
         SIDEBAR
    ═══════════════════════════════════════════ -->
    <Sidebar/>

    <aside class="sidebar @(SidebarCollapsed ? "collapsed" : "")">
        <div class="sidebar-brand">
            <div class="sidebar-seal">
                <img src="images/eemo-logov2.png" alt="EEMO" />
            </div>
            <div class="sidebar-brand-text">
                <div class="sidebar-brand-name">EEMO</div>
                <div class="sidebar-brand-sub">Admin Portal</div>
            </div>
        </div>

        <div class="sidebar-divider"></div>

        <nav class="sidebar-nav">
            <div class="nav-group-label">Main</div>

            <a href="/menu" class="nav-item active">
                <svg viewBox="0 0 24 24"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg>
                <span>Dashboard</span>
            </a>
            <a href="/collectors" class="nav-item">
                <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>
                <span>Collectors</span>
            </a>
            <a href="/vendors" class="nav-item">
                <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" /><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16" /></svg>
                <span>Vendors &amp; Stalls</span>
            </a>

            <div class="nav-group-label" style="margin-top:1rem;">Facilities</div>

            @foreach (var fac in Facilities)
            {
                <a href="/facility/@fac.Code.ToLower()" class="nav-item">
                    @((MarkupString)fac.IconSvg)
                    <span>@fac.ShortName</span>
                    @if (fac.UnpaidCount > 0)
                    {
                        <span class="nav-badge">@fac.UnpaidCount</span>
                    }
                </a>
            }

            <div class="nav-group-label" style="margin-top:1rem;">Reports</div>

            <a href="/reports" class="nav-item">
                <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
                <span>Financial Reports</span>
            </a>
            <a href="/audit" class="nav-item">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                <span>Audit Trail</span>
            </a>
            <a href="/export" class="nav-item">
                <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                <span>Export Data</span>
            </a>

            <div class="nav-group-label" style="margin-top:1rem;">System</div>

            <a href="/settings" class="nav-item">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3" /><path d="M19.07 4.93l-1.41 1.41M19.07 19.07l-1.41-1.41M4.93 19.07l1.41-1.41M4.93 4.93l1.41 1.41M21 12h-2M5 12H3M12 21v-2M12 5V3" /></svg>
                <span>Settings</span>
            </a>
        </nav>

        <button class="sidebar-toggle" @onclick="() => SidebarCollapsed = !SidebarCollapsed">
            <svg viewBox="0 0 24 24"><polyline points="@(SidebarCollapsed ? "9 6 15 12 9 18" : "15 18 9 12 15 6")" /></svg>
        </button>
    </aside>

    <!-- ═══════════════════════════════════════════
         MAIN CONTENT
    ═══════════════════════════════════════════ -->
    <main class="admin-main">

        <header class="topbar">
            <div class="topbar-left">
                <div class="topbar-title">Dashboard</div>
                <div class="topbar-breadcrumb">
                    <span>EEMO Admin</span>
                    <span class="breadcrumb-sep">/</span>
                    <span class="breadcrumb-active">Overview</span>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-period">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                    Collection Period: <strong>@DateTime.Now.ToString("MMMM yyyy")</strong>
                </div>
                <div class="topbar-admin">
                    <div class="admin-avatar">A</div>
                    <div class="admin-info">
                        <div class="admin-name">Administrator</div>
                        <div class="admin-role">EEMO Office</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">

            <!-- KPI Strip -->
            <div class="kpi-strip">
                <div class="kpi-card">
                    <div class="kpi-icon kpi-icon-blue">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                    </div>
                    <div class="kpi-body">
                        <div class="kpi-value">₱@TotalCollected.ToString("N0")</div>
                        <div class="kpi-label">Total Collected</div>
                        <div class="kpi-sub">@DateTime.Now.ToString("MMMM yyyy")</div>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon kpi-icon-red">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                    </div>
                    <div class="kpi-body">
                        <div class="kpi-value">₱@TotalPending.ToString("N0")</div>
                        <div class="kpi-label">Pending / Unpaid</div>
                        <div class="kpi-sub">@UnpaidCount vendors</div>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon kpi-icon-gold">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>
                    </div>
                    <div class="kpi-body">
                        <div class="kpi-value">@TotalCollectors</div>
                        <div class="kpi-label">Active Collectors</div>
                        <div class="kpi-sub">@ActiveFacilitiesCount facilities covered</div>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon kpi-icon-green">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                    </div>
                    <div class="kpi-body">
                        <div class="kpi-value">@PaidCount</div>
                        <div class="kpi-label">Paid Transactions</div>
                        <div class="kpi-sub">@CollectionRate% collection rate</div>
                    </div>
                </div>
            </div>

            <!-- Facility Cards -->
            <div class="section-header">
                <div class="section-title-block">
                    <div class="section-eyebrow">Facilities</div>
                    <div class="section-heading">Revenue by Facility — @DateTime.Now.ToString("MMMM yyyy")</div>
                </div>
                <a href="/reports" class="btn-outline">View Full Report</a>
            </div>

            <div class="facility-grid">
                @foreach (var fac in Facilities)
                {
                    <div class="facility-card @(fac.HasAlert ? "has-alert" : "")">
                        <div class="facility-card-header">
                            <div class="facility-card-icon">
                                @((MarkupString)fac.IconSvg)
                            </div>
                            <div class="facility-card-meta">
                                <div class="facility-card-code">@fac.Code</div>
                                <div class="facility-card-name">@fac.Name</div>
                            </div>
                            @if (fac.HasAlert)
                            {
                                <div class="facility-alert-dot" title="Has unpaid vendors"></div>
                            }
                        </div>

                        <div class="facility-card-stats">
                            <div class="fac-stat">
                                <div class="fac-stat-val">₱@fac.Collected.ToString("N0")</div>
                                <div class="fac-stat-key">Collected</div>
                            </div>
                            <div class="fac-stat">
                                <div class="fac-stat-val unpaid-val">@fac.UnpaidCount</div>
                                <div class="fac-stat-key">Unpaid</div>
                            </div>
                            <div class="fac-stat">
                                <div class="fac-stat-val">@fac.TotalVendors</div>
                                <div class="fac-stat-key">Vendors</div>
                            </div>
                        </div>

                        <div class="facility-progress-wrap">
                            <div class="facility-progress-bar">
                                <div class="facility-progress-fill" style="width:@fac.CollectionRate%"></div>
                            </div>
                            <span class="facility-progress-pct">@fac.CollectionRate%</span>
                        </div>

                        <div class="fee-chips">
                            @foreach (var fee in fac.FeeTypes)
                            {
                                <span class="fee-chip">@fee</span>
                            }
                        </div>

                        <a href="/facility/@fac.Code.ToLower()" class="facility-card-btn">
                            Manage Stalls
                            <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18" /></svg>
                        </a>
                    </div>
                }
            </div>

            <!-- Bottom Row -->
            <div class="bottom-row">

                <div class="panel">
                    <div class="panel-header">
                        <div class="panel-title">Recent Transactions</div>
                        <a href="/audit" class="panel-link">View All</a>
                    </div>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>OR #</th>
                                <th>Payor</th>
                                <th>Facility</th>
                                <th>Nature</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Collector</th>
                                <th>Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in RecentTransactions)
                            {
                                <tr>
                                    <td class="mono">#@tx.ORNumber</td>
                                    <td class="td-name">@tx.PayorName</td>
                                    <td><span class="code-badge">@tx.FacilityCode</span></td>
                                    <td class="td-nature">@tx.Nature</td>
                                    <td class="td-amount">₱@tx.Amount.ToString("N0")</td>
                                    <td>
                                        <span class="status-pill @(tx.IsPaid ? "pill-paid" : tx.IsPartial ? "pill-partial" : "pill-unpaid")">
                                            @(tx.IsPaid ? "Paid" : tx.IsPartial ? $"₱{tx.PartialAmount:N0} paid" : "Unpaid")
                                        </span>
                                    </td>
                                    <td class="td-collector">@tx.CollectorName</td>
                                    <td class="td-time">@tx.CollectedAt.ToString("hh:mm tt")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="panel panel-narrow">
                    <div class="panel-header">
                        <div class="panel-title">⚠ Overdue Vendors</div>
                        <a href="/vendors?filter=delinquent" class="panel-link">View All</a>
                    </div>
                    <div class="delinquent-list">
                        @foreach (var v in DelinquentVendors)
                        {
                            <div class="delinquent-item">
                                <div class="delinquent-info">
                                    <div class="delinquent-name">@v.Name</div>
                                    <div class="delinquent-meta">
                                        <span class="code-badge">@v.FacilityCode</span>
                                        Stall @v.StallNo
                                    </div>
                                </div>
                                <div class="delinquent-right">
                                    <div class="delinquent-amount">₱@v.Balance.ToString("N0")</div>
                                    <div class="delinquent-months @(v.MonthsUnpaid >= 3 ? "text-red" : "text-gold")">
                                        @v.MonthsUnpaid mo. unpaid
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>

    </main>
</div>


@code {

    bool SidebarCollapsed = false;

    decimal TotalCollected => Facilities.Sum(f => f.Collected);
    decimal TotalPending => Facilities.Sum(f => f.Pending);
    int UnpaidCount => Facilities.Sum(f => f.UnpaidCount);
    int TotalCollectors = 4;
    int ActiveFacilitiesCount => Facilities.Count(f => f.Collected > 0);
    int PaidCount => Facilities.Sum(f => f.TotalVendors - f.UnpaidCount);
    int CollectionRate => Facilities.Sum(f => f.TotalVendors) == 0 ? 0
                                     : (int)((double)PaidCount / Facilities.Sum(f => f.TotalVendors) * 100);

    class FacilityItem
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string ShortName { get; set; } = string.Empty;
        public string IconSvg { get; set; } = string.Empty;
        public decimal Collected { get; set; }
        public decimal Pending { get; set; }
        public int TotalVendors { get; set; }
        public int UnpaidCount { get; set; }
        public int CollectionRate => TotalVendors == 0 ? 0
                                        : (int)((double)(TotalVendors - UnpaidCount) / TotalVendors * 100);
        public bool HasAlert => UnpaidCount > 0;
        public List<string> FeeTypes { get; set; } = new();
    }

    List<FacilityItem> Facilities = new()
    {
        new() {
            Code="NPM", Name="New Public Market", ShortName="Public Market",
            IconSvg="""<svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>""",
            Collected=62400, Pending=18000, TotalVendors=100, UnpaidCount=20,
            FeeTypes=new() { "Stall ₱30/day", "Fish ₱1/kg", "Electricity", "Water" }
        },
        new() {
            Code="TCC", Name="Tampak Commercial Center", ShortName="Tampak Comm.",
            IconSvg="""<svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>""",
            Collected=48600, Pending=12000, TotalVendors=43, UnpaidCount=8,
            FeeTypes=new() { "Monthly Rental", "Electricity", "Water" }
        },
        new() {
            Code="NCC", Name="New Commercial Center", ShortName="New Comm. Center",
            IconSvg="""<svg viewBox="0 0 24 24"><path d="M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18"/></svg>""",
            Collected=56520, Pending=8400, TotalVendors=28, UnpaidCount=5,
            FeeTypes=new() { "Monthly Rental", "Corner Premium" }
        },
        new() {
            Code="BBQ", Name="Barbecue Stand", ShortName="BBQ Stand",
            IconSvg="""<svg viewBox="0 0 24 24"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>""",
            Collected=38400, Pending=9600, TotalVendors=5, UnpaidCount=1,
            FeeTypes=new() { "Space Rental" }
        },
        new() {
            Code="ICE", Name="Iceplant", ShortName="Iceplant",
            IconSvg="""<svg viewBox="0 0 24 24"><line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>""",
            Collected=24000, Pending=12000, TotalVendors=4, UnpaidCount=2,
            FeeTypes=new() { "Space Rental" }
        },
        new() {
            Code="SLH", Name="Slaughterhouse", ShortName="Slaughterhouse",
            IconSvg="""<svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>""",
            Collected=12250, Pending=3750, TotalVendors=30, UnpaidCount=6,
            FeeTypes=new() { "Hog ₱250/head", "Carabao/Cow ₱365/head" }
        },
    };

    class TxRecord
    {
        public string ORNumber { get; set; } = string.Empty;
        public string PayorName { get; set; } = string.Empty;
        public string FacilityCode { get; set; } = string.Empty;
        public string Nature { get; set; } = string.Empty;
        public decimal Amount { get; set; }
        public bool IsPaid { get; set; }
        public bool IsPartial { get; set; }
        public decimal PartialAmount { get; set; }
        public string CollectorName { get; set; } = string.Empty;
        public DateTime CollectedAt { get; set; }
    }

    List<TxRecord> RecentTransactions = new()
    {
        new() { ORNumber="2315701", PayorName="Dela Cruz, Maria S.",   FacilityCode="NPM", Nature="Stall Rental",   Amount=900,  IsPaid=true,  CollectorName="Clint", CollectedAt=DateTime.Today.AddHours(10).AddMinutes(14) },
        new() { ORNumber="2315702", PayorName="Guerta, Alvin",         FacilityCode="TCC", Nature="Monthly Rental", Amount=2400, IsPaid=true,  CollectorName="Clint", CollectedAt=DateTime.Today.AddHours(10).AddMinutes(32) },
        new() { ORNumber="2315703", PayorName="Bebero, Lucrecia R.",   FacilityCode="NCC", Nature="Monthly Rental", Amount=1200, IsPaid=true,  CollectorName="Ruel",  CollectedAt=DateTime.Today.AddHours(10).AddMinutes(55) },
        new() { ORNumber="2315704", PayorName="Mendaña, Recto",        FacilityCode="ICE", Nature="Space Rental",   Amount=1000, IsPaid=false, CollectorName="Ruel",  CollectedAt=DateTime.Today.AddHours(11).AddMinutes(8)  },
        new() { ORNumber="2315705", PayorName="Ruaza, Joy",            FacilityCode="BBQ", Nature="Space Rental",   Amount=1600, IsPaid=true,  CollectorName="Clint", CollectedAt=DateTime.Today.AddHours(11).AddMinutes(20) },
        new() { ORNumber="2315706", PayorName="Trugillo, Elpedia C.",  FacilityCode="NPM", Nature="Stall Rental",   Amount=900,  IsPaid=false, IsPartial=true, PartialAmount=450, CollectorName="Clint", CollectedAt=DateTime.Today.AddHours(11).AddMinutes(40) },
        new() { ORNumber="2315707", PayorName="Hog Slaughter",         FacilityCode="SLH", Nature="Slaughter Fee",  Amount=250,  IsPaid=true,  CollectorName="Marco", CollectedAt=DateTime.Today.AddHours(7).AddMinutes(30)  },
        new() { ORNumber="2315708", PayorName="Carabao Slaughter",     FacilityCode="SLH", Nature="Slaughter Fee",  Amount=365,  IsPaid=true,  CollectorName="Marco", CollectedAt=DateTime.Today.AddHours(8).AddMinutes(15)  },
    };

    class DelinquentItem
    {
        public string Name { get; set; } = string.Empty;
        public string StallNo { get; set; } = string.Empty;
        public string FacilityCode { get; set; } = string.Empty;
        public int MonthsUnpaid { get; set; }
        public decimal Balance { get; set; }
    }

    List<DelinquentItem> DelinquentVendors = new()
    {
        new() { Name="Salnoden Datumanong", StallNo="39",    FacilityCode="TCC", MonthsUnpaid=5, Balance=12000 },
        new() { Name="Mangubat, Jose P.",   StallNo="09",    FacilityCode="NPM", MonthsUnpaid=4, Balance=3600  },
        new() { Name="Orpina, Rebecca S.",  StallNo="ICE-2", FacilityCode="ICE", MonthsUnpaid=3, Balance=3000  },
        new() { Name="Datumanong, Jessie",  StallNo="40",    FacilityCode="TCC", MonthsUnpaid=3, Balance=7200  },
        new() { Name="Garcia, Flordeliza",  StallNo="06",    FacilityCode="NPM", MonthsUnpaid=2, Balance=1800  },
    };
}
