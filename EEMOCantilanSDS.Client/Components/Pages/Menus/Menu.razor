@page "/menu"
<PageTitle>EEMO Admin — Dashboard</PageTitle>

<div class="admin-layout">

    <!-- ═══════════════════════════════════════════
         SIDEBAR
    ═══════════════════════════════════════════ -->
    <Sidebar />

    <!-- ═══════════════════════════════════════════
         MAIN CONTENT
    ═══════════════════════════════════════════ -->
    <main class="admin-main">

        <header class="topbar">
            <div class="topbar-left">
                <div class="topbar-title">Dashboard</div>
                <div class="topbar-breadcrumb">
                    <span>EEMO Admin</span>
                    <span class="breadcrumb-sep">/</span>
                    <span class="breadcrumb-active">Overview</span>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-period">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                    Collection Period: <strong>@DateTime.Now.ToString("MMMM yyyy")</strong>
                </div>
                <div class="topbar-admin">
                    <div class="admin-avatar">A</div>
                    <div class="admin-info">
                        <div class="admin-name">Administrator</div>
                        <div class="admin-role">EEMO Office</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">

            <!-- Dashboard Hero Banner -->
            <div class="vs-hero">
                <div class="vs-hero-left">
                    <div class="vs-hero-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7" />
                            <rect x="14" y="3" width="7" height="7" />
                            <rect x="3" y="14" width="7" height="7" />
                            <rect x="14" y="14" width="7" height="7" />
                        </svg>
                    </div>
                    <div>
                        <div class="vs-hero-eyebrow">EEMO Admin · Overview</div>
                        <div class="vs-hero-title">Dashboard</div>
                        <div class="vs-hero-sub">Collection Period: @DateTime.Now.ToString("MMMM yyyy")</div>
                    </div>
                </div>
                <div class="vs-hero-stats">
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">₱@TotalCollected.ToString("N0")</div>
                        <div class="vs-hero-key">Total Collected</div>
                        <div class="vs-hero-sub2">@DateTime.Now.ToString("MMMM yyyy")</div>
                    </div>
                    <div class="vs-hero-divider"></div>
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">₱@TotalPending.ToString("N0")</div>
                        <div class="vs-hero-key">Pending / Unpaid</div>
                        <div class="vs-hero-sub2">@UnpaidCount vendors</div>
                    </div>
                    <div class="vs-hero-divider"></div>
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">@PaidCount</div>
                        <div class="vs-hero-key">Paid Transactions</div>
                        <div class="vs-hero-sub2">@ActiveFacilitiesCount facilities covered</div>
                    </div>
                    <div class="vs-hero-divider"></div>
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">@CollectionRate%</div>
                        <div class="vs-hero-key">Collection Rate</div>
                        <div class="vs-hero-sub2">@TotalCollectors active collectors</div>
                    </div>
                </div>
                <div class="vs-hero-progress">
                    <div class="vs-hero-progress-fill" style="width: @CollectionRate%;"></div>
                </div>
            </div>

            <!-- Facility Cards -->
            <div class="section-header">
                <div class="section-title-block">
                    <div class="section-eyebrow">Facilities</div>
                    <div class="section-heading">Revenue by Facility — @DateTime.Now.ToString("MMMM yyyy")</div>
                </div>
                <a href="/reports" class="btn-outline">View Full Report</a>
            </div>

            <div class="facility-grid">
                @foreach (var fac in Facilities)
                {
                    <div class="facility-card @(fac.HasAlert ? "has-alert" : "")">
                        <div class="facility-card-header">
                            <div class="facility-card-icon">
                                @((MarkupString)fac.IconSvg)
                            </div>
                            <div class="facility-card-meta">
                                <div class="facility-card-code">@fac.Code</div>
                                <div class="facility-card-name">@fac.Name</div>
                            </div>
                            @if (fac.HasAlert)
                            {
                                <div class="facility-alert-dot" title="Has unpaid vendors"></div>
                            }
                        </div>

                        <div class="facility-card-stats">
                            <div class="fac-stat">
                                <div class="fac-stat-val">₱@fac.Collected.ToString("N0")</div>
                                <div class="fac-stat-key">Collected</div>
                            </div>
                            <div class="fac-stat">
                                <div class="fac-stat-val unpaid-val">@fac.UnpaidCount</div>
                                <div class="fac-stat-key">Unpaid</div>
                            </div>
                            <div class="fac-stat">
                                <div class="fac-stat-val">@fac.TotalVendors</div>
                                <div class="fac-stat-key">Vendors</div>
                            </div>
                        </div>

                        <div class="facility-progress-wrap">
                            <div class="facility-progress-bar">
                                <div class="facility-progress-fill" style="width:@fac.CollectionRate%"></div>
                            </div>
                            <span class="facility-progress-pct">@fac.CollectionRate%</span>
                        </div>

                       

                        <a href="/facility/@fac.Code.ToLower()" class="facility-card-btn">
                            Manage Stalls
                            <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18" /></svg>
                        </a>
                    </div>
                }
            </div>

            <!-- Bottom Row -->
            <div class="bottom-row">

                <div class="panel">
                    <div class="panel-header">
                        <div class="panel-title">Recent Transactions</div>
                        <a href="/audit" class="panel-link">View All</a>
                    </div>
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>OR #</th>
                                <th>Payor</th>
                                <th>Facility</th>
                                <th>Nature</th>
                                <th>Amount</th>
                                <th>Status</th>
                                <th>Collector</th>
                                <th>Time</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in RecentTransactions)
                            {
                                <tr>
                                    <td class="mono">#@tx.ORNumber</td>
                                    <td class="td-name">@tx.PayorName</td>
                                    <td><span class="code-badge">@tx.FacilityCode</span></td>
                                    <td class="td-nature">@tx.Nature</td>
                                    <td class="td-amount">₱@tx.Amount.ToString("N0")</td>
                                    <td>
                                        <span class="status-pill @(tx.IsPaid ? "pill-paid" : tx.IsPartial ? "pill-partial" : "pill-unpaid")">
                                            @(tx.IsPaid ? "Paid" : tx.IsPartial ? $"₱{tx.PartialAmount:N0} paid" : "Unpaid")
                                        </span>
                                    </td>
                                    <td class="td-collector">@tx.CollectorName</td>
                                    <td class="td-time">@tx.CollectedAt.ToString("hh:mm tt")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="panel panel-narrow">
                    <div class="panel-header">
                        <div class="panel-title">⚠ Overdue Vendors</div>
                        <a href="/vendors?filter=delinquent" class="panel-link">View All</a>
                    </div>
                    <div class="delinquent-list">
                        @foreach (var v in DelinquentVendors)
                        {
                            <div class="delinquent-item">
                                <div class="delinquent-info">
                                    <div class="delinquent-name">@v.Name</div>
                                    <div class="delinquent-meta">
                                        <span class="code-badge">@v.FacilityCode</span>
                                        Stall @v.StallNo
                                    </div>
                                </div>
                                <div class="delinquent-right">
                                    <div class="delinquent-amount">₱@v.Balance.ToString("N0")</div>
                                    <div class="delinquent-months @(v.MonthsUnpaid >= 3 ? "text-red" : "text-gold")">
                                        @v.MonthsUnpaid mo. unpaid
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

            </div>
        </div>

    </main>
</div>


@code {

    bool SidebarCollapsed = false;

    decimal TotalCollected => Facilities.Sum(f => f.Collected);
    decimal TotalPending => Facilities.Sum(f => f.Pending);
    int UnpaidCount => Facilities.Sum(f => f.UnpaidCount);
    int TotalCollectors = 4;
    int ActiveFacilitiesCount => Facilities.Count(f => f.Collected > 0);
    int PaidCount => Facilities.Sum(f => f.TotalVendors - f.UnpaidCount);
    int CollectionRate => Facilities.Sum(f => f.TotalVendors) == 0 ? 0
                                     : (int)((double)PaidCount / Facilities.Sum(f => f.TotalVendors) * 100);

    class FacilityItem
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string ShortName { get; set; } = string.Empty;
        public string IconSvg { get; set; } = string.Empty;
        public decimal Collected { get; set; }
        public decimal Pending { get; set; }
        public int TotalVendors { get; set; }
        public int UnpaidCount { get; set; }
        public int CollectionRate => TotalVendors == 0 ? 0
                                        : (int)((double)(TotalVendors - UnpaidCount) / TotalVendors * 100);
        public bool HasAlert => UnpaidCount > 0;
    
    }

