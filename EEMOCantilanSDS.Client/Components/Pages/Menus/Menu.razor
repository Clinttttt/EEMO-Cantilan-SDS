<script>
  const d = new Date();
  document.getElementById('date-badge').textContent =
    d.toLocaleDateString('en-PH', { month: 'short', day: 'numeric', year: 'numeric' });

  const hour = d.getHours();
  const greet = document.querySelector('.greeting-text');
  const label = hour < 12 ? 'Good morning' : hour < 17 ? 'Good afternoon' : 'Good evening';
  greet.innerHTML = `${label}, <span>Collector</span>`;
</script>



