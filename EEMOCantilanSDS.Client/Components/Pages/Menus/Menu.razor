@page "/menu"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using EEMOCantilanSDS.Application.Dtos.Dashboard
@inject IDashboardApiClient DashboardApi
<PageTitle>EEMO Admin — Dashboard</PageTitle>

<header class="topbar">
            <div class="topbar-left">
                <div class="topbar-title">Dashboard</div>
                <div class="topbar-breadcrumb">
                    <span>EEMO Admin</span>
                    <span class="breadcrumb-sep">/</span>
                    <span class="breadcrumb-active">Overview</span>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @_now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-period">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                    Collection Period: <strong>@_now.ToString("MMMM yyyy")</strong>
                </div>
                <AccountChip />
            </div>
        </header>

        <div class="content-area">

            <!-- Dashboard Hero Banner (always visible — fixed banner, not skeletoned) -->
            <div class="vs-hero">
                <div class="vs-hero-left">
                    <div class="vs-hero-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="3" y="3" width="7" height="7" />
                            <rect x="14" y="3" width="7" height="7" />
                            <rect x="3" y="14" width="7" height="7" />
                            <rect x="14" y="14" width="7" height="7" />
                        </svg>
                    </div>
                    <div>
                        <div class="vs-hero-eyebrow">EEMO Admin · Overview</div>
                        <div class="vs-hero-title">Dashboard</div>
                        <div class="vs-hero-sub">Collection Period: @_now.ToString("MMMM yyyy")</div>
                    </div>
                </div>
                <div class="vs-hero-stats">
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">₱@TotalCollected.ToString("N0")</div>
                        <div class="vs-hero-key">Total Collected</div>
                        <div class="vs-hero-sub2">@_now.ToString("MMMM yyyy")</div>
                    </div>
                    <div class="vs-hero-divider"></div>
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">₱@TotalPending.ToString("N0")</div>
                        <div class="vs-hero-key">Pending / Unpaid</div>
                        <div class="vs-hero-sub2">@UnpaidCount vendors</div>
                    </div>
                    <div class="vs-hero-divider"></div>
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">@PaidCount</div>
                        <div class="vs-hero-key">Paid Transactions</div>
                        <div class="vs-hero-sub2">@ActiveFacilitiesCount facilities covered</div>
                    </div>
                    <div class="vs-hero-divider"></div>
                    <div class="vs-hero-stat">
                        <div class="vs-hero-val">@CollectionRate%</div>
                        <div class="vs-hero-key">Collection Rate</div>
                        <div class="vs-hero-sub2">@TotalCollectors active collectors</div>
                    </div>
                </div>
                <div class="vs-hero-progress">
                    <div class="vs-hero-progress-fill" style="width: @CollectionRate%;"></div>
                </div>
            </div>

            <!-- Facility Cards -->
            <div class="section-header">
                <div class="section-title-block">
                    <div class="section-eyebrow">Facilities</div>
                    <div class="section-heading">Revenue by Facility — @_now.ToString("MMMM yyyy")</div>
                </div>
                <div class="section-header-actions">
                    <div class="dashboard-report-tabs" role="group" aria-label="Dashboard report actions">
                        <a href="/reports/month-end" class="dashboard-report-tab">Month-End Report</a>
                        <a href="/reports/collections" class="dashboard-report-tab">Collection Manager</a>
                        <a href="/reports/follow-up" class="dashboard-report-tab">Follow-up Queue</a>
                        <a href="/stall-holders" class="dashboard-report-tab">Stall Holder List</a>
                    </div>
                </div>
            </div>

            @if (_loading)
            {
                <div class="facility-grid">
                    @for (var i = 0; i < 8; i++)
                    {
                        <div class="facility-card">
                            <div class="sk-stack">
                                <div class="sk-inline">
                                    <Skeleton Width="42px" Height="42px" Radius="10px" />
                                    <div class="sk-grow sk-stack-sm">
                                        <Skeleton Width="48px" Height="11px" />
                                        <Skeleton Width="75%" Height="14px" Radius="6px" />
                                    </div>
                                </div>
                                <div class="sk-grid-3">
                                    <Skeleton Height="40px" Radius="8px" />
                                    <Skeleton Height="40px" Radius="8px" />
                                    <Skeleton Height="40px" Radius="8px" />
                                </div>
                                <Skeleton Height="8px" Radius="999px" />
                                <Skeleton Height="38px" Radius="10px" />
                            </div>
                        </div>
                    }
                </div>

                <div class="bottom-row">
                    <div class="panel">
                        <div class="panel-header">
                            <Skeleton Width="180px" Height="16px" Radius="6px" />
                        </div>
                        <div class="sk-stack">
                            <Skeleton Height="34px" Radius="6px" />
                            @for (var i = 0; i < 6; i++)
                            {
                                <Skeleton Height="22px" Radius="6px" />
                            }
                        </div>
                    </div>

                    <div class="panel panel-narrow">
                        <div class="panel-header">
                            <Skeleton Width="150px" Height="16px" Radius="6px" />
                        </div>
                        <div class="sk-stack">
                            @for (var i = 0; i < 4; i++)
                            {
                                <Skeleton Height="46px" Radius="8px" />
                            }
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="facility-grid">
                    @foreach (var fac in Facilities)
                    {
                        <div class="facility-card @(fac.UnpaidCount > 0 ? "has-alert" : "")">
                            <div class="facility-card-header">
                                <div class="facility-card-icon">
                                    @((MarkupString)(Icons.GetValueOrDefault(fac.Code) ?? string.Empty))
                                </div>
                                <div class="facility-card-meta">
                                    <div class="facility-card-code">@fac.Code</div>
                                    <div class="facility-card-name">@fac.Name</div>
                                    <div class="fac-model-tag">@ModelLabel(fac.Code)</div>
                                </div>
                                @if (fac.UnpaidCount > 0)
                                {
                                    <div class="facility-alert-dot" title="Has unpaid vendors"></div>
                                }
                            </div>

                            <div class="facility-card-stats">
                                <div class="fac-stat">
                                    <div class="fac-stat-val">₱@fac.Collected.ToString("N0")</div>
                                    <div class="fac-stat-key">Collected</div>
                                </div>
                                <div class="fac-stat">
                                    @if (fac.Code == FacilityCode.NPM)
                                    {
                                        <div class="fac-stat-val partial-val">@fac.PartialCount</div>
                                        <div class="fac-stat-key">Partial</div>
                                    }
                                    else
                                    {
                                        <div class="fac-stat-val paid-val">@fac.PaidCount</div>
                                        <div class="fac-stat-key">@CountLabel(fac.Code)</div>
                                    }
                                </div>
                                <div class="fac-stat">
                                    <div class="fac-stat-val">@fac.TotalVendors</div>
                                    <div class="fac-stat-key">@VendorLabel(fac.Code)</div>
                                </div>
                            </div>

                            @if (PaidOnService(fac.Code))
                            {
                                <div class="facility-onservice" title="Collected at the point of service — no recurring balance">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                                    Paid on service
                                </div>
                            }
                            else
                            {
                                <div class="facility-progress-wrap">
                                    <div class="facility-progress-bar">
                                        <div class="facility-progress-fill" style="width:@fac.CollectionRate%"></div>
                                    </div>
                                    <span class="facility-progress-pct">@fac.CollectionRate%</span>
                                </div>
                            }

                            <a href="/facility/@fac.Code.ToString().ToLower()" class="facility-card-btn">
                                @ActionLabel(fac.Code)
                                <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18" /></svg>
                            </a>
                        </div>
                    }
                </div>

                <!-- Bottom Row -->
                <div class="bottom-row">

                    <div class="panel">
                        <div class="panel-header">
                            <div class="panel-title">Recent Transactions</div>
                            <a href="/audit" class="panel-link">View All</a>
                        </div>
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>OR #</th>
                                    <th>Payor</th>
                                    <th>Facility</th>
                                    <th>Amount</th>
                                    <th>Recorded By</th>
                                    <th>Time</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var tx in RecentTransactions)
                                {
                                    <tr>
                                        <td>#@tx.ORNumber</td>
                                        <td>@tx.PayorName</td>
                                        <td><span>@tx.FacilityCode</span></td>
                                        <td>₱@tx.Amount.ToString("N0")</td>
                                        <td>@tx.RecordedBy</td>
                                        <td>@tx.CollectedAt.ToString("hh:mm tt")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <div class="panel panel-narrow">
                        <div class="panel-header">
                            <div class="panel-title">⚠ Overdue Vendors</div>
                            <a href="/vendors?filter=delinquent" class="panel-link">View All</a>
                        </div>
                        <div class="delinquent-list">
                            @if (!DelinquentVendors.Any())
                            {
                                <div class="delinquent-empty">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                                        <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/>
                                        <polyline points="22 4 12 14.01 9 11.01"/>
                                    </svg>
                                    <div class="delinquent-empty-title">All accounts up to date</div>
                                    <div class="delinquent-empty-sub">No overdue balances from previous months.</div>
                                </div>
                            }
                            @foreach (var v in DelinquentVendors)
                            {
                                <div class="delinquent-item">
                                    <div class="delinquent-info">
                                        <div class="delinquent-name">@v.Name</div>
                                        <div class="delinquent-meta">
                                            <span class="code-badge">@v.FacilityCode</span>
                                            Stall @v.StallNo
                                        </div>
                                    </div>
                                    <div class="delinquent-right">
                                        <div class="delinquent-amount">₱@v.Balance.ToString("N0")</div>
                                        <div class="delinquent-months @(v.MonthsUnpaid >= 3 ? "text-red" : "text-gold")">
                                            @v.MonthsUnpaid mo. unpaid
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>

                </div>
            }
        </div>


@code {
    private bool _loading = true;
    private DashboardOverviewDto? _data;
    private readonly DateTime _now = EEMOCantilanSDS.Domain.Common.PhilippineTime.Now;

    protected override async Task OnInitializedAsync()
    {
        // Cold-start resilience: right after login the Blazor circuit may not have attached the JWT yet
        // when this first API call fires, yielding a transient 401/403 and an empty dashboard until a
        // re-navigation. Re-attempt briefly until the circuit's token is ready. Only auth failures are
        // retried; a genuine error (or success) returns immediately.
        try
        {
            for (var attempt = 0; attempt < 5; attempt++)
            {
                var result = await DashboardApi.GetOverviewAsync(_now.Year, _now.Month);
                if (result.IsSuccess)
                {
                    _data = result.Value;
                    return;
                }

                if (result.StatusCode is not (401 or 403))
                    return;

                await Task.Delay(400);
            }
        }
        finally
        {
            _loading = false;
        }
    }

    private decimal TotalCollected => _data?.TotalCollected ?? 0;
    private decimal TotalPending => _data?.TotalPending ?? 0;
    private int UnpaidCount => _data?.UnpaidCount ?? 0;
    private int PaidCount => _data?.PaidCount ?? 0;
    private int CollectionRate => _data?.CollectionRate ?? 0;
    private int ActiveFacilitiesCount => _data?.ActiveFacilitiesCount ?? 0;
    private int TotalCollectors => _data?.TotalCollectors ?? 0;
    private IReadOnlyList<DashboardFacilityDto> Facilities => _data?.Facilities ?? [];
    private IReadOnlyList<DashboardTransactionDto> RecentTransactions => _data?.RecentTransactions ?? [];
    private IReadOnlyList<DashboardDelinquentDto> DelinquentVendors => _data?.DelinquentVendors ?? [];

    // ── Model-aware card presentation (derived from the facility code) ──
    private static string ModelLabel(FacilityCode c) => c switch
    {
        FacilityCode.NPM => "Daily stall",
        FacilityCode.TCC or FacilityCode.NCC or FacilityCode.BBQ or FacilityCode.ICE => "Monthly rental",
        FacilityCode.SLH => "Per-head",
        FacilityCode.TRM => "Per-trip",
        FacilityCode.TPM => "Weekly market",
        _ => ""
    };

    // Per-head (SLH) / per-trip (TRM) / weekly-market (TPM) are paid on service — no recurring balance/rate.
    private static bool PaidOnService(FacilityCode c) => c is FacilityCode.SLH or FacilityCode.TRM or FacilityCode.TPM;

    private static string CountLabel(FacilityCode c) => c switch
    {
        FacilityCode.SLH => "Records",
        FacilityCode.TRM => "Trips",
        _ => "Paid"
    };

    private static string VendorLabel(FacilityCode c) => c switch
    {
        FacilityCode.SLH => "Owners",
        FacilityCode.TRM => "Drivers",
        _ => "Vendors"
    };

    private static string ActionLabel(FacilityCode c) => c switch
    {
        FacilityCode.SLH => "View Slaughterhouse",
        FacilityCode.TRM => "View Terminal",
        FacilityCode.TPM => "View Market",
        _ => "Manage Stalls"
    };

    // Presentation only: facility icon per code (data comes from the API).
    private static readonly Dictionary<FacilityCode, string> Icons = new()
    {
        [FacilityCode.NPM] = """<svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>""",
        [FacilityCode.TCC] = """<svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>""",
        [FacilityCode.NCC] = """<svg viewBox="0 0 24 24"><path d="M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18"/></svg>""",
        [FacilityCode.BBQ] = """<svg viewBox="0 0 24 24"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>""",
        [FacilityCode.ICE] = """<svg viewBox="0 0 24 24"><line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>""",
        [FacilityCode.SLH] = """<svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>""",
        [FacilityCode.TRM] = """<svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>""",
        [FacilityCode.TPM] = """<svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>""",
    };
}
