@page "/transactions"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using EEMOCantilanSDS.Application.Dtos.Transactions
@using EEMOCantilanSDS.Client.Components.Shared
@inject ITransactionsApiClient TransactionsApi
@inject IJSRuntime JS

<PageTitle>EEMO Admin — Transactions</PageTitle>

<header class="topbar">
    <div class="topbar-left">
        <div class="topbar-title">Transactions</div>
        <div class="topbar-breadcrumb">
            <span>EEMO Admin</span>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Transactions</span>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @PhilippineTime.Now.ToString("MMMM d, yyyy")
        </div>
    </div>
</header>

<div class="content-area">

    <FacilityHero Eyebrow="EEMO Admin · Transparency"
                  Title="Transactions"
                  Subtitle="@(IsToday ? "Today's recorded collections across all facilities" : $"Recorded collections on {SelectedDate:MMMM d, yyyy}")"
                  Icon="@LedgerIcon"
                  Stats="HeroStats" />

    <!-- Controls: facility filter + day navigator (single row) -->
    <div class="txn-controls">
        <div class="txn-segment">
            @foreach (var f in Filters)
            {
                <button type="button"
                        class="txn-seg-tab @(ActiveFilter == f.Code ? "active" : "")"
                        @onclick="() => SetFilter(f.Code)">
                    @f.Label
                </button>
            }
        </div>

      <div>
            <div class="txn-daynav">
                <button type="button" class="txn-navbtn" @onclick="PrevDay" aria-label="Previous day">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </button>

                <div class="txn-datebox @(IsToday ? "is-today" : "")" @onclick="OpenPicker">
                    <div class="txn-datebox-icon">
                        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    </div>
                    <div class="txn-datebox-text">
                        <span class="txn-datebox-main">@(IsToday ? "Today" : SelectedDate.ToString("dddd"))</span>
                        <span class="txn-datebox-sub">@SelectedDate.ToString("MMMM d, yyyy")</span>
                    </div>
                    <svg class="txn-datebox-chev" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" /></svg>
                    <input type="date" @ref="_dateInput" class="txn-datebox-input" value="@SelectedDate.ToString("yyyy-MM-dd")"
                           max="@PhilippineTime.Today.ToString("yyyy-MM-dd")" @onchange="OnDatePicked" aria-label="Pick a date" />
                </div>

                <button type="button" class="txn-navbtn" disabled="@IsToday" @onclick="NextDay" aria-label="Next day">
                    <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                </button>

                @if (!IsToday)
                {
                    <button type="button" class="txn-jump-today" @onclick="GoToday" title="Jump to Today">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><polyline points="12 7 12 12 15 14" /></svg>
                    </button>
                }
            </div>

            <button type="button" class="txn-refresh" title="Refresh" aria-label="Refresh" @onclick="Reload">
                <svg viewBox="0 0 24 24"><polyline points="23 4 23 10 17 10" /><polyline points="1 20 1 14 7 14" /><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15" /></svg>
            </button>
      </div>
    </div>

    <!-- Feed table -->
    <div class="section-card txn-card">
        @if (IsLoading)
        {
            <div class="sk-rows">
                @for (var i = 0; i < 8; i++)
                {
                    <div class="sk-row">
                        <Skeleton Width="78%" Height="13px" Radius="6px" />
                        <Skeleton Width="54px" Height="22px" Radius="999px" />
                        <Skeleton Width="82%" Height="13px" Radius="6px" />
                        <Skeleton Width="70%" Height="13px" Radius="6px" />
                        <Skeleton Width="60%" Height="13px" Radius="6px" />
                        <Skeleton Width="60px" Height="22px" Radius="999px" />
                    </div>
                }
            </div>
        }
        else if (!Feed.Any())
        {
            <div class="txn-empty">
                <div class="txn-empty-ic">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
                <div class="txn-empty-title">No transactions @(IsToday ? "yet today" : "on this day")</div>
                <div class="txn-empty-text">Nothing recorded for @SelectedDate.ToString("MMMM d, yyyy")@(ActiveFilter is null ? "" : $" at {ActiveLabel}"). Use the arrows or calendar to browse other days.</div>
            </div>
        }
        else
        {
            <table class="txn-table">
                <thead>
                    <tr>
                        <th>Date &amp; Time</th>
                        <th>Facility</th>
                        <th>Party</th>
                        <th>Details</th>
                        <th class="txn-num">Amount</th>
                        <th>OR No.</th>
                        <th>Status</th>
                        <th>Recorded by</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var g in GroupedFeed())
                    {
                        var t = g.Head;
                        var expanded = _expanded.Contains(g.Key);
                        <tr class="@(g.IsGroup ? "txn-grouprow" : "")" @onclick="() => ToggleGroup(g)">
                            <td class="txn-when">
                                <div class="txn-date">@t.OccurredAt.ToString("MMM d, yyyy")</div>
                                @if (t.HasTime)
                                {
                                    <div class="txn-time">@t.OccurredAt.ToString("h:mm tt")</div>
                                }
                            </td>
                            <td><span class="txn-fac-badge fac-@t.FacilityCode.ToString().ToLower()">@t.FacilityCode</span></td>
                            <td class="txn-party">@t.Party</td>
                            <td>
                                <div class="txn-kind">
                                    @if (g.IsGroup)
                                    {
                                        <svg class="txn-chev @(expanded ? "open" : "")" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" /></svg>
                                    }
                                    @t.Kind
                                </div>
                                <div class="txn-ref">@(g.IsGroup ? $"{g.Lines.Count} animals · {g.TotalHeads} heads" : t.Reference)</div>
                            </td>
                            <td class="txn-num txn-amount">&#8369;@g.Total.ToString("N2")</td>
                            <td class="txn-or">@(string.IsNullOrEmpty(t.ORNumber) ? "—" : t.ORNumber)</td>
                            <td><span class="txn-status @(t.Status == "Paid" ? "paid" : "partial")">@t.Status</span></td>
                            <td class="txn-recorder">@t.RecordedBy</td>
                        </tr>

                        @if (g.IsGroup && expanded)
                        {
                            @foreach (var line in g.Lines)
                            {
                                <tr class="txn-subrow">
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td>
                                        <div class="txn-subref">@line.Reference</div>
                                    </td>
                                    <td class="txn-num txn-subamount">&#8369;@line.Amount.ToString("N2")</td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                            }
                        }
                    }
                </tbody>
            </table>
        }
    </div>

</div>

@code {
    private RenderFragment LedgerIcon => @<svg viewBox="0 0 24 24" style="width:26px;height:26px;stroke:var(--gold);fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>;

    private FacilityCode? ActiveFilter;
    private DateOnly SelectedDate = PhilippineTime.Today;
    private bool IsLoading = true;
    private IReadOnlyList<TransactionFeedDto> Feed = Array.Empty<TransactionFeedDto>();

    [PersistentState(AllowUpdates = true)]
    public TransactionsPageState? CachedTransactions { get; set; }

    private bool IsToday => SelectedDate == PhilippineTime.Today;

    // SLH transactions recorded under one OR (multiple animal lines) collapse into one expandable row.
    private readonly HashSet<string> _expanded = new();

    private sealed class TxnGroup
    {
        public required TransactionFeedDto Head { get; init; }
        public required List<TransactionFeedDto> Lines { get; init; }
        public required string Key { get; init; }
        public bool IsGroup => Lines.Count > 1;
        public decimal Total => Lines.Sum(l => l.Amount);
        public int TotalHeads => Lines.Sum(l => ParseHeads(l.Reference));
    }

    // Reference looks like "Hog ×2" → pull the count after the × sign.
    private static int ParseHeads(string reference)
    {
        var idx = reference.LastIndexOf('×');
        return idx >= 0 && int.TryParse(reference[(idx + 1)..].Trim(), out var n) ? n : 1;
    }

    private List<TxnGroup> GroupedFeed()
    {
        var result = new List<TxnGroup>();
        var slhBuckets = new Dictionary<string, TxnGroup>();

        foreach (var t in Feed)
        {
            // Group only slaughter lines that share an OR + party + day.
            if (t.FacilityCode == FacilityCode.SLH && !string.IsNullOrWhiteSpace(t.ORNumber))
            {
                var key = $"SLH|{t.ORNumber}|{t.Party}|{t.OccurredAt:yyyyMMdd}";
                if (!slhBuckets.TryGetValue(key, out var g))
                {
                    g = new TxnGroup { Head = t, Lines = new List<TransactionFeedDto>(), Key = key };
                    slhBuckets[key] = g;
                    result.Add(g);
                }
                g.Lines.Add(t);
            }
            else
            {
                result.Add(new TxnGroup { Head = t, Lines = new List<TransactionFeedDto> { t }, Key = t.Id.ToString() });
            }
        }

        return result;
    }

    private void ToggleGroup(TxnGroup g)
    {
        if (!g.IsGroup) return;
        if (!_expanded.Add(g.Key)) _expanded.Remove(g.Key);
    }

    private ElementReference _dateInput;
    private async Task OpenPicker() => await JS.InvokeVoidAsync("openDatePicker", _dateInput);

    private record FilterOption(FacilityCode? Code, string Label);

    private static readonly FilterOption[] Filters =
    {
        new(null,              "All"),
        new(FacilityCode.NPM,  "NPM"),
        new(FacilityCode.TCC,  "TCC"),
        new(FacilityCode.NCC,  "NCC"),
        new(FacilityCode.BBQ,  "BBQ Stand"),
        new(FacilityCode.ICE,  "Iceplant"),
        new(FacilityCode.SLH,  "Slaughterhouse"),
        new(FacilityCode.TRM,  "Transport"),
        new(FacilityCode.TPM,  "Tabo-an"),
    };

    private string ActiveLabel => Filters.First(f => f.Code == ActiveFilter).Label;

    private List<FacilityHero.HeroStat> HeroStats => new()
    {
        new() { Value = Feed.Count.ToString(), Label = "Transactions" },
        new() { Value = "₱" + Feed.Sum(t => t.Amount).ToString("N0"), Label = "Total Value" },
        new() { Value = ActiveFilter is null ? "All" : ActiveFilter.ToString()!, Label = "Facility" },
    };

    protected override async Task OnInitializedAsync()
    {
        if (CachedTransactions is { } state
            && state.ActiveFilter == ActiveFilter
            && state.SelectedDate == SelectedDate)
        {
            Feed = state.Feed;
            IsLoading = false;
            return;
        }

        await ReloadAsync(paintLoading: true);
    }

    private async Task SetFilter(FacilityCode? code)
    {
        ActiveFilter = code;
        await Reload();
    }

    private async Task ShowLatest()
    {
        SelectedDate = PhilippineTime.Today;
        await Reload();
    }

    private Task GoToday() => ShowLatest();

    private async Task PrevDay()
    {
        SelectedDate = SelectedDate.AddDays(-1);
        await Reload();
    }

    private async Task NextDay()
    {
        if (IsToday) return;                       // never navigate into the future
        SelectedDate = SelectedDate.AddDays(1);
        await Reload();
    }

    private async Task OnDatePicked(ChangeEventArgs e)
    {
        if (DateOnly.TryParse(e.Value?.ToString(), out var d))
        {
            SelectedDate = d > PhilippineTime.Today ? PhilippineTime.Today : d;
            await Reload();
        }
    }

    private Task Reload() => ReloadAsync();

    private async Task ReloadAsync(bool paintLoading = false)
    {
        IsLoading = true;
        if (paintLoading)
            await PaintLoadingAsync();

        // Cold-start resilience: during prerender the JWT may not be attached yet, so the API can return
        // 401/403 before the circuit is ready. Retry briefly, and NEVER persist a failed/empty-by-error
        // load — otherwise the cached empty feed is served on the interactive pass and every refresh,
        // and the reload is skipped (the "refresh shows 0" bug).
        for (var attempt = 0; attempt < 5; attempt++)
        {
            var result = await TransactionsApi.GetRecentAsync(ActiveFilter, SelectedDate, 200);
            if (result.IsSuccess)
            {
                Feed = result.Value ?? Array.Empty<TransactionFeedDto>();
                CachedTransactions = new TransactionsPageState(ActiveFilter, SelectedDate, Feed.ToList());
                IsLoading = false;
                return;
            }
            if (result.StatusCode is not (401 or 403))
                break;
            await Task.Delay(400);
        }

        // Failed load: show an empty feed but do NOT cache it, so the next lifecycle/refresh retries.
        Feed = Array.Empty<TransactionFeedDto>();
        IsLoading = false;
    }

    private async Task PaintLoadingAsync()
    {
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
    }

    public sealed record TransactionsPageState(
        FacilityCode? ActiveFilter,
        DateOnly SelectedDate,
        List<TransactionFeedDto> Feed);
}
