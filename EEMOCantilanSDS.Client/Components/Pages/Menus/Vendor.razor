@page "/vendors"
@using EEMOCantilanSDS.Application.Dtos.Vendors
@attribute [Authorize]
@rendermode InteractiveServer
@inject IJSRuntime JS
@inject NavigationManager Nav
@inject IVendorsApiClient VendorsApi
@inject IStallsApiClient StallsApi
<PageTitle>EEMO Admin — Vendors &amp; Stalls</PageTitle>

<header class="topbar">
            <div class="topbar-left">
                <div class="topbar-title">Vendors &amp; Stalls</div>
                <div class="topbar-breadcrumb">
                    <span>EEMO Admin</span>
                    <span class="breadcrumb-sep">/</span>
                    <span class="breadcrumb-active">Vendors &amp; Stalls</span>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-admin">
                    <div class="admin-avatar">A</div>
                    <div class="admin-info">
                        <div class="admin-name">Administrator</div>
                        <div class="admin-role">EEMO Office</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">

            @if (isLoading)
            {
                <div class="loading-state">
                    <div class="spinner"></div>
                    <p>Loading vendor registry...</p>
                </div>
            }
            else
            {
                <!-- Vendor Hero Banner — Page-level overview (all facilities) -->
                <div class="vs-hero">
                    <div class="vs-hero-left">
                        <div class="vs-hero-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                                <circle cx="9" cy="7" r="4" />
                                <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                                <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                            </svg>
                        </div>
                        <div>
                            <div class="vs-hero-eyebrow">Vendors &amp; Stalls</div>
                            <div class="vs-hero-title">Vendor Registry</div>
                            <div class="vs-hero-sub">Municipality of Cantilan, SDS</div>
                        </div>
                    </div>
                    <div class="vs-hero-stats">
                        <div class="vs-hero-stat">
                            <div class="vs-hero-val">@AllVendors.Count</div>
                            <div class="vs-hero-key">Total Vendors</div>
                            <div class="vs-hero-sub2">@AllVendors.Count(v => v.IsActive) active · @AllVendors.Count(v => !v.IsActive) closed</div>
                        </div>
                        <div class="vs-hero-divider"></div>
                        <div class="vs-hero-stat">
                            <div class="vs-hero-val">@AllVendors.Count(v => v.IsActive && v.IsPaidThisMonth)</div>
                            <div class="vs-hero-key">Paid This Month</div>
                            <div class="vs-hero-sub2">out of @AllVendors.Count(v => v.IsActive) active vendors</div>
                        </div>
                        <div class="vs-hero-divider"></div>
                        <div class="vs-hero-stat">
                            <div class="vs-hero-val">@AllVendors.Count(v => v.IsActive && !v.IsPaidThisMonth)</div>
                            <div class="vs-hero-key">Unpaid</div>
                            <div class="vs-hero-sub2">@(AllVendors.Where(v => v.IsActive && !v.IsPaidThisMonth).Sum(v => v.MonthlyRate).ToString("N0")) outstanding</div>
                        </div>
                        <div class="vs-hero-divider"></div>
                        <div class="vs-hero-stat">
                            <div class="vs-hero-val">@(AllVendors.Where(v => v.IsActive).Sum(v => v.MonthlyRate).ToString("N0"))</div>
                            <div class="vs-hero-key">Monthly Target</div>
                            <div class="vs-hero-sub2">@DateTime.Now.ToString("MMMM yyyy") · All Facilities</div>
                        </div>
                    </div>
                    <div class="vs-hero-progress">
                        @{
                            var allActive = AllVendors.Count(v => v.IsActive);
                            var allPaid = AllVendors.Count(v => v.IsActive && v.IsPaidThisMonth);
                            var overallRate = allActive > 0 ? (allPaid * 100.0 / allActive) : 0;
                        }
                        <div class="vs-hero-progress-fill" style="@($"width: {overallRate}%;")"></div>
                    </div>
                </div>

                <!-- Toolbar (Single Row) -->
                <div class="vs-toolbar-unified">
                    <!-- Left: Facility Selector -->
                    <div class="facility-selector" id="facilitySelectorWrapper">
                        <div class="fac-trigger @(FacDropdownOpen ? "open" : "")" @onclick="ToggleFacDropdown">
                            <div class="fac-trigger-body">
                                <span class="fac-trigger-label">@ActiveFacilityTab.ShortName</span>
                                <span class="fac-trigger-sub">@ActiveFacilityTab.Name</span>
                            </div>
                            @if (ActiveFacilityTab.UnpaidCount > 0)
                            {
                                <span class="fac-trigger-badge">@ActiveFacilityTab.UnpaidCount unpaid</span>
                            }
                            <svg class="fac-trigger-chevron" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" /></svg>
                        </div>

                        @if (FacDropdownOpen)
                        {
                            <div class="fac-backdrop" @onclick="CloseFacDropdown"></div>
                            <div class="fac-dropdown">
                                <div class="fac-dd-header">Facility</div>
                                @foreach (var f in FacilityTabs)
                                {
                                    <div class="fac-dd-item @(ActiveFacility == f.Code ? "active" : "")" @onclick="() => SelectFacility(f.Code)">
                                        <div class="fac-dd-body"><span class="fac-dd-name">@f.Name</span></div>
                                        @if (f.UnpaidCount > 0)
                                        {
                                            <span class="fac-dd-badge">@f.UnpaidCount</span>
                                        }
                                        @if (ActiveFacility == f.Code)
                                        {
                                            <svg class="fac-dd-check" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>

                    <!-- Center: Filter Tabs -->
                    <div class="filter-tabs-inline">
                        @foreach (var f in StatusFilters)
                        {
                            <div class="filter-tab @(ActiveStatus == f ? "active" : "")" @onclick="() => ActiveStatus = f">@f</div>
                        }
                    </div>

                    <!-- Center-Right: Search -->
                    <div class="search-box">
                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                        <input type="text" placeholder="Search stall no. or name…" @bind="SearchQuery" @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(SearchQuery))
                        {
                            <span class="search-clear" @onclick="() => SearchQuery = string.Empty">×</span>
                        }
                    </div>

                    <!-- Right: Add Vendor + Count -->
                    <div class="vs-actions-compact">
                        <span class="vs-count-label">@FilteredVendors.Count() stalls</span>
                        <button class="btn-primary" @onclick="OpenCreate">
                            <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                            Add Vendor
                        </button>
                    </div>
                </div>

                <!-- Vendors Table — "This Month" column removed -->
                <div class="panel">
                    @if (!FilteredVendors.Any())
                    {
                        <div class="empty-state">
                            <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" /></svg>
                            <div class="empty-title">No Vendors Found</div>
                            <div class="empty-sub">Try adjusting the filters or search.</div>
                        </div>
                    }
                    else
                    {
                        <div class="table-wrap">
                            <table class="data-table">
                                <thead>
                                    <tr>
                                        <th>Stall No.</th>
                                        <th>Actual Occupant</th>
                                        <th>OR No.</th>
                                        <th>Section / Area</th>
                                        <th>Monthly Rate</th>
                                        <th>Status</th>
                                        <th style="width: 280px; text-align: right;">Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var v in FilteredVendors)
                                    {
                                        <tr class="@(!v.IsActive ? "row-inactive" : "") vendor-row" @onclick="() => OpenDetail(v)">
                                            <td>
                                                <div class="stall-num-cell">
                                                    <span>@v.StallNo</span>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="occupant-cell">
                                      
                                                    <div>
                                                        <div>@v.ActualOccupant</div>
                                                        @if (!string.IsNullOrEmpty(v.ContractName) && v.ContractName != "No contract" && v.ContractName != v.ActualOccupant)
                                                        {
                                                            <div class="occupant-contract">Contract: @v.ContractName</div>
                                                        }
                                                    </div>
                                                </div>
                                            </td>
                 
                                            <td>
                                                <span>@(string.IsNullOrEmpty(v.OrNo) ? "—" : v.OrNo)</span>
                                            </td>
                                     
                                            <td><span>@v.Section</span></td>
                                            <td>
                                                <span>@v.MonthlyRate.ToString("N0")</span>
                                            </td>
                                            <td @onclick:stopPropagation="true">
                                                <span class="status-pill @(v.IsActive ? "pill-active" : "pill-inactive")">
                                                    @(v.IsActive ? "Active" : "Closed")
                                                </span>
                                            </td>
                                            <td @onclick:stopPropagation="true" style="width: 280px;">
                                                <div class="action-btns" style="justify-content: flex-end;">
                                                    <button class="action-btn" title="View Details" @onclick="() => OpenDetail(v)">
                                                        <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                                                    </button>
                                                    <button class="action-btn" title="View Profile" @onclick="() => ViewProfile(v)">
                                                        <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                                    </button>
                                                    <button class="action-btn" title="Edit" @onclick="() => OpenEdit(v)">
                                                        <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                                                    </button>
                                                    <button class="action-btn" title="Payment History" @onclick="() => OpenHistory(v)">
                                                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                                                    </button>
                                                    <button class="action-btn @(v.IsActive ? "action-danger" : "action-success")"
                                                            title="@(v.IsActive ? "Close Stall" : "Reopen Stall")"
                                                            @onclick="() => ToggleVendor(v)">
                                                        @if (v.IsActive)
                                                        {
                                                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                                                        }
                                                        else
                                                        {
                                                            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                                        }
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>

            }

        </div>


<!-- ----------------------------------------------
     VENDOR DETAIL MODAL
---------------------------------------------- -->
@if (ShowDetail && DetailVendor is not null)
{
    <div class="eemo-modal-overlay" @onclick="() => ShowDetail = false">
        <div class="eemo-modal eemo-modal-wide detail-modal" @onclick:stopPropagation="true">

            <!-- Header -->
            <div class="detail-header">
                <div class="detail-header-left">
                    <div class="detail-avatar">@(DetailVendor.ActualOccupant.Length > 0 ? DetailVendor.ActualOccupant[0].ToString().ToUpper() : "?")</div>
                    <div>
                        <div class="detail-name">@DetailVendor.ActualOccupant</div>
                        <div class="detail-meta">
                            <span>Stall @DetailVendor.StallNo</span>
                            <span class="detail-sep">·</span>
                            <span>@DetailVendor.FacilityCode</span>
                            <span class="detail-sep">·</span>
                            <span>@DetailVendor.Section</span>
                            <span class="detail-sep">·</span>
                            <span class="status-pill @(DetailVendor.IsActive ? "pill-active" : "pill-inactive")">
                                @(DetailVendor.IsActive ? "Active" : "Closed")
                            </span>
                        </div>
                    </div>
                </div>
                <button class="eemo-modal-close" @onclick="() => ShowDetail = false">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>

            <div class="eemo-modal-body detail-body">

                <!-- Top Stats Row -->
                <div class="detail-stats-row">
                    <div class="detail-stat-card">
                        <div class="detail-stat-icon ds-icon-gold">
                            <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                        </div>
                        <div>
                            <div class="detail-stat-val">₱@DetailVendor.MonthlyRate.ToString("N0")</div>
                            <div class="detail-stat-key">Monthly Rental</div>
                        </div>
                    </div>
                    <div class="detail-stat-card">
                        <div class="detail-stat-icon ds-icon-navy">
                            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                        </div>
                        <div>
                            <div class="detail-stat-val">
                                @if (DetailVendor.ContractDate.HasValue)
                                {
                                    @DetailVendor.ContractDate.Value.ToString("MMM d, yyyy")
                                }
                                else
                                {
                                    <span style="color:var(--text-muted);font-size:13px">No Contract</span>
                                }
                            </div>
                            <div class="detail-stat-key">Contract Date</div>
                        </div>
                    </div>
                    <div class="detail-stat-card">
                        <div class="detail-stat-icon ds-icon-gold">
                            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                        </div>
                        <div>
                            <div class="detail-stat-val">
                                <span class="status-pill @(DetailVendor.IsPaidThisMonth ? "pill-paid" : DetailVendor.IsPartialThisMonth ? "pill-partial" : "pill-unpaid")" style="font-size:11px;padding:4px 12px;">
                                    @(DetailVendor.IsPaidThisMonth ? "Rental Paid" : DetailVendor.IsPartialThisMonth ? "Partial" : "Unpaid")
                                </span>
                            </div>
                            <div class="detail-stat-key">@DateTime.Now.ToString("MMMM yyyy")</div>
                        </div>
                    </div>
                    <div class="detail-stat-card">
                        <div class="detail-stat-icon ds-icon-gold">
                            <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z" /></svg>
                        </div>
                        <div>
                            <div class="detail-stat-val">@(DetailVendor.AreaSqm > 0 ? $"{DetailVendor.AreaSqm} sq.m" : "—")</div>
                            <div class="detail-stat-key">Stall Area</div>
                        </div>
                    </div>
                </div>

                <!-- Two-column info layout -->
                <div class="detail-two-col">

                    <!-- LEFT: Vendor Info -->
                    <div class="detail-section">
                        <div class="detail-section-title">
                            <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                            Vendor Information
                        </div>
                        <div class="detail-info-grid">
                            <div class="detail-info-row">
                                <span class="detail-info-key">Actual Occupant</span>
                                <span class="detail-info-val">@DetailVendor.ActualOccupant</span>
                            </div>
                            <div class="detail-info-row">
                                <span class="detail-info-key">Name on Contract</span>
                                <span class="detail-info-val">
                                    @if (string.IsNullOrEmpty(DetailVendor.ContractName) || DetailVendor.ContractName == "No contract")
                                    {
                                        <span class="no-contract">No contract</span>
                                    }
                                    else
                                    {
                                        @DetailVendor.ContractName
                                    }
                                </span>
                            </div>
                            <div class="detail-info-row">
                                <span class="detail-info-key">Facility</span>
                                <span class="detail-info-val">@ActiveFacilityTab.Name</span>
                            </div>
                            <div class="detail-info-row">
                                <span class="detail-info-key">Section / Area</span>
                                <span class="detail-info-val"><span class="section-tag">@DetailVendor.Section</span></span>
                            </div>
                            <div class="detail-info-row">
                                <span class="detail-info-key">Contract Duration</span>
                                <span class="detail-info-val">
                                    @if (DetailVendor.ContractYears == 0)
                                    {
                                        <span class="no-contract">No contract</span>
                                    }
                                    else
                                    {
                                        @($"{DetailVendor.ContractYears} year{(DetailVendor.ContractYears > 1 ? "s" : "")}")
                                        @if (DetailVendor.ContractDate.HasValue)
                                        {
                                            var expiry = DetailVendor.ContractDate.Value.AddYears(DetailVendor.ContractYears);
                                            <span class="detail-expiry @(expiry < DateTime.Now ? "expiry-expired" : "expiry-ok")">
                                                (expires @expiry.ToString("MMM d, yyyy"))
                                            </span>
                                        }
                                    }
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(DetailVendor.AreaLocation))
                            {
                                <div class="detail-info-row">
                                    <span class="detail-info-key">Area Note</span>
                                    <span class="detail-info-val">@DetailVendor.AreaLocation</span>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- RIGHT: Fee Structure — Fish & Meat now separate -->
                    <div class="detail-section">
                        <div class="detail-section-title">
                            <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                            Fee Structure
                        </div>

                        @{
                            bool hasVegDaily = DetailVendor.FacilityCode == "NPM" &&
                                                  DetailVendor.Section.Contains("Vegetable", StringComparison.OrdinalIgnoreCase);
                            bool hasFishSection = DetailVendor.FacilityCode == "NPM" &&
                                                  DetailVendor.Section.Contains("Fish", StringComparison.OrdinalIgnoreCase);
                            bool hasMeatSection = DetailVendor.FacilityCode == "NPM" &&
                                                  DetailVendor.Section.Contains("Meat", StringComparison.OrdinalIgnoreCase);
                            bool hasFishPerKg = DetailVendor.FeeTypes.Any(f => f.Contains("Fish") && f.Contains("kg"));
                        }

                        @if (hasVegDaily)
                        {
                            <div class="fee-breakdown-item fee-item-daily">
                                <div class="fee-item-left">
                                    <div class="fee-item-icon fee-icon-navy">
                                        <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 110 20A10 10 0 0112 2z" /><path d="M12 8v8M8 12h8" /></svg>
                                    </div>
                                    <div>
                                        <div class="fee-item-name">Daily Collection</div>
                                        <div class="fee-item-sub">Vegetable vendor · Collected daily</div>
                                    </div>
                                </div>
                                <div class="fee-item-amount">₱30<span class="fee-freq">/day</span></div>
                            </div>
                        }

                        @if (hasFishSection)
                        {
                            <div class="fee-breakdown-item fee-item-daily">
                                <div class="fee-item-left">
                                    <div class="fee-item-icon fee-icon-navy">
                                        <svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /><path d="M9 9h.01M15 9h.01M9.5 15a3.5 3.5 0 005 0" /></svg>
                                    </div>
                                    <div>
                                        <div class="fee-item-name">Daily Collection</div>
                                        <div class="fee-item-sub">Fish vendor · Collected daily</div>
                                    </div>
                                </div>
                                <div class="fee-item-amount">₱30<span class="fee-freq">/day</span></div>
                            </div>
                        }

                        @if (hasMeatSection)
                        {
                            <div class="fee-breakdown-item fee-item-daily">
                                <div class="fee-item-left">
                                    <div class="fee-item-icon fee-icon-navy">
                                        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z" /></svg>
                                    </div>
                                    <div>
                                        <div class="fee-item-name">Daily Collection</div>
                                        <div class="fee-item-sub">Meat vendor · Collected daily</div>
                                    </div>
                                </div>
                                <div class="fee-item-amount">₱30<span class="fee-freq">/day</span></div>
                            </div>
                        }

                        @if (hasFishPerKg)
                        {
                            <div class="fee-breakdown-item fee-item-perkg">
                                <div class="fee-item-left">
                                    <div class="fee-item-icon fee-icon-gold">
                                        <svg viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18" /></svg>
                                    </div>
                                    <div>
                                        <div class="fee-item-name">Fish Fee (by weight)</div>
                                        <div class="fee-item-sub">All fish types · Per kilo sold</div>
                                    </div>
                                </div>
                                <div class="fee-item-amount">₱1<span class="fee-freq">/kg</span></div>
                            </div>
                        }

                        @foreach (var fee in DetailVendor.FeeTypes.Where(f => !f.Contains("kg")))
                        {
                            var isElec = fee.Contains("Electricity");
                            var isWater = fee.Contains("Water");
                            <div class="fee-breakdown-item fee-item-utility">
                                <div class="fee-item-left">
                                    <div class="fee-item-icon fee-icon-utility">
                                        @if (isElec)
                                        {
                                            <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>
                                        }
                                        else if (isWater)
                                        {
                                            <svg viewBox="0 0 24 24"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z" /></svg>
                                        }
                                        else
                                        {
                                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="16" /></svg>
                                        }
                                    </div>
                                    <div>
                                        <div class="fee-item-name">@fee</div>
                                        <div class="fee-item-sub">Utility · Billed monthly</div>
                                    </div>
                                </div>
                                <div class="fee-item-amount fee-amount-variable">Variable</div>
                            </div>
                        }

                        @if (!DetailVendor.FeeTypes.Any() && !hasVegDaily && !hasFishSection && !hasMeatSection)
                        {
                            <div class="fee-none">No additional fees for this stall.</div>
                        }
                    </div>
                </div>

                <!-- ----------------------------------
                     DAILY COLLECTION CALENDAR
                ---------------------------------- -->
                @{
                    bool showDailyCal = DetailVendor.FacilityCode == "NPM" &&
                        (DetailVendor.Section.Contains("Vegetable", StringComparison.OrdinalIgnoreCase) ||
                         DetailVendor.Section.Contains("Fish", StringComparison.OrdinalIgnoreCase) ||
                         DetailVendor.Section.Contains("Meat", StringComparison.OrdinalIgnoreCase));
                }

                @if (showDailyCal)
                {

                    var calFirst = new DateTime(CalendarMonth.Year, CalendarMonth.Month, 1);
                    var calDays = DateTime.DaysInMonth(CalendarMonth.Year, CalendarMonth.Month);
                    var calOffset = (int)calFirst.DayOfWeek;
                    var calMStr = CalendarMonth.ToString("yyyy-MM");
                    var calToday = DateTime.Now.Date;
                    var isCurMo = CalendarMonth.Year == calToday.Year && CalendarMonth.Month == calToday.Month;
                    var maxDay = isCurMo ? calToday.Day : calDays;
                    var calCollected = 0;
                    for (int ci = 1; ci <= maxDay; ci++)
                    {
                        var ck = $"{calMStr}-{ci:D2}";
                        if (DetailVendor.DailyCollections.ContainsKey(ck) && DetailVendor.DailyCollections[ck])
                            calCollected++;
                    }
                    var calMissed = maxDay - calCollected;
                    var calTotal = calCollected * 30;
                    var canGoNext = CalendarMonth < new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);

                    // -- Fish section: Calculate total kilos and fee --
                    var isFishSection = DetailVendor.Section.Contains("Fish", StringComparison.OrdinalIgnoreCase);
                    var totalFishKilos = isFishSection ? GetMonthlyFishKilos(DetailVendor, CalendarMonth) : 0;
                    var totalFishFee = isFishSection ? GetMonthlyFishFee(DetailVendor, CalendarMonth) : 0;
                    var isVegetableSection = DetailVendor.Section.Contains("Vegetable", StringComparison.OrdinalIgnoreCase);
                    var isMeatSection = DetailVendor.Section.Contains("Meat", StringComparison.OrdinalIgnoreCase);

                    <div class="detail-section @(isVegetableSection ? "vegetables-section" : "") @(isMeatSection ? "meat-section" : "")">
                        <div class="detail-section-title">
                            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                            Daily Collection — ?30/day@(isFishSection ? " + Fish Fee (?1/kg)" : "")
                        </div>

                        <div class="cal-nav">
                            <button class="cal-nav-btn" @onclick="PrevCalMonth">
                                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                            </button>
                            <span class="cal-month-label">@CalendarMonth.ToString("MMMM yyyy")</span>
                            <button class="cal-nav-btn" @onclick="NextCalMonth" disabled="@(!canGoNext)">
                                <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                            </button>
                        </div>

                        <div class="cal-grid-wrap">
                            <div class="cal-day-hdr">Sun</div>
                            <div class="cal-day-hdr">Mon</div>
                            <div class="cal-day-hdr">Tue</div>
                            <div class="cal-day-hdr">Wed</div>
                            <div class="cal-day-hdr">Thu</div>
                            <div class="cal-day-hdr">Fri</div>
                            <div class="cal-day-hdr">Sat</div>

                            @for (int blank = 0; blank < calOffset; blank++)
                            {
                                <div class="cal-cell cal-empty"></div>
                            }

                            @for (int d = 1; d <= calDays; d++)
                            {
                                var day = new DateTime(CalendarMonth.Year, CalendarMonth.Month, d);
                                var dayKey = day.ToString("yyyy-MM-dd");
                                var isFuture = day.Date > calToday;
                                var isToday = day.Date == calToday;
                                var isMarked = DetailVendor.DailyCollections.ContainsKey(dayKey) && DetailVendor.DailyCollections[dayKey];
                                var cellClass = isFuture ? "cal-future" : (isMarked ? "cal-paid" : "cal-miss");
                                var dailyKilo = isFishSection ? GetDailyFishKilo(DetailVendor, day) : 0;
                                var showExtendedCell = (isFishSection || isVegetableSection || isMeatSection) && !isFuture;

                                <div class="cal-cell @cellClass @(isToday ? "cal-today" : "") @(showExtendedCell ? "cal-cell-fish" : "")"
                                     @onclick="() => { if (!isFuture) ToggleDailyCollection(DetailVendor, day); }">
                                    <span class="cal-num">@d</span>
                                    @if (!isFuture)
                                    {
                                        <span class="cal-checkmark @(isMarked ? "cal-check-yes" : "cal-check-no")">
                                            @(isMarked ? "✓" : "✕")
                                        </span>
                                    }
                                    @if (isFishSection && !isFuture && isMarked)
                                    {
                                        <div class="cal-kilo-display" @onclick:stopPropagation="true">
                                            <input type="number"
                                                   min="0"
                                                   step="0.5"
                                                   placeholder="0"
                                                   value="@dailyKilo"
                                                   @oninput="@(e => UpdateDailyFishKilo(DetailVendor, day, decimal.TryParse(e.Value?.ToString(), out var k) ? k : 0))"
                                                   class="cal-kilo-input" />
                                            <span class="cal-kilo-unit">kg</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <div class="cal-footer-stats">
                            <div class="cal-sum-item">
                                <span class="cal-sum-val cal-sum-green">@calCollected</span>
                                <span class="cal-sum-key">Days Collected</span>
                            </div>
                            <div class="cal-sum-item">
                                <span class="cal-sum-val cal-sum-red">@calMissed</span>
                                <span class="cal-sum-key">Days Missed</span>
                            </div>
                            <div class="cal-sum-item">
                                <span class="cal-sum-val">₱@calTotal.ToString("N0")</span>
                                <span class="cal-sum-key">Daily Collected @CalendarMonth.ToString("MMM yyyy")</span>
                            </div>
                            @if (isFishSection)
                            {
                                <div class="cal-sum-item fish-fee-item">
                                    <span class="cal-sum-val">@((int)totalFishKilos) kg</span>
                                    <span class="cal-sum-key">Fish Total</span>
                                </div>
                                <div class="cal-sum-item fish-fee-item">
                                    <span class="cal-sum-val">₱@((calTotal + (int)totalFishKilos).ToString("N0"))</span>
                                    <span class="cal-sum-key">Total Fee (@CalendarMonth.ToString("MMM yyyy"))</span>
                                </div>
                            }
                            @if (isVegetableSection)
                            {
                                <div class="cal-sum-item vegetables-fee-item">
                                    <span class="cal-sum-val">₱@calTotal.ToString("N0")</span>
                                    <span class="cal-sum-key">Total Fee (@CalendarMonth.ToString("MMM yyyy"))</span>
                                </div>
                            }
                            @if (isMeatSection)
                            {
                                <div class="cal-sum-item meat-fee-item">
                                    <span class="cal-sum-val">₱@calTotal.ToString("N0")</span>
                                    <span class="cal-sum-key">Total Fee (@CalendarMonth.ToString("MMM yyyy"))</span>
                                </div>
                            }
                        </div>
                    </div>
                }

                <!-- ══════════════════════════════════════════
                     MONTHLY PAYMENT CALENDAR
                     Only for non-NPM facilities (TCC, NCC, BBQ, ICE, SLH)
                ══════════════════════════════════════════ -->
                @if (DetailVendor.FacilityCode != "NPM")
                {
              
                    var moYear = MonthlyCalYear;
                    var moToday = DateTime.Now;
                    var moMonths = Enumerable.Range(1, 12).Select(m => new DateTime(moYear, m, 1)).ToList();
                    var moPaidCount = moMonths.Count(m => m <= moToday &&
                                            DetailVendor.PaymentHistory.ContainsKey(m.ToString("yyyy-MM")) &&
                                            DetailVendor.PaymentHistory[m.ToString("yyyy-MM")]);
                    var moMissed = moMonths.Count(m => m < new DateTime(moToday.Year, moToday.Month, 1) &&
                                            (!DetailVendor.PaymentHistory.ContainsKey(m.ToString("yyyy-MM")) ||
                                             !DetailVendor.PaymentHistory[m.ToString("yyyy-MM")]));
                    var moCollected = moPaidCount * DetailVendor.MonthlyRate;
                    var canGoNextYear = moYear < moToday.Year;
                

                    <div class="detail-section monthly-cal-section">
                        <div class="detail-section-title">
                            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                            Monthly Rental — ₱@DetailVendor.MonthlyRate.ToString("N0")/mo
                        </div>

                        <!-- Year Nav -->
                        <div class="cal-nav">
                            <button class="cal-nav-btn" @onclick="PrevMonthlyYear">
                                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                            </button>
                            <span class="cal-month-label">@moYear</span>
                            <button class="cal-nav-btn" @onclick="NextMonthlyYear" disabled="@(!canGoNextYear)">
                                <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                            </button>
                        </div>

                        <!-- 12-month grid — 4 cols x 3 rows -->
                        <div class="mo-cal-grid">
                            @foreach (var mo in moMonths)
                            {
                                var moKey = mo.ToString("yyyy-MM");
                                var isFuture = mo > new DateTime(moToday.Year, moToday.Month, 1);
                                var isThisMo = mo.Year == moToday.Year && mo.Month == moToday.Month;
                                var isPaid = DetailVendor.PaymentHistory.ContainsKey(moKey) && DetailVendor.PaymentHistory[moKey];
                                var cellCls = isFuture ? "mo-cell-future" : (isPaid ? "mo-cell-paid" : "mo-cell-miss");

                                <div class="mo-cal-cell @cellCls @(isThisMo ? "mo-cell-today" : "")">
                                    <span class="mo-cell-name">@mo.ToString("MMM")</span>
                                    @if (!isFuture)
                                    {
                                        <span class="mo-cell-mark">@(isPaid ? "✓" : "✕")</span>
                                    }
                                </div>
                            }
                        </div>

                        <!-- Summary Stats -->
                        <div class="cal-footer-stats">
                            <div class="cal-sum-item">
                                <span class="cal-sum-val cal-sum-green">@moPaidCount</span>
                                <span class="cal-sum-key">Months Paid</span>
                            </div>
                            <div class="cal-sum-item">
                                <span class="cal-sum-val cal-sum-red">@moMissed</span>
                                <span class="cal-sum-key">Months Missed</span>
                            </div>
                            <div class="cal-sum-item">
                                <span class="cal-sum-val">₱@moCollected.ToString("N0")</span>
                                <span class="cal-sum-key">Collected @moYear</span>
                            </div>
                            <div class="cal-sum-item" style="background:rgba(var(--gold-rgb),0.07); border-color:var(--gold);">
                                <span class="cal-sum-val" style="color:var(--gold);">₱@(moPaidCount* DetailVendor.MonthlyRate == DetailVendor.MonthlyRate * 12 ? (DetailVendor.MonthlyRate * 12).ToString("N0") : moCollected.ToString("N0"))</span>
                                <span class="cal-sum-key">Total Fee (@moYear)</span>
                            </div>
                        </div>
                    </div>
                }
                @* end non-NPM monthly calendar *@

            </div>

            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="() => ShowDetail = false">Close</button>
                <button class="btn-outline modal-icon-button"
                        @onclick="() => { ShowDetail = false; OpenHistory(DetailVendor); }">
                    History
                </button>
                <button class="btn-primary" @onclick="() => { ShowDetail = false; OpenEdit(DetailVendor); }">
                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                    Edit Vendor
                </button>
            </div>
        </div>
    </div>
}


<!-- ----------------------------------------------
     ADD / EDIT VENDOR MODAL
---------------------------------------------- -->
<AddVendorModal Show="ShowModal"
                IsEditing="IsEditing"
                Form="Form"
                @bind-FormError="FormError"
                FacilityOptions="FacilityTabsAsOptions()"
                FacilityLocked="false"
                OnSave="SaveVendor"
                OnCancel="CloseModal"
                OnFacilityChanged="OnFacilityChanged"
                OnSectionChanged="OnSectionChanged"
                OnToggleFee="ToggleFee" />

<!-- ----------------------------------------------
     PAYMENT HISTORY MODAL
---------------------------------------------- -->
<PaymentHistoryModal TStall="VendorEntry"
                     Show="@ShowHistory"
                     Stall="@HistoryVendor"
                     FacilityCode="@(HistoryVendor?.FacilityCode ?? string.Empty)"
                     FacilityName="@(FacilityTabs.FirstOrDefault(f => f.Code == (HistoryVendor?.FacilityCode ?? string.Empty))?.Name ?? string.Empty)"
                     OnClose="() => ShowHistory = false" />


<!-- Confirm close/reopen stall -->
@if (ShowConfirm && ConfirmTarget is not null)
{
    <div class="eemo-modal-overlay" @onclick="() => ShowConfirm = false">
        <div class="eemo-modal eemo-modal-sm" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div class="eemo-modal-title">@(ConfirmTarget.IsActive ? "Close Stall?" : "Reopen Stall?")</div>
            </div>
            <div class="eemo-modal-body">
                <p class="confirm-text">
                    @if (ConfirmTarget.IsActive)
                    {
                        @($"Mark stall {ConfirmTarget.StallNo} ({ConfirmTarget.ActualOccupant}) as Closed? It will be hidden from collection lists.")
                    }
                    else
                    {
                        @($"Reopen stall {ConfirmTarget.StallNo}? It will be re-added to the active collection list.")
                    }
                </p>
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="() => ShowConfirm = false">Cancel</button>
                <button class="@(ConfirmTarget.IsActive ? "btn-danger" : "btn-primary")" @onclick="ConfirmToggle">
                    @(ConfirmTarget.IsActive ? "Yes, Close" : "Yes, Reopen")
                </button>
            </div>
        </div>
    </div>
}


@code {

    // -- Data loading state --------------------------------------------------------
    bool isLoading = true;
    VendorRegistryDto? registryData = null;

    protected override async Task OnInitializedAsync()
    {
        await LoadVendorRegistry();
    }

    async Task LoadVendorRegistry()
    {
        isLoading = true;
        var result = await VendorsApi.GetVendorRegistryAsync(DateTime.Now.Year, DateTime.Now.Month);
        if (result.IsSuccess && result.Value != null)
        {
            registryData = result.Value;
            MapRegistryToVendors();
        }
        isLoading = false;
    }

    void MapRegistryToVendors()
    {
        if (registryData == null) return;

        Vendors.Clear();
        foreach (var item in registryData.Vendors)
        {
            Vendors.Add(new VendorEntry
            {
                Id = Vendors.Count + 1,
                FacilityCode = item.FacilityCode.ToString(),
                StallNo = item.StallNo,
                ActualOccupant = item.ActualOccupant,
                ContractName = item.NameOnContract ?? "No contract",
                Section = item.SectionDisplay ?? item.AreaLocationDisplay ?? item.FacilityName,
                OrNo = item.ORNumber,
                AreaSqm = 0,
                ContractDate = null,
                ContractYears = 0,
                MonthlyRate = item.MonthlyRate,
                ActualMonthlyRental = item.MonthlyRate,
                AreaLocation = item.AreaLocationDisplay ?? "",
                FeeTypes = new List<string>(),
                IsActive = item.Status == Domain.Enums.StallStatus.Active,
                IsPaidThisMonth = item.PaymentStatus == Domain.Enums.PaymentStatus.Paid,
                IsPartialThisMonth = item.PaymentStatus == Domain.Enums.PaymentStatus.Partial,
                PaymentHistory = new Dictionary<string, bool>(),
                DailyCollections = new Dictionary<string, bool>(),
                DailyFishKilos = new Dictionary<string, decimal>()
            });
        }

        // Update facility tabs unpaid counts
        foreach (var tab in FacilityTabs)
        {
            tab.UnpaidCount = Vendors.Count(v => v.FacilityCode == tab.Code && v.IsActive && !v.IsPaidThisMonth);
        }
    }

    // -- Calendar state --------------------------------------------------------
    DateTime CalendarMonth = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
    int MonthlyCalYear = DateTime.Now.Year;

    void PrevCalMonth() => CalendarMonth = CalendarMonth.AddMonths(-1);
    void NextCalMonth()
    {
        if (CalendarMonth < new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1))
            CalendarMonth = CalendarMonth.AddMonths(1);
    }

    void PrevMonthlyYear() => MonthlyCalYear--;
    void NextMonthlyYear()
    {
        if (MonthlyCalYear < DateTime.Now.Year)
            MonthlyCalYear++;
    }

    void ToggleDailyCollection(VendorEntry v, DateTime date)
    {
        var key = date.ToString("yyyy-MM-dd");
        if (v.DailyCollections.ContainsKey(key))
            v.DailyCollections[key] = !v.DailyCollections[key];
        else
            v.DailyCollections[key] = true;
    }

    // -- Dropdown state --------------------------------------------------------
    bool FacDropdownOpen = false;
    void ToggleFacDropdown() => FacDropdownOpen = !FacDropdownOpen;
    void CloseFacDropdown() => FacDropdownOpen = false;

    // -- Filters ---------------------------------------------------------------
    string SearchQuery = string.Empty;
    string ActiveFacility = "NPM";
    string ActiveStatus = "All";

    readonly List<string> StatusFilters = new() { "All", "Paid", "Partial", "Unpaid", "Closed" };

    FacilityTab ActiveFacilityTab => FacilityTabs.First(f => f.Code == ActiveFacility);

    // -- Facility Tab Model ----------------------------------------------------
    class FacilityTab
    {
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string ShortName { get; set; } = string.Empty;
        public string IconSvg { get; set; } = string.Empty;
        public int UnpaidCount { get; set; }
    }

    List<FacilityTab> FacilityTabs = new()
    {
        new() { Code="NPM", Name="New Public Market",        ShortName="Public Market",   UnpaidCount=20,
            IconSvg="""<svg viewBox="0 0 24 24" ><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>""" },
        new() { Code="TCC", Name="Tampak Commercial Center", ShortName="Tampak CC",       UnpaidCount=8,
            IconSvg="""<svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>""" },
        new() { Code="NCC", Name="New Commercial Center",    ShortName="New CC",          UnpaidCount=5,
            IconSvg="""<svg viewBox="0 0 24 24"><path d="M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18"/></svg>""" },
        new() { Code="BBQ", Name="Barbecue Stand",           ShortName="BBQ Stand",       UnpaidCount=1,
            IconSvg="""<svg viewBox="0 0 24 24"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>""" },
        new() { Code="ICE", Name="Iceplant",                 ShortName="Iceplant",        UnpaidCount=2,
            IconSvg="""<svg viewBox="0 0 24 24"><line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>""" },
        new() { Code="SLH", Name="Slaughterhouse",           ShortName="Slaughterhouse",  UnpaidCount=6,
            IconSvg="""<svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>""" },
    };

    // -- Vendor Model ----------------------------------------------------------
    class VendorEntry
    {
        public int Id { get; set; }
        public string FacilityCode { get; set; } = string.Empty;
        public string StallNo { get; set; } = string.Empty;
        public string ActualOccupant { get; set; } = string.Empty;
        public string ContractName { get; set; } = string.Empty;
        public string Section { get; set; } = string.Empty;
        public string? OrNo { get; set; }
        public double AreaSqm { get; set; }
        public DateTime? ContractDate { get; set; }
        public int ContractYears { get; set; }
        public decimal MonthlyRate { get; set; }
        public decimal ActualMonthlyRental { get; set; }
        public string AreaLocation { get; set; } = string.Empty;
        public List<string> FeeTypes { get; set; } = new();
        public bool HasAdditionalFees => FeeTypes.Any();
        public bool IsActive { get; set; } = true;
        public bool IsPaidThisMonth { get; set; }
        public bool IsPartialThisMonth { get; set; }
        public decimal PartialAmount { get; set; } = 0m;
        public Dictionary<string, bool> PaymentHistory { get; set; } = new();
        public Dictionary<string, bool> DailyCollections { get; set; } = new();
        public Dictionary<string, decimal> DailyFishKilos { get; set; } = new();
        public HashSet<string> ElectricityPaidMonths { get; set; } = new();
        public HashSet<string> WaterPaidMonths { get; set; } = new();

        public decimal WholeYearRental => MonthlyRate * 12;
        public decimal WholeYearActualRental => ActualMonthlyRental > 0 ? ActualMonthlyRental * 12 : WholeYearRental;
    }

    List<VendorEntry> Vendors = new();

    // All vendors across every facility — used by the page-level hero
    List<VendorEntry> AllVendors => Vendors;
    IEnumerable<VendorEntry> FilteredVendors => Vendors.Where(v =>
    {
        if (v.FacilityCode != ActiveFacility) return false;
        bool matchStatus = ActiveStatus switch
        {
            "Paid" => v.IsPaidThisMonth && v.IsActive,
            "Partial" => v.IsPartialThisMonth && v.IsActive,
            "Unpaid" => !v.IsPaidThisMonth && !v.IsPartialThisMonth && v.IsActive,
            "Closed" => !v.IsActive,
            _ => true
        };
        bool matchSearch = string.IsNullOrWhiteSpace(SearchQuery)
            || v.ActualOccupant.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || v.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || v.ContractName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);
        return matchStatus && matchSearch;
    }).OrderBy(v => v.StallNo);

    // -- Vendor Detail Modal ---------------------------------------------------
    bool ShowDetail = false;
    VendorEntry? DetailVendor = null;

    void OpenDetail(VendorEntry v)
    {
        DetailVendor = v;
        ShowDetail = true;
        CalendarMonth = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
    }

    // -- Form ------------------------------------------------------------------
    bool ShowModal = false;
    bool IsEditing = false;
    int EditingId = 0;
    AddVendorModal.VendorModalForm Form = new();

    string FormError = string.Empty;

    void OpenCreate()
    {
        IsEditing = false;
        Form = new AddVendorModal.VendorModalForm
        {
            FacilityCode = ActiveFacility,
            ContractDate = new DateTime(2023, 6, 7),
            ContractYears = 3,
            StallNo = string.Empty,
            ActualOccupant = string.Empty,
            ContractName = string.Empty,
            SelectedSection = string.Empty,
            FeeTypes = new List<string>()
        };
        FormError = string.Empty;
        AutoPopulateFees();
        ShowModal = true;
    }

    void OnFacilityChanged()
    {
        Form.SelectedSection = string.Empty;
        Form.FeeTypes.Clear();
        AutoPopulateFees();
    }

    void OnSectionChanged()
    {
        Form.FeeTypes.Clear();
        AutoPopulateFees();
    }

    void AutoPopulateFees()
    {
        Form.FeeTypes.Clear();

        if (Form.FacilityCode == "SLH")
        {
            Form.FeeTypes.AddRange(new[] { "Slaughter Fee", "Ante Mortem", "Post Mortem", "Table Charge", "Entrance Fee", "Livestock Fee" });
        }
        else if (Form.FacilityCode == "NPM")
        {
            // Default ON for NPM
            Form.FeeTypes.Add("Electricity");
            Form.FeeTypes.Add("Water");
            if (Form.SelectedSection == "Fish")
                Form.FeeTypes.Add("Fish ?1/kg");

            // Pre-fill rate if empty
            if (Form.MonthlyRate <= 0) Form.MonthlyRate = 900;
        }
        else if (Form.FacilityCode == "TCC")
        {
            if (Form.MonthlyRate <= 0) Form.MonthlyRate = 2400; // default TCC rate (most stalls ?2,400)
        }
        else if (Form.FacilityCode == "NCC" || Form.FacilityCode == "BBQ" || Form.FacilityCode == "ICE")
        {
            if (Form.MonthlyRate <= 0) Form.MonthlyRate = 900; // adjust as needed
        }
    }

  

    void SelectFacility(string code)
    {
        ActiveFacility = code;
        FacDropdownOpen = false;
    }

    void OpenEdit(VendorEntry v)
    {
        IsEditing = true;
        EditingId = v.Id;
        string selectedSection = string.Empty;
        if (v.FacilityCode == "NPM" && !string.IsNullOrEmpty(v.Section))
        {
            if (v.Section.Contains("Vegetable", StringComparison.OrdinalIgnoreCase))
                selectedSection = "Vegetable";
            else if (v.Section.Contains("Fish", StringComparison.OrdinalIgnoreCase))
                selectedSection = "Fish";
            else if (v.Section.Contains("Meat", StringComparison.OrdinalIgnoreCase))
                selectedSection = "Meat";
        }
        Form = new AddVendorModal.VendorModalForm
        {
            FacilityCode = v.FacilityCode,
            StallNo = v.StallNo,
            ActualOccupant = v.ActualOccupant,
            ContractName = v.ContractName,
            SelectedSection = selectedSection,
            AreaSqm = v.AreaSqm,
            ContractDate = v.ContractDate,
            ContractYears = v.ContractYears,
            MonthlyRate = v.MonthlyRate,
            ActualMonthlyRental = v.ActualMonthlyRental,
            AreaLocation = v.AreaLocation,
            FeeTypes = new List<string>(v.FeeTypes)
        };
        FormError = string.Empty;
        ShowModal = true;
    }
    List<AddVendorModal.VendorFacilityOption> FacilityTabsAsOptions() =>
    FacilityTabs.Select(f => new AddVendorModal.VendorFacilityOption
    { Code = f.Code, Name = f.Name }).ToList();
    void ToggleFee(string fee)
    {
        if (Form.FeeTypes.Contains(fee)) Form.FeeTypes.Remove(fee);
        else Form.FeeTypes.Add(fee);
    }

    async Task SaveVendor()
    {
        if (string.IsNullOrWhiteSpace(Form.FacilityCode)) { FormError = "Please select a facility."; return; }
        if (string.IsNullOrWhiteSpace(Form.StallNo)) { FormError = "Stall number is required."; return; }
        if (string.IsNullOrWhiteSpace(Form.ActualOccupant)) { FormError = "Actual occupant name is required."; return; }
        if (Form.FacilityCode == "NPM" && string.IsNullOrWhiteSpace(Form.SelectedSection)) { FormError = "Please select a section for NPM."; return; }
        if (Form.MonthlyRate <= 0) { FormError = "Monthly rate must be greater than 0."; return; }

        // Auto-populate Section from SelectedSection for NPM
        string section = Form.FacilityCode == "NPM" && !string.IsNullOrEmpty(Form.SelectedSection)
            ? $"{Form.SelectedSection} Area"
            : string.Empty;

        if (IsEditing)
        {
            var v = Vendors.First(x => x.Id == EditingId);
            v.FacilityCode = Form.FacilityCode;
            v.StallNo = Form.StallNo.Trim();
            v.ActualOccupant = Form.ActualOccupant.Trim();
            v.ContractName = Form.ContractName.Trim();
            v.Section = section;
            v.AreaSqm = Form.AreaSqm;
            v.ContractDate = Form.ContractDate;
            v.ContractYears = Form.ContractYears;
            v.MonthlyRate = Form.MonthlyRate;
            v.ActualMonthlyRental = Form.ActualMonthlyRental;
            v.AreaLocation = Form.AreaLocation.Trim();
            v.FeeTypes = new(Form.FeeTypes);
        }
        else
        {
            // Create new stall via API
            var facilityCode = Enum.Parse<Domain.Enums.FacilityCode>(Form.FacilityCode);
            
            // Map UI section names to enum values
            Domain.Enums.MarketSection? marketSection = null;
            if (Form.FacilityCode == "NPM" && !string.IsNullOrWhiteSpace(Form.SelectedSection))
            {
                marketSection = Form.SelectedSection switch
                {
                    "Vegetable" => Domain.Enums.MarketSection.VegetableArea,
                    "Fish" => Domain.Enums.MarketSection.FishSection,
                    "Meat" => Domain.Enums.MarketSection.MeatSection,
                    _ => null
                };
            }
            
            var nccAreaLocation = Form.FacilityCode == "NCC" && !string.IsNullOrWhiteSpace(Form.AreaLocation)
                ? Enum.Parse<Domain.Enums.NccAreaLocation>(Form.AreaLocation)
                : (Domain.Enums.NccAreaLocation?)null;
            
            // Calculate ApplicableFees from FeeTypes
            var fees = Domain.Enums.ApplicableFees.BaseRental;
            if (Form.FeeTypes.Contains("Electricity")) fees |= Domain.Enums.ApplicableFees.Electricity;
            if (Form.FeeTypes.Contains("Water")) fees |= Domain.Enums.ApplicableFees.Water;
            if (Form.FeeTypes.Any(f => f.Contains("Fish") && f.Contains("kg"))) fees |= Domain.Enums.ApplicableFees.FishFee;

            var command = new Application.Command.Stalls.CreateStall.CreateStallCommand(
                FacilityCode: facilityCode,
                StallNo: Form.StallNo.Trim(),
                MonthlyRate: Form.MonthlyRate,
                Fees: fees,
                Section: marketSection,
                AreaLocation: nccAreaLocation,
                AreaSqm: Form.AreaSqm > 0 ? Form.AreaSqm : null,
                AreaNote: string.IsNullOrWhiteSpace(Form.AreaLocation) ? null : Form.AreaLocation.Trim(),
                DailyRate: Form.FacilityCode == "NPM" ? 30.00m : null,
                ActualOccupant: Form.ActualOccupant.Trim(),
                NameOnContract: string.IsNullOrWhiteSpace(Form.ContractName) ? null : Form.ContractName.Trim(),
                ContractDate: Form.ContractDate,
                ContractYears: Form.ContractYears
            );

            var result = await StallsApi.CreateStallAsync(command);
            
            if (!result.IsSuccess)
            {
                FormError = result.Error ?? "Failed to create stall";
                return;
            }
            
            // Reload vendor registry to get the new stall
            await LoadVendorRegistry();
        }
        CloseModal();
    }

    void CloseModal() { ShowModal = false; FormError = string.Empty; }

    // -- Fish Kilo Tracking Methods --------------------------------------------
    /// <summary>
    /// Calculate total kilos for fish vendors for a specific month
    /// </summary>
    decimal GetMonthlyFishKilos(VendorEntry vendor, DateTime month)
    {
        if (!vendor.Section.Contains("Fish", StringComparison.OrdinalIgnoreCase))
            return 0;

        decimal totalKilos = 0;
        var monthStr = month.ToString("yyyy-MM");
        var daysInMonth = DateTime.DaysInMonth(month.Year, month.Month);

        for (int day = 1; day <= daysInMonth; day++)
        {
            var dayKey = $"{monthStr}-{day:D2}";
            var isCollected = vendor.DailyCollections.ContainsKey(dayKey) && vendor.DailyCollections[dayKey];
            if (isCollected && vendor.DailyFishKilos.ContainsKey(dayKey))
            {
                totalKilos += vendor.DailyFishKilos[dayKey];
            }
        }
        return totalKilos;
    }

    /// <summary>
    /// Calculate fish fee (?1/kilo) for a specific month
    /// </summary>
    decimal GetMonthlyFishFee(VendorEntry vendor, DateTime month)
    {
        return GetMonthlyFishKilos(vendor, month) * 1m; // ?1 per kilo
    }

    /// <summary>
    /// Update daily fish kilo count
    /// </summary>
    void UpdateDailyFishKilo(VendorEntry vendor, DateTime day, decimal kilos)
    {
        var dayKey = day.ToString("yyyy-MM-dd");
        if (kilos > 0)
        {
            vendor.DailyFishKilos[dayKey] = kilos;
        }
        else if (vendor.DailyFishKilos.ContainsKey(dayKey))
        {
            vendor.DailyFishKilos.Remove(dayKey);
        }
        StateHasChanged();
    }

    /// <summary>
    /// Get daily fish kilo count for a specific day
    /// </summary>
    decimal GetDailyFishKilo(VendorEntry vendor, DateTime day)
    {
        var dayKey = day.ToString("yyyy-MM-dd");
        return vendor.DailyFishKilos.ContainsKey(dayKey) ? vendor.DailyFishKilos[dayKey] : 0;
    }

