                <div>
                    <div class="eemo-modal-title">@HistoryVendor.ActualOccupant</div>
                    <div class="eemo-modal-sub">Stall @HistoryVendor.StallNo · @HistoryVendor.FacilityCode · ₱@HistoryVendor.MonthlyRate.ToString("N0")/month</div>
                </div>
                <button class="eemo-modal-close" @onclick="() => ShowHistory = false">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="eemo-modal-body">
                <div class="hist-label">12-Month Rental Payment History</div>
                <div class="hist-grid">
