    static Dictionary<string, bool> MakeHistory(int paidCount)
    {
        var dict = new Dictionary<string, bool>();
        for (int i = 11; i >= 0; i--)
        {
            var key = DateTime.Now.AddMonths(-i).ToString("yyyy-MM");
            dict[key] = (11 - i) < paidCount;
        }
        return dict;
    }

    IEnumerable<VendorEntry> FilteredVendors => Vendors.Where(v =>
    {
        if (v.FacilityCode != ActiveFacility) return false;
        bool matchStatus = ActiveStatus switch
        {
            "Paid"   =>  v.IsPaidThisMonth && v.IsActive,
            "Unpaid" => !v.IsPaidThisMonth && v.IsActive,
            "Closed" => !v.IsActive,
            _        => true
        };
        bool matchSearch = string.IsNullOrWhiteSpace(SearchQuery)
            || v.ActualOccupant.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || v.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || v.ContractName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);
        return matchStatus && matchSearch;
    }).OrderBy(v => v.StallNo);

