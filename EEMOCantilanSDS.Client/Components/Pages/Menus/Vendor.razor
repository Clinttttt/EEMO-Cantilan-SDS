    void OpenCreate()
    {
        IsEditing = false;
        Form      = new VendorForm { FacilityCode = ActiveFacility, ContractDate = new DateTime(2023,6,7), ContractYears = 3 };
        FormError = string.Empty;
        ShowModal = true;
    }

    void SelectFacility(string code)
    {
        ActiveFacility  = code;
        FacDropdownOpen = false;
    }

    void OpenEdit(VendorEntry v)
    {
        IsEditing = true;
        EditingId = v.Id;
        Form = new VendorForm
        {
            FacilityCode   = v.FacilityCode,
            StallNo        = v.StallNo,
            ActualOccupant = v.ActualOccupant,
            ContractName   = v.ContractName,
            Section        = v.Section,
            AreaSqm        = v.AreaSqm,
            ContractDate   = v.ContractDate,
            ContractYears  = v.ContractYears,
            MonthlyRate    = v.MonthlyRate,
            AreaLocation   = v.AreaLocation,
            FeeTypes       = new(v.FeeTypes)
        };
        FormError = string.Empty;
        ShowModal = true;
    }

    void ToggleFee(string fee)
    {
        if (Form.FeeTypes.Contains(fee)) Form.FeeTypes.Remove(fee);
        else Form.FeeTypes.Add(fee);
    }

    void SaveVendor()
    {
        if (string.IsNullOrWhiteSpace(Form.FacilityCode))  { FormError = "Please select a facility."; return; }
        if (string.IsNullOrWhiteSpace(Form.StallNo))       { FormError = "Stall number is required."; return; }
        if (string.IsNullOrWhiteSpace(Form.ActualOccupant)){ FormError = "Actual occupant name is required."; return; }
        if (Form.MonthlyRate <= 0)                          { FormError = "Monthly rate must be greater than ₱0."; return; }

        if (IsEditing)
        {
            var v = Vendors.First(x => x.Id == EditingId);
            v.FacilityCode   = Form.FacilityCode;
            v.StallNo        = Form.StallNo.Trim();
            v.ActualOccupant = Form.ActualOccupant.Trim();
            v.ContractName   = Form.ContractName.Trim();
            v.Section        = Form.Section.Trim();
            v.AreaSqm        = Form.AreaSqm;
            v.ContractDate   = Form.ContractDate;
            v.ContractYears  = Form.ContractYears;
            v.MonthlyRate    = Form.MonthlyRate;
            v.AreaLocation   = Form.AreaLocation.Trim();
            v.FeeTypes       = new(Form.FeeTypes);
        }
        else
        {
            Vendors.Add(new VendorEntry
            {
                Id             = Vendors.Count + 1,
                FacilityCode   = Form.FacilityCode,
                StallNo        = Form.StallNo.Trim(),
                ActualOccupant = Form.ActualOccupant.Trim(),
                ContractName   = Form.ContractName.Trim(),
                Section        = Form.Section.Trim(),
                AreaSqm        = Form.AreaSqm,
                ContractDate   = Form.ContractDate,
                ContractYears  = Form.ContractYears,
                MonthlyRate    = Form.MonthlyRate,
                AreaLocation   = Form.AreaLocation.Trim(),
                FeeTypes       = new(Form.FeeTypes),
                IsActive       = true,
                PaymentHistory = MakeHistory(0)
            });
        }
        CloseModal();
    }

    void CloseModal() { ShowModal = false; FormError = string.Empty; }

