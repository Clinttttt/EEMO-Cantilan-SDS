    string FormError = string.Empty;

    void OpenCreate()
    {
        IsEditing = false;
        Form = new AddVendorModal.VendorModalForm
        {
            FacilityCode = ActiveFacility,
            ContractDate = new DateTime(2023, 6, 7),
            ContractYears = 3,
            StallNo = string.Empty,
            ActualOccupant = string.Empty,
            ContractName = string.Empty,
            SelectedSection = string.Empty,
            Section = string.Empty,
            FeeTypes = new List<string>()
        };
        FormError = string.Empty;
        AutoPopulateFees();
        ShowModal = true;
    }

    void OnFacilityChanged()
    {
        Form.SelectedSection = string.Empty;
        Form.FeeTypes.Clear();
        AutoPopulateFees();
    }

    void OnSectionChanged()
    {
        Form.FeeTypes.Clear();
        AutoPopulateFees();
    }

    void AutoPopulateFees()
    {
        Form.FeeTypes.Clear();

        if (Form.FacilityCode == "SLH")
        {
            Form.FeeTypes.AddRange(new[] { "Slaughter Fee", "Ante Mortem", "Post Mortem", "Table Charge", "Entrance Fee", "Livestock Fee" });
        }
        else if (Form.FacilityCode == "NPM")
        {
            // Default ON for NPM
            Form.FeeTypes.Add("Electricity");
            Form.FeeTypes.Add("Water");
            if (Form.SelectedSection == "Fish")
                Form.FeeTypes.Add("Fish ₱1/kg");

            // Pre-fill rate if empty
            if (Form.MonthlyRate <= 0) Form.MonthlyRate = 900;
        }
        else if (Form.FacilityCode == "TCC")
        {
            if (Form.MonthlyRate <= 0) Form.MonthlyRate = 2400; // default TCC rate (most stalls ₱2,400)
        }
        else if (Form.FacilityCode == "NCC" || Form.FacilityCode == "BBQ" || Form.FacilityCode == "ICE")
        {
            if (Form.MonthlyRate <= 0) Form.MonthlyRate = 900; // adjust as needed
        }
    }

  

    void SelectFacility(string code)
    {
