@page "/vendors"
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>EEMO Admin — Vendors &amp; Stalls</PageTitle>

<div class="admin-layout">

    <Sidebar />

    <main class="admin-main">

        <header class="topbar">
            <div class="topbar-left">
                <div class="topbar-title">Vendors &amp; Stalls</div>
                <div class="topbar-breadcrumb">
                    <span>EEMO Admin</span>
                    <span class="breadcrumb-sep">/</span>
                    <span class="breadcrumb-active">Vendors &amp; Stalls</span>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-admin">
                    <div class="admin-avatar">A</div>
                    <div class="admin-info">
                        <div class="admin-name">Administrator</div>
                        <div class="admin-role">EEMO Office</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">

            <!-- KPI Strip -->
            <div class="kpi-strip">
                <div class="kpi-card kpi-card-stalls">
                    <div class="kpi-icon kpi-icon-blue">
                        <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/><path d="M16 21V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v16"/></svg>
                    </div>
                    <div class="kpi-body kpi-body-stalls">
                        <div class="kpi-stalls-row">
                            <div class="kpi-stalls-main">
                                <div class="kpi-value">@Vendors.Count</div>
                                <div class="kpi-label">Total Stalls</div>
                                <div class="kpi-sub">@Vendors.Count(v => v.IsActive) active · @Vendors.Count(v => !v.IsActive) closed</div>
                            </div>
                            <div class="kpi-stalls-divider"></div>
                            <div class="kpi-stalls-unpaid">
                                <div class="kpi-unpaid-val">@Vendors.Count(v => v.IsActive && !v.IsPaidThisMonth)</div>
                                <div class="kpi-unpaid-label">Unpaid</div>
                                <div class="kpi-unpaid-sub">rental</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon kpi-icon-green">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <div class="kpi-body">
                        <div class="kpi-value">@Vendors.Count(v => v.IsActive && v.IsPaidThisMonth)</div>
                        <div class="kpi-label">Rental Paid</div>
                        <div class="kpi-sub">out of @Vendors.Count(v => v.IsActive) active stalls</div>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon kpi-icon-red">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    </div>
                    <div class="kpi-body">
                        <div class="kpi-value">@Vendors.Count(v => v.IsActive && !v.IsPaidThisMonth)</div>
                        <div class="kpi-label">Rental Unpaid</div>
                        <div class="kpi-sub">₱@(Vendors.Where(v => v.IsActive && !v.IsPaidThisMonth).Sum(v => v.MonthlyRate).ToString("N0")) outstanding</div>
                    </div>
                </div>
                <div class="kpi-card">
                    <div class="kpi-icon kpi-icon-gold">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                    </div>
                    <div class="kpi-body">
                        <div class="kpi-value">₱@(Vendors.Where(v => v.IsActive).Sum(v => v.MonthlyRate).ToString("N0"))</div>
                        <div class="kpi-label">Monthly Target</div>
                        <div class="kpi-sub">@DateTime.Now.ToString("MMMM yyyy")</div>
                    </div>
                </div>
            </div>

            <!-- Toolbar -->
            <div class="vs-toolbar">
                <div class="facility-selector" id="facilitySelectorWrapper">
                    <div class="fac-trigger @(FacDropdownOpen ? "open" : "")" @onclick="ToggleFacDropdown">
                        <div class="fac-trigger-body">
                            <span class="fac-trigger-label">@ActiveFacilityTab.ShortName</span>
                            <span class="fac-trigger-sub">@ActiveFacilityTab.Name</span>
                        </div>
                        @if (ActiveFacilityTab.UnpaidCount > 0)
                        {
                            <span class="fac-trigger-badge">@ActiveFacilityTab.UnpaidCount unpaid</span>
                        }
                        <svg class="fac-trigger-chevron" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9"/></svg>
                    </div>

                    @if (FacDropdownOpen)
                    {
                        <div class="fac-backdrop" @onclick="CloseFacDropdown"></div>
                        <div class="fac-dropdown">
                            <div class="fac-dd-header">Facility</div>
                            @foreach (var f in FacilityTabs)
                            {
                                <div class="fac-dd-item @(ActiveFacility == f.Code ? "active" : "")" @onclick="() => SelectFacility(f.Code)">
                                    <div class="fac-dd-body"><span class="fac-dd-name">@f.Name</span></div>
                                    @if (f.UnpaidCount > 0) { <span class="fac-dd-badge">@f.UnpaidCount</span> }
                                    @if (ActiveFacility == f.Code)
                                    {
                                        <svg class="fac-dd-check" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <div class="vs-actions">
                    <div class="search-box">
                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                        <input type="text" placeholder="Search stall no. or name…" @bind="SearchQuery" @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(SearchQuery))
                        {
                            <span class="search-clear" @onclick="() => SearchQuery = string.Empty">×</span>
                        }
                    </div>
                    <button class="btn-primary" @onclick="OpenCreate">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Add Vendor
                    </button>
                </div>
            </div>

            <!-- Status Filter -->
            <div class="vs-status-row">
                <div class="filter-tabs">
                    @foreach (var f in StatusFilters)
                    {
                        <div class="filter-tab @(ActiveStatus == f ? "active" : "")" @onclick="() => ActiveStatus = f">@f</div>
                    }
                </div>
                <div class="vs-count-label">@FilteredVendors.Count() stalls</div>
            </div>

            <!-- Vendors Table — "This Month" column removed -->
            <div class="panel">
                @if (!FilteredVendors.Any())
                {
                    <div class="empty-state">
                        <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/></svg>
                        <div class="empty-title">No Vendors Found</div>
                        <div class="empty-sub">Try adjusting the filters or search.</div>
                    </div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Stall No.</th>
                                    <th>Actual Occupant</th>
                                    <th>Section / Area</th>
                                    <th>Status</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var v in FilteredVendors)
                                {
                                    <tr class="@(!v.IsActive ? "row-inactive" : "") vendor-row" @onclick="() => OpenDetail(v)">
                                        <td>
                                            <div class="stall-num-cell">
                                                <span class="stall-num-badge">@v.StallNo</span>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="occupant-cell">
                                                <div class="occupant-avatar">@(v.ActualOccupant.Length > 0 ? v.ActualOccupant[0].ToString().ToUpper() : "?")</div>
                                                <div>
                                                    <div class="occupant-name">@v.ActualOccupant</div>
                                                    @if (!string.IsNullOrEmpty(v.ContractName) && v.ContractName != "No contract" && v.ContractName != v.ActualOccupant)
                                                    {
                                                        <div class="occupant-contract">Contract: @v.ContractName</div>
                                                    }
                                                </div>
                                            </div>
                                        </td>
                                        <td><span class="section-tag">@v.Section</span></td>
                                        <td @onclick:stopPropagation="true">
                                            <span class="status-pill @(v.IsActive ? "pill-active" : "pill-inactive")">
                                                @(v.IsActive ? "Active" : "Closed")
                                            </span>
                                        </td>
                                        <td @onclick:stopPropagation="true">
                                            <div class="action-btns">
                                                <button class="action-btn" title="View Details" @onclick="() => OpenDetail(v)">
                                                    <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                                </button>
                                                <button class="action-btn" title="Edit" @onclick="() => OpenEdit(v)">
                                                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                                <button class="action-btn" title="Payment History" @onclick="() => OpenHistory(v)">
                                                    <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                                                </button>
                                                <button class="action-btn @(v.IsActive ? "action-danger" : "action-success")"
                                                        title="@(v.IsActive ? "Close Stall" : "Reopen Stall")"
                                                        @onclick="() => ToggleVendor(v)">
                                                    @if (v.IsActive)
                                                    {
                                                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                                                    }
                                                    else
                                                    {
                                                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                                                    }
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

        </div>
    </main>
</div>


<!-- ══════════════════════════════════════════════
     VENDOR DETAIL MODAL
══════════════════════════════════════════════ -->
@if (ShowDetail && DetailVendor is not null)
{
    <div class="eemo-modal-overlay" @onclick="() => ShowDetail = false">
        <div class="eemo-modal eemo-modal-wide detail-modal" @onclick:stopPropagation="true">

            <!-- Header -->
            <div class="detail-header">
                <div class="detail-header-left">
                    <div class="detail-avatar">@(DetailVendor.ActualOccupant.Length > 0 ? DetailVendor.ActualOccupant[0].ToString().ToUpper() : "?")</div>
                    <div>
                        <div class="detail-name">@DetailVendor.ActualOccupant</div>
                        <div class="detail-meta">
                            <span class="detail-stall-badge">Stall @DetailVendor.StallNo</span>
                            <span class="detail-sep">·</span>
                            <span>@DetailVendor.FacilityCode</span>
                            <span class="detail-sep">·</span>
                            <span class="section-tag">@DetailVendor.Section</span>
                            <span class="detail-sep">·</span>
                            <span class="status-pill @(DetailVendor.IsActive ? "pill-active" : "pill-inactive")">
                                @(DetailVendor.IsActive ? "Active" : "Closed")
                            </span>
                        </div>
                    </div>
                </div>
                <button class="eemo-modal-close" @onclick="() => ShowDetail = false">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>

            <div class="eemo-modal-body detail-body">

                <!-- Top Stats Row -->
                <div class="detail-stats-row">
                    <div class="detail-stat-card">
                        <div class="detail-stat-icon ds-icon-gold">
                            <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                        </div>
                        <div>
                            <div class="detail-stat-val">₱@DetailVendor.MonthlyRate.ToString("N0")</div>
                            <div class="detail-stat-key">Monthly Rental Rate</div>
                        </div>
                    </div>
                    <div class="detail-stat-card">
                        <div class="detail-stat-icon ds-icon-blue">
                            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        </div>
                        <div>
                            <div class="detail-stat-val">
                                @if (DetailVendor.ContractDate.HasValue)
                                {
                                    @DetailVendor.ContractDate.Value.ToString("MMM d, yyyy")
                                }
                                else
                                {
                                    <span style="color:var(--text-muted);font-size:13px">No Contract</span>
                                }
                            </div>
                            <div class="detail-stat-key">Contract Date</div>
                        </div>
                    </div>
                    <div class="detail-stat-card">
                        <div class="detail-stat-icon ds-icon-green">
                            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                        <div>
                            <div class="detail-stat-val">
                                <span class="status-pill @(DetailVendor.IsPaidThisMonth ? "pill-paid" : DetailVendor.IsPartialThisMonth ? "pill-partial" : "pill-unpaid")" style="font-size:11px;padding:4px 12px;">
                                    @(DetailVendor.IsPaidThisMonth ? "Rental Paid" : DetailVendor.IsPartialThisMonth ? "Partial" : "Unpaid")
                                </span>
                            </div>
                            <div class="detail-stat-key">Rental @DateTime.Now.ToString("MMMM yyyy")</div>
                        </div>
                    </div>
                    <div class="detail-stat-card">
                        <div class="detail-stat-icon ds-icon-navy">
                            <svg viewBox="0 0 24 24"><path d="M20 7H4a2 2 0 00-2 2v6a2 2 0 002 2h16a2 2 0 002-2V9a2 2 0 00-2-2z"/></svg>
                        </div>
                        <div>
                            <div class="detail-stat-val">@(DetailVendor.AreaSqm > 0 ? $"{DetailVendor.AreaSqm} sq.m" : "—")</div>
                            <div class="detail-stat-key">Stall Area</div>
                        </div>
                    </div>
                </div>

                <!-- Two-column info layout -->
                <div class="detail-two-col">

                    <!-- LEFT: Vendor Info -->
                    <div class="detail-section">
                        <div class="detail-section-title">
                            <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            Vendor Information
                        </div>
                        <div class="detail-info-grid">
                            <div class="detail-info-row">
                                <span class="detail-info-key">Actual Occupant</span>
                                <span class="detail-info-val">@DetailVendor.ActualOccupant</span>
                            </div>
                            <div class="detail-info-row">
                                <span class="detail-info-key">Name on Contract</span>
                                <span class="detail-info-val">
                                    @if (string.IsNullOrEmpty(DetailVendor.ContractName) || DetailVendor.ContractName == "No contract")
                                    {
                                        <span class="no-contract">No contract</span>
                                    }
                                    else
                                    {
                                        @DetailVendor.ContractName
                                    }
                                </span>
                            </div>
                            <div class="detail-info-row">
                                <span class="detail-info-key">Facility</span>
                                <span class="detail-info-val">@ActiveFacilityTab.Name</span>
                            </div>
                            <div class="detail-info-row">
                                <span class="detail-info-key">Section / Area</span>
                                <span class="detail-info-val"><span class="section-tag">@DetailVendor.Section</span></span>
                            </div>
                            <div class="detail-info-row">
                                <span class="detail-info-key">Contract Duration</span>
                                <span class="detail-info-val">
                                    @if (DetailVendor.ContractYears == 0)
                                    {
                                        <span class="no-contract">No contract</span>
                                    }
                                    else
                                    {
                                        @($"{DetailVendor.ContractYears} year{(DetailVendor.ContractYears > 1 ? "s" : "")}")
                                        @if (DetailVendor.ContractDate.HasValue)
                                        {
                                            var expiry = DetailVendor.ContractDate.Value.AddYears(DetailVendor.ContractYears);
                                            <span class="detail-expiry @(expiry < DateTime.Now ? "expiry-expired" : "expiry-ok")">
                                                (expires @expiry.ToString("MMM d, yyyy"))
                                            </span>
                                        }
                                    }
                                </span>
                            </div>
                            @if (!string.IsNullOrEmpty(DetailVendor.AreaLocation))
                            {
                                <div class="detail-info-row">
                                    <span class="detail-info-key">Area Note</span>
                                    <span class="detail-info-val">@DetailVendor.AreaLocation</span>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- RIGHT: Fee Structure — Fish & Meat now separate -->
                    <div class="detail-section">
                        <div class="detail-section-title">
                            <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
                            Fee Structure
                        </div>

                        @{
                            bool hasVegDaily    = DetailVendor.FacilityCode == "NPM" &&
                                                  DetailVendor.Section.Contains("Vegetable", StringComparison.OrdinalIgnoreCase);
                            bool hasFishSection = DetailVendor.FacilityCode == "NPM" &&
                                                  DetailVendor.Section.Contains("Fish", StringComparison.OrdinalIgnoreCase);
                            bool hasMeatSection = DetailVendor.FacilityCode == "NPM" &&
                                                  DetailVendor.Section.Contains("Meat", StringComparison.OrdinalIgnoreCase);
                            bool hasFishPerKg   = DetailVendor.FeeTypes.Any(f => f.Contains("Fish") && f.Contains("kg"));
                        }

                        <!-- Monthly rental -->
                        <div class="fee-breakdown-item fee-item-rental">
                            <div class="fee-item-left">
                                <div class="fee-item-icon">
                                    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
                                </div>
                                <div>
                                    <div class="fee-item-name">Monthly Rental</div>
                                    <div class="fee-item-sub">Fixed · Billed monthly</div>
                                </div>
                            </div>
                            <div class="fee-item-amount">₱@DetailVendor.MonthlyRate.ToString("N0")<span class="fee-freq">/mo</span></div>
                        </div>

                        @if (hasVegDaily)
                        {
                            <div class="fee-breakdown-item fee-item-daily">
                                <div class="fee-item-left">
                                    <div class="fee-item-icon fee-icon-green">
                                        <svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 110 20A10 10 0 0112 2z"/><path d="M12 8v8M8 12h8"/></svg>
                                    </div>
                                    <div>
                                        <div class="fee-item-name">Daily Collection</div>
                                        <div class="fee-item-sub">Vegetable vendor · Collected daily</div>
                                    </div>
                                </div>
                                <div class="fee-item-amount">₱30<span class="fee-freq">/day</span></div>
                            </div>
                        }

                        @if (hasFishSection)
                        {
                            <div class="fee-breakdown-item fee-item-daily">
                                <div class="fee-item-left">
                                    <div class="fee-item-icon fee-icon-blue">
                                        <svg viewBox="0 0 24 24"><path d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/><path d="M9 9h.01M15 9h.01M9.5 15a3.5 3.5 0 005 0"/></svg>
                                    </div>
                                    <div>
                                        <div class="fee-item-name">Daily Collection</div>
                                        <div class="fee-item-sub">Fish vendor · Collected daily</div>
                                    </div>
                                </div>
                                <div class="fee-item-amount">₱30<span class="fee-freq">/day</span></div>
                            </div>
                        }

                        @if (hasMeatSection)
                        {
                            <div class="fee-breakdown-item fee-item-daily">
                                <div class="fee-item-left">
                                    <div class="fee-item-icon fee-icon-red-soft">
                                        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
                                    </div>
                                    <div>
                                        <div class="fee-item-name">Daily Collection</div>
                                        <div class="fee-item-sub">Meat vendor · Collected daily</div>
                                    </div>
                                </div>
                                <div class="fee-item-amount">₱30<span class="fee-freq">/day</span></div>
                            </div>
                        }

                        @if (hasFishPerKg)
                        {
                            <div class="fee-breakdown-item fee-item-perkg">
                                <div class="fee-item-left">
                                    <div class="fee-item-icon fee-icon-gold">
                                        <svg viewBox="0 0 24 24"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
                                    </div>
                                    <div>
                                        <div class="fee-item-name">Fish Fee (by weight)</div>
                                        <div class="fee-item-sub">All fish types · Per kilo sold</div>
                                    </div>
                                </div>
                                <div class="fee-item-amount">₱1<span class="fee-freq">/kg</span></div>
                            </div>
                        }

                        @foreach (var fee in DetailVendor.FeeTypes.Where(f => !f.Contains("kg")))
                        {
                            var isElec  = fee.Contains("Electricity");
                            var isWater = fee.Contains("Water");
                            <div class="fee-breakdown-item fee-item-utility">
                                <div class="fee-item-left">
                                    <div class="fee-item-icon fee-icon-utility">
                                        @if (isElec)
                                        {
                                            <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                                        }
                                        else if (isWater)
                                        {
                                            <svg viewBox="0 0 24 24"><path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/></svg>
                                        }
                                        else
                                        {
                                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/></svg>
                                        }
                                    </div>
                                    <div>
                                        <div class="fee-item-name">@fee</div>
                                        <div class="fee-item-sub">Utility · Billed monthly</div>
                                    </div>
                                </div>
                                <div class="fee-item-amount fee-amount-variable">Variable</div>
                            </div>
                        }

                        @if (!DetailVendor.FeeTypes.Any() && !hasVegDaily && !hasFishSection && !hasMeatSection)
                        {
                            <div class="fee-none">No additional fees for this stall.</div>
                        }
                    </div>
                </div>

                <!-- ══════════════════════════════════
                     DAILY COLLECTION CALENDAR
                ══════════════════════════════════ -->
                @{
                    bool showDailyCal = DetailVendor.FacilityCode == "NPM" &&
                        (DetailVendor.Section.Contains("Vegetable", StringComparison.OrdinalIgnoreCase) ||
                         DetailVendor.Section.Contains("Fish", StringComparison.OrdinalIgnoreCase) ||
                         DetailVendor.Section.Contains("Meat", StringComparison.OrdinalIgnoreCase));
                }

                @if (showDailyCal)
                {
                   
                        var calFirst   = new DateTime(CalendarMonth.Year, CalendarMonth.Month, 1);
                        var calDays    = DateTime.DaysInMonth(CalendarMonth.Year, CalendarMonth.Month);
                        var calOffset  = (int)calFirst.DayOfWeek;
                        var calMStr    = CalendarMonth.ToString("yyyy-MM");
                        var calToday   = DateTime.Now.Date;
                        var isCurMo    = CalendarMonth.Year == calToday.Year && CalendarMonth.Month == calToday.Month;
                        var maxDay     = isCurMo ? calToday.Day : calDays;
                        var calCollected = 0;
                        for (int ci = 1; ci <= maxDay; ci++)
                        {
                            var ck = $"{calMStr}-{ci:D2}";
                            if (DetailVendor.DailyCollections.ContainsKey(ck) && DetailVendor.DailyCollections[ck])
                                calCollected++;
                        }
                        var calMissed  = maxDay - calCollected;
                        var calTotal   = calCollected * 30;
                        var canGoNext  = CalendarMonth < new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);
                    
                    <div class="detail-section">
                        <div class="detail-section-title">
                            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            Daily Collection — ₱30/day
                        </div>

                        <div class="cal-nav">
                            <button class="cal-nav-btn" @onclick="PrevCalMonth">
                                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
                            </button>
                            <span class="cal-month-label">@CalendarMonth.ToString("MMMM yyyy")</span>
                            <button class="cal-nav-btn" @onclick="NextCalMonth" disabled="@(!canGoNext)">
                                <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
                            </button>
                        </div>

                        <div class="cal-grid-wrap">
                            <div class="cal-day-hdr">Sun</div>
                            <div class="cal-day-hdr">Mon</div>
                            <div class="cal-day-hdr">Tue</div>
                            <div class="cal-day-hdr">Wed</div>
                            <div class="cal-day-hdr">Thu</div>
                            <div class="cal-day-hdr">Fri</div>
                            <div class="cal-day-hdr">Sat</div>

                            @for (int blank = 0; blank < calOffset; blank++)
                            {
                                <div class="cal-cell cal-empty"></div>
                            }

                            @for (int d = 1; d <= calDays; d++)
                            {
                                var day      = new DateTime(CalendarMonth.Year, CalendarMonth.Month, d);
                                var dayKey   = day.ToString("yyyy-MM-dd");
                                var isFuture = day.Date > calToday;
                                var isToday  = day.Date == calToday;
                                var isMarked = DetailVendor.DailyCollections.ContainsKey(dayKey) && DetailVendor.DailyCollections[dayKey];
                                var cellClass = isFuture ? "cal-future" : (isMarked ? "cal-paid" : "cal-miss");

                                <div class="cal-cell @cellClass @(isToday ? "cal-today" : "")"
                                     @onclick="() => { if (!isFuture) ToggleDailyCollection(DetailVendor, day); }">
                                    <span class="cal-num">@d</span>
                                    @if (!isFuture)
                                    {
                                        <span class="cal-mark">@(isMarked ? "✓" : "×")</span>
                                    }
                                </div>
                            }
                        </div>

                        <div class="cal-footer-stats">
                            <div class="cal-sum-item">
                                <span class="cal-sum-val cal-sum-green">@calCollected</span>
                                <span class="cal-sum-key">Days Collected</span>
                            </div>
                            <div class="cal-sum-item">
                                <span class="cal-sum-val cal-sum-red">@calMissed</span>
                                <span class="cal-sum-key">Days Missed</span>
                            </div>
                            <div class="cal-sum-item">
                                <span class="cal-sum-val">₱@calTotal.ToString("N0")</span>
                                <span class="cal-sum-key">Collected @CalendarMonth.ToString("MMM yyyy")</span>
                            </div>
                        </div>
                    </div>
                }

                <!-- ══════════════════════════════════
                     MONTHLY UTILITY PAYMENTS
                ══════════════════════════════════ -->
                @{
                    bool hasElecFee  = DetailVendor.FeeTypes.Contains("Electricity");
                    bool hasWaterFee = DetailVendor.FeeTypes.Contains("Water");
                }

                @if (hasElecFee || hasWaterFee)
                {
                    <div class="detail-section">
                        <div class="detail-section-title">
                            <svg viewBox="0 0 24 24"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                            Monthly Utility Payments
                        </div>
                        <div class="util-months-list">
      @for (int mo = 0; mo >= -5; mo--)
    {
        var mDate = DateTime.Now.AddMonths(mo);
        var mKey = mDate.ToString("yyyy-MM");
        var mLabel = mDate.ToString("MMMM yyyy");

        var elecPaid = DetailVendor.ElectricityPaidMonths.Contains(mKey);
        var waterPaid = DetailVendor.WaterPaidMonths.Contains(mKey);

        <div class="util-month-row">
            <span class="util-month-name">@mLabel</span>
            
            <div class="util-pills">
                @if (hasElecFee)
                {
                    <button class="util-pill @(elecPaid ? "util-pill-paid" : "util-pill-unpaid")"
                            @onclick="@(() => ToggleUtility(DetailVendor, "Electricity", mKey))">
                        <svg viewBox="0 0 24 24">
                            <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                        </svg>
                        @(elecPaid ? "Electricity Paid ✓" : "Electricity Unpaid")
                    </button>
                }

                @if (hasWaterFee)
                {
                    <button class="util-pill @(waterPaid ? "util-pill-paid" : "util-pill-unpaid")"
                            @onclick="@(() => ToggleUtility(DetailVendor, "Water", mKey))">
                        <svg viewBox="0 0 24 24">
                            <path d="M12 2.69l5.66 5.66a8 8 0 11-11.31 0z"/>
                        </svg>
                        @(waterPaid ? "Water Paid ✓" : "Water Unpaid")
                    </button>
                }
            </div>
        </div>
    }
    
                        </div>
                    </div>
                }

                <!-- ══════════════════════════════════
                     12-MONTH RENTAL PAYMENT HISTORY
                ══════════════════════════════════ -->
                <div class="detail-section" style="margin-top:0;">
                    <div class="detail-section-title">
                        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                        12-Month Rental Payment History
                    </div>
                    <div class="hist-grid" style="margin-bottom:14px;">
                        @for (int i = 11; i >= 0; i--)
                        {
                            var month = DateTime.Now.AddMonths(-i);
                            var paid  = DetailVendor.PaymentHistory.ContainsKey(month.ToString("yyyy-MM"))
                                        && DetailVendor.PaymentHistory[month.ToString("yyyy-MM")];
                            <div class="hist-month @(paid ? "hist-paid" : "hist-unpaid")">
                                <div class="hist-month-name">@month.ToString("MMM")</div>
                                <div class="hist-month-year">@month.ToString("yy")</div>
                                <div class="hist-month-icon">@(paid ? "✓" : "✗")</div>
                            </div>
                        }
                    </div>
                    <div class="hist-summary">
                        <div class="act-stat">
                            <div class="act-stat-val">@DetailVendor.PaymentHistory.Count(p => p.Value)</div>
                            <div class="act-stat-key">Months Paid</div>
                        </div>
                        <div class="act-stat">
                            <div class="act-stat-val">@(12 - DetailVendor.PaymentHistory.Count(p => p.Value))</div>
                            <div class="act-stat-key">Months Unpaid</div>
                        </div>
                        <div class="act-stat">
                            <div class="act-stat-val">₱@((DetailVendor.MonthlyRate * DetailVendor.PaymentHistory.Count(p => p.Value)).ToString("N0"))</div>
                            <div class="act-stat-key">Total Collected</div>
                        </div>
                        <div class="act-stat" style="@(DetailVendor.PaymentHistory.Count(p => !p.Value) > 0 ? "background:var(--red-bg);" : "")">
                            <div class="act-stat-val" style="color:var(--red)">₱@((DetailVendor.MonthlyRate * DetailVendor.PaymentHistory.Count(p => !p.Value)).ToString("N0"))</div>
                            <div class="act-stat-key">Balance Due</div>
                        </div>
                    </div>
                </div>

            </div>

            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="() => ShowDetail = false">Close</button>
                <button class="btn-outline" @onclick="() => { ShowDetail = false; OpenHistory(DetailVendor); }">
                    <svg viewBox="0 0 24 24" style="width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;margin-right:5px;"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    Payment History
                </button>
                <button class="btn-primary" @onclick="() => { ShowDetail = false; OpenEdit(DetailVendor); }">
                    <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    Edit Vendor
                </button>
            </div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════
     ADD / EDIT VENDOR MODAL
══════════════════════════════════════════════ -->
@if (ShowModal)
{
    <div class="eemo-modal-overlay" @onclick="CloseModal">
        <div class="eemo-modal eemo-modal-wide" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div>
                    <div class="eemo-modal-title">@(IsEditing ? "Edit Vendor / Stall" : "Add New Vendor")</div>
                    <div class="eemo-modal-sub">@(IsEditing ? "Update vendor and stall information." : "Register a new stall vendor in the system.")</div>
                </div>
                <button class="eemo-modal-close" @onclick="CloseModal">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </button>
            </div>
            <div class="eemo-modal-body">
                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label">Facility <span class="req">*</span></label>
                        <select class="form-input" @bind="Form.FacilityCode">
                            <option value="">-- Select Facility --</option>
                            @foreach (var f in FacilityTabs)
                            {
                                <option value="@f.Code">@f.Name</option>
                            }
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Stall / Space No. <span class="req">*</span></label>
                        <input class="form-input" type="text" placeholder="e.g. 01, T4, B-02" @bind="Form.StallNo" @bind:event="oninput" />
                    </div>
                </div>
                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label">Section / Area</label>
                        <input class="form-input" type="text" placeholder="e.g. Vegetable Area, Fish Section" @bind="Form.Section" @bind:event="oninput" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Area (sq.m)</label>
                        <input class="form-input" type="number" min="0" placeholder="e.g. 4.8" @bind="Form.AreaSqm" @bind:event="oninput" />
                    </div>
                </div>
                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label">Actual Occupant <span class="req">*</span></label>
                        <input class="form-input" type="text" placeholder="Current stall occupant" @bind="Form.ActualOccupant" @bind:event="oninput" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Name on Contract</label>
                        <input class="form-input" type="text" placeholder="Leave blank if no contract" @bind="Form.ContractName" @bind:event="oninput" />
                    </div>
                </div>
                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label">Contract Effectivity Date</label>
                        <input class="form-input" type="date" @bind="Form.ContractDate" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Contract Duration</label>
                        <select class="form-input" @bind="Form.ContractYears">
                            <option value="0">No contract</option>
                            <option value="1">1 year</option>
                            <option value="2">2 years</option>
                            <option value="3">3 years</option>
                            <option value="5">5 years</option>
                        </select>
                    </div>
                </div>
                <div class="form-row-2">
                    <div class="form-group">
                        <label class="form-label">Monthly Rental Rate (₱) <span class="req">*</span></label>
                        <input class="form-input" type="number" min="0" placeholder="e.g. 900" @bind="Form.MonthlyRate" @bind:event="oninput" />
                    </div>
                    <div class="form-group">
                        <label class="form-label">Area Location / Note</label>
                        <input class="form-input" type="text" placeholder="e.g. Extension, Corner" @bind="Form.AreaLocation" @bind:event="oninput" />
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Additional Fees</label>
                    <div class="fee-checkbox-grid">
                        @foreach (var fee in AvailableFeeTypes)
                        {
                            var isChecked = Form.FeeTypes.Contains(fee);
                            <div class="fac-checkbox @(isChecked ? "checked" : "")" @onclick="() => ToggleFee(fee)">
                                <div class="fac-check-box">
                                    @if (isChecked) { <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg> }
                                </div>
                                <span class="fac-check-name">@fee</span>
                            </div>
                        }
                    </div>
                </div>
                @if (!string.IsNullOrEmpty(FormError))
                {
                    <div class="form-error">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                        @FormError
                    </div>
                }
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="CloseModal">Cancel</button>
                <button class="btn-primary" @onclick="SaveVendor">
                    @(IsEditing ? "Save Changes" : "Add Vendor")
                </button>
            </div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════
     PAYMENT HISTORY MODAL
══════════════════════════════════════════════ -->
@if (ShowHistory && HistoryVendor is not null)
{
    <div class="eemo-modal-overlay" @onclick="() => ShowHistory = false">
