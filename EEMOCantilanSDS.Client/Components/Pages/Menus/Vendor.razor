                    {
                        var month = DateTime.Now.AddMonths(-i);
                        var paid  = HistoryVendor.PaymentHistory.ContainsKey(month.ToString("yyyy-MM"))
                                    && HistoryVendor.PaymentHistory[month.ToString("yyyy-MM")];
                        <div class="hist-month @(paid ? "hist-paid" : "hist-unpaid")">
                            <div class="hist-month-name">@month.ToString("MMM")</div>
                            <div class="hist-month-year">@month.ToString("yy")</div>
                            <div class="hist-month-icon">@(paid ? "✓" : "✗")</div>
                        </div>
                    }
                </div>
                <div class="hist-summary">
                    <div class="act-stat">
                        <div class="act-stat-val">@HistoryVendor.PaymentHistory.Count(p => p.Value)</div>
                        <div class="act-stat-key">Months Paid (12mo)</div>
                    </div>
                    <div class="act-stat">
                        <div class="act-stat-val">@(12 - HistoryVendor.PaymentHistory.Count(p => p.Value))</div>
                        <div class="act-stat-key">Months Unpaid</div>
                    </div>
                    <div class="act-stat">
                        <div class="act-stat-val">₱@((HistoryVendor.MonthlyRate * HistoryVendor.PaymentHistory.Count(p => p.Value)).ToString("N0"))</div>
                        <div class="act-stat-key">Total Collected</div>
                    </div>
                    <div class="act-stat" style="@(HistoryVendor.PaymentHistory.Count(p => !p.Value) > 0 ? "background:var(--red-bg);" : "")">
                        <div class="act-stat-val" style="color:var(--red)">₱@((HistoryVendor.MonthlyRate * HistoryVendor.PaymentHistory.Count(p => !p.Value)).ToString("N0"))</div>
                        <div class="act-stat-key">Balance Due</div>
                    </div>
                </div>
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="() => ShowHistory = false">Close</button>
            </div>
        </div>
    </div>
}


<!-- Confirm close/reopen stall -->
@if (ShowConfirm && ConfirmTarget is not null)
{
    <div class="eemo-modal-overlay" @onclick="() => ShowConfirm = false">
        <div class="eemo-modal eemo-modal-sm" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div class="eemo-modal-title">@(ConfirmTarget.IsActive ? "Close Stall?" : "Reopen Stall?")</div>
            </div>
            <div class="eemo-modal-body">
                <p class="confirm-text">
                    @if (ConfirmTarget.IsActive)
                    {
                        @($"Mark stall {ConfirmTarget.StallNo} ({ConfirmTarget.ActualOccupant}) as Closed? It will be hidden from collection lists.")
                    }
                    else
                    {
                        @($"Reopen stall {ConfirmTarget.StallNo}? It will be re-added to the active collection list.")
                    }
                </p>
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="() => ShowConfirm = false">Cancel</button>
                <button class="@(ConfirmTarget.IsActive ? "btn-danger" : "btn-primary")" @onclick="ConfirmToggle">
                    @(ConfirmTarget.IsActive ? "Yes, Close" : "Yes, Reopen")
                </button>
            </div>
        </div>
    </div>
}


@code {

    // ── Calendar state ────────────────────────────────────────────────────────
    DateTime CalendarMonth = new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1);

    void PrevCalMonth() => CalendarMonth = CalendarMonth.AddMonths(-1);
    void NextCalMonth()
    {
        if (CalendarMonth < new DateTime(DateTime.Now.Year, DateTime.Now.Month, 1))
            CalendarMonth = CalendarMonth.AddMonths(1);
    }

    void ToggleDailyCollection(VendorEntry v, DateTime date)
    {
        var key = date.ToString("yyyy-MM-dd");
        if (v.DailyCollections.ContainsKey(key))
            v.DailyCollections[key] = !v.DailyCollections[key];
        else
            v.DailyCollections[key] = true;
    }

    void ToggleUtility(VendorEntry v, string type, string monthKey)
    {
        var set = type == "Electricity" ? v.ElectricityPaidMonths : v.WaterPaidMonths;
        if (set.Contains(monthKey)) set.Remove(monthKey);
        else set.Add(monthKey);
    }

    // ── Dropdown state ────────────────────────────────────────────────────────
    bool FacDropdownOpen = false;
    void ToggleFacDropdown() => FacDropdownOpen = !FacDropdownOpen;
    void CloseFacDropdown()  => FacDropdownOpen = false;

    // ── Filters ───────────────────────────────────────────────────────────────
    string SearchQuery    = string.Empty;
    string ActiveFacility = "NPM";
    string ActiveStatus   = "All";

    readonly List<string> StatusFilters = new() { "All", "Paid", "Unpaid", "Closed" };

    FacilityTab ActiveFacilityTab => FacilityTabs.First(f => f.Code == ActiveFacility);

    // ── Facility Tab Model ────────────────────────────────────────────────────
    class FacilityTab
    {
        public string Code        { get; set; } = string.Empty;
        public string Name        { get; set; } = string.Empty;
        public string ShortName   { get; set; } = string.Empty;
        public string IconSvg     { get; set; } = string.Empty;
        public int    UnpaidCount { get; set; }
    }

    List<FacilityTab> FacilityTabs = new()
    {
        new() { Code="NPM", Name="New Public Market",        ShortName="Public Market",   UnpaidCount=20,
            IconSvg="""<svg viewBox="0 0 24 24" ><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>""" },
        new() { Code="TCC", Name="Tampak Commercial Center", ShortName="Tampak CC",       UnpaidCount=8,
            IconSvg="""<svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>""" },
        new() { Code="NCC", Name="New Commercial Center",    ShortName="New CC",          UnpaidCount=5,
            IconSvg="""<svg viewBox="0 0 24 24"><path d="M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18"/></svg>""" },
        new() { Code="BBQ", Name="Barbecue Stand",           ShortName="BBQ Stand",       UnpaidCount=1,
            IconSvg="""<svg viewBox="0 0 24 24"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" y1="22" x2="4" y2="15"/></svg>""" },
        new() { Code="ICE", Name="Iceplant",                 ShortName="Iceplant",        UnpaidCount=2,
            IconSvg="""<svg viewBox="0 0 24 24"><line x1="12" y1="2" x2="12" y2="22"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>""" },
        new() { Code="SLH", Name="Slaughterhouse",           ShortName="Slaughterhouse",  UnpaidCount=6,
            IconSvg="""<svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>""" },
    };

    // ── Vendor Model ──────────────────────────────────────────────────────────
    class VendorEntry
    {
        public int       Id                  { get; set; }
