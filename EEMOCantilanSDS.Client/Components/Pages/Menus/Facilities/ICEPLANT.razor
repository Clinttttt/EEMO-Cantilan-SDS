@page "/ice"
@page "/facility/ice"
@rendermode InteractiveServer
@inject NavigationManager Navigation
<PageTitle>EEMO Admin — Iceplant</PageTitle>

<div class="admin-layout">
    <Sidebar />

    <main class="admin-main">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left flex gap-2">
                <a href="/menu" class="ice-back-btn">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div>
                    <div class="topbar-title">Iceplant</div>
                    <div class="topbar-breadcrumb">
                        <a href="/menu" class="breadcrumb-link">Dashboard</a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">Iceplant — @DateTime.Now.ToString("MMMM yyyy")</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-admin">
                    <div class="admin-avatar">A</div>
                    <div class="admin-info">
                        <div class="admin-name">Administrator</div>
                        <div class="admin-role">EEMO Office</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">

            <!-- ── Hero Banner ── -->
            <div class="ice-hero">
                <div class="ice-hero-left">
                    <div class="ice-hero-icon">
                        <svg viewBox="0 0 24 24"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" /></svg>
                    </div>
                    <div>
                        <div class="ice-hero-eyebrow">Facility · ICE</div>
                        <div class="ice-hero-title">Iceplant</div>
                        <div class="ice-hero-sub">Municipality of Cantilan, Surigao del Sur</div>
                    </div>
                </div>
                <div class="ice-hero-stats">
                    <div class="ice-hero-stat">
                        <div class="ice-hero-val">₱@TotalCollected.ToString("N0")</div>
                        <div class="ice-hero-key">Collected</div>
                    </div>
                    <div class="ice-hero-divider"></div>
                    <div class="ice-hero-stat">
                        <div class="ice-hero-val">₱@TotalPending.ToString("N0")</div>
                        <div class="ice-hero-key">Pending</div>
                    </div>
                    <div class="ice-hero-divider"></div>
                    <div class="ice-hero-stat">
                        <div class="ice-hero-val">@CollectionRate%</div>
                        <div class="ice-hero-key">Collection Rate</div>
                    </div>
                    <div class="ice-hero-divider"></div>
                    <div class="ice-hero-stat">
                        <div class="ice-hero-val">@ActiveStalls.Count()</div>
                        <div class="ice-hero-key">Total Stalls</div>
                    </div>
                </div>
                <div class="ice-hero-progress">
                    <div class="ice-hero-progress-fill" style="width:@CollectionRate%"></div>
                </div>
            </div>

            <!-- ── Toolbar ── -->
            <Toolbar SearchQuery="@SearchQuery"
                     OnSearch="OnSearchInput"
                     ActiveFilter="@ActiveStatus"
                     OnFilterChanged="OnFilterChange"
                     Filters="@StatusFilters"
                     ShowSearch="true"
                     SearchPlaceholder="Search stall no. or occupant…"
                     MiddleContent="@ActionBarContent"
                     Actions="@ToolbarActions">
            </Toolbar>

            <!-- ── Info Bar ── -->
            <div class="ice-section-info">
                <div class="ice-section-info-left">
                    <div class="ice-section-label">All Stalls</div>
                    <div class="ice-section-desc">Monthly rental · 1,000.00 - 2,000.00 · Space Only</div>
                 
                </div>
                <div class="ice-section-mini-stats">
                    <div class="ice-mini-stat">
                        <div class="ice-mini-val">@FilteredStalls.Count(s => s.IsPaid)</div>
                        <div class="ice-mini-key">Paid</div>
                    </div>
                    <div class="ice-mini-stat unpaid-stat">
                        <div class="ice-mini-val">@FilteredStalls.Count(s => !s.IsPaid && !s.IsPartial)</div>
                        <div class="ice-mini-key">Unpaid</div>
                    </div>
                    <div class="ice-mini-stat partial-stat">
                        <div class="ice-mini-val">@FilteredStalls.Count(s => s.IsPartial)</div>
                        <div class="ice-mini-key">Partial</div>
                    </div>
                    <div class="ice-mini-stat">
                        <div class="ice-mini-val">₱@FilteredStalls.Where(s => s.IsPaid).Sum(s => s.MonthlyRate).ToString("N0")</div>
                        <div class="ice-mini-key">Collected</div>
                    </div>
                </div>
            </div>

            <!-- ── Stalls Table ── -->
            <FacilityStallsTable TStall="IceplantStall"
                                 Facility="ICE"
                                 FilteredStalls="FilteredStalls"
                                 OnPaymentClick="OpenPayment"
                                 OnHistoryClick="OpenHistory"
                                 OnEditClick="OpenEdit" />

        </div><!-- end content-area -->
    </main>
</div>


<!-- ══════════════════════════════════════════════
     PAYMENT MODAL (Reusable)
══════════════════════════════════════════════ -->
<FacilityPaymentModal TStall="IceplantStall"
                      Facility="ICE"
                      Stall="PaymentStall"
                      Show="ShowPayment"
                      OnClose="ClosePayment" />


<!-- ══════════════════════════════════════════════
     PAYMENT HISTORY MODAL (Reusable)
══════════════════════════════════════════════ -->
<PaymentHistoryModal TStall="IceplantStall"
                     Show="ShowHistory"
                     Stall="HistoryStall"
                     OnClose="() => ShowHistory = false" />

<!-- ADD / EDIT VENDOR MODAL (ICEPLANT) -->
<AddVendorModal Show="ShowAddVendorModal"
                IsEditing="false"
                Form="VendorForm"
                @bind-FormError="VendorErrorMessage"
                FacilityOptions="IcePlantFacilityOptions"
                FacilityLocked="true"
                OnSave="SubmitAddVendor"
                OnCancel="CloseAddVendorModal"
                OnFacilityChanged="() => {}"
                OnSectionChanged="() => {}"
                OnToggleFee="ToggleVendorFee" />

@code {

    string SearchQuery = string.Empty;
    string ActiveStatus = "All";
    readonly List<string> StatusFilters = new() { "All", "Paid", "Partial", "Unpaid", "Closed" };

    // Toolbar management
    private List<Toolbar.ToolbarAction> ToolbarActions => new()
    {
        new()
        {
            Label = "Add New",
            Icon = """<svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>""",
            ClassName = "btn-primary",
            Title = "Add a new stall",
            OnClickHandler = async () => { OpenAddVendorModal(); await Task.CompletedTask; }
        }
    };

    private RenderFragment ActionBarContent => @<ActionBar Facility="ice" />;

    private async Task OnSearchInput(string value)
    {
        SearchQuery = value;
    }

    private async Task OnFilterChange(string filter)
    {
        ActiveStatus = filter;
    }

    class IceplantStall
    {
        public int Id { get; set; }
        public string StallNo { get; set; } = string.Empty;
        public string ActualOccupant { get; set; } = string.Empty;
        public string ContractName { get; set; } = string.Empty;
        public double AreaSqm { get; set; }
        public DateTime? ContractDate { get; set; }
        public decimal MonthlyRate { get; set; }
        public bool HasElectricity { get; set; } = true;
        public bool HasWater { get; set; } = true;
        public bool IsPaid { get; set; }
        public bool IsPartial { get; set; }
        public decimal PartialAmount { get; set; }
        public bool IsActive { get; set; } = true;
        public string ORNumber { get; set; } = string.Empty;
        public string CollectorName { get; set; } = string.Empty;
        public decimal ElecAmount { get; set; }
        public decimal WaterAmount { get; set; }
        public decimal TotalBill => MonthlyRate;
        public decimal TotalPaid => IsPaid ? MonthlyRate : IsPartial ? PartialAmount : 0;
        public decimal BalanceDue => MonthlyRate - TotalPaid;
        public Dictionary<string, bool> PaymentHistory { get; set; } = new();
    }

    List<IceplantStall> Stalls = new()
    {
        new() { Id=1,  StallNo="I-01", ActualOccupant="Villarin, Cresencia B.",    ContractName="Cresencia B. Villarin",    AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=true,    MonthlyRate=900,  ElecAmount=310, WaterAmount=120, ORNumber="OR-2026-I01",  CollectorName="Clint Reyes",  PaymentHistory=MakeH(12) },
        new() { Id=2,  StallNo="I-02", ActualOccupant="Orbeta, Renante M.",         ContractName="Renante M. Orbeta",         AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=true,    MonthlyRate=900,  ElecAmount=275, WaterAmount=105, ORNumber="OR-2026-I02",  CollectorName="Ruel Santos",  PaymentHistory=MakeH(10) },
        new() { Id=3,  StallNo="I-03", ActualOccupant="Capuyan, Delia F.",          ContractName="Delia F. Capuyan",          AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=false,   MonthlyRate=900,  ElecAmount=295, WaterAmount=115, ORNumber="",             CollectorName="Marco Dizon",  PaymentHistory=MakeH(5)  },
        new() { Id=4,  StallNo="I-04", ActualOccupant="Dumagco, Artemio S.",        ContractName="Artemio S. Dumagco",        AreaSqm=17.5, ContractDate=new DateTime(2023,6,7), IsPaid=true,    MonthlyRate=1500, ElecAmount=510, WaterAmount=185, ORNumber="OR-2026-I04",  CollectorName="Clint Reyes",  PaymentHistory=MakeH(12) },
        new() { Id=5,  StallNo="I-05", ActualOccupant="Pacquiao, Maribel T.",       ContractName="Maribel T. Pacquiao",       AreaSqm=17.5, ContractDate=new DateTime(2023,6,7), IsPartial=true, PartialAmount=1000, MonthlyRate=1500, ElecAmount=490, WaterAmount=178, ORNumber="OR-2026-I05", CollectorName="Ruel Santos", PaymentHistory=MakeH(8) },
        new() { Id=6,  StallNo="I-06", ActualOccupant="Torregosa, Loreta C.",       ContractName="Loreta C. Torregosa",       AreaSqm=17.5, ContractDate=new DateTime(2023,6,7), IsPaid=false,   MonthlyRate=1500, ElecAmount=505, WaterAmount=183, ORNumber="",             CollectorName="Marco Dizon",  PaymentHistory=MakeH(3)  },
        new() { Id=7,  StallNo="I-07", ActualOccupant="Espinosa, Gilbert A.",       ContractName="Gilbert A. Espinosa",       AreaSqm=35.0, ContractDate=new DateTime(2023,6,7), IsPaid=true,    MonthlyRate=2800, ElecAmount=960, WaterAmount=350, ORNumber="OR-2026-I07",  CollectorName="Clint Reyes",  PaymentHistory=MakeH(11) },
        new() { Id=8,  StallNo="I-08", ActualOccupant="Baluyot, Sonia R.",          ContractName="Sonia R. Baluyot",          AreaSqm=35.0, ContractDate=new DateTime(2023,6,7), IsPaid=false,   MonthlyRate=2800, ElecAmount=935, WaterAmount=342, ORNumber="",             CollectorName="Ruel Santos",  PaymentHistory=MakeH(4)  },
        new() { Id=9,  StallNo="I-09", ActualOccupant="Closed",                     ContractName="Herminia D. Castillo",      AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=false,   IsActive=false, MonthlyRate=900, ORNumber="", CollectorName="", PaymentHistory=MakeH(1) },
        new() { Id=10, StallNo="I-10", ActualOccupant="Lazo, Cornelio M.",           ContractName="Cornelio M. Lazo",           AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=true,    MonthlyRate=900,  ElecAmount=288, WaterAmount=112, ORNumber="OR-2026-I10",  CollectorName="Marco Dizon",  PaymentHistory=MakeH(12) },
        new() { Id=11, StallNo="I-11", ActualOccupant="Pedrosa, Marilou G.",        ContractName="Marilou G. Pedrosa",        AreaSqm=17.5, ContractDate=new DateTime(2023,6,7), IsPaid=true,    MonthlyRate=1500, ElecAmount=475, WaterAmount=172, ORNumber="OR-2026-I11",  CollectorName="Clint Reyes",  PaymentHistory=MakeH(9)  },
        new() { Id=12, StallNo="I-12", ActualOccupant="Closed",                     ContractName="Domingo A. Soriano",        AreaSqm=17.5, ContractDate=new DateTime(2023,6,7), IsPaid=false,   IsActive=false, MonthlyRate=1500, ORNumber="", CollectorName="", PaymentHistory=MakeH(0) },
    };

    static Dictionary<string, bool> MakeH(int paid)
    {
        var d = new Dictionary<string, bool>();
        for (int i = 11; i >= 0; i--)
            d[DateTime.Now.AddMonths(-i).ToString("yyyy-MM")] = (11 - i) < paid;
        return d;
    }

    IEnumerable<IceplantStall> ActiveStalls => Stalls.Where(s => s.IsActive);

    decimal TotalCollected => ActiveStalls.Where(s => s.IsPaid || s.IsPartial).Sum(s => s.IsPartial ? s.PartialAmount : s.MonthlyRate);
    decimal TotalPending => ActiveStalls.Where(s => !s.IsPaid).Sum(s => s.MonthlyRate - (s.IsPartial ? s.PartialAmount : 0));
    int CollectionRate => ActiveStalls.Any() ? (int)((double)ActiveStalls.Count(s => s.IsPaid) / ActiveStalls.Count() * 100) : 0;

    IEnumerable<IceplantStall> FilteredStalls => Stalls.Where(s =>
    {
        bool matchStatus = ActiveStatus switch
        {
            "Paid" => s.IsPaid && !s.IsPartial && s.IsActive,
            "Partial" => s.IsPartial && s.IsActive,
            "Unpaid" => !s.IsPaid && !s.IsPartial && s.IsActive,
            "Closed" => !s.IsActive,
            _ => true
        };
        bool matchSearch = string.IsNullOrWhiteSpace(SearchQuery)
            || s.ActualOccupant.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.ContractName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);
        return matchStatus && matchSearch;
    }).OrderBy(s => s.StallNo);

    class PaymentForm { public string Status { get; set; } = "Paid"; }

    bool ShowPayment = false;
    IceplantStall? PaymentStall = null;
    string PayError = string.Empty;

    void OpenPayment(IceplantStall s)
    {
        PaymentStall = s;
        PayError = string.Empty;
        ShowPayment = true;
    }

    void ClosePayment() { ShowPayment = false; PaymentStall = null; PayError = string.Empty; }

    bool ShowHistory = false;
    IceplantStall? HistoryStall = null;
    void OpenHistory(IceplantStall s) { HistoryStall = s; ShowHistory = true; }
    void OpenEdit(IceplantStall s) { Navigation.NavigateTo("profile"); }

    // Add Vendor Modal (shared AddVendorModal)
    private bool ShowAddVendorModal { get; set; }
    private string VendorErrorMessage { get; set; } = string.Empty;
    private AddVendorModal.VendorModalForm VendorForm { get; set; } = new();
    private List<AddVendorModal.VendorFacilityOption> IcePlantFacilityOptions => new() { new() { Code = "ICE", Name = "Iceplant" } };

    private void OpenAddVendorModal()
    {
        VendorForm = new()
        {
            FacilityCode = "ICE",
            StallNo = string.Empty,
            ActualOccupant = string.Empty,
            ContractName = string.Empty,
            Section = "Iceplant",
            SelectedSection = string.Empty,
            AreaSqm = 0,
            MonthlyRate = 900,
            ContractDate = DateTime.Now,
            ContractYears = 1,
            AreaLocation = string.Empty,
            FeeTypes = new()
        };
        VendorErrorMessage = string.Empty;
        ShowAddVendorModal = true;
        StateHasChanged();
    }

    private void CloseAddVendorModal()
    {
        ShowAddVendorModal = false;
        VendorForm = new();
        VendorErrorMessage = string.Empty;
    }

    private void ToggleVendorFee(string fee)
    {
        if (VendorForm.FeeTypes.Contains(fee))
            VendorForm.FeeTypes.Remove(fee);
        else
            VendorForm.FeeTypes.Add(fee);
    }

    private async Task SubmitAddVendor()
    {
        // Validate form
        if (string.IsNullOrWhiteSpace(VendorForm.ActualOccupant))
        {
            VendorErrorMessage = "Actual occupant name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(VendorForm.StallNo))
        {
            VendorErrorMessage = "Stall number is required.";
            return;
        }
        if (VendorForm.MonthlyRate <= 0)
        {
            VendorErrorMessage = "Monthly rental rate is required.";
            return;
        }

            // Here you would typically save to database
            // For now, just close the modal
            CloseAddVendorModal();
        }
}
