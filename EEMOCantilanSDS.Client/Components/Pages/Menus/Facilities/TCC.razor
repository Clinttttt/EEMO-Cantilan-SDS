    static Dictionary<string, bool> MakeH(int paid)
    {
        var d = new Dictionary<string, bool>();
        for (int i = 11; i >= 0; i--)
            d[DateTime.Now.AddMonths(-i).ToString("yyyy-MM")] = (11 - i) < paid;
        return d;
    }

    IEnumerable<TccStall> ActiveStalls => Stalls.Where(s => s.IsActive);

    decimal TotalCollected => ActiveStalls.Where(s => s.IsPaid || s.IsPartial).Sum(s => s.IsPartial ? s.PartialAmount : s.MonthlyRate);
    decimal TotalPending => ActiveStalls.Where(s => !s.IsPaid).Sum(s => s.MonthlyRate - (s.IsPartial ? s.PartialAmount : 0));
    int CollectionRate => ActiveStalls.Any() ? (int)((double)ActiveStalls.Count(s => s.IsPaid) / ActiveStalls.Count() * 100) : 0;

    IEnumerable<TccStall> FilteredStalls => Stalls.Where(s =>
    {
        bool matchStatus = ActiveStatus switch
        {
            "Paid" => s.IsPaid && !s.IsPartial && s.IsActive,
            "Partial" => s.IsPartial && s.IsActive,
            "Unpaid" => !s.IsPaid && !s.IsPartial && s.IsActive,
            "Closed" => !s.IsActive,
            _ => true
        };
        bool matchSearch = string.IsNullOrWhiteSpace(SearchQuery)
            || s.ActualOccupant.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.ContractName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);
        return matchStatus && matchSearch;
    }).OrderBy(s => s.StallNo);

    class PaymentForm { public string Status { get; set; } = "Paid"; }

    bool ShowPayment = false;
    TccStall? PaymentStall = null;

    void OpenPayment(TccStall s)
    {
        PaymentStall = s;
        ShowPayment = true;
    }

    void ClosePayment() { ShowPayment = false; PaymentStall = null; }

    bool ShowHistory = false;
    TccStall? HistoryStall = null;
    void OpenHistory(TccStall s) { HistoryStall = s; ShowHistory = true; }
    void OpenEdit(TccStall s) { Navigation.NavigateTo("/profile"); }

    // Add Vendor Modal
    private bool ShowAddVendorModal { get; set; }
    private string VendorErrorMessage { get; set; } = string.Empty;
    private AddVendorModal.VendorModalForm VendorForm = new();
    private List<AddVendorModal.VendorFacilityOption> TccFacilityOptions => new() { new() { Code = "TCC", Name = "Tampak Commercial Center" } };

    private void OpenAddVendorModal()
    {
        VendorForm = new() 
        { 
            FacilityCode = "TCC",
            StallNo = string.Empty,
            ActualOccupant = string.Empty,
            ContractName = string.Empty,
            Section = "TCC",
            SelectedSection = string.Empty,
            AreaSqm = 0,
            MonthlyRate = 2400,
            ContractDate = new DateTime(2023, 6, 7),
            ContractYears = 3,
            AreaLocation = string.Empty,
            FeeTypes = new() { "Electricity", "Water" }
        };
        VendorErrorMessage = string.Empty;
        ShowAddVendorModal = true;
        StateHasChanged();
    }

    private void CloseAddVendorModal()
    {
        ShowAddVendorModal = false;
        VendorForm = new();
        VendorErrorMessage = string.Empty;
    }

    private void ToggleVendorFee(string fee)
    {
        if (VendorForm.FeeTypes.Contains(fee))
            VendorForm.FeeTypes.Remove(fee);
        else
            VendorForm.FeeTypes.Add(fee);
    }

    private async Task SubmitAddVendor()
    {
        // Validate form
        if (string.IsNullOrWhiteSpace(VendorForm.ActualOccupant))
        {
            VendorErrorMessage = "Actual occupant name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(VendorForm.StallNo))
        {
            VendorErrorMessage = "Stall number is required.";
            return;
        }
        if (VendorForm.MonthlyRate <= 0)
        {
            VendorErrorMessage = "Monthly rate must be greater than ₱0.";
            return;
        }

        // Add new stall to list
        var newStall = new TccStall
        {
            Id = Stalls.Max(s => s.Id) + 1,
            StallNo = VendorForm.StallNo.Trim(),
            ActualOccupant = VendorForm.ActualOccupant.Trim(),
            ContractName = VendorForm.ContractName.Trim(),
            AreaSqm = VendorForm.AreaSqm,
            ContractDate = VendorForm.ContractDate,
            MonthlyRate = VendorForm.MonthlyRate,
            HasElectricity = VendorForm.FeeTypes.Contains("Electricity"),
            HasWater = VendorForm.FeeTypes.Contains("Water"),
            IsActive = true,
            PaymentHistory = new()
        };

            Stalls.Add(newStall);
            CloseAddVendorModal();
        }
}
