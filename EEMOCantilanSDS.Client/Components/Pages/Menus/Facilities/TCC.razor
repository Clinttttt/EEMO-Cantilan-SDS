@page "/tcc"
@page "/facility/tcc"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]

@using EEMOCantilanSDS.Application.Command.Stalls.CreateStall
@using EEMOCantilanSDS.Application.Command.Stalls.UpdateStall
@using EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Application.Dtos.Facilities
@using EEMOCantilanSDS.Client.Components.Shared
@inject IStallsApiClient StallsApi
@inject IPaymentsApiClient PaymentsApi
@inject IFacilitiesApiClient FacilitiesApi
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))
@inject NavigationManager Navigation

<PageTitle>EEMO Admin — Tampak Commercial Center</PageTitle>

<!-- Topbar -->
<header class="topbar">
            <div class="topbar-left flex gap-2">
                <a href="/menu" class="tcc-back-btn">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div>
                    <div class="topbar-title">Tampak Commercial Center</div>
                    <div class="topbar-breadcrumb">
                        <a href="/menu" class="breadcrumb-link">Dashboard</a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">TCC — @PhilippineTime.Now.ToString("MMMM yyyy")</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @PhilippineTime.Now.ToString("MMMM d, yyyy")
                </div>
                <AccountChip />
            </div>
        </header>

        <div class="content-area">

            <!-- ── Hero Banner ── -->
            <FacilityHero 
                Eyebrow="FACILITY · TCC"
                Title="Tampak Commercial Center"
                Icon="@TccIcon"
                Stats="@HeroStats"
                ShowProgress="true"
                ProgressPercentage="@CollectionRate" />

            <!-- ── Toolbar ── -->
            <Toolbar SearchQuery="@SearchQuery"
                     OnSearch="OnSearchInput"
                     ActiveFilter="@ActiveStatus"
                     OnFilterChanged="OnFilterChange"
                     Filters="@StatusFilters"
                     ShowSearch="true"
                     SearchPlaceholder="Search stall no. or occupant…"
                     MiddleContent="@ActionBarContent"
                     Actions="@ToolbarActions">
            </Toolbar>

            <!-- ── Info Bar ── -->
            <div class="tcc-section-info">
                <div class="tcc-section-info-left">
                    <div class="tcc-section-label">All Stalls</div>
                    <div class="tcc-section-desc">Monthly rental · 2,400.00 - 3,000.00 · Sizes: 10.5–70+ sqm</div>
                
                </div>
                <div class="tcc-section-mini-stats">
                    <div class="tcc-mini-stat">
                        <div class="tcc-mini-val">@ActiveStalls.Count(s => s.IsPaid)</div>
                        <div class="tcc-mini-key">Paid</div>
                    </div>
                    <div class="tcc-mini-stat unpaid-stat">
                        <div class="tcc-mini-val">@ActiveStalls.Count(s => !s.IsPaid && !s.IsPartial)</div>
                        <div class="tcc-mini-key">Unpaid</div>
                    </div>
                    <div class="tcc-mini-stat partial-stat">
                        <div class="tcc-mini-val">@ActiveStalls.Count(s => s.IsPartial)</div>
                        <div class="tcc-mini-key">Partial</div>
                    </div>
                    <div class="tcc-mini-stat">
                        <div class="tcc-mini-val">₱@((Report?.TotalRevenue ?? TotalCollected).ToString("N0"))</div>
                        <div class="tcc-mini-key">Collected</div>
                    </div>
                </div>
            </div>

            <!-- ── Stalls (NPM-style cards · 2 per row) ── -->
            <FacilityStallsTable TStall="TccStall"
                                 Facility="TCC"
                                 ColumnSet="MonthlyCard"
                                 IsLoading="_loading"
                                 FilteredStalls="FilteredStalls"
                                 OnPaymentClick="OpenPayment"
                                 OnHistoryClick="OpenHistory"
                                 OnEditClick="OpenEdit" />

        </div><!-- end content-area -->

<!-- ══════════════════════════════════════════════
     PAYMENT RECORD MODAL (Reusable Component)
══════════════════════════════════════════════ -->
<FacilityPaymentModal TStall="TccStall"
                      Facility="TCC"
                      Stall="PaymentStall"
                      Show="ShowPayment"
                      OnClose="ClosePayment"
                      OnSave="HandleSavePayment" />


<!-- ══════════════════════════════════════════════
     PAYMENT HISTORY MODAL
══════════════════════════════════════════════ -->
<PaymentHistoryModal TStall="TccStall"
                     Show="ShowHistory"
                     Stall="HistoryStall"
                     OnClose="() => ShowHistory = false" />

<!-- ══════════════════════════════════════════════
     ADD / EDIT VENDOR MODAL (TAMPAK COMMERCIAL CENTER)
══════════════════════════════════════════════ -->
<AddVendorModal Show="ShowAddVendorModal"
                IsEditing="false"
                Form="VendorForm"
                @bind-FormError="VendorErrorMessage"
                FieldErrors="VendorFieldErrors"
                FacilityOptions="TccFacilityOptions"
                FacilityLocked="true"
                ExistingStallNos="TccStallNos"
                OnSave="SubmitAddVendor"
                OnCancel="CloseAddVendorModal"
                OnFacilityChanged="() => {}"
                OnSectionChanged="() => {}"
                OnToggleFee="ToggleVendorFee" />



@code {

    private bool _loading = true;
    string SearchQuery = string.Empty;
    string ActiveStatus = "All";
    readonly List<string> StatusFilters = new() { "All", "Paid", "Partial", "Unpaid", "Closed" };

    private RenderFragment TccIcon => @<svg viewBox="0 0 24 24" style="width: 26px; height: 26px; stroke: var(--gold); fill: none; stroke-width: 2;"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" /><line x1="12" y1="12" x2="12" y2="16" /><line x1="10" y1="14" x2="14" y2="14" /></svg>;

    // Monthly report — single source of truth for hero + collection rate (matches the Reports page).
    private FacilityReportsDto? Report;

    private List<FacilityHero.HeroStat> HeroStats => new()
    {
        new() { Value = $"₱{(Report?.TotalRevenue ?? TotalCollected):N0}", Label = "Collected" },
        new() { Value = $"₱{(Report?.PendingPaymentAmount ?? TotalPending):N0}", Label = "Pending" },
        new() { Value = $"{CollectionRate}%", Label = "Collection Rate" },
        new() { Value = $"{(Report?.OccupiedStalls ?? ActiveStalls.Count())}", Label = "Total Stalls" }
    };

    protected override async Task OnInitializedAsync()
    {
        ResetState();
        try { await LoadStallsFromApi(paintLoading: true); }
        finally { _loading = false; }
    }

    private async Task LoadStallsFromApi(bool paintLoading = false)
    {
        if (paintLoading)
        {
            _loading = true;
            await PaintLoadingStateAsync();
        }

        var now = DateTime.Now;

        // Monthly report for the hero + collection rate (same source as the Reports page).
        var reportTask = FacilitiesApi.GetFacilityReportsAsync(
            FacilityCode.TCC, ReportPeriod.Monthly, now.Year, now.Month);
        var stallsTask = StallsApi.GetStallsByFacilityPaginatedAsync(FacilityCode.TCC, null, null, 100);
        var paymentsTask = PaymentsApi.GetFacilityPaymentRecordsAsync(FacilityCode.TCC, now.Year, now.Month);

        await Task.WhenAll(reportTask, stallsTask, paymentsTask);

        var reportResult = await reportTask;
        if (reportResult.IsSuccess) Report = reportResult.Value;

        var result = await stallsTask;
        if (result.IsSuccess && result.Value != null)
        {
            // Single batch call for all current-month payment records (avoids per-stall N+1)
            var paymentsResult = await paymentsTask;
            var payments = paymentsResult.IsSuccess && paymentsResult.Value != null
                ? paymentsResult.Value.ToDictionary(p => p.StallId)
                : new();

            Stalls.Clear();
            int id = 1;
            foreach (var dto in result.Value.Items)
            {
                bool isPaid = false;
                bool isPartial = false;
                decimal partialAmount = 0;
                string orNumber = dto.ORNumber ?? string.Empty;

                if (payments.TryGetValue(dto.Id, out var payment))
                {
                    isPaid = payment.Status == PaymentStatus.Paid;
                    isPartial = payment.Status == PaymentStatus.Partial;
                    partialAmount = payment.TotalPaid;
                    orNumber = payment.ORNumber ?? dto.ORNumber ?? string.Empty;
                }
                
                Stalls.Add(new TccStall
                {
                    Id = id++,
                    StallGuid = dto.Id,
                    StallNo = dto.StallNo,
                    ActualOccupant = dto.ActualOccupant ?? "N/A",
                    ContractName = dto.NameOnContract ?? "N/A",
                    AreaSqm = dto.AreaSqm ?? 0,
                    ContractDate = dto.ContractDate,
                    MonthlyRate = dto.MonthlyRate,
                    IsActive = dto.Status == StallStatus.Active,
                    ORNumber = orNumber,
                    IsPaid = isPaid,
                    IsPartial = isPartial,
                    PartialAmount = partialAmount,
                    HasElectricity = true,
                    HasWater = true,
                    PaymentHistory = MakeH(0)
                });
            }
        }
    }

    private async Task PaintLoadingStateAsync()
    {
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
    }

    private void ResetState()
    {
        SearchQuery = string.Empty;
        ActiveStatus = "All";
        ShowPayment = false;
        PaymentStall = null;
        ShowHistory = false;
        HistoryStall = null;
    }

    // Toolbar management
    private List<Toolbar.ToolbarAction> ToolbarActions => new()
    {
        new()
        {
            Label = "Reports",
            Icon = """<svg viewBox="0 0 24 24"><path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z" /></svg>""",
            ClassName = "btn-outline",
            Title = "View Facility Reports & Analytics",
            OnClickHandler = async () =>
            {
                Navigation.NavigateTo("/tcc/reports");
                await Task.CompletedTask;
            }
        },
        new()
        {
            Label = "Add New",
            Icon = """<svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>""",
            ClassName = "btn-primary",
            Title = "Add a new stall",
            OnClickHandler = async () => { OpenAddVendorModal(); await Task.CompletedTask; }
        }
    };

    private RenderFragment ActionBarContent => @<ActionBar Facility="tcc" />;

    private async Task OnSearchInput(string value)
    {
        SearchQuery = value;
    }

    private async Task OnFilterChange(string filter)
    {
        ActiveStatus = filter;
    }

    class TccStall
    {
        public int Id { get; set; }
        public Guid StallGuid { get; set; } = Guid.Empty;
        public string StallNo { get; set; } = string.Empty;
        public string ActualOccupant { get; set; } = string.Empty;
        public string ContractName { get; set; } = string.Empty;
        public double AreaSqm { get; set; }
        public bool IsCorner { get; set; }
        public DateTime? ContractDate { get; set; }
        public decimal MonthlyRate { get; set; }
        public bool HasElectricity { get; set; } = true;
        public bool HasWater { get; set; } = true;
        public bool IsPaid { get; set; }
        public bool IsPartial { get; set; }
        public decimal PartialAmount { get; set; }
        public bool IsActive { get; set; } = true;
        public string ORNumber { get; set; } = string.Empty;
        public string CollectorName { get; set; } = string.Empty;
        public decimal ElecAmount { get; set; }
        public decimal WaterAmount { get; set; }
        public decimal TotalBill => MonthlyRate + ElecAmount + WaterAmount;
        public decimal TotalPaid => IsPaid ? TotalBill : IsPartial ? PartialAmount : 0;
        public decimal BalanceDue => TotalBill - TotalPaid;
        public Dictionary<string, bool> PaymentHistory { get; set; } = new();
    }

    List<TccStall> Stalls = new();

    // Existing stall numbers — feeds the modal's next-number suggestion.
    private IReadOnlyCollection<string> TccStallNos => Stalls.Select(s => s.StallNo).ToList();

    static Dictionary<string, bool> MakeH(int paid)
    {
        var d = new Dictionary<string, bool>();
        for (int i = 11; i >= 0; i--)
            d[DateTime.Now.AddMonths(-i).ToString("yyyy-MM")] = (11 - i) < paid;
        return d;
    }

    IEnumerable<TccStall> ActiveStalls => Stalls.Where(s => s.IsActive);

    decimal TotalCollected => ActiveStalls.Where(s => s.IsPaid || s.IsPartial).Sum(s => s.IsPartial ? s.PartialAmount : s.MonthlyRate);
    decimal TotalPending => ActiveStalls.Where(s => !s.IsPaid).Sum(s => s.MonthlyRate - (s.IsPartial ? s.PartialAmount : 0));
    int CollectionRate => Report is not null
        ? (int)Math.Round(Report.CollectionRate)
        : (ActiveStalls.Any() ? (int)((double)ActiveStalls.Count(s => s.IsPaid) / ActiveStalls.Count() * 100) : 0);

    IEnumerable<TccStall> FilteredStalls => Stalls.Where(s =>
    {
        bool matchStatus = ActiveStatus switch
        {
            "Paid" => s.IsPaid && !s.IsPartial && s.IsActive,
            "Partial" => s.IsPartial && s.IsActive,
            "Unpaid" => !s.IsPaid && !s.IsPartial && s.IsActive,
            "Closed" => !s.IsActive,
            _ => true
        };
        bool matchSearch = string.IsNullOrWhiteSpace(SearchQuery)
            || s.ActualOccupant.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.ContractName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);
        return matchStatus && matchSearch;
    }).OrderBy(s => s.StallNo);

    class PaymentForm { public string Status { get; set; } = "Paid"; }

    bool ShowPayment = false;
    TccStall? PaymentStall = null;

    void OpenPayment(TccStall s)
    {
        PaymentStall = s;
        ShowPayment = true;
    }

    void ClosePayment() { ShowPayment = false; PaymentStall = null; }

    private async Task HandleSavePayment(FacilityPaymentModal<TccStall>.PaymentSubmitDto payment)
    {
        if (PaymentStall != null)
        {
            PaymentStall.ORNumber = payment.OrNumber;

            // Reload from API so payment status, hero stats and mini-stats reflect the recorded payment.
            await LoadStallsFromApi();

            ShowPayment = false;
            PaymentStall = null;
        }
    }

    bool ShowHistory = false;
    TccStall? HistoryStall = null;
    void OpenHistory(TccStall s) { HistoryStall = s; ShowHistory = true; }
    void OpenEdit(TccStall s) { Navigation.NavigateTo($"/profile/tcc/{s.StallGuid}"); }

    // Add Vendor Modal
    private bool ShowAddVendorModal { get; set; }
    private string VendorErrorMessage { get; set; } = string.Empty;
    private Dictionary<string, string> VendorFieldErrors { get; set; } = new();
    private AddVendorModal.VendorModalForm VendorForm = new();
    private List<AddVendorModal.VendorFacilityOption> TccFacilityOptions => new() { new() { Code = "TCC", Name = "Tampak Commercial Center" } };

    private void OpenAddVendorModal()
    {
        VendorForm = new() 
        { 
            FacilityCode = "TCC",
            StallNo = string.Empty,
            ActualOccupant = string.Empty,
            ContractName = string.Empty,
            SelectedSection = string.Empty,
            AreaSqm = 0,
            MonthlyRate = 2400,
            ContractDate = DateTime.Today,
            ContractYears = 3,
            AreaLocation = string.Empty,
            FeeTypes = new() { "Electricity", "Water" }
        };
        VendorErrorMessage = string.Empty;
        VendorFieldErrors.Clear();
        ShowAddVendorModal = true;
        StateHasChanged();
    }

    private void CloseAddVendorModal()
    {
        ShowAddVendorModal = false;
        VendorForm = new();
        VendorErrorMessage = string.Empty;
        VendorFieldErrors.Clear();
    }

    private void ToggleVendorFee(string fee)
    {
        if (VendorForm.FeeTypes.Contains(fee))
            VendorForm.FeeTypes.Remove(fee);
        else
            VendorForm.FeeTypes.Add(fee);
    }

    private async Task SubmitAddVendor()
    {
        VendorErrorMessage = string.Empty;
        VendorFieldErrors.Clear();

        var fees = ApplicableFees.BaseRental;
        if (VendorForm.FeeTypes.Contains("Electricity"))
            fees |= ApplicableFees.Electricity;
        if (VendorForm.FeeTypes.Contains("Water"))
            fees |= ApplicableFees.Water;

        var command = new CreateStallCommand(
            FacilityCode.TCC,
            VendorForm.StallNo.Trim(),
            VendorForm.MonthlyRate,
            fees,
            null,
            null,
            VendorForm.AreaSqm,
            null,
            null,
            VendorForm.ActualOccupant.Trim(),
            string.IsNullOrWhiteSpace(VendorForm.ContractName) ? null : VendorForm.ContractName.Trim(),
            VendorForm.ContractDate,
            VendorForm.ContractYears);

        var result = await StallsApi.CreateStallAsync(command);

        if (result.IsSuccess)
        {
            // Reload from API so the new stall reflects backend truth (GUID, name fallback, status).
            await LoadStallsFromApi();
            CloseAddVendorModal();
        }
        else
        {
            if (result.ValidationErrors != null && result.ValidationErrors.Any())
            {
                foreach (var error in result.ValidationErrors)
                {
                    VendorFieldErrors[error.Key] = error.Value.FirstOrDefault() ?? string.Empty;
                }
                StateHasChanged();
            }
            else
            {
                VendorErrorMessage = result.Error ?? "Failed to create stall.";
            }
        }
    }
}
