@page "/tcc"
@page "/facility/tcc"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>EEMO Admin — Tampak Commercial Center</PageTitle>

<div class="admin-layout">
    <Sidebar />

    <main class="admin-main">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left flex gap-2">
                <a href="/menu" class="tcc-back-btn">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div>
                    <div class="topbar-title">Tampak Commercial Center</div>
                    <div class="topbar-breadcrumb">
                        <a href="/menu" class="breadcrumb-link">Dashboard</a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">TCC — @DateTime.Now.ToString("MMMM yyyy")</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-admin">
                    <div class="admin-avatar">A</div>
                    <div class="admin-info">
                        <div class="admin-name">Administrator</div>
                        <div class="admin-role">EEMO Office</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">

            <!-- ── Hero Banner ── -->
            <div class="tcc-hero">
                <div class="tcc-hero-left">
                    <div class="tcc-hero-icon">
                        <svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" /><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" /><line x1="12" y1="12" x2="12" y2="16" /><line x1="10" y1="14" x2="14" y2="14" /></svg>
                    </div>
                    <div>
                        <div class="tcc-hero-eyebrow">Facility · TCC</div>
                        <div class="tcc-hero-title">Tampak Commercial Center</div>
                        <div class="tcc-hero-sub">Municipality of Cantilan, Surigao del Sur</div>
                    </div>
                </div>
                <div class="tcc-hero-stats">
                    <div class="tcc-hero-stat">
                        <div class="tcc-hero-val">₱@TotalCollected.ToString("N0")</div>
                        <div class="tcc-hero-key">Collected</div>
                    </div>
                    <div class="tcc-hero-divider"></div>
                    <div class="tcc-hero-stat">
                        <div class="tcc-hero-val">₱@TotalPending.ToString("N0")</div>
                        <div class="tcc-hero-key">Pending</div>
                    </div>
                    <div class="tcc-hero-divider"></div>
                    <div class="tcc-hero-stat">
                        <div class="tcc-hero-val">@CollectionRate%</div>
                        <div class="tcc-hero-key">Collection Rate</div>
                    </div>
                    <div class="tcc-hero-divider"></div>
                    <div class="tcc-hero-stat">
                        <div class="tcc-hero-val">@ActiveStalls.Count()</div>
                        <div class="tcc-hero-key">Total Stalls</div>
                    </div>
                </div>
                <div class="tcc-hero-progress">
                    <div class="tcc-hero-progress-fill" style="width:@CollectionRate%"></div>
                </div>
            </div>

            <!-- ── Toolbar ── -->
            <Toolbar SearchQuery="@SearchQuery"
                     OnSearch="OnSearchInput"
                     ActiveFilter="@ActiveStatus"
                     OnFilterChanged="OnFilterChange"
                     Filters="@StatusFilters"
                     ShowSearch="true"
                     SearchPlaceholder="Search stall no. or occupant…"
                     MiddleContent="@ActionBarContent"
                     Actions="@ToolbarActions">
            </Toolbar>

            <!-- ── Info Bar ── -->
            <div class="tcc-section-info">
                <div class="tcc-section-info-left">
                    <div class="tcc-section-label">All Stalls</div>
                    <div class="tcc-section-desc">Monthly rental · 2,400.00 - 3,000.00 · Sizes: 10.5–70+ sqm</div>
                
                </div>
                <div class="tcc-section-mini-stats">
                    <div class="tcc-mini-stat">
                        <div class="tcc-mini-val">@FilteredStalls.Count(s => s.IsPaid)</div>
                        <div class="tcc-mini-key">Paid</div>
                    </div>
                    <div class="tcc-mini-stat unpaid-stat">
                        <div class="tcc-mini-val">@FilteredStalls.Count(s => !s.IsPaid && !s.IsPartial)</div>
                        <div class="tcc-mini-key">Unpaid</div>
                    </div>
                    <div class="tcc-mini-stat partial-stat">
                        <div class="tcc-mini-val">@FilteredStalls.Count(s => s.IsPartial)</div>
                        <div class="tcc-mini-key">Partial</div>
                    </div>
                    <div class="tcc-mini-stat">
                        <div class="tcc-mini-val">₱@FilteredStalls.Where(s => s.IsPaid).Sum(s => s.MonthlyRate).ToString("N0")</div>
                        <div class="tcc-mini-key">Collected</div>
                    </div>
                </div>
            </div>

            <!-- ── Stalls Table ── -->
            <FacilityStallsTable TStall="TccStall"
                                 Facility="TCC"
                                 FilteredStalls="FilteredStalls"
                                 OnPaymentClick="OpenPayment"
                                 OnHistoryClick="OpenHistory"
                                 OnEditClick="OpenEdit" />

        </div><!-- end content-area -->
    </main>
</div>


<!-- ══════════════════════════════════════════════
     RECORD PAYMENT MODAL
══════════════════════════════════════════════ -->
@if (ShowPayment && PaymentStall is not null)
{
    <div class="eemo-modal-overlay" @onclick="ClosePayment">
        <div class="eemo-modal" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div>
                    <div class="eemo-modal-title">Payment Record</div>
                    <div class="eemo-modal-sub">Stall @PaymentStall.StallNo · @PaymentStall.ActualOccupant · @DateTime.Now.ToString("MMMM yyyy")</div>
                </div>
                <button class="eemo-modal-close" @onclick="ClosePayment">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="eemo-modal-body">

                <!-- Status Badge -->
                <div style="padding:12px 16px;border-radius:8px;text-align:center;margin-bottom:16px;
                            background:@(PaymentStall.IsPaid ? "var(--green-bg)" : PaymentStall.IsPartial ? "rgba(184, 115, 51, 0.08)" : "var(--red-bg)");">
                    <div style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;
                               color:@(PaymentStall.IsPaid ? "var(--green)" : PaymentStall.IsPartial ? "#b87333" : "var(--red)");">
                        Status: @(PaymentStall.IsPaid ? "Paid" : PaymentStall.IsPartial ? $"Partial — ₱{PaymentStall.PartialAmount:N0}" : "Unpaid")
                    </div>
                </div>

                <!-- Monthly Rental -->
                <div class="pay-fee-block">
                    <div class="pay-fee-header">
                        <span class="pay-fee-label">Monthly Rental</span>
                        <span class="pay-fee-rate">₱@PaymentStall.MonthlyRate.ToString("N0")/mo · @PaymentStall.AreaSqm sqm</span>
                    </div>
                    @if (PaymentStall.IsPaid)
                    {
                        <div class="pay-record-row">
                            <span class="pay-record-key">Amount Due</span>
                            <span class="pay-record-val">✓ ₱@PaymentStall.MonthlyRate.ToString("N0")</span>
                        </div>
                    }
                    else if (PaymentStall.IsPartial)
                    {
                        <div class="pay-record-row">
                            <span class="pay-record-key">Amount Due</span>
                            <span class="pay-record-val">₱@PaymentStall.MonthlyRate.ToString("N0")</span>
                        </div>
                        <div class="pay-record-row">
                            <span class="pay-record-key">Amount Paid</span>
                            <span class="pay-record-val">✓ ₱@PaymentStall.PartialAmount.ToString("N0")</span>
                        </div>
                        <div class="pay-record-row">
                            <span class="pay-record-key">Balance Remaining</span>
                            <span class="pay-record-val">⚠ ₱@((PaymentStall.MonthlyRate - PaymentStall.PartialAmount).ToString("N0"))</span>
                        </div>
                    }
                    else
                    {
                        <div class="pay-record-row">
                            <span class="pay-record-key">Amount Due</span>
                            <span class="pay-record-val">✗ ₱@PaymentStall.MonthlyRate.ToString("N0")</span>
                        </div>
                    }
                </div>

                <!-- Financial Summary/Breakdown -->
                <div style="margin-top:20px;padding:16px;border-radius:8px;background:var(--bg-card);border:1px solid var(--border);">
                    <div style="font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--navy);margin-bottom:12px;">
                        Financial Breakdown
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;border-bottom:2px solid var(--border);margin-bottom:8px;">
                        <span>Monthly Rental:</span>
                        <span style="font-weight:600;">₱@PaymentStall.MonthlyRate.ToString("N0")</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;">
                        <span>Total Paid:</span>
                        <span style="font-weight:600;">₱@PaymentStall.TotalPaid.ToString("N0")</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;">
                        <span>Balance Due:</span>
                        <span style="font-weight:600;">₱@PaymentStall.BalanceDue.ToString("N0")</span>
                    </div>
                </div>

            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="ClosePayment">Close</button>
            </div>
        </div>
    </div>
}


<!-- ══════════════════════════════════════════════
     PAYMENT HISTORY MODAL
══════════════════════════════════════════════ -->
<PaymentHistoryModal TStall="TccStall"
                     Show="ShowHistory"
                     Stall="HistoryStall"
                     OnClose="() => ShowHistory = false" />

<!-- ══════════════════════════════════════════════
     ADD / EDIT VENDOR MODAL (TAMPAK COMMERCIAL CENTER)
══════════════════════════════════════════════ -->
