                FacilityOptions="TccFacilityOptions"
                FacilityLocked="true"
                OnSave="SubmitAddVendor"
                OnCancel="CloseAddVendorModal"
                OnFacilityChanged="() => {}"
                OnSectionChanged="() => {}"
                OnToggleFee="ToggleVendorFee" />

