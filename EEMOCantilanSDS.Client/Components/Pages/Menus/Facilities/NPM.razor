@page "/npm"
@page "/facility/npm"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>EEMO Admin — New Public Market</PageTitle>

<div class="admin-layout">

    <!-- ═══════════════════════════════════════
         SIDEBAR
    ═══════════════════════════════════════ -->
    <Sidebar />

    <main class="admin-main">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left flex gap-2">
                <a href="/menu" class="npm-back-btn">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div>
                    <div class="topbar-title">New Public Market</div>
                    <div class="topbar-breadcrumb">
                        <a href="/menu" class="breadcrumb-link">Dashboard</a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">NPM — @DateTime.Now.ToString("MMMM yyyy")</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-admin">
                    <div class="admin-avatar">A</div>
                    <div class="admin-info">
                        <div class="admin-name">Administrator</div>
                        <div class="admin-role">EEMO Office</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">

            <!-- ── NPM Hero Banner ── -->
            <div class="npm-hero">
                <div class="npm-hero-left">
                    <div class="npm-hero-icon">
                        <svg viewBox="0 0 24 24" class="npm-icon-svg"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                    </div>
                    <div>
                        <div class="npm-hero-eyebrow">Facility · NPM</div>
                        <div class="npm-hero-title">New Public Market</div>
                        <div class="npm-hero-sub">Municipality of Cantilan, Surigao del Sur</div>
                    </div>
                </div>
                <div class="npm-hero-stats">
                    <div class="npm-hero-stat">
                        <div class="npm-hero-val">₱@TotalCollected.ToString("N0")</div>
                        <div class="npm-hero-key">Collected</div>
                    </div>
                    <div class="npm-hero-divider"></div>
                    <div class="npm-hero-stat">
                        <div class="npm-hero-val">₱@TotalPending.ToString("N0")</div>
                        <div class="npm-hero-key">Pending</div>
                    </div>
                    <div class="npm-hero-divider"></div>
                    <div class="npm-hero-stat">
                        <div class="npm-hero-val">@CollectionRate%</div>
                        <div class="npm-hero-key">Collection Rate</div>
                    </div>
                    <div class="npm-hero-divider"></div>
                    <div class="npm-hero-stat">
                        <div class="npm-hero-val">@ActiveStalls.Count()</div>
                        <div class="npm-hero-key">Total Stalls</div>
                    </div>
                </div>
                <div class="npm-hero-progress">
                    <div class="npm-hero-progress-fill" style="width:@CollectionRate%"></div>
                </div>
            </div>

            <!-- ── Section Tabs ── -->
            <div class="npm-section-tabs">
                @foreach (var secs in Sections)
                {
                    var count = StallsBySection(secs.Key).Count();
                    var unpaid = StallsBySection(secs.Key).Count(s => !s.IsPaid);
                    <div class="npm-sec-tab @(ActiveSection == secs.Key ? "active" : "")"
                         @onclick="() => SetSection(secs.Key)">
                        <div class="npm-sec-icon">@((MarkupString)secs.Value.Icon)</div>
                        <div class="npm-sec-info">
                            <div class="npm-sec-name">@secs.Key</div>
                            <div class="npm-sec-sub">@count stalls @(unpaid > 0 ? $"· {unpaid} unpaid" : "")</div>
                        </div>
                        @if (unpaid > 0)
                        {
                            <span class="npm-sec-badge">@unpaid</span>
                        }
                    </div>
                }
            </div>

            <!-- ── Toolbar ── -->
            <div class="page-toolbar">
                <div class="toolbar-left">
                    <div class="search-box">
                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                        <input type="text" placeholder="Search stall no. or occupant…"
                               @bind="SearchQuery" @bind:event="oninput" />
                        @if (!string.IsNullOrEmpty(SearchQuery))
                        {
                            <span class="search-clear" @onclick="() => SearchQuery = string.Empty">×</span>
                        }
                    </div>
                    <div class="filter-tabs">
                        @foreach (var f in StatusFilters)
                        {
                            <div class="filter-tab @(ActiveStatus == f ? "active" : "")"
                                 @onclick="() => ActiveStatus = f">
                                @f
                            </div>
                        }
                    </div>
                </div>
                <div style="display:flex;gap:8px;">
                    <a href="/vendors?facility=npm" class="btn-outline">
                        <svg viewBox="0 0 24 24" style="width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;vertical-align:middle;margin-right:4px;"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                        Manage Vendors
                    </a>
                </div>
            </div>

            <!-- ── Section Info Bar ── -->
            @{
                var sec = Sections[ActiveSection];
            }
            <div class="npm-section-info">
                <div class="npm-section-info-left">
                    <div class="npm-section-label">@ActiveSection</div>
                    <div class="npm-section-desc">@sec.Description</div>
                    <div class="fee-chips" style="margin-top:8px;">
                        @foreach (var fee in sec.FeeTypes)
                        {
                            <span class="fee-chip">@fee</span>
                        }
                    </div>
                </div>
                <div class="npm-section-mini-stats">
                    <div class="npm-mini-stat">
                        <div class="npm-mini-val">@FilteredStalls.Count(s => s.IsPaid)</div>
                        <div class="npm-mini-key">Paid</div>
                    </div>
                    <div class="npm-mini-stat unpaid-stat">
                        <div class="npm-mini-val">@FilteredStalls.Count(s => !s.IsPaid && !s.IsPartial)</div>
                        <div class="npm-mini-key">Unpaid</div>
                    </div>
                    <div class="npm-mini-stat partial-stat">
                        <div class="npm-mini-val">@FilteredStalls.Count(s => s.IsPartial)</div>
                        <div class="npm-mini-key">Partial</div>
                    </div>
                    <div class="npm-mini-stat">
                        <div class="npm-mini-val">₱@FilteredStalls.Where(s => s.IsPaid).Sum(s => s.MonthlyRate).ToString("N0")</div>
                        <div class="npm-mini-key">Collected</div>
                    </div>
                </div>
            </div>

            <!-- ── Stalls Table ── -->
            <div class="panel">
                @if (!FilteredStalls.Any())
                {
                    <div class="empty-state">
                        <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /></svg>
                        <div class="empty-title">No Stalls Found</div>
                        <div class="empty-sub">Try adjusting the filters or search.</div>
                    </div>
                }
                else
                {
                    <div class="table-wrap">
                        <table class="data-table">
                            <thead>
                                <tr>
                                    <th>Stall No.</th>
                                    <th>Actual Occupant</th>
                                    <th>Name on Contract</th>
                                    <th>Area (sqm)</th>
                                    <th>Contract Date</th>
                                    <th>Monthly Rent</th>
                                    <th>OR No.</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in FilteredStalls)
                                {
                                    <tr class="@GetRowClass(s)">
                                        <td>@s.StallNo</td>
                                        <td>@s.ActualOccupant</td>
                                        <td>
                                            @if (string.IsNullOrEmpty(s.ContractName) || s.ContractName.StartsWith("No contract"))
                                            {
                                                <span>No contract</span>
                                            }
                                            else
                                            {
                                                @s.ContractName
                                            }
                                        </td>
                                        <td>@(s.AreaSqm > 0 ? $"{s.AreaSqm}" : "—")</td>
                                        <td>@(s.ContractDate.HasValue? s.ContractDate.Value.ToString("MMM d, yyyy") : "—")</td>
                                        <td>₱@s.MonthlyRate.ToString("N0")</td>
                                        <td>
                                            <span class="mono">@(string.IsNullOrEmpty(s.ORNumber) ? "—" : s.ORNumber)</span>
                                        </td>
                                        <td>
                                            <div class="action-btns">
                                                <button class="action-btn" title="View / Record Payment" @onclick="() => OpenPayment(s)">
                                                    <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                                                </button>
                                                <button class="action-btn" title="Payment History" @onclick="() => OpenHistory(s)">
                                                    <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                                                </button>
                                                <button class="action-btn" title="View Profile" @onclick="() => OpenEdit(s)">
                                                    <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

        </div><!-- end content-area -->
    </main>
</div>


<!-- ══════════════════════════════════════════════
     PAYMENT RECORD MODAL (READ-ONLY)
══════════════════════════════════════════════ -->
@if (ShowPayment && PaymentStall is not null)
{
    <div class="eemo-modal-overlay" @onclick="ClosePayment">
        <div class="eemo-modal" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div>
                    <div class="eemo-modal-title">Payment Record</div>
                    <div class="eemo-modal-sub">Stall @PaymentStall.StallNo · @PaymentStall.ActualOccupant · @DateTime.Now.ToString("MMMM yyyy")</div>
                </div>
                <button class="eemo-modal-close" @onclick="ClosePayment">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="eemo-modal-body">

                <!-- Status Badge -->
                <div style="padding:12px 16px;border-radius:8px;text-align:center;margin-bottom:16px;
                            background:@(PaymentStall.IsPaid ? "var(--green-bg)" : PaymentStall.IsPartial ? "rgba(184, 115, 51, 0.08)" : "var(--red-bg)");">
                    <div style="font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;
                               color:@(PaymentStall.IsPaid ? "var(--green)" : PaymentStall.IsPartial ? "#b87333" : "var(--red)");">
                        Status: @(PaymentStall.IsPaid ? "Paid" : PaymentStall.IsPartial ? $"Partial — ₱{PaymentStall.PartialAmount:N0}" : "Unpaid")
                    </div>
                </div>

                <!-- Daily Market Fee -->
                <div class="pay-fee-block">
                    <div class="pay-fee-header">
                        <span class="pay-fee-label">Daily Market Fee</span>
                        <span class="pay-fee-rate">₱30/day · ₱@PaymentStall.MonthlyRate.ToString("N0")/mo</span>
                    </div>
                    @if (PaymentStall.IsPaid)
                    {
                        <div class="pay-record-row">
                            <span class="pay-record-key">Amount Due</span>
                            <span class="pay-record-val">✓ ₱@PaymentStall.MonthlyRate.ToString("N0")</span>
                        </div>
                    }
                    else if (PaymentStall.IsPartial)
                    {
                        <div class="pay-record-row">
                            <span class="pay-record-key">Amount Due</span>
                            <span class="pay-record-val">₱@PaymentStall.MonthlyRate.ToString("N0")</span>
                        </div>
                        <div class="pay-record-row">
                            <span class="pay-record-key">Amount Paid</span>
                            <span class="pay-record-val">✓ ₱@PaymentStall.PartialAmount.ToString("N0")</span>
                        </div>
                        <div class="pay-record-row">
                            <span class="pay-record-key">Balance Remaining</span>
                            <span class="pay-record-val">⚠ ₱@((PaymentStall.MonthlyRate - PaymentStall.PartialAmount).ToString("N0"))</span>
                        </div>
                    }
                    else
                    {
                        <div class="pay-record-row">
                            <span class="pay-record-key">Amount Due</span>
                            <span class="pay-record-val">✗ ₱@PaymentStall.MonthlyRate.ToString("N0")</span>
                        </div>
                    }
                </div>

                <!-- Electricity -->
                @if (PaymentStall.HasElectricity)
                {
                    <div class="pay-fee-block">
                        <div class="pay-fee-header">
                            <span class="pay-fee-label">Electricity Bill</span>
                        </div>
                        @if (PaymentStall.IsPaid)
                        {
                            <div class="pay-record-row">
                                <span class="pay-record-key">Amount Due</span>
                                <span class="pay-record-val">✓ ₱@PaymentStall.ElecAmount.ToString("N0")</span>
                            </div>
                        }
                        else if (PaymentStall.IsPartial)
                        {
                            <div class="pay-record-row">
                                <span class="pay-record-key">Amount Due</span>
                                <span class="pay-record-val">₱@PaymentStall.ElecAmount.ToString("N0")</span>
                            </div>
                            <div class="pay-record-row">
                                <span class="pay-record-key">Amount Paid</span>
                                <span class="pay-record-val">✓ ₱@((PaymentStall.ElecAmount / 2).ToString("N0"))</span>
                            </div>
                            <div class="pay-record-row">
                                <span class="pay-record-key">Balance Remaining</span>
                                <span class="pay-record-val">⚠ ₱@((PaymentStall.ElecAmount / 2).ToString("N0"))</span>
                            </div>
                        }
                        else
                        {
                            <div class="pay-record-row">
                                <span class="pay-record-key">Amount Due</span>
                                <span class="pay-record-val">✗ ₱@PaymentStall.ElecAmount.ToString("N0")</span>
                            </div>
                        }
                    </div>
                }

                <!-- Water -->
                @if (PaymentStall.HasWater)
                {
                    <div class="pay-fee-block">
                        <div class="pay-fee-header">
                            <span class="pay-fee-label">Water Bill</span>
                        </div>
                        @if (PaymentStall.IsPaid)
                        {
                            <div class="pay-record-row">
                                <span class="pay-record-key">Amount Due</span>
                                <span class="pay-record-val">✓ ₱@PaymentStall.WaterAmount.ToString("N0")</span>
                            </div>
                        }
                        else if (PaymentStall.IsPartial)
                        {
                            <div class="pay-record-row">
                                <span class="pay-record-key">Amount Due</span>
                                <span class="pay-record-val">₱@PaymentStall.WaterAmount.ToString("N0")</span>
                            </div>
                            <div class="pay-record-row">
                                <span class="pay-record-key">Amount Paid</span>
                                <span class="pay-record-val">✓ ₱@((PaymentStall.WaterAmount / 2).ToString("N0"))</span>
                            </div>
                            <div class="pay-record-row">
                                <span class="pay-record-key">Balance Remaining</span>
                                <span class="pay-record-val">⚠ ₱@((PaymentStall.WaterAmount / 2).ToString("N0"))</span>
                            </div>
                        }
                        else
                        {
                            <div class="pay-record-row">
                                <span class="pay-record-key">Amount Due</span>
                                <span class="pay-record-val">✗ ₱@PaymentStall.WaterAmount.ToString("N0")</span>
                            </div>
                        }
                    </div>
                     }

                    <!-- Financial Summary/Breakdown -->
                    <div style="margin-top:20px;padding:16px;border-radius:8px;background:var(--bg-card);border:1px solid var(--border);">
                        <div style="font-size:13px;font-weight:600;text-transform:uppercase;letter-spacing:.05em;color:var(--navy);margin-bottom:12px;">
                            Financial Breakdown
                        </div>
                        <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;border-bottom:1px solid var(--border);">
                            <span>Daily Market Fee:</span>
                            <span style="font-weight:600;">₱@PaymentStall.MonthlyRate.ToString("N0")</span>
                        </div>
                        @if (PaymentStall.HasElectricity)
                        {
                            <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;border-bottom:1px solid var(--border);">
                                <span>Electricity Bill:</span>
                                <span style="font-weight:600;">₱@PaymentStall.ElecAmount.ToString("N0")</span>
                            </div>
                        }
                        @if (PaymentStall.HasWater)
                        {
                            <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;border-bottom:1px solid var(--border);">
                                <span>Water Bill:</span>
                                <span style="font-weight:600;">₱@PaymentStall.WaterAmount.ToString("N0")</span>
                            </div>
                        }
                        @if (PaymentStall.FishFee > 0)
                        {
                            <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;border-bottom:1px solid var(--border);">
                                <span>Fish Fee (@PaymentStall.FishKilos kg @@₱1/kg):</span>
                                <span style="font-weight:600;">₱@PaymentStall.FishFee.ToString("N0")</span>
                            </div>
                        }
                        <div style="display:flex;justify-content:space-between;padding:12px 0;font-size:14px;font-weight:700;border-bottom:2px solid var(--border);margin:8px 0;">
                            <span>TOTAL BILL:</span>
                            <span>₱@PaymentStall.TotalBill.ToString("N0")</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;">
                            <span>Total Paid:</span>
                            <span style="font-weight:600;">₱@PaymentStall.TotalPaid.ToString("N0")</span>
                        </div>
                        <div style="display:flex;justify-content:space-between;padding:8px 0;font-size:13px;">
                            <span>Balance Due:</span>
                            <span style="font-weight:600;">₱@PaymentStall.BalanceDue.ToString("N0")</span>
                        </div>
                    </div>

                </div>
                <div class="eemo-modal-footer">
                    <button class="btn-ghost" @onclick="ClosePayment">Close</button>
                </div>
        </div>
    </div>
}


<!-- Payment History Modal -->
@if (ShowHistory && HistoryStall is not null)
{
    <div class="eemo-modal-overlay" @onclick="() => ShowHistory = false">
        <div class="eemo-modal eemo-modal-wide" @onclick:stopPropagation="true">
            <div class="eemo-modal-header">
                <div>
                    <div class="eemo-modal-title">@HistoryStall.ActualOccupant</div>
                    <div class="eemo-modal-sub">Stall @HistoryStall.StallNo · @ActiveSection · ₱@HistoryStall.MonthlyRate.ToString("N0")/month</div>
                </div>
                <button class="eemo-modal-close" @onclick="() => ShowHistory = false">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="eemo-modal-body">
                <div class="hist-label">12-Month Payment History</div>
                <div class="hist-grid">
                    @for (int i = 11; i >= 0; i--)
                    {
                        var month = DateTime.Now.AddMonths(-i);
                        var key = month.ToString("yyyy-MM");
                        var paid = HistoryStall.PaymentHistory.ContainsKey(key) && HistoryStall.PaymentHistory[key];
                        <div class="hist-month @(paid ? "hist-paid" : "hist-unpaid")">
                            <div class="hist-month-name">@month.ToString("MMM")</div>
                            <div class="hist-month-year">@month.ToString("yy")</div>
                            <div class="hist-month-icon">@(paid ? "✓" : "✗")</div>
                        </div>
                    }
                </div>
                <div class="hist-summary">
                    <div class="act-stat">
                        <div class="act-stat-val">@HistoryStall.PaymentHistory.Count(p => p.Value)</div>
                        <div class="act-stat-key">Months Paid</div>
                    </div>
                    <div class="act-stat">
                        <div class="act-stat-val">@(12 - HistoryStall.PaymentHistory.Count(p => p.Value))</div>
                        <div class="act-stat-key">Months Unpaid</div>
                    </div>
                    <div class="act-stat">
                        <div class="act-stat-val">₱@(HistoryStall.MonthlyRate* HistoryStall.PaymentHistory.Count(p => p.Value)).ToString("N0")</div>
                        <div class="act-stat-key">Total Collected</div>
                    </div>
                    <div class="act-stat" style="@(HistoryStall.PaymentHistory.Any(p => !p.Value) ? "background:var(--red-bg);" : "")">
                        <div class="act-stat-val" style="color:var(--red)">₱@(HistoryStall.MonthlyRate* HistoryStall.PaymentHistory.Count(p => !p.Value)).ToString("N0")</div>
                        <div class="act-stat-key">Balance Due</div>
                    </div>
                </div>
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="() => ShowHistory = false">Close</button>
            </div>
        </div>
    </div>
}


@code {

    bool SidebarCollapsed = false;

    string SearchQuery = string.Empty;
    string ActiveSection = "Vegetable Section";
    string ActiveStatus = "All";
    readonly List<string> StatusFilters = new() { "All", "Paid", "Partial", "Unpaid", "Closed" };

    protected override void OnInitialized()
    {
        ResetState();
    }

    private void ResetState()
    {
        SearchQuery = string.Empty;
        ActiveSection = "Vegetable Area";
        ActiveStatus = "All";
        ShowPayment = false;
        PaymentStall = null;
        ShowHistory = false;
        HistoryStall = null;
    }

    class SectionInfo
    {
        public string Icon { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public List<string> FeeTypes { get; set; } = new();
    }

    Dictionary<string, SectionInfo> Sections = new()
    {
        ["Vegetable Area"] = new()
        {
            Icon = """<svg viewBox="0 0 24 24"><path d="M12 2a10 10 0 00-6.88 17.25C7 21 8.5 22 12 22s5-1 6.88-2.75A10 10 0 0012 2z"/></svg>""",
            Description = "Fresh vegetable stalls — ₱900/month · ₱30/day",
            FeeTypes = new() { "Stall ₱900/mo", "Daily ₱30/day", "Electricity", "Water" }
        },
        ["Fish Section"] = new()
