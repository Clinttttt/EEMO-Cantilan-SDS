    }

    // Add Vendor Modal
    private bool ShowAddVendorModal { get; set; }
    private string VendorErrorMessage { get; set; } = string.Empty;
    private AddVendorModal.VendorModalForm VendorForm = new();
    private List<AddVendorModal.VendorFacilityOption> NpmFacilityOptions => new() { new() { Code = "NPM", Name = "New Public Market" } };

    private void OpenAddVendorModal()
    {
        VendorForm = new() 
        { 
            FacilityCode = "NPM",
            StallNo = string.Empty,
            ActualOccupant = string.Empty,
            ContractName = string.Empty,
            SelectedSection = "Vegetable",
            Section = "Vegetable Area",
            AreaSqm = 0,
            MonthlyRate = 900,
            ContractDate = new DateTime(2023, 6, 7),
            ContractYears = 3,
            AreaLocation = string.Empty,
            FeeTypes = new() { "Electricity", "Water" }
        };
        VendorErrorMessage = string.Empty;
        ShowAddVendorModal = true;
        StateHasChanged();
    }

    private void CloseAddVendorModal()
    {
        ShowAddVendorModal = false;
        VendorForm = new();
        VendorErrorMessage = string.Empty;
    }

    private void OnSectionModalChanged()
    {
        // Auto-populate section and fees based on selected section
        if (VendorForm.SelectedSection == "Vegetable")
        {
            VendorForm.Section = "Vegetable Area";
            VendorForm.MonthlyRate = 900;
            VendorForm.FeeTypes = new() { "Electricity", "Water" };
        }
        else if (VendorForm.SelectedSection == "Fish")
        {
            VendorForm.Section = "Fish Section";
            VendorForm.MonthlyRate = 900;
            VendorForm.FeeTypes = new() { "Electricity", "Water", "Fish ₱1/kg" };
        }
        else if (VendorForm.SelectedSection == "Meat")
        {
            VendorForm.Section = "Meat Section";
            VendorForm.MonthlyRate = 900;
            VendorForm.FeeTypes = new() { "Electricity", "Water" };
        }
    }

    private void ToggleVendorFee(string fee)
    {
        if (VendorForm.FeeTypes.Contains(fee))
            VendorForm.FeeTypes.Remove(fee);
        else
            VendorForm.FeeTypes.Add(fee);
    }

    private async Task SubmitAddVendor()
    {
        // Validate form
        if (string.IsNullOrWhiteSpace(VendorForm.ActualOccupant))
        {
            VendorErrorMessage = "Actual occupant name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(VendorForm.StallNo))
        {
            VendorErrorMessage = "Stall number is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(VendorForm.SelectedSection))
        {
            VendorErrorMessage = "Please select a section for NPM.";
            return;
        }
        if (VendorForm.MonthlyRate <= 0)
        {
            VendorErrorMessage = "Monthly rate must be greater than ₱0.";
            return;
        }

        // Add new stall to list
        var newStall = new NpmStall
        {
            Id = Stalls.Max(s => s.Id) + 1,
            StallNo = VendorForm.StallNo.Trim(),
            Section = VendorForm.Section,
            ActualOccupant = VendorForm.ActualOccupant.Trim(),
            ContractName = VendorForm.ContractName.Trim(),
            AreaSqm = VendorForm.AreaSqm,
            ContractDate = VendorForm.ContractDate,
            MonthlyRate = VendorForm.MonthlyRate,
            HasElectricity = VendorForm.FeeTypes.Contains("Electricity"),
            HasWater = VendorForm.FeeTypes.Contains("Water"),
            IsActive = true,
            PaymentHistory = new()
        };

            Stalls.Add(newStall);
            CloseAddVendorModal();
        }
}
