@page "/npm"
@page "/facility/npm"
@attribute [Authorize]

@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject IStallsApiClient StallsApi
@inject IPaymentsApiClient PaymentsApi

<PageTitle>EEMO Admin — New Public Market</PageTitle>

<div class="admin-layout">

    <!-- ═══════════════════════════════════════
         SIDEBAR
    ═══════════════════════════════════════ -->
    <Sidebar />

    <main class="admin-main">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left flex gap-2">
                <a href="/menu" class="npm-back-btn">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div>
                    <div class="topbar-title">New Public Market</div>
                    <div class="topbar-breadcrumb">
                        <a href="/menu" class="breadcrumb-link">Dashboard</a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">NPM — @DateTime.Now.ToString("MMMM yyyy")</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-admin">
                    <div class="admin-avatar">A</div>
                    <div class="admin-info">
                        <div class="admin-name">Administrator</div>
                        <div class="admin-role">EEMO Office</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">

            <!-- ── NPM Hero Banner ── -->
            <div class="npm-hero">
                <div class="npm-hero-left">
                    <div class="npm-hero-icon">
                        <svg viewBox="0 0 24 24" class="npm-icon-svg"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                    </div>
                    <div>
                        <div class="npm-hero-eyebrow">Facility · NPM</div>
                        <div class="npm-hero-title">New Public Market</div>
                        <div class="npm-hero-sub">Municipality of Cantilan, Surigao del Sur</div>
                    </div>
                </div>
                <div class="npm-hero-stats">
                    <div class="npm-hero-stat">
                        <div class="npm-hero-val">₱@TotalCollected.ToString("N0")</div>
                        <div class="npm-hero-key">Collected</div>
                    </div>
                    <div class="npm-hero-divider"></div>
                    <div class="npm-hero-stat">
                        <div class="npm-hero-val">₱@TotalPending.ToString("N0")</div>
                        <div class="npm-hero-key">Pending</div>
                    </div>
                    <div class="npm-hero-divider"></div>
                    <div class="npm-hero-stat">
                        <div class="npm-hero-val">@CollectionRate%</div>
                        <div class="npm-hero-key">Collection Rate</div>
                    </div>
                    <div class="npm-hero-divider"></div>
                    <div class="npm-hero-stat">
                        <div class="npm-hero-val">@ActiveStalls.Count()</div>
                        <div class="npm-hero-key">Total Stalls</div>
                    </div>
                </div>
                <div class="npm-hero-progress">
                    <div class="npm-hero-progress-fill" style="width:@CollectionRate%"></div>
                </div>
            </div>

            <!-- ── Section Tabs ── -->
            <div class="npm-section-tabs">
                @foreach (var secs in Sections)
                {
                    var count = StallsBySection(secs.Key).Count();
                    var unpaid = StallsBySection(secs.Key).Count(s => !s.IsPaid);
                    <div class="npm-sec-tab @(ActiveSection == secs.Key ? "active" : "")"
                         @onclick="() => SetSection(secs.Key)">
                        <div class="npm-sec-icon">@((MarkupString)secs.Value.Icon)</div>
                        <div class="npm-sec-info">
                            <div class="npm-sec-name">@secs.Key</div>
                            <div class="npm-sec-sub">@count stalls @(unpaid > 0 ? $"· {unpaid} unpaid" : "")</div>
                        </div>
                        @if (unpaid > 0)
                        {
                            <span class="npm-sec-badge">@unpaid</span>
                        }
                    </div>
                }
            </div>

            <!-- ── Toolbar (Reusable Component) ── -->
            <Toolbar SearchQuery="@SearchQuery"
                     OnSearch="OnSearchChanged"
                     ActiveFilter="@ActiveStatus"
                     OnFilterChanged="OnFilterStatusChanged"
                     Filters="@StatusFilters"
                     MiddleContent="@ActionBarContent"
                     Actions="@ToolbarActions">
            </Toolbar>

            <!-- ── Section Info Bar ── -->
            @{
                var sec = Sections[ActiveSection];
            }
            <div class="npm-section-info">
                <div class="npm-section-info-left">
                    <div class="npm-section-label">@ActiveSection</div>
                    <div class="npm-section-desc">@sec.Description</div>
                   
                </div>
                <div class="npm-section-mini-stats">
                    <div class="npm-mini-stat">
                        <div class="npm-mini-val">@FilteredStalls.Count(s => s.IsPaid)</div>
                        <div class="npm-mini-key">Paid</div>
                    </div>
                    <div class="npm-mini-stat unpaid-stat">
                        <div class="npm-mini-val">@FilteredStalls.Count(s => !s.IsPaid && !s.IsPartial)</div>
                        <div class="npm-mini-key">Unpaid</div>
                    </div>
                    <div class="npm-mini-stat partial-stat">
                        <div class="npm-mini-val">@FilteredStalls.Count(s => s.IsPartial)</div>
                        <div class="npm-mini-key">Partial</div>
                    </div>
                    <div class="npm-mini-stat">
                        <div class="npm-mini-val">₱@FilteredStalls.Where(s => s.IsPaid).Sum(s => s.MonthlyRate).ToString("N0")</div>
                        <div class="npm-mini-key">Collected</div>
                    </div>
                </div>
            </div>

            <!-- ── Stalls Table (Reusable Component) ── -->
            <FacilityStallsTable TStall="NpmStall"
                                 Facility="NPM"
                                 FilteredStalls="FilteredStalls"
                                 OnPaymentClick="OpenPayment"
                                 OnHistoryClick="OpenHistory"
                                 OnEditClick="OpenEdit" />

        </div><!-- end content-area -->
    </main>
</div>


<!-- ══════════════════════════════════════════════
     PAYMENT RECORD MODAL (Reusable Component)
══════════════════════════════════════════════ -->
<FacilityPaymentModal TStall="NpmStall"
                      Facility="NPM"
                      Stall="PaymentStall"
                      Show="ShowPayment"
                      OnClose="ClosePayment"
                      OnSave="HandleSavePayment" />


<!-- ══════════════════════════════════════════════
     PAYMENT HISTORY MODAL (Reusable)
══════════════════════════════════════════════ -->
<PaymentHistoryModal TStall="NpmStall"
                     Show="ShowHistory"
                     Stall="HistoryStall"
                     OnClose="() => ShowHistory = false" />

<!-- ══════════════════════════════════════════════
     ADD / EDIT VENDOR MODAL (NEW PUBLIC MARKET)
══════════════════════════════════════════════ -->
<AddVendorModal Show="ShowAddVendorModal"
                IsEditing="IsEditingVendor"
                Form="VendorForm"
                @bind-FormError="VendorErrorMessage"
                FieldErrors="VendorFieldErrors"
                FacilityOptions="NpmFacilityOptions"
                FacilityLocked="true"
                OnSave="SubmitVendor"
                OnCancel="CloseAddVendorModal"
                OnFacilityChanged="() => {}"
                OnSectionChanged="OnSectionModalChanged"
                OnToggleFee="ToggleVendorFee" />

@code {

    bool SidebarCollapsed = false;

    string SearchQuery = string.Empty;
    string ActiveSection = "Vegetable Section";
    string ActiveStatus = "All";
    readonly List<string> StatusFilters = new() { "All", "Paid", "Partial", "Unpaid", "Closed" };

    private List<Toolbar.ToolbarAction> ToolbarActions = new();

    private RenderFragment ActionBarContent => @<ActionBar Facility="npm" />;

    protected override async Task OnInitializedAsync()
    {
        ResetState();
        InitializeToolbarActions();
        await LoadStallsFromApi();
    }

    private async Task LoadStallsFromApi()
    {
        var result = await StallsApi.GetStallsByFacilityPaginatedAsync(FacilityCode.NPM, null, null, 100);
        if (result.IsSuccess && result.Value != null)
        {
            Stalls.Clear();
            int id = 1;
            foreach (var dto in result.Value.Items)
            {
                var section = dto.Section switch
                {
                    MarketSection.VegetableArea => "Vegetable Area",
                    MarketSection.FishSection => "Fish Section",
                    MarketSection.MeatSection => "Meat Section",
                    _ => "Vegetable Area"
                };

                // Fetch current month's payment record for this stall
                var paymentResult = await PaymentsApi.GetPaymentRecordAsync(
                    dto.Id,
                    DateTime.Now.Year,
                    DateTime.Now.Month);

                bool isPaid = false;
                bool isPartial = false;
                decimal partialAmount = 0;
                string orNumber = dto.ORNumber ?? string.Empty;

                if (paymentResult.IsSuccess && paymentResult.Value != null)
                {
                    var payment = paymentResult.Value;
                    isPaid = payment.Status == PaymentStatus.Paid;
                    isPartial = payment.Status == PaymentStatus.Partial;
                    partialAmount = payment.TotalPaid;
                    orNumber = payment.ORNumber ?? dto.ORNumber ?? string.Empty;
                }

                Stalls.Add(new NpmStall
                {
                    Id = id++,
                    StallGuid = dto.Id,
                    StallNo = dto.StallNo,
                    Section = section,
                    ActualOccupant = dto.ActualOccupant ?? "N/A",
                    ContractName = dto.NameOnContract ?? "N/A",
                    AreaSqm = dto.AreaSqm ?? 0,
                    ContractDate = dto.ContractDate,
                    MonthlyRate = dto.MonthlyRate,
                    IsActive = dto.Status == StallStatus.Active,
                    ORNumber = orNumber,
                    IsPaid = isPaid,
                    IsPartial = isPartial,
                    PartialAmount = partialAmount,
                    PaymentHistory = new()
                });
            }
        }
    }

    private void InitializeToolbarActions()
    {
        ToolbarActions = new()
        {
            new()
            {
                Label = "Add New",
                Icon = """<svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>""",
                ClassName = "btn-primary",
                Title = "Add New Vendor",
                OnClickHandler = async () => { OpenAddVendorModal(); await Task.CompletedTask; }
            }
        };
    }

    private async Task OnSearchChanged(string value)
    {
        SearchQuery = value;
    }

    private async Task OnFilterStatusChanged(string filter)
    {
        ActiveStatus = filter;
    }

    private void ResetState()
    {
        SearchQuery = string.Empty;
        ActiveSection = "Vegetable Area";
        ActiveStatus = "All";
        ShowPayment = false;
        PaymentStall = null;
        ShowHistory = false;
        HistoryStall = null;
    }

    class SectionInfo
    {
        public string Icon { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public List<string> FeeTypes { get; set; } = new();
    }

    Dictionary<string, SectionInfo> Sections = new()
    {
        ["Vegetable Area"] = new()
        {
            // Carrot icon — clearly a vegetable
            Icon = """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2c0 0-1 3-1 6s1 5 1 5"/><path d="M12 13s-4-2-7-1c1 4 4 6 7 6s6-2 7-6c-3-1-7 1-7 1z"/><path d="M9 4c-2 1-3 3-3 5"/><path d="M15 4c2 1 3 3 3 5"/></svg>""",
            Description = "Fresh vegetable stalls — ₱30/day · Water ·  Electricity",
           
        },
        ["Fish Section"] = new()
        {
            // Clear fish icon with tail, eye, and fins
            Icon = """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12c0 0 3-5 8-5s8 2 8 2l3-4v10l-3-4s-3 2-8 2-8-5-8-5z"/><circle cx="14" cy="11" r="1" fill="currentColor" stroke="none"/></svg>""",
            Description = "Fish stalls — ₱30/day · ₱1/kg · Water · Electricity",
         
        },
        ["Meat Section"] = new()
        {
            // Steak / meat cut viewed from above — outer shape + bone
            Icon = """<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 14c-1-2-.5-5 1.5-7s5-2.5 7.5-1.5 5 1 6 3-.5 4.5-2.5 5.5-4.5 1-7 .5S5 16 4 14z"/><path d="M10 11c-.5-1 0-2.5 1.5-3s3 0 3.5 1.5-1 3-2.5 3-2.5-.5-2.5-1.5z"/></svg>""",
            Description = "Meat stalls — ₱30/day · Water ·  Electricity",
        },
    };

    class NpmStall
    {
        public int Id { get; set; }
        public Guid StallGuid { get; set; } = Guid.Empty;
        public string StallNo { get; set; } = string.Empty;
        public string Section { get; set; } = string.Empty;
        public string ActualOccupant { get; set; } = string.Empty;
        public string ContractName { get; set; } = string.Empty;
        public double AreaSqm { get; set; }
        public DateTime? ContractDate { get; set; }
        public decimal MonthlyRate { get; set; }
        public bool HasElectricity { get; set; }
        public bool HasWater { get; set; }
        public bool IsPaid { get; set; }
        public bool IsPartial { get; set; }
        public decimal PartialAmount { get; set; }
        public bool IsActive { get; set; }
        public string ORNumber { get; set; } = string.Empty;
        public string CollectorName { get; set; } = string.Empty;
        public decimal ElecReading { get; set; }
        public decimal ElecAmount { get; set; }
        public decimal WaterReading { get; set; }
        public decimal WaterAmount { get; set; }
        public decimal FishKilos { get; set; }
        public decimal FishFee => FishKilos;
        public decimal TotalBill => MonthlyRate + ElecAmount + WaterAmount + FishFee;
        public decimal TotalPaid => IsPaid ? TotalBill : IsPartial ? PartialAmount : 0;
        public decimal BalanceDue => TotalBill - TotalPaid;
        public Dictionary<string, bool> PaymentHistory { get; set; } = new();
    }

    List<NpmStall> Stalls = new();

    static Dictionary<string, bool> MakeH(int paid)
    {
        var d = new Dictionary<string, bool>();
        for (int i = 11; i >= 0; i--)
            d[DateTime.Now.AddMonths(-i).ToString("yyyy-MM")] = (11 - i) < paid;
        return d;
    }

    IEnumerable<NpmStall> ActiveStalls => Stalls.Where(s => s.IsActive);
    IEnumerable<NpmStall> StallsBySection(string sec) => ActiveStalls.Where(s => s.Section == sec);

    decimal TotalCollected => ActiveStalls.Where(s => s.IsPaid || s.IsPartial).Sum(s => s.IsPartial ? s.PartialAmount : s.MonthlyRate);
    decimal TotalPending => ActiveStalls.Where(s => !s.IsPaid).Sum(s => s.MonthlyRate - (s.IsPartial ? s.PartialAmount : 0));
    int CollectionRate => ActiveStalls.Any() ? (int)((double)ActiveStalls.Count(s => s.IsPaid) / ActiveStalls.Count() * 100) : 0;

    IEnumerable<NpmStall> FilteredStalls => Stalls.Where(s =>
    {
        if (s.Section != ActiveSection) return false;
        bool matchStatus = ActiveStatus switch
        {
            "Paid" => s.IsPaid && !s.IsPartial && s.IsActive,
            "Partial" => s.IsPartial && s.IsActive,
            "Unpaid" => !s.IsPaid && !s.IsPartial && s.IsActive,
            "Closed" => !s.IsActive,
            _ => true
        };
        bool matchSearch = string.IsNullOrWhiteSpace(SearchQuery)
            || s.ActualOccupant.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.ContractName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);
        return matchStatus && matchSearch;
    }).OrderBy(s => s.StallNo);

    string GetPayPillClass(NpmStall s) =>
        s.IsPartial ? "pill-partial" :
        s.IsPaid ? "pill-paid" : "pill-unpaid";

    string GetPayLabel(NpmStall s) =>
        s.IsPartial ? $"₱{s.PartialAmount:N0} paid" :
        s.IsPaid ? "Paid" : "Unpaid";

    bool ShowPayment = false;
    NpmStall? PaymentStall = null;

    void OpenPayment(NpmStall s)
    {
        PaymentStall = s;
        ShowPayment = true;
    }

    void ClosePayment() { ShowPayment = false; PaymentStall = null; }

    private async Task HandleSavePayment(FacilityPaymentModal<NpmStall>.PaymentSubmitDto payment)
    {
        if (PaymentStall != null)
        {
            // Update the stall's OR Number
            PaymentStall.ORNumber = payment.OrNumber;

            // Reload the stall data from API to get updated payment status
            await LoadStallsFromApi();

            // Close the modal
            ShowPayment = false;
            PaymentStall = null;
        }
    }

    bool ShowHistory = false;
    NpmStall? HistoryStall = null;
    void OpenHistory(NpmStall s) { HistoryStall = s; ShowHistory = true; }
    void OpenEdit(NpmStall s)
    {
        IsEditingVendor = true;
        EditingStallId = s.Id;
        VendorForm = new()
        {
            FacilityCode = "NPM",
            StallNo = s.StallNo,
            ActualOccupant = s.ActualOccupant,
            ContractName = s.ContractName,
            SelectedSection = s.Section.Replace(" Area", "").Replace(" Section", ""),
            AreaSqm = s.AreaSqm,
            MonthlyRate = s.MonthlyRate,
            ContractDate = s.ContractDate,
            ContractYears = 0,
            AreaLocation = string.Empty,
            FeeTypes = new()
        };
        
        if (s.HasElectricity) VendorForm.FeeTypes.Add("Electricity");
        if (s.HasWater) VendorForm.FeeTypes.Add("Water");
        if (s.Section == "Fish Section") VendorForm.FeeTypes.Add("Fish ₱1/kg");
        
        VendorErrorMessage = string.Empty;
        ShowAddVendorModal = true;
    }
    void SetSection(string key)
    {
        ActiveSection = key;
        ActiveStatus = "All";
        SearchQuery = string.Empty;
    }

    // Add/Edit Vendor Modal
    private bool ShowAddVendorModal { get; set; }
    private bool IsEditingVendor { get; set; }
    private int EditingStallId { get; set; }
    private string VendorErrorMessage { get; set; } = string.Empty;
    private Dictionary<string, string> VendorFieldErrors { get; set; } = new();
    private AddVendorModal.VendorModalForm VendorForm = new();
    private List<AddVendorModal.VendorFacilityOption> NpmFacilityOptions => new() { new() { Code = "NPM", Name = "New Public Market" } };

    private void OpenAddVendorModal()
    {
        IsEditingVendor = false;
        EditingStallId = 0;
        VendorForm = new()
        {
            FacilityCode = "NPM",
            StallNo = string.Empty,
            ActualOccupant = string.Empty,
            ContractName = string.Empty,
            SelectedSection = "Vegetable",
            AreaSqm = 0,
            MonthlyRate = 0,
            ContractDate = null,
            ContractYears = 0,
            AreaLocation = string.Empty,
            FeeTypes = new()
        };
        VendorErrorMessage = string.Empty;
        VendorFieldErrors.Clear();
        ShowAddVendorModal = true;
        StateHasChanged();
    }

    private void CloseAddVendorModal()
    {
        ShowAddVendorModal = false;
        IsEditingVendor = false;
        EditingStallId = 0;
        VendorForm = new();
        VendorErrorMessage = string.Empty;
        VendorFieldErrors.Clear();
    }

    private void OnSectionModalChanged()
    {
        // Reset fees when section changes - user will select what applies
        VendorForm.FeeTypes = new();
    }

    private void ToggleVendorFee(string fee)
    {
        if (VendorForm.FeeTypes.Contains(fee))
            VendorForm.FeeTypes.Remove(fee);
        else
            VendorForm.FeeTypes.Add(fee);
    }

    private async Task SubmitAddVendor()
    {
        VendorErrorMessage = string.Empty;
        VendorFieldErrors.Clear();
        StateHasChanged();

        var section = VendorForm.SelectedSection switch
        {
            "Vegetable" => MarketSection.VegetableArea,
            "Fish" => MarketSection.FishSection,
            "Meat" => MarketSection.MeatSection,
            _ => MarketSection.VegetableArea
        };

        var fees = ApplicableFees.BaseRental;
        if (VendorForm.FeeTypes.Contains("Electricity"))
            fees |= ApplicableFees.Electricity;
        if (VendorForm.FeeTypes.Contains("Water"))
            fees |= ApplicableFees.Water;
        if (VendorForm.FeeTypes.Contains("Fish ₱1/kg"))
            fees |= ApplicableFees.FishFee;

        var command = new CreateStallCommand(
            FacilityCode.NPM,
            VendorForm.StallNo.Trim(),
            VendorForm.MonthlyRate,
            fees,
            section,
            null,
            VendorForm.AreaSqm,
            null,
            30m,
            VendorForm.ActualOccupant.Trim(),
            string.IsNullOrWhiteSpace(VendorForm.ContractName) ? null : VendorForm.ContractName.Trim(),
            VendorForm.ContractDate,
            VendorForm.ContractYears);

        var result = await StallsApi.CreateStallAsync(command);

        if (result.IsSuccess)
        {
            var newStall = new NpmStall
            {
                Id = Stalls.Any() ? Stalls.Max(s => s.Id) + 1 : 1,
                StallGuid = result.Value!.Id,
                StallNo = VendorForm.StallNo.Trim(),
                Section = $"{VendorForm.SelectedSection} Area",
                ActualOccupant = VendorForm.ActualOccupant.Trim(),
                ContractName = VendorForm.ContractName.Trim(),
                AreaSqm = VendorForm.AreaSqm,
                ContractDate = VendorForm.ContractDate,
                MonthlyRate = VendorForm.MonthlyRate,
                HasElectricity = VendorForm.FeeTypes.Contains("Electricity"),
                HasWater = VendorForm.FeeTypes.Contains("Water"),
                IsActive = true,
                PaymentHistory = new()
            };

            Stalls.Add(newStall);
            CloseAddVendorModal();
        }
        else
        {
            if (result.ValidationErrors != null && result.ValidationErrors.Any())
            {
                foreach (var error in result.ValidationErrors)
                {
                    VendorFieldErrors[error.Key] = error.Value.FirstOrDefault() ?? string.Empty;
                }
            }
            else
            {
                VendorErrorMessage = result.Error ?? "Failed to create stall.";
            }
            StateHasChanged();
        }
    }

    private async Task SubmitVendor()
    {
        if (IsEditingVendor)
            await SubmitEditVendor();
        else
            await SubmitAddVendor();
    }

    private async Task SubmitEditVendor()
    {
        VendorErrorMessage = string.Empty;
        VendorFieldErrors.Clear();
        StateHasChanged();

        var existingStall = Stalls.FirstOrDefault(s => s.Id == EditingStallId);
        if (existingStall == null)
        {
            VendorErrorMessage = "Stall not found.";
            StateHasChanged();
            return;
        }

        var fees = ApplicableFees.BaseRental;
        if (VendorForm.FeeTypes.Contains("Electricity"))
            fees |= ApplicableFees.Electricity;
        if (VendorForm.FeeTypes.Contains("Water"))
            fees |= ApplicableFees.Water;
        if (VendorForm.FeeTypes.Contains("Fish ₱1/kg"))
            fees |= ApplicableFees.FishFee;

        if (existingStall.StallGuid != Guid.Empty)
        {
            var command = new UpdateStallCommand(
                existingStall.StallGuid,
                VendorForm.MonthlyRate,
                fees,
                VendorForm.AreaSqm,
                null,
                30m,
                VendorForm.ActualOccupant.Trim(),
                string.IsNullOrWhiteSpace(VendorForm.ContractName) ? null : VendorForm.ContractName.Trim(),
                null);

            var result = await StallsApi.UpdateStallAsync(existingStall.StallGuid, command);
            
            if (!result.IsSuccess)
            {
                if (result.ValidationErrors != null && result.ValidationErrors.Any())
                {
                    foreach (var error in result.ValidationErrors)
                    {
                        VendorFieldErrors[error.Key] = error.Value.FirstOrDefault() ?? string.Empty;
                    }
                }
                else
                {
                    VendorErrorMessage = result.Error ?? "Failed to update stall.";
                }
                StateHasChanged();
                return;
            }
        }

        existingStall.ActualOccupant = VendorForm.ActualOccupant.Trim();
        existingStall.ContractName = VendorForm.ContractName.Trim();
        existingStall.MonthlyRate = VendorForm.MonthlyRate;
        existingStall.AreaSqm = VendorForm.AreaSqm;
        existingStall.HasElectricity = VendorForm.FeeTypes.Contains("Electricity");
        existingStall.HasWater = VendorForm.FeeTypes.Contains("Water");

        CloseAddVendorModal();
    }
}
