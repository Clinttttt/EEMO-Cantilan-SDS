@page "/bbq"
@page "/facility/bbq"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>EEMO Admin — BBQ Stand</PageTitle>

<div class="admin-layout">

    <!-- ---------------------------------------
         SIDEBAR
    --------------------------------------- -->
    <Sidebar />

    <main class="admin-main">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left flex gap-2">
                <a href="/menu" class="bbq-back-btn">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div>
                    <div class="topbar-title">BBQ Stand</div>
                    <div class="topbar-breadcrumb">
                        <a href="/menu" class="breadcrumb-link">Dashboard</a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">BBQ — @DateTime.Now.ToString("MMMM yyyy")</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-admin">
                    <div class="admin-avatar">A</div>
                    <div class="admin-info">
                        <div class="admin-name">Administrator</div>
                        <div class="admin-role">EEMO Office</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">

            <!-- -- BBQ Hero Banner -- -->
            <!-- -- BBQ Hero Banner -- -->
            <div class="bbq-hero">
                <div class="bbq-hero-left">
                    <div class="bbq-hero-icon">
                        <svg viewBox="0 0 24 24"><path d="M3 2h18l-2 7H5L3 2z" /><path d="M5 9c0 5 3 9 7 9s7-4 7-9" /><line x1="12" y1="18" x2="12" y2="22" /><line x1="8" y1="22" x2="16" y2="22" /></svg>
                    </div>
                    <div>
                        <div class="bbq-hero-eyebrow">Facility · BBQ</div>
                        <div class="bbq-hero-title">BBQ Stand</div>
                        <div class="bbq-hero-sub">Municipality of Cantilan, Surigao del Sur</div>
                    </div>
                </div>
                <div class="bbq-hero-stats">
                    <div class="bbq-hero-stat">
                        <div class="bbq-hero-val">?@TotalCollected.ToString("N0")</div>
                        <div class="bbq-hero-key">Collected</div>
                    </div>
                    <div class="bbq-hero-divider"></div>
                    <div class="bbq-hero-stat">
                        <div class="bbq-hero-val">?@TotalPending.ToString("N0")</div>
                        <div class="bbq-hero-key">Pending</div>
                    </div>
                    <div class="bbq-hero-divider"></div>
                    <div class="bbq-hero-stat">
                        <div class="bbq-hero-val">@CollectionRate%</div>
                        <div class="bbq-hero-key">Collection Rate</div>
                    </div>
                    <div class="bbq-hero-divider"></div>
                    <div class="bbq-hero-stat">
                        <div class="bbq-hero-val">@TotalStalls</div>
                        <div class="bbq-hero-key">Total Stalls</div>
                    </div>
                </div>
                <div class="bbq-hero-progress">
                    <div class="bbq-hero-progress-fill" style="width:@CollectionRate%"></div>
                </div>
            </div>

            <!-- -- Toolbar -- -->
            <Toolbar SearchQuery="@SearchQuery"
                     OnSearch="OnSearchInput"
                     ActiveFilter="@ActiveTab"
                     OnFilterChanged="OnFilterChange"
                     Filters="@Tabs"
                     ShowSearch="true"
                     SearchPlaceholder="Search stall no. or occupant…"
                     MiddleContent="@ActionBarContent"
                     Actions="@ToolbarActions">
            </Toolbar>

            <!-- -- Facility Info Bar -- -->
            <div class="bbq-facility-info">
                <div class="bbq-facility-info-left">
                    <div class="bbq-facility-label">All Stalls</div>
                    <div class="bbq-facility-desc">Monthly rental · 1,600.00 - 3,200.00 · Space Only</div>
                </div>
                <div class="bbq-facility-mini-stats">
                    <div class="bbq-mini-stat">
                        <div class="bbq-mini-val">@PaidCount</div>
                        <div class="bbq-mini-key">Paid</div>
                    </div>
                    <div class="bbq-mini-stat unpaid-stat">
                        <div class="bbq-mini-val">@UnpaidCount</div>
                        <div class="bbq-mini-key">Unpaid</div>
                    </div>
                    <div class="bbq-mini-stat partial-stat">
                        <div class="bbq-mini-val">@PartialCount</div>
                        <div class="bbq-mini-key">Partial</div>
                    </div>
                    <div class="bbq-mini-stat">
                        <div class="bbq-mini-val">?@PanelCollected.ToString("N0")</div>
                        <div class="bbq-mini-key">Collected</div>
                    </div>
                </div>
            </div>

            <!-- -- Stalls Table -- -->
            <FacilityStallsTable TStall="BbqStall"
                                 Facility="BBQ"
                                 FilteredStalls="FilteredStalls"
                                 OnPaymentClick="OnPaymentClicked"
                                 OnHistoryClick="OnReceiptClicked"
                                 OnEditClick="OnEditClicked" />

        </div><!-- end content-area -->

    </main>

</div><!-- end admin-layout -->
<!-- ══════════════════════════════════════════════
     PAYMENT MODAL (Reusable)
══════════════════════════════════════════════ -->
<FacilityPaymentModal TStall="BbqStall"
                      Facility="BBQ"
                      Stall="PaymentStall"
                      Show="ShowPayment"
                      OnClose="ClosePayment" />


<!-- ══════════════════════════════════════════════
     PAYMENT HISTORY MODAL (Reusable)
══════════════════════════════════════════════ -->
<PaymentHistoryModal TStall="BbqStall"
                     Show="ShowHistory"
                     Stall="HistoryStall"
                     OnClose="() => ShowHistory = false" />

<!-- ADD NEW VENDOR MODAL -->
<AddVendorModal Show="ShowAddVendorModal"
                IsEditing="false"
                Form="VendorForm"
                @bind-FormError="VendorErrorMessage"
                FacilityOptions="BbqFacilityOptions"
                FacilityLocked="true"
                OnSave="SubmitAddVendor"
                OnCancel="CloseAddVendorModal"
                OnFacilityChanged="() => {}"
                OnSectionChanged="() => {}"
                OnToggleFee="ToggleVendorFee" />

@code {
    string SearchQuery = string.Empty;
    string ActiveTab = "All";
    readonly List<string> Tabs = new() { "All", "Paid", "Partial", "Unpaid", "Closed" };

    bool ShowPayment = false;
    BbqStall? PaymentStall = null;

    bool ShowHistory = false;
    BbqStall? HistoryStall = null;

    static Dictionary<string, bool> MakeH(int paid)
    {
        var d = new Dictionary<string, bool>();
        for (int i = 11; i >= 0; i--)
            d[DateTime.Now.AddMonths(-i).ToString("yyyy-MM")] = (11 - i) < paid;
        return d;
    }

    class BbqStall
    {
        public int Id { get; set; }
        public string StallNo { get; set; } = string.Empty;
        public string ActualOccupant { get; set; } = string.Empty;
        public string ContractName { get; set; } = string.Empty;
        public double AreaSqm { get; set; }
        public DateTime? ContractDate { get; set; }
        public decimal MonthlyRate { get; set; }
        public bool IsPaid { get; set; }
        public bool IsPartial { get; set; }
        public decimal PartialAmount { get; set; }
        public bool IsActive { get; set; } = true;
        public string ORNumber { get; set; } = string.Empty;
        public string CollectorName { get; set; } = string.Empty;
        public decimal TotalBill => MonthlyRate;
        public decimal TotalPaid => IsPaid ? MonthlyRate : IsPartial ? PartialAmount : 0;
        public decimal BalanceDue => MonthlyRate - TotalPaid;
        public Dictionary<string, bool> PaymentHistory { get; set; } = new();
    }

    List<BbqStall> Stalls = new()
    {
        new() { Id=1,  StallNo="B-01", ActualOccupant="Reyes, Carlo M.",      ContractName="Carlo M. Reyes",      AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=true,    MonthlyRate=900,  ORNumber="OR-2026-B01",  CollectorName="Clint Reyes", PaymentHistory=MakeH(12) },
        new() { Id=2,  StallNo="B-02", ActualOccupant="Lim, Josephine T.",    ContractName="Josephine T. Lim",    AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=true,    MonthlyRate=900,  ORNumber="OR-2026-B02",  CollectorName="Ruel Santos", PaymentHistory=MakeH(11) },
        new() { Id=3,  StallNo="B-03", ActualOccupant="Tan, Roberto A.",      ContractName="Roberto A. Tan",      AreaSqm=17.5, ContractDate=new DateTime(2023,6,7), IsPaid=false,   MonthlyRate=1500, ORNumber="",             CollectorName="Marco Dizon", PaymentHistory=MakeH(6) },
        new() { Id=4,  StallNo="B-04", ActualOccupant="Flores, Gloria M.",    ContractName="Gloria M. Flores",    AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=true,    MonthlyRate=900,  ORNumber="OR-2026-B04",  CollectorName="Clint Reyes", PaymentHistory=MakeH(12) },
        new() { Id=5,  StallNo="B-05", ActualOccupant="Cabrera, Nestor P.",   ContractName="Nestor P. Cabrera",   AreaSqm=35.0, ContractDate=new DateTime(2023,6,7), IsPartial=true, PartialAmount=1500, MonthlyRate=2800, ORNumber="OR-2026-B05", CollectorName="Ruel Santos", PaymentHistory=MakeH(8) },
        new() { Id=6,  StallNo="B-06", ActualOccupant="Ramos, Elvira S.",     ContractName="Elvira S. Ramos",     AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=false,   MonthlyRate=900,  ORNumber="",             CollectorName="Marco Dizon", PaymentHistory=MakeH(3) },
        new() { Id=7,  StallNo="B-07", ActualOccupant="Villanueva, Ana L.",   ContractName="Ana L. Villanueva",   AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=true,    MonthlyRate=900,  ORNumber="OR-2026-B07",  CollectorName="Clint Reyes", PaymentHistory=MakeH(10) },
        new() { Id=8,  StallNo="B-08", ActualOccupant="Closed",                ContractName="Ramon B. Castro",     AreaSqm=17.5, ContractDate=new DateTime(2023,6,7), IsPaid=false,   IsActive=false, MonthlyRate=1500, ORNumber="", CollectorName="", PaymentHistory=MakeH(2) },
        new() { Id=9,  StallNo="B-09", ActualOccupant="Mendoza, Lourdes G.",  ContractName="Lourdes G. Mendoza",  AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=true,    MonthlyRate=900,  ORNumber="OR-2026-B09",  CollectorName="Ruel Santos", PaymentHistory=MakeH(12) },
        new() { Id=10, StallNo="B-10", ActualOccupant="Santos, Eduardo F.",   ContractName="Eduardo F. Santos",   AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), IsPaid=false,   MonthlyRate=900,  ORNumber="",             CollectorName="Marco Dizon", PaymentHistory=MakeH(4) },
    };

    IEnumerable<BbqStall> ActiveStalls => Stalls.Where(s => s.IsActive);

    decimal TotalCollected => ActiveStalls.Where(s => s.IsPaid || s.IsPartial).Sum(s => s.IsPartial ? s.PartialAmount : s.MonthlyRate);
    decimal TotalPending => ActiveStalls.Where(s => !s.IsPaid).Sum(s => s.MonthlyRate - (s.IsPartial ? s.PartialAmount : 0));
    int CollectionRate => ActiveStalls.Any() ? (int)((double)ActiveStalls.Count(s => s.IsPaid) / ActiveStalls.Count() * 100) : 0;

    int TotalStalls => Stalls.Count;
    int PaidCount => Stalls.Count(s => s.IsPaid && !s.IsPartial && s.IsActive);
    int UnpaidCount => Stalls.Count(s => !s.IsPaid && !s.IsPartial && s.IsActive);
    int PartialCount => Stalls.Count(s => s.IsPartial && s.IsActive);
    decimal PanelCollected => FilteredStalls.Where(s => s.IsPaid || s.IsPartial).Sum(s => s.IsPartial ? s.PartialAmount : s.MonthlyRate);

    IEnumerable<BbqStall> FilteredStalls => Stalls.Where(s =>
    {
        bool matchStatus = ActiveTab switch
        {
            "Paid" => s.IsPaid && !s.IsPartial && s.IsActive,
            "Partial" => s.IsPartial && s.IsActive,
            "Unpaid" => !s.IsPaid && !s.IsPartial && s.IsActive,
            "Closed" => !s.IsActive,
            _ => true
        };
        bool matchSearch = string.IsNullOrWhiteSpace(SearchQuery)
            || s.ActualOccupant.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.ContractName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);
        return matchStatus && matchSearch;
    }).OrderBy(s => s.StallNo);

    // Toolbar management
    private List<Toolbar.ToolbarAction> ToolbarActions => new()
    {
        new()
        {
            Label = "Add New",
            Icon = """<svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>""",
            ClassName = "btn-primary",
            Title = "Add a new stall",
            OnClickHandler = async () => { OpenAddVendorModal(); await Task.CompletedTask; }
        }
    };

    private RenderFragment ActionBarContent => @<ActionBar Facility="bbq" />;

    private async Task OnSearchInput(string value)
    {
        SearchQuery = value;
    }

    private async Task OnFilterChange(string filter)
    {
        ActiveTab = filter;
    }

    private void OnPaymentClicked(BbqStall s)
    {
        PaymentStall = s;
        ShowPayment = true;
    }

    private void OnReceiptClicked(BbqStall s)
    {
        HistoryStall = s;
        ShowHistory = true;
    }

    private void OnEditClicked(BbqStall s)
    {
        Navigation.NavigateTo("/profile");
    }

    private void ClosePayment() { ShowPayment = false; PaymentStall = null; }

    // Add Vendor Modal (shared AddVendorModal)
    private bool ShowAddVendorModal { get; set; }
    private string VendorErrorMessage { get; set; } = string.Empty;
    private AddVendorModal.VendorModalForm VendorForm { get; set; } = new();
    private List<AddVendorModal.VendorFacilityOption> BbqFacilityOptions => new() { new() { Code = "BBQ", Name = "BBQ Stand" } };

    private void OpenAddVendorModal()
    {
        VendorForm = new()
        {
            FacilityCode = "BBQ",
            StallNo = string.Empty,
            ActualOccupant = string.Empty,
            ContractName = string.Empty,
            Section = "BBQ",
            SelectedSection = string.Empty,
            AreaSqm = 0,
            MonthlyRate = 900,
            ContractDate = DateTime.Now,
            ContractYears = 1,
            AreaLocation = string.Empty,
            FeeTypes = new()
        };
        VendorErrorMessage = string.Empty;
        ShowAddVendorModal = true;
        StateHasChanged();
    }

    private void CloseAddVendorModal()
    {
        ShowAddVendorModal = false;
        VendorForm = new();
        VendorErrorMessage = string.Empty;
    }

    private void ToggleVendorFee(string fee)
    {
        if (VendorForm.FeeTypes.Contains(fee))
            VendorForm.FeeTypes.Remove(fee);
        else
            VendorForm.FeeTypes.Add(fee);
    }

    private async Task SubmitAddVendor()
    {
        // Validate form
        if (string.IsNullOrWhiteSpace(VendorForm.ActualOccupant))
        {
            VendorErrorMessage = "Actual occupant name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(VendorForm.StallNo))
        {
            VendorErrorMessage = "Stall number is required.";
            return;
        }
        if (VendorForm.MonthlyRate <= 0)
        {
            VendorErrorMessage = "Monthly rental rate is required.";
            return;
        }

        // Here you would typically save to database
        // For now, just close the modal
        CloseAddVendorModal();
    }
}

