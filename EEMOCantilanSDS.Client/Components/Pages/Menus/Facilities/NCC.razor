@page "/ncc"
@page "/facility/ncc"

@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>EEMO Admin — New Commercial Center</PageTitle>

<div class="admin-layout">

    <!-- ═══════════════════════════════════════
         SIDEBAR
    ═══════════════════════════════════════ -->
    <Sidebar />

    <main class="admin-main">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left flex gap-2">
                <a href="/menu" class="ncc-back-btn">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div>
                    <div class="topbar-title">New Commercial Center</div>
                    <div class="topbar-breadcrumb">
                        <a href="/menu" class="breadcrumb-link">Dashboard</a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">NCC — @DateTime.Now.ToString("MMMM yyyy")</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-admin">
                    <div class="admin-avatar">A</div>
                    <div class="admin-info">
                        <div class="admin-name">Administrator</div>
                        <div class="admin-role">EEMO Office</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">

            <!-- ── NCC Hero Banner ── -->
            <div class="ncc-hero">
                <div class="ncc-hero-left">
                    <div class="ncc-hero-icon">
                        <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 9h6M9 12h6M9 15h4"/></svg>
                    </div>
                    <div>
                        <div class="ncc-hero-eyebrow">Facility · NCC</div>
                        <div class="ncc-hero-title">New Commercial Center</div>
                        <div class="ncc-hero-sub">Municipality of Cantilan, Surigao del Sur</div>
                    </div>
                </div>
                <div class="ncc-hero-stats">
                    <div class="ncc-hero-stat">
                        <div class="ncc-hero-val">₱@TotalCollected.ToString("N0")</div>
                        <div class="ncc-hero-key">Collected</div>
                    </div>
                    <div class="ncc-hero-divider"></div>
                    <div class="ncc-hero-stat">
                        <div class="ncc-hero-val">₱@TotalPending.ToString("N0")</div>
                        <div class="ncc-hero-key">Pending</div>
                    </div>
                    <div class="ncc-hero-divider"></div>
                    <div class="ncc-hero-stat">
                        <div class="ncc-hero-val">@CollectionRate%</div>
                        <div class="ncc-hero-key">Collection Rate</div>
                    </div>
                    <div class="ncc-hero-divider"></div>
                    <div class="ncc-hero-stat">
                        <div class="ncc-hero-val">@ActiveStalls.Count()</div>
                        <div class="ncc-hero-key">Total Stalls</div>
                    </div>
                </div>
                <div class="ncc-hero-progress">
                    <div class="ncc-hero-progress-fill" style="width:@CollectionRate%"></div>
                </div>
            </div>

            <!-- ── Toolbar ── -->
            <Toolbar SearchQuery="@SearchQuery"
                     OnSearch="OnSearchInput"
                     ActiveFilter="@ActiveStatus"
                     OnFilterChanged="OnFilterChange"
                     Filters="@StatusFilters"
                     ShowSearch="true"
                     SearchPlaceholder="Search stall no. or occupant…"
                     MiddleContent="@ActionBarContent"
                     Actions="@ToolbarActions">
            </Toolbar>

            <!-- ── Facility Info Bar ── -->
            <div class="ncc-facility-info">
                <div class="ncc-facility-info-left">
                    <div class="ncc-facility-label">All Stalls</div>
                    <div class="ncc-facility-desc">Monthly rental · 1,200.00 - 3,840.00 · Stall sizes: 10.5-70+ sqm</div>
                 
                </div>
                <div class="ncc-facility-mini-stats">
                    <div class="ncc-mini-stat">
                        <div class="ncc-mini-val">@FilteredStalls.Count(s => s.IsPaid)</div>
                        <div class="ncc-mini-key">Paid</div>
                    </div>
                    <div class="ncc-mini-stat unpaid-stat">
                        <div class="ncc-mini-val">@FilteredStalls.Count(s => !s.IsPaid && !s.IsPartial)</div>
                        <div class="ncc-mini-key">Unpaid</div>
                    </div>
                    <div class="ncc-mini-stat partial-stat">
                        <div class="ncc-mini-val">@FilteredStalls.Count(s => s.IsPartial)</div>
                        <div class="ncc-mini-key">Partial</div>
                    </div>
                    <div class="ncc-mini-stat">
                        <div class="ncc-mini-val">₱@FilteredStalls.Where(s => s.IsPaid).Sum(s => s.MonthlyRate).ToString("N0")</div>
                        <div class="ncc-mini-key">Collected</div>
                    </div>
                </div>
            </div>

            <!-- ── Stalls Table (Reusable Component) ── -->
            <FacilityStallsTable TStall="NccStall"
                                 Facility="NCC"
                                 FilteredStalls="FilteredStalls"
                                 OnPaymentClick="OpenPayment"
                                 OnHistoryClick="OpenHistory"
                                 OnEditClick="OpenEdit" />

        </div><!-- end content-area -->
    </main>
</div>

<!-- ══════════════════════════════════════════════
     PAYMENT MODAL (Reusable Component)
══════════════════════════════════════════════ -->
<FacilityPaymentModal TStall="NccStall"
                      Facility="NCC"
                      Stall="PaymentStall"
                      Show="ShowPayment"
                      OnClose="ClosePayment" />

<!-- ══════════════════════════════════════════════
     PAYMENT HISTORY MODAL (Reusable)
══════════════════════════════════════════════ -->
<PaymentHistoryModal TStall="NccStall"
                     Show="@ShowHistory"
                     Stall="@HistoryStall"
                     FacilityCode="NCC"
                     FacilityName="New Commercial Center"
                     OnClose="() => ShowHistory = false" />

<!-- ══════════════════════════════════════════════
     ADD / EDIT VENDOR MODAL (NEW COMMERCIAL CENTER)
══════════════════════════════════════════════ -->
<AddVendorModal Show="ShowAddVendorModal"
                IsEditing="false"
                Form="VendorForm"
                @bind-FormError="VendorErrorMessage"
                FacilityOptions="NccFacilityOptions"
                FacilityLocked="true"
                OnSave="SubmitAddVendor"
                OnCancel="CloseAddVendorModal"
                OnFacilityChanged="() => {}"
                OnSectionChanged="() => {}"
                OnToggleFee="ToggleVendorFee" />

@code {

    bool SidebarCollapsed = false;

    string SearchQuery = string.Empty;
    string ActiveStatus = "All";
    readonly List<string> StatusFilters = new() { "All", "Paid", "Partial", "Unpaid", "Closed" };

    protected override void OnInitialized()
    {
        ResetState();
    }

    private void ResetState()
    {
        SearchQuery = string.Empty;
        ActiveStatus = "All";
        ShowPayment = false;
        PaymentStall = null;
        ShowHistory = false;
        HistoryStall = null;
    }

    // Toolbar management
    private List<Toolbar.ToolbarAction> ToolbarActions => new()
    {
        new()
        {
            Label = "Add New",
            Icon = """<svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>""",
            ClassName = "btn-primary",
            Title = "Add a new stall",
            OnClickHandler = async () => { OpenAddVendorModal(); await Task.CompletedTask; }
        }
    };

    private RenderFragment ActionBarContent => @<ActionBar Facility="ncc" />;

    private async Task OnSearchInput(string value)
    {
        SearchQuery = value;
    }

    private async Task OnFilterChange(string filter)
    {
        ActiveStatus = filter;
    }

    class NccStall
    {
        public int Id { get; set; }
        public string StallNo { get; set; } = string.Empty;
        public string ActualOccupant { get; set; } = string.Empty;
        public string ContractName { get; set; } = string.Empty;
        public double AreaSqm { get; set; }
        public DateTime? ContractDate { get; set; }
        public decimal MonthlyRate { get; set; }
        public bool HasElectricity { get; set; } = true;
        public bool HasWater { get; set; } = true;
        public bool IsPaid { get; set; }
        public bool IsPartial { get; set; }
        public decimal PartialAmount { get; set; }
        public bool IsActive { get; set; } = true;
        public string ORNumber { get; set; } = string.Empty;
        public string CollectorName { get; set; } = string.Empty;
        public decimal ElecReading { get; set; }
        public decimal ElecAmount { get; set; }
        public decimal WaterReading { get; set; }
        public decimal WaterAmount { get; set; }
        public decimal TotalBill => MonthlyRate + ElecAmount + WaterAmount;
        public decimal TotalPaid => IsPaid ? TotalBill : IsPartial ? PartialAmount : 0;
        public decimal BalanceDue => TotalBill - TotalPaid;
        public Dictionary<string, bool> PaymentHistory { get; set; } = new();
    }

    List<NccStall> Stalls = new()
    {
        new() { Id=1,  StallNo="N-01", ActualOccupant="Santos, Maria L.",        ContractName="Maria L. Santos",        AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), MonthlyRate=900, IsPaid=true,  ElecReading=142, ElecAmount=285, WaterReading=18, WaterAmount=120, ORNumber="OR-2026-N01", CollectorName="Clint Reyes",  PaymentHistory=MakeH(12) },
        new() { Id=2,  StallNo="N-02", ActualOccupant="Dela Cruz, Jose R.",      ContractName="Jose R. Dela Cruz",      AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), MonthlyRate=900, IsPaid=true,  ElecReading=98,  ElecAmount=196, WaterReading=12, WaterAmount=80,  ORNumber="OR-2026-N02", CollectorName="Ruel Santos",  PaymentHistory=MakeH(12) },
        new() { Id=3,  StallNo="N-03", ActualOccupant="Reyes, Ana M.",           ContractName="Ana M. Reyes",           AreaSqm=17.5, ContractDate=new DateTime(2023,6,7), MonthlyRate=1500, IsPaid=true,  ElecReading=115, ElecAmount=230, WaterReading=14, WaterAmount=95,  ORNumber="OR-2026-N03", CollectorName="Marco Dizon",  PaymentHistory=MakeH(12) },
        new() { Id=4,  StallNo="N-04", ActualOccupant="Garcia, Luz P.",          ContractName="Luz P. Garcia",          AreaSqm=17.5, ContractDate=new DateTime(2023,6,7), MonthlyRate=1500, IsPartial=true, PartialAmount=750, ElecReading=130, ElecAmount=260, WaterReading=16, WaterAmount=110, ORNumber="OR-2026-N04", CollectorName="Clint Reyes",  PaymentHistory=MakeH(7) },
        new() { Id=5,  StallNo="N-05", ActualOccupant="Bautista, Carlo T.",     ContractName="Carlo T. Bautista",     AreaSqm=35,   ContractDate=new DateTime(2023,6,7), MonthlyRate=2800, IsPaid=true,  ElecReading=88,  ElecAmount=176, WaterReading=10, WaterAmount=70,  ORNumber="OR-2026-N05", CollectorName="Ruel Santos",  PaymentHistory=MakeH(12) },
        new() { Id=6,  StallNo="N-06", ActualOccupant="Torres, Myla S.",        ContractName="Myla S. Torres",        AreaSqm=35,   ContractDate=new DateTime(2023,6,7), MonthlyRate=2800, IsPartial=true, PartialAmount=2100, ElecReading=105, ElecAmount=210, WaterReading=13, WaterAmount=88,  ORNumber="OR-2026-N06", CollectorName="Marco Dizon",  PaymentHistory=MakeH(8) },
        new() { Id=7,  StallNo="N-07", ActualOccupant="Navarro, Ben E.",        ContractName="Ben E. Navarro",        AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), MonthlyRate=900, IsPaid=true,  ElecReading=92,  ElecAmount=184, WaterReading=11, WaterAmount=75,  ORNumber="OR-2026-N07", CollectorName="Clint Reyes",  PaymentHistory=MakeH(10) },
        new() { Id=8,  StallNo="N-08", ActualOccupant="Lim, Patricia D.",       ContractName="Patricia D. Lim",       AreaSqm=70,   ContractDate=new DateTime(2023,6,7), MonthlyRate=4800, IsPaid=true,  ElecReading=120, ElecAmount=240, WaterReading=15, WaterAmount=100, ORNumber="OR-2026-N08", CollectorName="Ruel Santos",  PaymentHistory=MakeH(12) },
        new() { Id=9,  StallNo="N-09", ActualOccupant="Cabrera, Roy A.",        ContractName="Roy A. Cabrera",        AreaSqm=17.5, ContractDate=new DateTime(2023,6,7), MonthlyRate=1500, IsPaid=false, ElecReading=110, ElecAmount=220, WaterReading=14, WaterAmount=93,  ORNumber="",             CollectorName="Marco Dizon",  PaymentHistory=MakeH(11) },
        new() { Id=10, StallNo="N-10", ActualOccupant="Villanueva, Carmen O.",  ContractName="Carmen O. Villanueva",  AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), MonthlyRate=900, IsPaid=true,  ElecReading=95,  ElecAmount=190, WaterReading=12, WaterAmount=80,  ORNumber="OR-2026-N10", CollectorName="Clint Reyes",  PaymentHistory=MakeH(12) },
        new() { Id=11, StallNo="N-11", ActualOccupant="Closed",                 ContractName="",                      AreaSqm=35,   ContractDate=new DateTime(2023,6,7), MonthlyRate=2800, IsPaid=false, IsActive=false, ORNumber="",             CollectorName="", PaymentHistory=MakeH(2) },
        new() { Id=12, StallNo="N-12", ActualOccupant="Mendoza, Erlinda V.",    ContractName="Erlinda V. Mendoza",    AreaSqm=17.5, ContractDate=new DateTime(2023,6,7), MonthlyRate=1500, IsPaid=true,  ElecReading=102, ElecAmount=204, WaterReading=13, WaterAmount=86,  ORNumber="OR-2026-N12", CollectorName="Marco Dizon",  PaymentHistory=MakeH(9) },
        new() { Id=13, StallNo="N-13", ActualOccupant="Aquino, Roberto F.",     ContractName="Roberto F. Aquino",     AreaSqm=70,   ContractDate=new DateTime(2023,6,7), MonthlyRate=4800, IsPartial=true, PartialAmount=3600, ElecReading=135, ElecAmount=270, WaterReading=17, WaterAmount=113, ORNumber="OR-2026-N13", CollectorName="Clint Reyes",  PaymentHistory=MakeH(12) },
        new() { Id=14, StallNo="N-14", ActualOccupant="Fernandez, Diana C.",    ContractName="Diana C. Fernandez",    AreaSqm=10.5, ContractDate=new DateTime(2023,6,7), MonthlyRate=900, IsPaid=true,  ElecReading=118, ElecAmount=236, WaterReading=15, WaterAmount=99,  ORNumber="OR-2026-N14", CollectorName="Ruel Santos",  PaymentHistory=MakeH(4) },
        new() { Id=15, StallNo="N-15", ActualOccupant="Soriano, Felix G.",      ContractName="Felix G. Soriano",      AreaSqm=35,   ContractDate=new DateTime(2023,6,7), MonthlyRate=2800, IsPaid=false, ElecReading=89,  ElecAmount=178, WaterReading=11, WaterAmount=73,  ORNumber="",             CollectorName="Marco Dizon",  PaymentHistory=MakeH(12) },
    };

    static Dictionary<string, bool> MakeH(int paid)
    {
        var d = new Dictionary<string, bool>();
        for (int i = 11; i >= 0; i--)
            d[DateTime.Now.AddMonths(-i).ToString("yyyy-MM")] = (11 - i) < paid;
        return d;
    }

    IEnumerable<NccStall> ActiveStalls => Stalls.Where(s => s.IsActive);

    decimal TotalCollected => ActiveStalls.Where(s => s.IsPaid || s.IsPartial).Sum(s => s.IsPartial ? s.PartialAmount : s.MonthlyRate);
    decimal TotalPending => ActiveStalls.Where(s => !s.IsPaid).Sum(s => s.MonthlyRate - (s.IsPartial ? s.PartialAmount : 0));
    int CollectionRate => ActiveStalls.Any() ? (int)((double)ActiveStalls.Count(s => s.IsPaid) / ActiveStalls.Count() * 100) : 0;

    IEnumerable<NccStall> FilteredStalls => Stalls.Where(s =>
    {
        bool matchStatus = ActiveStatus switch
        {
            "Paid" => s.IsPaid && !s.IsPartial && s.IsActive,
            "Partial" => s.IsPartial && s.IsActive,
            "Unpaid" => !s.IsPaid && !s.IsPartial && s.IsActive,
            "Closed" => !s.IsActive,
            _ => true
        };
        bool matchSearch = string.IsNullOrWhiteSpace(SearchQuery)
            || s.ActualOccupant.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.ContractName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);
        return matchStatus && matchSearch;
    }).OrderBy(s => s.StallNo);

    string GetPayPillClass(NccStall s) =>
        s.IsPartial ? "pill-partial" :
        s.IsPaid ? "pill-paid" : "pill-unpaid";

    string GetPayLabel(NccStall s) =>
        s.IsPartial ? $"₱{s.PartialAmount:N0} paid" :
        s.IsPaid ? "Paid" : "Unpaid";

    // Payment modal state
    bool ShowPayment = false;
    NccStall? PaymentStall = null;

    void OpenPayment(NccStall s)
    {
        PaymentStall = s;
        ShowPayment = true;
    }

    void MarkAsPaid()
    {
        if (PaymentStall is null) return;
        PaymentStall.IsPaid = true;
        PaymentStall.IsPartial = false;
        var key = DateTime.Now.ToString("yyyy-MM");
        PaymentStall.PaymentHistory[key] = true;
        ClosePayment();
    }

    void ClosePayment() { ShowPayment = false; PaymentStall = null; }

    bool ShowHistory = false;
    NccStall? HistoryStall = null;
    void OpenHistory(NccStall s) { HistoryStall = s; ShowHistory = true; }
    void OpenEdit(NccStall s) { Navigation.NavigateTo("/profile"); }

    // Add Vendor Modal
    private bool ShowAddVendorModal { get; set; }
    private string VendorErrorMessage { get; set; } = string.Empty;
    private AddVendorModal.VendorModalForm VendorForm = new();
    private List<AddVendorModal.VendorFacilityOption> NccFacilityOptions => new() { new() { Code = "NCC", Name = "New Commercial Center" } };

    private void OpenAddVendorModal()
    {
        VendorForm = new() 
        { 
            FacilityCode = "NCC",
            StallNo = string.Empty,
            ActualOccupant = string.Empty,
            ContractName = string.Empty,
            Section = "NCC",
            SelectedSection = string.Empty,
            AreaSqm = 0,
            MonthlyRate = 1200,
            ContractDate = new DateTime(2023, 6, 7),
            ContractYears = 3,
            AreaLocation = string.Empty,
            FeeTypes = new()
        };
        VendorErrorMessage = string.Empty;
        ShowAddVendorModal = true;
        StateHasChanged();
    }

    private void CloseAddVendorModal()
    {
        ShowAddVendorModal = false;
        VendorForm = new();
        VendorErrorMessage = string.Empty;
    }

    private void ToggleVendorFee(string fee)
    {
        if (VendorForm.FeeTypes.Contains(fee))
            VendorForm.FeeTypes.Remove(fee);
        else
            VendorForm.FeeTypes.Add(fee);
    }

    private async Task SubmitAddVendor()
    {
        // Validate form
        if (string.IsNullOrWhiteSpace(VendorForm.ActualOccupant))
        {
            VendorErrorMessage = "Actual occupant name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(VendorForm.StallNo))
        {
            VendorErrorMessage = "Stall number is required.";
            return;
        }
        if (VendorForm.MonthlyRate <= 0)
        {
            VendorErrorMessage = "Monthly rate must be greater than ₱0.";
            return;
        }

        // Add new stall to list
        var newStall = new NccStall
        {
            Id = Stalls.Max(s => s.Id) + 1,
            StallNo = VendorForm.StallNo.Trim(),
            ActualOccupant = VendorForm.ActualOccupant.Trim(),
            ContractName = VendorForm.ContractName.Trim(),
            AreaSqm = VendorForm.AreaSqm,
            ContractDate = VendorForm.ContractDate,
            MonthlyRate = VendorForm.MonthlyRate,
            IsActive = true,
            PaymentHistory = new()
        };

            Stalls.Add(newStall);
            CloseAddVendorModal();
        }
}

