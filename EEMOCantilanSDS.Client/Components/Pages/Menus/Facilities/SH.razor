@page "/slh"
@page "/facility/slh"
@rendermode InteractiveServer
<PageTitle>EEMO Admin — Slaughterhouse</PageTitle>

<div class="admin-layout">

    <Sidebar />

    <main class="admin-main">

        <!-- Topbar -->
        <header class="topbar">
            <div class="topbar-left flex gap-2">
                <a href="/menu" class="slh-back-btn">
                    <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </a>
                <div>
                    <div class="topbar-title">Slaughterhouse</div>
                    <div class="topbar-breadcrumb">
                        <a href="/menu" class="breadcrumb-link">Dashboard</a>
                        <span class="breadcrumb-sep">/</span>
                        <span class="breadcrumb-active">Slaughterhouse — @DateTime.Now.ToString("MMMM yyyy")</span>
                    </div>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-date">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    @DateTime.Now.ToString("MMMM d, yyyy")
                </div>
                <div class="topbar-admin">
                    <div class="admin-avatar">A</div>
                    <div class="admin-info">
                        <div class="admin-name">Administrator</div>
                        <div class="admin-role">EEMO Office</div>
                    </div>
                </div>
            </div>
        </header>

        <div class="content-area">

            <!-- -- SLH Hero Banner -- -->
            <div class="slh-hero">
                <div class="slh-hero-left">
                    <div class="slh-hero-icon">
                        <svg viewBox="0 0 24 24"><path d="M14.5 2.5c0 1.5-1.5 5-1.5 5h-2S9.5 4 9.5 2.5a2.5 2.5 0 0 1 5 0z" /><path d="M12 7.5V22" /><path d="M5 12h14" /></svg>
                    </div>
                    <div>
                        <div class="slh-hero-eyebrow">Facility · SLH</div>
                        <div class="slh-hero-title">Slaughterhouse</div>
                        <div class="slh-hero-sub">Municipality of Cantilan, Surigao del Sur</div>
                    </div>
                </div>
                <div class="slh-hero-stats">
                    <div class="slh-hero-stat">
                        <div class="slh-hero-val">@TotalCollected.ToString("N0")</div>
                        <div class="slh-hero-key">Collected</div>
                    </div>
                    <div class="slh-hero-divider"></div>
                    <div class="slh-hero-stat">
                        <div class="slh-hero-val">@TotalHeads</div>
                        <div class="slh-hero-key">Total Heads</div>
                    </div>
                    <div class="slh-hero-divider"></div>
                    <div class="slh-hero-stat">
                        <div class="slh-hero-val">@Entries.Count</div>
                        <div class="slh-hero-key">Transactions</div>
                    </div>
                    <div class="slh-hero-divider"></div>
                    <div class="slh-hero-stat">
                        <div class="slh-hero-val">@DateTime.Now.ToString("MMM yyyy")</div>
                        <div class="slh-hero-key">Period</div>
                    </div>
                </div>
                <div class="slh-hero-progress">
                    <div class="slh-hero-progress-fill" style="width:100%"></div>
                </div>
            </div>

            <!-- -- Toolbar (Unified Design) -- -->
            <div class="toolbar-unified">
                <!-- LEFT: Search Box -->
                <div class="search-box">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    <input type="text" placeholder="Search owner or OR no..."
                           @bind-value="SearchTerm" @bind-value:event="oninput" />
                    @if (!string.IsNullOrEmpty(SearchTerm))
                    {
                        <span class="search-clear" @onclick="() => SearchTerm = string.Empty">×</span>
                    }
                </div>

                <!-- CENTER-LEFT: Filter Tabs -->
                <div class="filter-tabs-inline">
                    @foreach (var tab in AnimalFilters)
                    {
                        <div class="filter-tab @(ActiveAnimalFilter == tab ? "active" : "")"
                             @onclick="() => SetAnimalFilter(tab)">
                            @tab
                        </div>
                    }
                </div>

                <!-- CENTER: Action Bar -->
                <div class="toolbar-middle">
                    <ActionBar Facility="slh" />
                </div>

                <!-- RIGHT: Record Button -->
                <div class="toolbar-actions">
                    <button class="btn btn-primary" @onclick="OpenRecordSlaughterModal">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Record Slaughter
                    </button>
                </div>
            </div>

            <!-- SLAUGHTER RECORD MODAL -->
            <SlaughterRecordModal ShowModal="ShowRecordModal"
                                  OnClose="CloseRecordModal"
                                  OnSubmit="SubmitSlaughterRecord"
                                  ErrorMessage="@ErrorMessage" />


            <!-- -- Facility Info Bar -- -->
            <div class="slh-facility-info">
                <div class="slh-facility-info-left">
                    <div class="slh-facility-label-row">
                        <span class="slh-facility-label">
                            @(ActiveAnimalFilter == "All" ? "All Transactions" : ActiveAnimalFilter + " Transactions")
                            — @DateTime.Now.ToString("MMMM yyyy")
                        </span>
                        <!-- Info Icon + Hover Tooltip -->
                        <div class="slh-info-wrap">
                            <span class="slh-info-icon">
                                <svg viewBox="0 0 24 24">
                                    <circle cx="12" cy="12" r="10" />
                                    <line x1="12" y1="8" x2="12" y2="8" />
                                    <line x1="12" y1="12" x2="12" y2="16" />
                                </svg>
                            </span>
                            <div class="slh-tooltip">
                                <div class="slh-tooltip-title">Slaughterhouse Fees (per head)</div>

                                <div class="slh-tooltip-section">
                                    <div class="slh-tooltip-animal">?? Hog — ?250 total</div>
                                    <div class="slh-tooltip-breakdown">
                                        <span>Slaughter</span><span>?50</span>
                                        <span>Ante Mortem</span><span>?20</span>
                                        <span>Table Charge</span><span>?30</span>
                                        <span>Entrance</span><span>?150</span>
                                    </div>
                                </div>

                                <div class="slh-tooltip-divider"></div>

                                <div class="slh-tooltip-section">
                                    <div class="slh-tooltip-animal">?? Carabao / Cow — ?365 total</div>
                                    <div class="slh-tooltip-breakdown">
                                        <span>Slaughter</span><span>?150</span>
                                        <span>Permit</span><span>?100</span>
                                        <span>Ante Mortem</span><span>?20</span>
                                        <span>Post Mortem</span><span>?25</span>
                                        <span>Table Charge</span><span>?30</span>
                                        <span>Livestock</span><span>?40</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="slh-facility-desc">Per-head fees · Collected per slaughter transaction</div>
                </div>
                <div class="slh-facility-mini-stats">
                    <div class="slh-mini-stat hog-stat">
                        <div class="slh-mini-val">@HogCount</div>
                        <div class="slh-mini-key">Hogs</div>
                    </div>
                    <div class="slh-mini-stat carabao-stat">
                        <div class="slh-mini-val">@CarabaoCount</div>
                        <div class="slh-mini-key">Carabao</div>
                    </div>
                    <div class="slh-mini-stat cow-stat">
                        <div class="slh-mini-val">@CowCount</div>
                        <div class="slh-mini-key">Cows</div>
                    </div>
                    <div class="slh-mini-stat">
                        <div class="slh-mini-val">@FilteredEntries.Sum(e => e.NumberOfHeads)</div>
                        <div class="slh-mini-key">Heads</div>
                    </div>
                    <div class="slh-mini-stat">
                        <div class="slh-mini-val">?@FilteredEntries.Sum(e => e.TotalAmount).ToString("N0")</div>
                        <div class="slh-mini-key">Collected</div>
                    </div>
                </div>
            </div>

            <!-- -- Transactions Table -- -->
            <div class="panel">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Date</th>
                            <th>Owner / Client</th>
                            <th>Animal Type</th>
                            <th>No. of Heads</th>
                            <th>Rate / Head</th>
                            <th>Total Amount</th>
                            <th>OR No.</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rowNum = 1;
                        }
                        @foreach (var entry in FilteredEntries)
                        {
                            <tr class="@GetRowClass(entry.AnimalType)">
                                <td>@rowNum</td>
                                <td>@entry.Date.ToString("MMM d, yyyy")</td>
                                <td>@entry.OwnerName</td>
                                <td>@entry.AnimalType</td>
                                <td>@entry.NumberOfHeads</td>
                                <td>?@entry.RatePerHead.ToString("N0")</td>
                                <td>?@entry.TotalAmount.ToString("N0")</td>
                                <td><span class="mono">@entry.ORNo</span></td>
                                <td>
                                    <div class="action-btns">
                                        <button class="btn-action" title="View Details" @onclick="() => ViewEntry(entry)">
                                            <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                                        </button>
                                        <button class="btn-action" title="View Receipt" @onclick="() => ViewReceipt(entry)">
                                            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                                        </button>
                                        <button class="btn-action" title="Edit" @onclick="() => EditEntry(entry)">
                                            <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                            rowNum++;
                        }
                        @if (!FilteredEntries.Any())
                        {
                            <tr>
                                <td colspan="9" class="empty-state">
                                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                                    <span>No transactions found</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </main>
</div>

@code {

    // -- STATE ----------------------------------------------------
    private string SearchTerm { get; set; } = string.Empty;
    private string ActiveAnimalFilter { get; set; } = "All";
    private bool ShowRecordModal { get; set; }
    private string ErrorMessage { get; set; } = string.Empty;

    // Carabao and Cow are now separate (same ?365 rate)
    private readonly List<string> AnimalFilters = new() { "All", "Hog", "Carabao", "Cow" };

    // -- COMPUTED -------------------------------------------------
    private decimal TotalCollected => Entries.Sum(e => e.TotalAmount);
    private int TotalHeads => Entries.Sum(e => e.NumberOfHeads);
    private int HogCount => Entries.Where(e => e.AnimalType == "Hog").Sum(e => e.NumberOfHeads);
    private int CarabaoCount => Entries.Where(e => e.AnimalType == "Carabao").Sum(e => e.NumberOfHeads);
    private int CowCount => Entries.Where(e => e.AnimalType == "Cow").Sum(e => e.NumberOfHeads);

    private IEnumerable<SlaughterEntry> FilteredEntries => Entries
        .Where(e => ActiveAnimalFilter == "All" || e.AnimalType == ActiveAnimalFilter)
        .Where(e => string.IsNullOrWhiteSpace(SearchTerm)
            || e.OwnerName.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase)
            || e.ORNo.Contains(SearchTerm, StringComparison.OrdinalIgnoreCase));

    // -- ROW CLASS ------------------------------------------------
    private static string GetRowClass(string animalType) => animalType switch
    {
        "Hog" => "row-hog",
        "Carabao" => "row-carabao",
        "Cow" => "row-cow",
        _ => ""
    };

    // -- ACTIONS --------------------------------------------------
    private void SetAnimalFilter(string filter) => ActiveAnimalFilter = filter;

    private void OpenRecordSlaughterModal()
    {
        ErrorMessage = string.Empty;
        ShowRecordModal = true;
        StateHasChanged();
    }

    private async Task CloseRecordModal()
    {
        ShowRecordModal = false;
        ErrorMessage = string.Empty;
    }

    private async Task SubmitSlaughterRecord(SlaughterRecordModal.SlaughterRecordForm form)
    {
        // Validation
        if (form.TransactionDate == default)
        {
            ErrorMessage = "Please select a transaction date.";
            return;
        }
        if (string.IsNullOrWhiteSpace(form.OwnerName))
        {
            ErrorMessage = "Owner name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(form.AnimalType))
        {
            ErrorMessage = "Please select an animal type.";
            return;
        }
        if (form.NumberOfHeads <= 0)
        {
            ErrorMessage = "Number of heads must be greater than 0.";
            return;
        }
        if (string.IsNullOrWhiteSpace(form.ORNo))
        {
            ErrorMessage = "OR number is required.";
            return;
        }

        // Get rate per head based on animal type
        decimal ratePerHead = form.AnimalType switch
        {
            "Hog" => 250,
            "Carabao" => 365,
            "Cow" => 365,
            _ => 0
        };

        // Create new entry
        var newEntry = new SlaughterEntry(
            Entries.Max(e => e.Id) + 1,
            form.TransactionDate,
            form.OwnerName.Trim(),
            form.AnimalType,
            form.NumberOfHeads,
            ratePerHead,
            form.ORNo.Trim()
        );

        // Add to list
        Entries.Add(newEntry);

        // Close modal
        await CloseRecordModal();
    }

    private void ViewEntry(SlaughterEntry e) { /* TODO: view detail modal */ }
    private void ViewReceipt(SlaughterEntry e) { /* TODO: print/view receipt */ }
    private void EditEntry(SlaughterEntry e) { /* TODO: edit modal */ }

    // -- DATA MODEL -----------------------------------------------
    public record SlaughterEntry(
        int Id,
        DateTime Date,
        string OwnerName,
        string AnimalType,    // "Hog" | "Carabao" | "Cow"
        int NumberOfHeads,
        decimal RatePerHead,
        string ORNo
    )
    {
        public decimal TotalAmount => RatePerHead * NumberOfHeads;
    }

    public class SlaughterRecordForm
    {
        public DateTime TransactionDate { get; set; } = DateTime.Now;
        public string OwnerName { get; set; } = string.Empty;
        public string AnimalType { get; set; } = string.Empty;
        public int NumberOfHeads { get; set; } = 1;
        public string ORNo { get; set; } = string.Empty;
    }
    private readonly List<SlaughterEntry> Entries = new()
    {
        new(1,  new DateTime(2026,3,1),  "Dela Cruz, Ramon A.",   "Hog",     3, 250, "OR-2026-SLH-001"),
        new(2,  new DateTime(2026,3,1),  "Santos, Lito B.",       "Hog",     2, 250, "OR-2026-SLH-002"),
        new(3,  new DateTime(2026,3,2),  "Reyes, Mario C.",       "Carabao", 1, 365, "OR-2026-SLH-003"),
        new(4,  new DateTime(2026,3,3),  "Garcia, Noel D.",       "Hog",     5, 250, "OR-2026-SLH-004"),
        new(5,  new DateTime(2026,3,5),  "Bautista, Jun E.",      "Cow",     2, 365, "OR-2026-SLH-005"),
        new(6,  new DateTime(2026,3,6),  "Torres, Ronnie F.",     "Hog",     1, 250, "OR-2026-SLH-006"),
        new(7,  new DateTime(2026,3,8),  "Navarro, Edwin G.",     "Hog",     4, 250, "OR-2026-SLH-007"),
        new(8,  new DateTime(2026,3,10), "Lim, Domingo H.",       "Carabao", 1, 365, "OR-2026-SLH-008"),
        new(9,  new DateTime(2026,3,12), "Cabrera, Felix I.",     "Hog",     2, 250, "OR-2026-SLH-009"),
        new(10, new DateTime(2026,3,14), "Villanueva, Nestor J.", "Hog",     3, 250, "OR-2026-SLH-010"),
        new(11, new DateTime(2026,3,15), "Mendoza, Cesar K.",     "Cow",     1, 365, "OR-2026-SLH-011"),
        new(12, new DateTime(2026,3,17), "Aquino, Pedro L.",      "Hog",     2, 250, "OR-2026-SLH-012"),
        new(13, new DateTime(2026,3,19), "Fernandez, Alex M.",    "Carabao", 2, 365, "OR-2026-SLH-013"),
        new(14, new DateTime(2026,3,20), "Soriano, Bart N.",      "Hog",     1, 250, "OR-2026-SLH-014"),
        new(15, new DateTime(2026,3,22), "Cruz, Danny O.",        "Hog",     4, 250, "OR-2026-SLH-015"),
        new(16, new DateTime(2026,3,24), "Ramos, Joel P.",        "Cow",     1, 365, "OR-2026-SLH-016"),
        new(17, new DateTime(2026,3,25), "Flores, Rudy Q.",       "Hog",     2, 250, "OR-2026-SLH-017"),
        new(18, new DateTime(2026,3,26), "Diaz, Arnel R.",        "Hog",     3, 250, "OR-2026-SLH-018"),
    };
}
