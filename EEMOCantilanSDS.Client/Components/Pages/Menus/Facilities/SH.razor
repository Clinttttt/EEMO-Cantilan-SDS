    private void ViewEntry(SlaughterTransactionDto e)
    {
        Navigation.NavigateTo($"/facility/slh/transaction/{e.OwnerName}");
    }

    private void AddTransactionForOwner(SlaughterTransactionDto e)
    {
        SelectedOwnerName = e.OwnerName;
        SelectedTransactionDate = e.TransactionDate.ToDateTime(TimeOnly.MinValue);
        SelectedORNumber = "";  // Don't pre-fill OR number for new transactions
        ErrorMessage = string.Empty;
        ShowAddTransactionModal = true;
        StateHasChanged();
    }

    private void EditEntry(SlaughterTransactionDto e)
    {
        var ownerGroup = GroupedOwnerTransactions.FirstOrDefault(g => g.OwnerName == e.OwnerName);
        if (ownerGroup != null)
        {
            SelectedGroupEntries = ownerGroup.LatestTransactions.ToList();
        }
        
        SelectedEntry = e;
        ErrorMessage = string.Empty;
        ShowEditModal = true;
        StateHasChanged();
    }

    private async Task SubmitEditTransaction(EditSlaughterTransactionModal.EditTransactionForm form)
    {
        var animals = new List<AnimalEntry>();

        if (form.HogHeads > 0)
        {
            animals.Add(new AnimalEntry(AnimalType.Hog, null, form.HogHeads, null));
        }

        if (form.CarabaoHeads > 0)
        {
            animals.Add(new AnimalEntry(AnimalType.Carabao, null, form.CarabaoHeads, null));
        }

        if (form.CowHeads > 0)
        {
            animals.Add(new AnimalEntry(AnimalType.Cow, null, form.CowHeads, null));
        }

        if (form.CustomHeads > 0)
        {
            animals.Add(new AnimalEntry(AnimalType.Other, form.CustomAnimalType, form.CustomHeads, form.CustomRate));
        }

        var command = new UpdateSlaughterCommand(
            form.OwnerName,
            DateOnly.FromDateTime(form.TransactionDate),
            form.ORNumber,
            animals
        );

        var result = await SlaughterApi.UpdateTransactionAsync(command);
        
        if (result.IsSuccess)
        {
            await LoadData();
            await CloseEditModal();
        }
        else
        {
            ErrorMessage = result.Error ?? "Failed to update transaction";
        }
    }
