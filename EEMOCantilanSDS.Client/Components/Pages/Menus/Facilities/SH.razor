            if (!result.IsSuccess)
            {
                hasError = true;
                errorMsg = result.Error ?? "Failed to record custom animal transaction";
            }
        }

        if (hasError)
        {
            ErrorMessage = errorMsg;
        }
        else
        {
            await LoadData();
            await CloseRecordModal();
        }
    }

