@page "/tpm"
@page "/facility/tpm"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using EEMOCantilanSDS.Application.Command.TaboanMarket.AddVendor
@using EEMOCantilanSDS.Application.Dtos.TaboanMarket
@using EEMOCantilanSDS.Application.Requests.TaboanMarket
@using EEMOCantilanSDS.Client.Components.Shared
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))
@inject ITpmApiClient TpmApi
@inject NavigationManager Navigation

<PageTitle>EEMO Admin — Tabo-an Public Market</PageTitle>

<!-- ── Topbar ── -->
<header class="tpm-topbar">
    <div class="tpm-topbar-left">
        <a href="/menu" class="tpm-back-btn">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
        </a>
        <div>
            <div class="tpm-topbar-title">Tabo-an Public Market</div>
            <div class="tpm-topbar-breadcrumb">
                <a href="/menu" class="tpm-breadcrumb-link">Dashboard</a>
                <span class="tpm-breadcrumb-sep">/</span>
                <span class="tpm-breadcrumb-active">TPM — @CalendarMonth.ToString("MMMM yyyy")</span>
            </div>
        </div>
    </div>
    <div class="tpm-topbar-right">
        <div class="tpm-topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @DateTime.Now.ToString("MMMM d, yyyy")
        </div>
    </div>
</header>

<div class="tpm-content-area">

    <!-- ── Hero Banner ── -->
    <FacilityHero
        Eyebrow="FACILITY · TPM"
        Title="Tabo-an Public Market"
        Icon="@TpmIcon"
        Stats="@HeroStats"
        ShowProgress="true"
        ProgressPercentage="@(Overview?.CollectionRate ?? 0)" />

    <!-- ── Two-column layout ── -->
    <div class="tpm-columns">

        <!-- ── LEFT: Friday Calendar ── -->
        <div class="tpm-panel">
            <div class="tpm-panel-header">
                <div class="tpm-panel-title">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    Market Days
                </div>
                <div class="tpm-cal-nav">
                    <button class="tpm-cal-nav-btn" @onclick="PrevMonth">
                        <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                    </button>
                    <span class="tpm-cal-month">@CalendarMonth.ToString("MMMM yyyy")</span>
                    <button class="tpm-cal-nav-btn" disabled="@(CalendarMonth >= CurrentMonthStart)" @onclick="NextMonth">
                        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                    </button>
                </div>
            </div>

            <div class="tpm-cal-desc">Every Friday · ₱100 per vendor</div>

            <div class="tpm-friday-list">
                @foreach (var friday in GetFridaysInMonth(CalendarMonth))
                {
                    var isFuture = friday > DateTime.Today;
                    var record = MarketDays.FirstOrDefault(m => m.MarketDate.ToDateTime(TimeOnly.MinValue).Date == friday.Date);
                    var isSelected = SelectedFriday.HasValue && SelectedFriday.Value.Date == friday.Date;

                    <div class="tpm-friday-item @(isSelected ? "friday-selected" : "") @(isFuture ? "friday-future" : "")"
                         @onclick="async () => { if (!isFuture) await SelectFriday(friday); }">
                        <div class="tpm-friday-date-block">
                            <div class="tpm-friday-day">@friday.ToString("dd")</div>
                            <div class="tpm-friday-label">Friday</div>
                        </div>
                        <div class="tpm-friday-info">
                            <div class="tpm-friday-full">@friday.ToString("MMMM d, yyyy")</div>
                            @if (!isFuture && record != null)
                            {
                                <div class="tpm-friday-meta">@record.VendorsPaid vendor@(record.VendorsPaid == 1 ? "" : "s") · ₱@(record.TotalCollected.ToString("N0")) collected</div>
                            }
                            else if (!isFuture)
                            {
                                <div class="tpm-friday-meta tpm-meta-none">No records yet</div>
                            }
                            else
                            {
                                <div class="tpm-friday-meta tpm-meta-future">Upcoming</div>
                            }
                        </div>
                        @if (!isFuture && record != null)
                        {
                            <div class="tpm-friday-badge tpm-badge-done">
                               
                                @record.VendorsPaid
                            </div>
                        }
                        else if (isFuture)
                        {
                            <div class="tpm-friday-badge tpm-badge-future">—</div>
                        }
                        else
                        {
                            <div class="tpm-friday-badge tpm-badge-empty">0</div>
                        }
                    </div>
                }
            </div>

            <div class="tpm-cal-footer">
                <div class="tpm-cal-sum-item">
                    <span class="tpm-cal-sum-val tpm-sum-green">@MarketDays.Count</span>
                    <span class="tpm-cal-sum-key">Days Recorded</span>
                </div>
                <div class="tpm-cal-sum-item">
                    <span class="tpm-cal-sum-val">@MarketDays.Sum(m => m.VendorsPaid)</span>
                    <span class="tpm-cal-sum-key">Total Vendors</span>
                </div>
                <div class="tpm-cal-sum-item">
                    <span class="tpm-cal-sum-val tpm-sum-gold">₱@MarketDays.Sum(m => m.TotalCollected).ToString("N0")</span>
                    <span class="tpm-cal-sum-key">Total Collected</span>
                </div>
            </div>
        </div>

        <!-- ── RIGHT: Vendor Attendance ── -->
        <div class="tpm-panel">
            <div class="tpm-panel-header">
                <div class="tpm-panel-title">
                    <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" /></svg>
                    Vendor Attendance
                </div>
                @if (SelectedFriday.HasValue)
                {
                    <div class="tpm-selected-date">
                        <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                        @SelectedFriday.Value.ToString("MMMM d, yyyy")
                    </div>
                }
                <button class="btn-outline" @onclick='() => Navigation.NavigateTo("/tpm/reports")' title="View Tabo-an Public Market Reports">
                    <svg viewBox="0 0 24 24" style="width:14px;height:14px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;vertical-align:middle;margin-right:4px;">
                        <path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z" />
                    </svg>
                    Reports
                </button>
            </div>

            @if (!SelectedFriday.HasValue)
            {
                <div class="tpm-empty">
                    <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
                    <span>Select a Friday to view vendor attendance</span>
                </div>
            }
            else if (isLoadingAttendance)
            {
                <div class="sk-rows">
                    @for (var _i = 0; _i < 8; _i++)
                    {
                        <div class="sk-row">
                            <Skeleton Width="80%" Height="13px" Radius="6px" />
                            <Skeleton Width="60px" Height="22px" Radius="999px" />
                            <Skeleton Width="60%" Height="13px" Radius="6px" />
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="tpm-attendance-info">
                    <div class="tpm-attend-stat">
                        <span class="tpm-attend-val tpm-sum-green">@FilteredVendors.Count()</span>
                        <span class="tpm-attend-key">Vendors</span>
                    </div>
                    <div class="tpm-attend-stat">
                        <span class="tpm-attend-val tpm-sum-gold">₱@(FilteredVendors.Sum(v => v.Fee).ToString("N0"))</span>
                        <span class="tpm-attend-key">Collected</span>
                    </div>
                    <button class="tpm-add-vendor-btn" @onclick="OpenAddVendorModal">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Add Vendor
                    </button>
                </div>

                <div class="tpm-search-wrap">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    <input class="tpm-search-input" placeholder="Search vendor name…" @bind="VendorSearch" @bind:event="oninput" />
                </div>

                @if (!FilteredVendors.Any())
                {
                    <div class="tpm-empty">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /></svg>
                        <span>No vendors found</span>
                    </div>
                }
                else
                {
                    <div class="tpm-vendor-table-wrap">
                        <table class="tpm-vendor-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Vendor Name</th>
                                    <th>Goods / Product</th>
                                    <th>OR No.</th>
                                    <th>Fee</th>
                                    <th>Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var (vendor, index) in FilteredVendors.Select((v, i) => (v, i + 1)))
                                {
                                    <tr>
                                        <td class="tpm-row-num">@index</td>
                                        <td class="tpm-vendor-name-cell">@vendor.VendorName</td>
                                        <td class="tpm-goods-cell">@vendor.Goods</td>
                                        <td class="tpm-or-cell">
                                            @if (!string.IsNullOrEmpty(vendor.ORNumber))
                                            {
                                                <span class="tpm-or-badge">@vendor.ORNumber</span>
                                            }
                                            else if (vendor.IsPaid)
                                            {
                                                <button class="tpm-or-btn" @onclick="() => OpenOrModal(vendor)">
                                                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                                                    OR No.
                                                </button>
                                            }
                                            else
                                            {
                                                <span class="tpm-or-none">—</span>
                                            }
                                        </td>
                                        <td class="tpm-fee-cell">₱@vendor.Fee.ToString("N0")</td>
                                        <td class="tpm-actions-cell">
                                            <button class="tpm-edit-btn" @onclick="() => OpenEditModal(vendor)" title="Edit vendor">
                                                <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                                                Edit
                                            </button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            }
        </div>

    </div>
</div>

<!-- ── Add Vendor Modal ── -->


@if (ShowAddVendorModal)
{
    <div class="tpm-modal-overlay" @onclick="CloseAddVendorModal">
        <div class="tpm-modal" @onclick:stopPropagation="true">
            <div class="tpm-modal-header">
                <div class="tpm-modal-title">Add Vendor</div>
                <button class="tpm-modal-close" @onclick="CloseAddVendorModal">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="tpm-modal-body">
                <div class="tpm-form-group">
                    <label class="tpm-form-label">Vendor Name</label>
                    <input class="tpm-form-input" placeholder="e.g. Maria Dela Cruz" @bind="NewVendorName" />
                    @if (VendorFieldErrors.ContainsKey("VendorName"))
                    {
                        <div class="tpm-form-error">@VendorFieldErrors["VendorName"]</div>
                    }
                </div>
                <div class="tpm-form-group">
                    <label class="tpm-form-label">Goods / Product</label>
                    <input class="tpm-form-input" placeholder="e.g. Vegetables, Cooked Food" @bind="NewGoods" />
                    @if (VendorFieldErrors.ContainsKey("Goods"))
                    {
                        <div class="tpm-form-error">@VendorFieldErrors["Goods"]</div>
                    }
                </div>
                @if (!string.IsNullOrEmpty(AddVendorError))
                {
                    <div class="tpm-form-error-banner">@AddVendorError</div>
                }
            </div>
            <div class="tpm-modal-footer">
                <button class="tpm-btn-ghost" @onclick="CloseAddVendorModal">Cancel</button>
                <button class="tpm-btn-primary" @onclick="SubmitAddVendor" disabled="@isSaving">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    @(isSaving ? "Saving..." : "Add Vendor")
                </button>
            </div>
        </div>
    </div>
}

<!-- ── OR Number Modal ── -->
@if (ShowOrModal && OrVendor != null)
{
    <div class="tpm-modal-overlay" @onclick="CloseOrModal">
        <div class="tpm-modal" @onclick:stopPropagation="true">
            <div class="tpm-modal-header">
                <div class="tpm-modal-title">Enter OR Number</div>
                <button class="tpm-modal-close" @onclick="CloseOrModal">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="tpm-modal-body">
                <div class="tpm-or-info-block">
                    <div class="tpm-or-info-row">
                        <span class="tpm-or-info-key">Vendor</span>
                        <span class="tpm-or-info-val">@OrVendor.VendorName</span>
                    </div>
                    <div class="tpm-or-info-row">
                        <span class="tpm-or-info-key">Market Day</span>
                        <span class="tpm-or-info-val">@SelectedFriday?.ToString("MMMM d, yyyy")</span>
                    </div>
                    <div class="tpm-or-info-row">
                        <span class="tpm-or-info-key">Fee</span>
                        <span class="tpm-or-info-val tpm-or-fee">₱@OrVendor.Fee.ToString("N0")</span>
                    </div>
                </div>
                <div class="tpm-form-group">
                    <label class="tpm-form-label">OR Number</label>
                    <input class="tpm-form-input" placeholder="e.g. OR-2026-0501" @bind="OrNumberInput" />
                    @if (!string.IsNullOrEmpty(OrErrorMessage))
                    {
                        <div class="tpm-form-error">@OrErrorMessage</div>
                    }
                </div>
            </div>
            <div class="tpm-modal-footer">
                <button class="tpm-btn-ghost" @onclick="CloseOrModal">Cancel</button>
                <button class="tpm-btn-primary" @onclick="SaveOrNumber" disabled="@isSaving">
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                    @(isSaving ? "Saving..." : "Save OR Number")
                </button>
            </div>
        </div>
    </div>
}

<!-- ── Edit Vendor Modal ── -->
@if (ShowEditModal && EditVendor != null)
{
    <div class="tpm-modal-overlay" @onclick="CloseEditModal">
        <div class="tpm-modal" @onclick:stopPropagation="true">
            <div class="tpm-modal-header">
                <div class="tpm-modal-title">Edit Vendor</div>
                <button class="tpm-modal-close" @onclick="CloseEditModal">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>
            <div class="tpm-modal-body">
                <div class="tpm-form-group">
                    <label class="tpm-form-label">Vendor Name</label>
                    <input class="tpm-form-input" placeholder="e.g. Maria Dela Cruz" @bind="EditVendorName" />
                    @if (EditFieldErrors.ContainsKey("VendorName"))
                    {
                        <div class="tpm-form-error">@EditFieldErrors["VendorName"]</div>
                    }
                </div>
                <div class="tpm-form-group">
                    <label class="tpm-form-label">Goods / Product</label>
                    <input class="tpm-form-input" list="tpm-goods-options" placeholder="e.g. Vegetables, Cooked Food" @bind="EditGoods" />
                    <datalist id="tpm-goods-options">
                        @foreach (var g in KnownGoods)
                        {
                            <option value="@g" />
                        }
                    </datalist>
                    @if (EditFieldErrors.ContainsKey("Goods"))
                    {
                        <div class="tpm-form-error">@EditFieldErrors["Goods"]</div>
                    }
                </div>
                <div class="tpm-form-group">
                    <label class="tpm-form-label">OR Number <span style="font-weight:400;color:var(--text-muted)">(optional)</span></label>
                    <input class="tpm-form-input" placeholder="e.g. 000001" @bind="EditORNumber" />
                </div>
                @if (!string.IsNullOrEmpty(EditError))
                {
                    <div class="tpm-form-error-banner">@EditError</div>
                }
            </div>
            <div class="tpm-modal-footer">
                <button class="tpm-btn-ghost" @onclick="CloseEditModal">Cancel</button>
                <button class="tpm-btn-primary" @onclick="SubmitEditVendor" disabled="@isSaving">
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                    @(isSaving ? "Saving..." : "Save Changes")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private RenderFragment TpmIcon => @<svg viewBox="0 0 24 24" style="width: 26px; height: 26px; stroke: var(--gold); fill: none; stroke-width: 2;"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>;

    private List<FacilityHero.HeroStat> HeroStats => new()
    {
        new() { Value = $"₱{Overview?.CollectedThisMonth ?? 0:N0}", Label = "Collected This Month" },
        new() { Value = $"{Overview?.FridaysThisMonth ?? 0}", Label = "Fridays This Month" },
        new() { Value = $"{Overview?.VendorEntriesThisMonth ?? 0}", Label = "Vendor Entries" }
    };

    // ── State ─────────────────────────────────────
    private TpmOverviewDto? Overview;
    private List<TpmMarketDayDto> MarketDays = new();
    private List<TpmVendorAttendanceDto> Attendance = new();

    private DateTime CalendarMonth = new(DateTime.Now.Year, DateTime.Now.Month, 1);
    private DateTime CurrentMonthStart => new(DateTime.Now.Year, DateTime.Now.Month, 1);
    private DateTime? SelectedFriday;
    private string VendorSearch = string.Empty;
    private bool isLoadingAttendance;
    private bool isSaving;

    // ── Computed ──────────────────────────────────
    private IEnumerable<TpmVendorAttendanceDto> FilteredVendors => Attendance
        .Where(a => string.IsNullOrWhiteSpace(VendorSearch)
                 || a.VendorName.Contains(VendorSearch, StringComparison.OrdinalIgnoreCase))
        .OrderBy(a => a.VendorName);
    private int TpmPaidCount => Attendance.Count(v => v.IsPaid);
    private int TpmUnpaidCount => Attendance.Count(v => !v.IsPaid);
    private int TpmActiveVendorCount => Attendance.Any() ? Attendance.Count : Overview?.VendorEntriesThisMonth ?? 0;
    private int TpmVendorEntryCount => Math.Max(Overview?.VendorEntriesThisMonth ?? 0, TpmActiveVendorCount);
    private decimal TpmCollectedAmount => Attendance.Any()
        ? Attendance.Where(v => v.IsPaid).Sum(v => v.Fee)
        : Overview?.CollectedThisMonth ?? 0m;
    private decimal TpmUncollectedAmount => Attendance.Any()
        ? Attendance.Where(v => !v.IsPaid).Sum(v => v.Fee)
        : TpmUnpaidCount * 100m;
    private decimal TpmCollectionRate => Attendance.Any()
        ? (TpmPaidCount * 100m) / Attendance.Count
        : Overview?.CollectionRate ?? 0m;
    private IReadOnlyList<FacilityReportsModal.ReportTrendPoint> TpmTrendPoints => MarketDays
        .OrderBy(m => m.MarketDate)
        .Select(m => new FacilityReportsModal.ReportTrendPoint(m.MarketDate.ToString("MMM d"), m.TotalCollected))
        .ToList();

    // ── Lifecycle ─────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        await LoadOverviewAndMarketDaysAsync();
    }

    private async Task LoadOverviewAndMarketDaysAsync()
    {
        var overviewResult = await TpmApi.GetOverviewAsync(CalendarMonth.Year, CalendarMonth.Month);
        if (overviewResult.IsSuccess) Overview = overviewResult.Value;

        var marketDaysResult = await TpmApi.GetMarketDaysAsync(CalendarMonth.Year, CalendarMonth.Month);
        MarketDays = marketDaysResult.IsSuccess && marketDaysResult.Value != null
            ? marketDaysResult.Value.ToList()
            : new();
    }

    // ── Navigation ────────────────────────────────
    private async Task PrevMonth()
    {
        CalendarMonth = CalendarMonth.AddMonths(-1);
        SelectedFriday = null;
        Attendance.Clear();
        await LoadOverviewAndMarketDaysAsync();
    }

    private async Task NextMonth()
    {
        if (CalendarMonth >= CurrentMonthStart) return;
        CalendarMonth = CalendarMonth.AddMonths(1);
        SelectedFriday = null;
        Attendance.Clear();
        await LoadOverviewAndMarketDaysAsync();
    }

    private async Task SelectFriday(DateTime friday)
    {
        SelectedFriday = friday;
        VendorSearch = string.Empty;
        isLoadingAttendance = true;

        var result = await TpmApi.GetVendorAttendanceAsync(DateOnly.FromDateTime(friday));
        Attendance = result.IsSuccess && result.Value != null ? result.Value.ToList() : new();

        isLoadingAttendance = false;
    }

    // ── Payment status is now edited via the Edit modal (SubmitEditVendor). ──

    // ── Add Vendor Modal ──────────────────────────
    private bool ShowAddVendorModal;
    private string NewVendorName = string.Empty;
    private string NewGoods = string.Empty;
    private string AddVendorError = string.Empty;
    private Dictionary<string, string> VendorFieldErrors = new();

    private void OpenAddVendorModal()
    {
        NewVendorName = string.Empty;
        NewGoods = string.Empty;
        AddVendorError = string.Empty;
        VendorFieldErrors.Clear();
        ShowAddVendorModal = true;
    }

    private void CloseAddVendorModal()
    {
        ShowAddVendorModal = false;
        VendorFieldErrors.Clear();
        AddVendorError = string.Empty;
    }

    private async Task SubmitAddVendor()
    {
        VendorFieldErrors.Clear();
        AddVendorError = string.Empty;

        if (string.IsNullOrWhiteSpace(NewVendorName))
            VendorFieldErrors["VendorName"] = "Vendor name is required.";
        if (string.IsNullOrWhiteSpace(NewGoods))
            VendorFieldErrors["Goods"] = "Goods / product is required.";
        if (VendorFieldErrors.Any()) return;

        if (!SelectedFriday.HasValue) return;
        isSaving = true;

        var command = new AddVendorToMarketDayCommand(
            NewVendorName.Trim(),
            NewGoods.Trim(),
            DateOnly.FromDateTime(SelectedFriday.Value));
        var result = await TpmApi.AddVendorAsync(command);
        isSaving = false;

        if (result.IsSuccess)
        {
            await SelectFriday(SelectedFriday.Value);
            await LoadOverviewAndMarketDaysAsync();
            CloseAddVendorModal();
        }
        else if (result.ValidationErrors != null && result.ValidationErrors.Any())
        {
            foreach (var error in result.ValidationErrors)
                VendorFieldErrors[error.Key] = error.Value.FirstOrDefault() ?? string.Empty;
        }
        else
        {
            AddVendorError = result.Error ?? "Failed to add vendor.";
        }
    }

    // ── OR Number Modal ───────────────────────────
    private bool ShowOrModal;
    private TpmVendorAttendanceDto? OrVendor;
    private string OrNumberInput = string.Empty;
    private string OrErrorMessage = string.Empty;

    private void OpenOrModal(TpmVendorAttendanceDto vendor)
    {
        OrVendor = vendor;
        OrNumberInput = string.Empty;
        OrErrorMessage = string.Empty;
        ShowOrModal = true;
    }

    private void CloseOrModal()
    {
        ShowOrModal = false;
        OrVendor = null;
        OrErrorMessage = string.Empty;
    }

    private async Task SaveOrNumber()
    {
        OrErrorMessage = string.Empty;
        if (string.IsNullOrWhiteSpace(OrNumberInput))
        {
            OrErrorMessage = "OR number is required.";
            return;
        }
        if (OrVendor == null) return;

        isSaving = true;
        var result = await TpmApi.SaveOrNumberAsync(OrVendor.Id, new SaveOrNumberRequest(OrNumberInput.Trim()));
        isSaving = false;

        if (result.IsSuccess)
        {
            if (SelectedFriday.HasValue) await SelectFriday(SelectedFriday.Value);
            CloseOrModal();
        }
        else if (result.ValidationErrors != null && result.ValidationErrors.Any())
        {
            OrErrorMessage = result.ValidationErrors.First().Value.FirstOrDefault() ?? "Invalid OR number.";
        }
        else
        {
            OrErrorMessage = result.Error ?? "Failed to save OR number.";
        }
    }

    // ── Edit Vendor Modal ─────────────────────────
    private bool ShowEditModal;
    private TpmVendorAttendanceDto? EditVendor;
    private string EditVendorName = string.Empty;
    private string EditGoods = string.Empty;
    private string EditORNumber = string.Empty;
    private string EditError = string.Empty;
    private Dictionary<string, string> EditFieldErrors = new();

    // Existing goods on the selected day — feeds the edit modal's goods suggestions.
    private IReadOnlyList<string> KnownGoods => Attendance
        .Select(a => a.Goods)
        .Where(g => !string.IsNullOrWhiteSpace(g))
        .Select(g => g.Trim())
        .Distinct(StringComparer.OrdinalIgnoreCase)
        .OrderBy(g => g, StringComparer.OrdinalIgnoreCase)
        .ToList();

    private void OpenEditModal(TpmVendorAttendanceDto vendor)
    {
        EditVendor = vendor;
        EditVendorName = vendor.VendorName;
        EditGoods = vendor.Goods;
        EditORNumber = vendor.ORNumber ?? string.Empty;
        EditError = string.Empty;
        EditFieldErrors.Clear();
        ShowEditModal = true;
    }

    private void CloseEditModal()
    {
        ShowEditModal = false;
        EditVendor = null;
        EditFieldErrors.Clear();
        EditError = string.Empty;
    }

    private async Task SubmitEditVendor()
    {
        EditFieldErrors.Clear();
        EditError = string.Empty;

        if (string.IsNullOrWhiteSpace(EditVendorName))
            EditFieldErrors["VendorName"] = "Vendor name is required.";
        if (string.IsNullOrWhiteSpace(EditGoods))
            EditFieldErrors["Goods"] = "Goods / product is required.";
        if (EditFieldErrors.Any()) return;
        if (EditVendor == null) return;

        isSaving = true;
        var request = new UpdateTpmVendorRequest(
            EditVendorName.Trim(),
            EditGoods.Trim(),
            true,
            !string.IsNullOrWhiteSpace(EditORNumber) ? EditORNumber.Trim() : null);
        var result = await TpmApi.UpdateVendorAsync(EditVendor.Id, request);
        isSaving = false;

        if (result.IsSuccess)
        {
            if (SelectedFriday.HasValue) await SelectFriday(SelectedFriday.Value);
            await LoadOverviewAndMarketDaysAsync();
            CloseEditModal();
        }
        else if (result.ValidationErrors != null && result.ValidationErrors.Any())
        {
            foreach (var error in result.ValidationErrors)
                EditFieldErrors[error.Key] = error.Value.FirstOrDefault() ?? string.Empty;
        }
        else
        {
            EditError = result.Error ?? "Failed to update vendor.";
        }
    }

    // ── Helpers ───────────────────────────────────
    private static List<DateTime> GetFridaysInMonth(DateTime month)
    {
        var fridays = new List<DateTime>();
        var d = new DateTime(month.Year, month.Month, 1);
        while (d.DayOfWeek != DayOfWeek.Friday) d = d.AddDays(1);
        while (d.Month == month.Month) { fridays.Add(d); d = d.AddDays(7); }
        return fridays;
    }
}
