    private static string FormatSize(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        double kb = bytes / 1024d;
        if (kb < 1024) return $"{kb:0.#} KB";
        double mb = kb / 1024d;
        return $"{mb:0.#} MB";
    }

    private async Task LoadRunsAsync(bool silent = false)
    {
        if (!silent)
        {
            _loadingRuns = true;
            _runsError = null;
            await InvokeAsync(StateHasChanged);
        }

        var result = await BackupApi.GetRecentRunsAsync();
        if (result.IsSuccess && result.Value is not null)
            _runs = result.Value;
        else if (!silent)
            _runsError = string.IsNullOrWhiteSpace(result.Error)
                ? "Recent backups could not be retrieved."
                : result.Error;

        _loadingRuns = false;
        if (!silent) MaybeStartListPolling();
    }

    private async Task LoadRestoreRunsAsync(bool silent = false)
    {
        if (!silent)
        {
            _loadingRestoreRuns = true;
            _restoreRunsError = null;
