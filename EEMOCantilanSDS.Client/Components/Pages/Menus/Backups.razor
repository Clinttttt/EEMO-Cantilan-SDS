@page "/settings/backups"
@using Microsoft.AspNetCore.Authorization
@using EEMOCantilanSDS.Application.Dtos.Backup
@using EEMOCantilanSDS.Application.Requests.Backup
@using EEMOCantilanSDS.Domain.Common
@using Microsoft.AspNetCore.Components.Forms
@attribute [Authorize(Roles = "SuperAdmin")]
@rendermode InteractiveServer
@inject IBackupApiClient BackupApi
@inject ITenantUsageApiClient TenantUsageApi
@inject IJSRuntime JS
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject EEMOCantilanSDS.Client.Services.RestoreNotifier Notifier
@implements IDisposable

@*
    Backups — Head-only (SuperAdmin) on-demand database backups.
    Everything is proxied through api/backup/*: the page triggers the GitHub Actions backup workflow,
    lists recent runs, and downloads the latest artifact. The GitHub token lives strictly server-side
    and is never sent to or reachable by the browser. In-app restore is Head-only and hard-guarded
    (retype RESTORE + re-enter the admin password, both verified server-side); it triggers the atomic
    restore workflow, which takes a pre-restore safety backup first.
*@

<PageTitle>@Branding.OfficeAcronym Admin — Backups</PageTitle>

<header class="topbar">
    <div class="topbar-left">
        <div class="topbar-title">Backups</div>
        <div class="topbar-breadcrumb">
            <span>@Branding.OfficeAcronym Admin</span>
            <span class="breadcrumb-sep">/</span>
            <span>Settings</span>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Backups</span>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @_now.ToString("MMMM d, yyyy")
        </div>
        <AccountChip />
    </div>
</header>

<div class="content-area">

    <!-- ══ Your municipality (every Head) ══ -->
    <section class="set-card">
        <div class="set-card-head">
            <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" /><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3" /></svg></div>
            <div class="set-card-titles">
                <div class="set-card-title">Backup &amp; restore</div>
                <div class="set-card-sub">@Branding.Municipality's own backup &amp; restore — download a backup (restore point) and restore from it. Scoped to your LGU only; another municipality is never affected.</div>
            </div>
        </div>
        <div class="bk-info-grid">
            <div class="bk-info">
                <div class="bk-info-key">Data archive</div>
                <div class="bk-info-val">A readable JSON copy of your records, for keeping or audit.</div>
            </div>
            <div class="bk-info">
                <div class="bk-info-key">Restore point (backup file)</div>
                <div class="bk-info-val">A complete backup of your LGU's data — the file the restore below accepts.</div>
            </div>
            <div class="bk-info">
                <div class="bk-info-key">Scope</div>
                <div class="bk-info-val">Everything here affects <strong>only your municipality</strong> — never another LGU.</div>
            </div>
        </div>
        <div class="bk-actions">
            <button class="bk-btn bk-btn-ghost" @onclick="ExportMineAsync" disabled="@_meBusy">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                <span>Back up my data (archive)</span>
            </button>
            <button class="bk-btn bk-btn-primary" @onclick="DownloadRestorePointAsync" disabled="@_meBusy">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" /><polyline points="17 21 17 13 7 13 7 21" /><polyline points="7 3 7 8 15 8" /></svg>
                <span>Download restore point</span>
            </button>
        </div>
    </section>

    <!-- ══ Restore your municipality (upload a restore point) ══ -->
    <section class="bk-danger">
        <div class="bk-danger-head">
            <div class="bk-danger-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6" /><path d="M3 13a9 9 0 1 0 3-7.7L3 8" /></svg></div>
            <div class="bk-danger-titles">
                <div class="bk-danger-title">Restore your municipality</div>
                <div class="bk-danger-sub">Replaces your LGU's records from a restore point — other municipalities are never affected</div>
            </div>
            @if (!_showMineRestore)
            {
                <button class="bk-btn bk-btn-ghost" type="button" @onclick="() => _showMineRestore = true">Start restore…</button>
            }
        </div>

        @if (_showMineRestore)
        {
            <div class="bk-mine-restore">
                <div class="bk-warn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                    <div class="bk-warn-text">
                        This replaces <strong>@Branding.Municipality's</strong> current records with the uploaded restore point.
                        A copy of your current data is downloaded first as a safety net, and the whole restore runs in one
                        transaction — if anything fails, nothing changes.
                    </div>
                </div>

                <div class="bk-mine-form">
                    <div class="bk-field">
                        <label class="bk-label">Step 1 · Restore-point file</label>
                        <label class="bk-filepick @(_mineUploadName is not null ? "has-file" : "")">
                            <InputFile OnChange="OnMineFileSelected" accept=".json" />
                            <span class="bk-filepick-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="17 8 12 3 7 8" /><line x1="12" y1="3" x2="12" y2="15" /></svg></span>
                            <span class="bk-filepick-text">@(_mineUploadName ?? "Choose a restore-point (.json) file…")</span>
                            <span class="bk-filepick-btn">Browse</span>
                        </label>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label" for="bk-mine-phrase">Step 2 · Type <code>RESTORE</code> to confirm</label>
                        <input id="bk-mine-phrase" class="bk-input" type="text" autocomplete="off" placeholder="RESTORE" @bind="_minePhrase" @bind:event="oninput" disabled="@_mineRestoring" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label" for="bk-mine-pass">Step 3 · Confirm your admin password</label>
                        <input id="bk-mine-pass" class="bk-input" type="password" autocomplete="off" placeholder="Password" @bind="_minePassword" @bind:event="oninput" disabled="@_mineRestoring" />
                    </div>

                    @if (_mineError is not null)
                    {
                        <div class="bk-alert bk-alert-err" role="alert">@_mineError</div>
                    }

                    <div class="bk-mine-actions">
                        <button class="bk-btn bk-btn-ghost" type="button" @onclick="() => _showMineRestore = false" disabled="@_mineRestoring">Cancel</button>
                        <button class="bk-btn bk-btn-danger" type="button" @onclick="RestoreMineAsync" disabled="@(!CanRestoreMine)">
                            @if (_mineRestoring)
                            {
                                <span class="bk-spin" aria-hidden="true"></span>
                                <span>Restoring…</span>
                            }
                            else
                            {
                                <span>Restore my municipality</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        }
    </section>

    <!-- ══ Recent backups (stored history — every Head, scoped to their own LGU) ══ -->
    <section class="set-card">
        <div class="set-card-head">
            <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg></div>
            <div class="set-card-titles">
                <div class="set-card-title">Recent backups</div>
                <div class="set-card-sub">Saved backups of @Branding.Municipality's data — download or restore any of them. The most recent 15 are kept.</div>
            </div>
            <button class="bk-btn bk-btn-primary" @onclick="CreateBackupAsync" disabled="@_creatingBackup">
                @if (_creatingBackup)
                {
                    <span class="bk-spin" aria-hidden="true"></span>
                    <span>Creating…</span>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z" /><polyline points="17 21 17 13 7 13 7 21" /><polyline points="7 3 7 8 15 8" /></svg>
                    <span>Create backup now</span>
                }
            </button>
        </div>

        @if (_loadingBackups)
        {
            <div class="bk-rows">
                @for (var i = 0; i < 3; i++)
                {
                    <div class="bk-run bk-run-sk"><div class="sk bk-sk-pill"></div><div class="sk bk-sk-line"></div><div class="sk bk-sk-short"></div></div>
                }
            </div>
        }
        else if (_backupsError is not null)
        {
            <div class="bk-empty">
                <div class="bk-empty-title">Couldn't load backups</div>
                <div class="bk-empty-text">@_backupsError</div>
                <button class="set-retry" @onclick="LoadBackupsAsync">Try again</button>
            </div>
        }
        else if (_backups is null || _backups.Count == 0)
        {
            <div class="bk-empty">
                <div class="bk-empty-title">No backups yet</div>
                <div class="bk-empty-text">Click <strong>Create backup now</strong> to save your first restore point here.</div>
            </div>
        }
        else
        {
            <table class="set-table bk-table">
                <thead>
                    <tr><th>When (PH time)</th><th>By</th><th>Contents</th><th class="set-th-r">Size</th><th class="set-th-r">Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var b in _backups)
                    {
                        <tr>
                            <td>@PhilippineTime.ToPhilippineTime(b.CreatedAtUtc).ToString("MMM d, yyyy · h:mm tt")</td>
                            <td>@b.CreatedBy</td>
                            <td>@b.RowCount.ToString("N0") record@(b.RowCount == 1 ? "" : "s") · @b.TableCount table@(b.TableCount == 1 ? "" : "s")</td>
                            <td class="set-td-r">@FormatSize(b.SizeBytes)</td>
                            <td class="set-td-r">
                                <div class="bk-actions-row">
                                    <button class="bk-action" @onclick="() => OpenBackupContents(b)" title="View what this backup contains">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z" /><circle cx="12" cy="12" r="3" /></svg>
                                        <span>View</span>
                                    </button>
                                    <button class="bk-action" @onclick="() => DownloadBackupAsync(b.Id)" disabled="@_meBusy" title="Download the backup file">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                                        <span>Download</span>
                                    </button>
                                    <button class="bk-action bk-action-danger" @onclick="() => OpenBackupRestore(b)" title="Restore your municipality from this backup">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6" /><path d="M3 13a9 9 0 1 0 3-7.7L3 8" /></svg>
                                        <span>Restore</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <!-- ══ Recent restores (this LGU's restore history) ══ -->
    <section class="set-card">
        <div class="set-card-head">
            <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6" /><path d="M3 13a9 9 0 1 0 3-7.7L3 8" /></svg></div>
            <div class="set-card-titles">
                <div class="set-card-title">Recent restores</div>
                <div class="set-card-sub">When @Branding.Municipality's data was restored, and by whom</div>
            </div>
        </div>

        @if (_loadingRestoreHistory)
        {
            <div class="bk-rows">
                @for (var i = 0; i < 2; i++)
                {
                    <div class="bk-run bk-run-sk"><div class="sk bk-sk-pill"></div><div class="sk bk-sk-line"></div><div class="sk bk-sk-short"></div></div>
                }
            </div>
        }
        else if (_restoreHistory is null || _restoreHistory.Count == 0)
        {
            <div class="bk-empty">
                <div class="bk-empty-title">No restores yet</div>
                <div class="bk-empty-text">When you restore from a backup, it will be listed here.</div>
            </div>
        }
        else
        {
            <table class="set-table bk-table">
                <thead>
                    <tr><th>When (PH time)</th><th>By</th><th>Restored</th><th class="set-th-r">Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var e in _restoreHistory)
                    {
                        <tr>
                            <td>@PhilippineTime.ToPhilippineTime(e.WhenUtc).ToString("MMM d, yyyy · h:mm tt")</td>
                            <td>@e.By</td>
                            <td>
                                @if (e.RowsRestored > 0)
                                {
                                    <div class="bk-restore-cell">
                                        <span class="bk-restore-main">@e.RowsRestored.ToString("N0") record@(e.RowsRestored == 1 ? "" : "s") · @e.TablesRestored table@(e.TablesRestored == 1 ? "" : "s")</span>
                                        @if (e.SnapshotUtc is not null)
                                        {
                                            <span class="bk-restore-sub">from a backup dated @PhilippineTime.ToPhilippineTime(e.SnapshotUtc.Value).ToString("MMM d, yyyy · h:mm tt")</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="bk-muted">@e.Summary</span>
                                }
                            </td>
                            <td class="set-td-r">
                                <div class="bk-actions-row">
                                    <button class="bk-action" @onclick="() => OpenRestoreDetail(e)" title="View what this restore replaced">
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-7 11-7 11 7 11 7-4 7-11 7-11-7-11-7z" /><circle cx="12" cy="12" r="3" /></svg>
                                        <span>View</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    @if (_isOperator)
    {

    <!-- ── How backups work ── -->
    <section class="set-card">
        <div class="set-card-head">
            <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" /><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3" /></svg></div>
            <div class="set-card-titles">
                <div class="set-card-title">Database backups</div>
                <div class="set-card-sub">How your data is protected</div>
            </div>
        </div>
        <div class="bk-info-grid">
            <div class="bk-info">
                <div class="bk-info-key">Automated daily</div>
                <div class="bk-info-val">A full backup runs every day at <strong>01:00 Philippine time</strong> via CI.</div>
            </div>
            <div class="bk-info">
                <div class="bk-info-key">Point-in-time recovery</div>
                <div class="bk-info-val"><strong>7-day Azure PITR</strong> lets ops restore to any moment in the last week.</div>
            </div>
            <div class="bk-info">
                <div class="bk-info-key">This page</div>
                <div class="bk-info-val">Run an <strong>on-demand backup</strong> now and download the latest backup file.</div>
            </div>
        </div>
    </section>

    <!-- ── On-demand actions ── -->
    <section class="set-card">
        <div class="set-card-head">
            <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7" /><polyline points="21 3 21 9 15 9" /></svg></div>
            <div class="set-card-titles">
                <div class="set-card-title">On-demand backup</div>
                <div class="set-card-sub">Trigger a backup or download the most recent one</div>
            </div>
            <button class="bk-info-btn" type="button" @onclick="() => _showRestore = true"
                    title="How to restore a backup" aria-label="Restore instructions">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>
                <span>Restore help</span>
            </button>
        </div>

        <div class="bk-actions">
            <button class="bk-btn bk-btn-primary" @onclick="RunBackupAsync" disabled="@(_running || _downloading)">
                @if (_running)
                {
                    <span class="bk-spin" aria-hidden="true"></span>
                    <span>Starting backup…</span>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7" /><polyline points="21 3 21 9 15 9" /></svg>
                    <span>Run backup now</span>
                }
            </button>

            <button class="bk-btn bk-btn-ghost" @onclick="DownloadLatestAsync" disabled="@(_running || _downloading)">
                @if (_downloading)
                {
                    <span class="bk-spin bk-spin-dark" aria-hidden="true"></span>
                    <span>Preparing download…</span>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                    <span>Download latest backup</span>
                }
            </button>
        </div>
    </section>

    <!-- ── Recent backups ── -->
    <section class="set-card">
        <div class="set-card-head">
            <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg></div>
            <div class="set-card-titles">
                <div class="set-card-title">Recent backups</div>
                <div class="set-card-sub">The latest backup runs</div>
            </div>
            <button class="set-link bk-refresh" @onclick="() => LoadRunsAsync()" disabled="@_loadingRuns">Refresh<span class="set-link-arrow">↻</span></button>
        </div>

        @if (_loadingRuns)
        {
            <div class="bk-rows">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="bk-run bk-run-sk">
                        <div class="sk bk-sk-pill"></div>
                        <div class="sk bk-sk-line"></div>
                        <div class="sk bk-sk-short"></div>
                    </div>
                }
            </div>
        }
        else if (_runsError is not null)
        {
            <div class="bk-empty">
                <div class="bk-empty-title">Couldn't load recent backups</div>
                <div class="bk-empty-text">@_runsError</div>
                <button class="set-retry" @onclick="() => LoadRunsAsync()">Try again</button>
            </div>
        }
        else if (_runs is null || _runs.Count == 0)
        {
            <div class="bk-empty">
                <div class="bk-empty-title">No backups yet</div>
                <div class="bk-empty-text">Once a backup runs, it will appear here.</div>
            </div>
        }
        else
        {
            <table class="set-table bk-table">
                <thead>
                    <tr><th>When (PH time)</th><th>Trigger</th><th>Status</th><th class="set-th-r">Details</th></tr>
                </thead>
                <tbody>
                    @foreach (var run in _runs)
                    {
                        <tr>
                            <td>@PhilippineTime.ToPhilippineTime(run.CreatedAt).ToString("MMM d, yyyy · h:mm tt")</td>
                            <td>@TriggerLabel(run.Event)</td>
                            <td><span class="bk-pill @PillClass(run)">@StatusLabel(run)</span></td>
                            <td class="set-td-r">
                                <button class="set-link bk-viewlog" @onclick="() => OpenLog(run)">View log<span class="set-link-arrow">→</span></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <!-- ── Recent restores ── -->
    <section class="set-card">
        <div class="set-card-head">
            <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6" /><path d="M3 13a9 9 0 1 0 3-7.7L3 8" /></svg></div>
            <div class="set-card-titles">
                <div class="set-card-title">Recent restores</div>
                <div class="set-card-sub">The latest restore runs</div>
            </div>
            <button class="set-link bk-refresh" @onclick="() => LoadRestoreRunsAsync()" disabled="@_loadingRestoreRuns">Refresh<span class="set-link-arrow">↻</span></button>
        </div>

        @if (_loadingRestoreRuns)
        {
            <div class="bk-rows">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="bk-run bk-run-sk">
                        <div class="sk bk-sk-pill"></div>
                        <div class="sk bk-sk-line"></div>
                        <div class="sk bk-sk-short"></div>
                    </div>
                }
            </div>
        }
        else if (_restoreRunsError is not null)
        {
            <div class="bk-empty">
                <div class="bk-empty-title">Couldn't load recent restores</div>
                <div class="bk-empty-text">@_restoreRunsError</div>
                <button class="set-retry" @onclick="() => LoadRestoreRunsAsync()">Try again</button>
            </div>
        }
        else if (_restoreRuns is null || _restoreRuns.Count == 0)
        {
            <div class="bk-empty">
                <div class="bk-empty-title">No restores yet</div>
                <div class="bk-empty-text">When you run a restore, it will appear here.</div>
            </div>
        }
        else
        {
            <table class="set-table bk-table">
                <thead>
                    <tr><th>When (PH time)</th><th>Trigger</th><th>Status</th><th class="set-th-r">Details</th></tr>
                </thead>
                <tbody>
                    @foreach (var run in _restoreRuns)
                    {
                        <tr>
                            <td>@PhilippineTime.ToPhilippineTime(run.CreatedAt).ToString("MMM d, yyyy · h:mm tt")</td>
                            <td>@TriggerLabel(run.Event)</td>
                            <td><span class="bk-pill @PillClass(run)">@StatusLabel(run)</span></td>
                            <td class="set-td-r">
                                <button class="set-link bk-viewlog" @onclick="() => OpenLog(run)">View log<span class="set-link-arrow">→</span></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <!-- ── Danger zone: destructive restore ── -->
    <section class="bk-danger">
        <div class="bk-danger-head">
            <div class="bk-danger-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
            </div>
            <div class="bk-danger-titles">
                <div class="bk-danger-title">Danger zone</div>
                <div class="bk-danger-sub">Irreversible operation — restores the entire database</div>
            </div>
        </div>
        <div class="bk-danger-body">
            <div class="bk-danger-copy">
                <div class="bk-danger-copy-title">Restore latest backup</div>
                <div class="bk-danger-copy-text">
                    Replaces <strong>all current data</strong> with the most recent backup. A safety backup is
                    taken automatically first. Best run when the system is idle. Requires re-authentication.
                </div>
            </div>
            <button class="bk-btn bk-btn-danger" type="button" @onclick="OpenRestoreConfirm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6" /><path d="M3 13a9 9 0 1 0 3-7.7L3 8" /></svg>
                <span>Restore latest backup</span>
            </button>
        </div>
    </section>
    }

    <!-- ── Backup contents (manifest) ── -->
    @if (_contentsFor is not null)
    {
        <div class="bk-modal-overlay" @onclick="CloseBackupContents">
            <div class="bk-modal bk-modal-wide" role="dialog" aria-modal="true" aria-label="Backup contents" @onclick:stopPropagation="true">
                <div class="bk-modal-head">
                    <div class="bk-modal-titles">
                        <div class="bk-modal-title">Backup contents</div>
                        <div class="bk-modal-sub">
                            @PhilippineTime.ToPhilippineTime(_contentsFor.CreatedAtUtc).ToString("MMM d, yyyy · h:mm tt") · by @_contentsFor.CreatedBy
                        </div>
                    </div>
                    <button class="bk-modal-close" @onclick="CloseBackupContents" aria-label="Close">
                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                    </button>
                </div>
                <div class="bk-modal-body">
                    @if (_rowsTable is not null)
                    {
                        <!-- Drilled-in: the actual records of one table -->
                        <button class="bk-back" type="button" @onclick="BackToContents">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6" /></svg>
                            Back to contents
                        </button>
                        <div class="bk-rows-title">@_rowsDisplayName</div>

                        @if (_rowsLoading)
                        {
                            <div class="hist-loading"><span class="set-spinner"></span></div>
                        }
                        else if (_rowsError is not null)
                        {
                            <div class="bk-alert bk-alert-err" role="alert">@_rowsError</div>
                        }
                        else if (_rows is not null)
                        {
                            <div class="bk-contents-note">
                                @if (_rows.Truncated)
                                {
                                    <text>Showing the first @_rows.Rows.Count.ToString("N0") of @_rows.TotalRows.ToString("N0") records.</text>
                                }
                                else
                                {
                                    <text>@_rows.TotalRows.ToString("N0") record@(_rows.TotalRows == 1 ? "" : "s").</text>
                                }
                            </div>
                            @if (_rows.Columns.Count == 0)
                            {
                                <div class="bk-empty"><div class="bk-empty-text">This table has no records in the backup.</div></div>
                            }
                            else
                            {
                                <div class="bk-grid-scroll">
                                    <table class="set-table bk-table bk-grid">
                                        <thead>
                                            <tr>@foreach (var c in _rows.Columns) { <th>@c</th> }</tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var row in _rows.Rows)
                                            {
                                                <tr>
                                                    @foreach (var val in row)
                                                    {
                                                        <td title="@val">@(string.IsNullOrEmpty(val) ? "—" : val)</td>
                                                    }
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        }
                    }
                    else
                    {
                        <div class="bk-contents-summary">
                            <div class="bk-contents-stat"><span class="bk-contents-num">@_contentsFor.RowCount.ToString("N0")</span><span class="bk-contents-lbl">Records</span></div>
                            <div class="bk-contents-stat"><span class="bk-contents-num">@_contentsFor.TableCount</span><span class="bk-contents-lbl">Tables with data</span></div>
                            <div class="bk-contents-stat"><span class="bk-contents-num">@FormatSize(_contentsFor.SizeBytes)</span><span class="bk-contents-lbl">File size</span></div>
                        </div>

                        @if (_contentsLoading)
                        {
                            <div class="hist-loading"><span class="set-spinner"></span></div>
                        }
                        else if (_contentsError is not null)
                        {
                            <div class="bk-alert bk-alert-err" role="alert">@_contentsError</div>
                        }
                        else if (_contents is not null)
                        {
                            <div class="bk-contents-note">Every table saved in this backup and how many records it holds. Click a table with records to view its exact data. A restore replaces your municipality's data with these records.</div>
                            <table class="set-table bk-table bk-contents-table">
                                <thead>
                                    <tr><th>Table</th><th class="set-th-r">Records</th><th class="set-th-r"></th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var t in _contents.Tables)
                                    {
                                        <tr class="@(t.RowCount == 0 ? "bk-contents-empty" : "bk-rowlink")" @onclick="() => ViewTableRows(t)">
                                            <td>@t.DisplayName</td>
                                            <td class="set-td-r">@t.RowCount.ToString("N0")</td>
                                            <td class="set-td-r">@if (t.RowCount > 0) { <span class="bk-view-rows">View&nbsp;→</span> }</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    }
                </div>
                <div class="bk-modal-foot">
                    <button class="bk-btn bk-btn-ghost" @onclick="() => DownloadBackupAsync(_contentsFor.Id)" disabled="@_meBusy">Download file</button>
                    <button class="bk-btn bk-btn-primary bk-modal-closebtn" @onclick="CloseBackupContents">Close</button>
                </div>
            </div>
        </div>
    }

    <!-- ── Restore details (per-table breakdown of a past restore) ── -->
    @if (_restoreDetail is not null)
    {
        <div class="bk-modal-overlay" @onclick="CloseRestoreDetail">
            <div class="bk-modal bk-modal-wide" role="dialog" aria-modal="true" aria-label="Restore details" @onclick:stopPropagation="true">
                <div class="bk-modal-head">
                    <div class="bk-modal-titles">
                        <div class="bk-modal-title">Restore details</div>
                        <div class="bk-modal-sub">@PhilippineTime.ToPhilippineTime(_restoreDetail.WhenUtc).ToString("MMM d, yyyy · h:mm tt") · by @_restoreDetail.By</div>
                    </div>
                    <button class="bk-modal-close" @onclick="CloseRestoreDetail" aria-label="Close">
                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                    </button>
                </div>
                <div class="bk-modal-body">
                    <div class="bk-contents-summary">
                        <div class="bk-contents-stat"><span class="bk-contents-num">@_restoreDetail.RowsRestored.ToString("N0")</span><span class="bk-contents-lbl">Records restored</span></div>
                        <div class="bk-contents-stat"><span class="bk-contents-num">@_restoreDetail.TablesRestored</span><span class="bk-contents-lbl">Tables</span></div>
                        <div class="bk-contents-stat"><span class="bk-contents-num">@(_restoreDetail.SnapshotUtc is null ? "—" : PhilippineTime.ToPhilippineTime(_restoreDetail.SnapshotUtc.Value).ToString("MMM d · h:mm tt"))</span><span class="bk-contents-lbl">From backup dated</span></div>
                    </div>
                    @if (_restoreDetail.Tables is { Count: > 0 })
                    {
                        <div class="bk-contents-note">Records restored into each table.</div>
                        <table class="set-table bk-table bk-contents-table">
                            <thead><tr><th>Table</th><th class="set-th-r">Records restored</th></tr></thead>
                            <tbody>
                                @foreach (var t in _restoreDetail.Tables)
                                {
                                    <tr><td>@t.DisplayName</td><td class="set-td-r">@t.RowCount.ToString("N0")</td></tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="bk-contents-note">@_restoreDetail.Summary</div>
                        <div class="bk-empty"><div class="bk-empty-text">A detailed table breakdown wasn't recorded for this restore.</div></div>
                    }
                </div>
                <div class="bk-modal-foot">
                    <button class="bk-btn bk-btn-primary bk-modal-closebtn" @onclick="CloseRestoreDetail">Close</button>
                </div>
            </div>
        </div>
    }

    <!-- ── Restore-from-stored-backup confirmation ── -->
    @if (_restoreBackup is not null)
    {
        <div class="bk-modal-overlay" @onclick="CloseBackupRestore">
            <div class="bk-modal bk-modal-danger" role="dialog" aria-modal="true" aria-label="Confirm restore from backup" @onclick:stopPropagation="true">
                <div class="bk-modal-head">
                    <div class="bk-modal-titles">
                        <div class="bk-modal-title">Restore from this backup</div>
                        <div class="bk-modal-sub">@PhilippineTime.ToPhilippineTime(_restoreBackup.CreatedAtUtc).ToString("MMM d, yyyy · h:mm tt") · @_restoreBackup.RowCount.ToString("N0") record(s)</div>
                    </div>
                    <button class="bk-modal-close" @onclick="CloseBackupRestore" aria-label="Close" disabled="@_backupRestoring">
                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                    </button>
                </div>
                <div class="bk-modal-body">
                    <div class="bk-warn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                        <div class="bk-warn-text">
                            This replaces <strong>@Branding.Municipality's</strong> current records with this backup. A copy of your
                            current data is downloaded first as a safety net, and the whole restore runs in one transaction —
                            if anything fails, nothing changes. Other municipalities are never affected.
                        </div>
                    </div>
                    <div class="bk-field">
                        <label class="bk-label" for="bk-br-phrase">Type <code>RESTORE</code> to confirm</label>
                        <input id="bk-br-phrase" class="bk-input" type="text" autocomplete="off" placeholder="RESTORE" @bind="_backupPhrase" @bind:event="oninput" disabled="@_backupRestoring" />
                    </div>
                    <div class="bk-field">
                        <label class="bk-label" for="bk-br-pass">Confirm your admin password</label>
                        <input id="bk-br-pass" class="bk-input" type="password" autocomplete="off" placeholder="Password" @bind="_backupPassword" @bind:event="oninput" disabled="@_backupRestoring" />
                    </div>
                    @if (_backupRestoreError is not null)
                    {
                        <div class="bk-alert bk-alert-err" role="alert">@_backupRestoreError</div>
                    }
                </div>
                <div class="bk-modal-foot">
                    <button class="bk-btn bk-btn-ghost bk-modal-closebtn" @onclick="CloseBackupRestore" disabled="@_backupRestoring">Cancel</button>
                    <button class="bk-btn bk-btn-danger" @onclick="RestoreFromBackupAsync" disabled="@(!CanRestoreBackup)">
                        @if (_backupRestoring)
                        {
                            <span class="bk-spin" aria-hidden="true"></span>
                            <span>Restoring…</span>
                        }
                        else
                        {
                            <span>Restore this backup</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- ── Restore confirmation (hard-confirm danger modal) ── -->
    @if (_showRestoreConfirm)
    {
        <div class="bk-modal-overlay" @onclick="CloseRestoreConfirm">
            <div class="bk-modal bk-modal-danger" role="dialog" aria-modal="true" aria-label="Confirm database restore" @onclick:stopPropagation="true">
                <div class="bk-modal-head">
                    <div class="bk-modal-titles">
                        <div class="bk-modal-title">Restore latest backup</div>
                        <div class="bk-modal-sub">This action cannot be undone</div>
                    </div>
                    <button class="bk-modal-close" @onclick="CloseRestoreConfirm" aria-label="Close" disabled="@_restoreSubmitting">
                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                    </button>
                </div>
                <div class="bk-modal-body">
                    <div class="bk-warn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                        <div class="bk-warn-text">
                            This <strong>replaces all current data</strong> with the most recent backup — anything
                            recorded since that backup will be <strong>permanently lost</strong>. A safety backup is
                            taken automatically first. Best run when the system is idle.
                        </div>
                    </div>

                    <div class="bk-field">
                        <label class="bk-label" for="bk-restore-phrase">Type <code>RESTORE</code> to confirm</label>
                        <input id="bk-restore-phrase" class="bk-input" type="text" autocomplete="off"
                               placeholder="RESTORE" @bind="_restorePhrase" @bind:event="oninput"
                               disabled="@_restoreSubmitting" />
                    </div>

                    <div class="bk-field">
                        <label class="bk-label" for="bk-restore-pass">Confirm your admin password</label>
                        <input id="bk-restore-pass" class="bk-input" type="password" autocomplete="off"
                               placeholder="Password" @bind="_restorePassword" @bind:event="oninput"
                               disabled="@_restoreSubmitting" />
                    </div>

                    @if (_restoreError is not null)
                    {
                        <div class="bk-alert bk-alert-err" role="alert">@_restoreError</div>
                    }
                </div>
                <div class="bk-modal-foot">
                    <button class="bk-btn bk-btn-ghost bk-modal-closebtn" @onclick="CloseRestoreConfirm" disabled="@_restoreSubmitting">Cancel</button>
                    <button class="bk-btn bk-btn-danger" @onclick="SubmitRestoreAsync" disabled="@(!CanConfirmRestore || _restoreSubmitting)">
                        @if (_restoreSubmitting)
                        {
                            <span class="bk-spin" aria-hidden="true"></span>
                            <span>Starting restore…</span>
                        }
                        else
                        {
                            <span>Restore now</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- ── Restore instructions (opened from the On-demand card's "Restore help" icon) ── -->
    @if (_showRestore)
    {
        <div class="bk-modal-overlay" @onclick="() => _showRestore = false">
            <div class="bk-modal" role="dialog" aria-modal="true" aria-label="Restoring a backup" @onclick:stopPropagation="true">
                <div class="bk-modal-head">
                    <div class="bk-modal-titles">
                        <div class="bk-modal-title">Restoring a backup</div>
                        <div class="bk-modal-sub">A controlled ops procedure — not performed in-app</div>
                    </div>
                    <button class="bk-modal-close" @onclick="() => _showRestore = false" aria-label="Close">
                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                    </button>
                </div>
                <div class="bk-modal-body">
                    <p class="bk-restore-text">
                        Restores are deliberate, high-impact operations run by an operator, never from this dashboard.
                        There are two supported paths:
                    </p>
                    <div class="bk-restore-step">
                        <div class="bk-restore-step-title">1 · Restore a downloaded backup</div>
                        <div class="bk-restore-step-text">Download the latest backup above, then run <code>pg_restore</code> against the target database:</div>
                        <pre class="bk-code"><code>pg_restore --no-owner --no-privileges --clean --if-exists -d "postgresql://user:pass@@host:5432/dbname?sslmode=require" backup.dump</code></pre>
                    </div>
                    <div class="bk-restore-step">
                        <div class="bk-restore-step-title">2 · Azure point-in-time recovery</div>
                        <div class="bk-restore-step-text">For recovery to a specific moment within the last 7 days, use Azure PITR to provision a restored server, then repoint the app's connection string.</div>
                    </div>
                </div>
                <div class="bk-modal-foot">
                    <button class="bk-btn bk-btn-ghost bk-modal-closebtn" @onclick="() => _showRestore = false">Close</button>
                </div>
            </div>
        </div>
    }
</div>

@* ── Run pipeline modal ── *@
@if (_logRun is not null)
{
    <div class="bk-modal-overlay" @onclick="CloseLog">
        <div class="bk-modal" role="dialog" aria-modal="true" aria-label="Backup run details" @onclick:stopPropagation="true">

            <div class="bk-modal-head">
                <div class="bk-modal-titles">
                    <div class="bk-modal-title">Backup run</div>
                    <div class="bk-modal-sub">
                        <span>@TriggerLabel(_logRun.Event)</span>
                        <span class="bk-modal-dot">•</span>
                        <span>@PhilippineTime.ToPhilippineTime(_logRun.CreatedAt).ToString("MMM d, yyyy · h:mm tt")</span>
                    </div>
                </div>
                @if (LogIsLive)
                {
                    <span class="bk-live" title="Updating live"><span class="bk-live-dot"></span>Live</span>
                }
                <span class="bk-pill @LivePillClass() bk-modal-pill">@LiveStatusLabel()</span>
                <button class="bk-modal-close" @onclick="CloseLog" aria-label="Close">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>

            <div class="bk-modal-body">
                @if (_logLoading)
                {
                    <div class="bk-steps">
                        @for (var i = 0; i < 5; i++)
                        {
                            <div class="bk-step bk-step-sk">
                                <span class="bk-step-rail"></span>
                                <span class="sk bk-step-dot-sk"></span>
                                <span class="sk bk-sk-line"></span>
                                <span class="sk bk-sk-short"></span>
                            </div>
                        }
                    </div>
                }
                else if (_logError is not null)
                {
                    <div class="bk-empty">
                        <div class="bk-empty-title">Couldn't load this run</div>
                        <div class="bk-empty-text">@_logError</div>
                    </div>
                }
                else if (_logDetail is null || _logDetail.Steps.Count == 0)
                {
                    <div class="bk-empty">
                        <div class="bk-empty-title">No steps to show</div>
                        <div class="bk-empty-text">This run hasn't reported any steps yet.</div>
                    </div>
                }
                else
                {
                    <ol class="bk-steps">
                        @foreach (var step in _logDetail.Steps)
                        {
                            <li class="bk-step">
                                <span class="bk-step-rail"></span>
                                <span class="bk-step-dot @StepDotClass(step)">
                                    @if (StepIsSuccess(step))
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                    }
                                    else if (StepIsFailure(step))
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                                    }
                                </span>
                                <span class="bk-step-name">@step.Name</span>
                                <span class="bk-step-dur">@StepDuration(step)</span>
                            </li>
                        }
                    </ol>
                }
            </div>

            <div class="bk-modal-foot">
                @if (!string.IsNullOrWhiteSpace(_logRun.HtmlUrl))
                {
                    <a class="bk-modal-github" href="@_logRun.HtmlUrl" target="_blank" rel="noopener">Open on GitHub<span class="set-link-arrow">→</span></a>
                }
                <button class="bk-btn bk-btn-ghost bk-modal-closebtn" @onclick="CloseLog">Close</button>
            </div>
        </div>
    </div>
}

@* ── Toast (top-right notifications for backup actions) ── *@
@if (_message is not null)
{
    <div class="bk-toast-wrap">
        <div class="bk-toast @(_messageOk ? "bk-toast-ok" : "bk-toast-err")" role="status" aria-live="polite">
            <span class="bk-toast-ico">
                @if (_messageOk)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                }
            </span>
            <span class="bk-toast-msg">@_message</span>
            <button class="bk-toast-x" @onclick="DismissToast" aria-label="Dismiss">
                <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
            </button>
        </div>
    </div>
}

@code {
    private readonly DateTime _now = PhilippineTime.Now;

    private bool _isOperator;

    // ── Per-municipality (own LGU) backup & restore ──
    private bool _meBusy;                       // export / download-restore-point in flight
    private bool _showMineRestore;
    private bool _mineRestoring;
