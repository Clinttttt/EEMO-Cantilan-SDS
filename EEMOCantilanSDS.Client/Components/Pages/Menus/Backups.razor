    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var isSuperAdmin = state.User.IsInRole("SuperAdmin")
            || state.User.Claims.Any(c => string.Equals(c.Value, "SuperAdmin", StringComparison.OrdinalIgnoreCase)
                && c.Type.Contains("role", StringComparison.OrdinalIgnoreCase));
        if (!isSuperAdmin)   // Heads only (the [Authorize] also enforces this)
        {
            Nav.NavigateTo("/menu", replace: true);
            return;
        }

        // Every LGU Head uses the per-municipality section below. Whole-database backup/restore stays
        // platform-operator (Cantilan Head) only — those API calls are PlatformOperator-gated, so only load
        // them for the operator (a per-LGU Head would just get 403s).
        var municipality = state.User.Claims.FirstOrDefault(c => c.Type == "municipality")?.Value;
        _isOperator = string.Equals(municipality, "cantilan-sds", StringComparison.OrdinalIgnoreCase);

        if (_isOperator)
        {
            await LoadRunsAsync();
            await LoadRestoreRunsAsync();
        }

        // Every Head gets their own scoped stored-backup history + restore log.
        await LoadBackupsAsync();
        await LoadRestoreHistoryAsync();
    }

