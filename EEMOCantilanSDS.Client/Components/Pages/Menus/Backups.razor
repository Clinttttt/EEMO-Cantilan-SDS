@page "/settings/backups"
@using Microsoft.AspNetCore.Authorization
@using EEMOCantilanSDS.Application.Dtos.Backup
@using EEMOCantilanSDS.Domain.Common
@attribute [Authorize(Roles = "SuperAdmin")]
@rendermode InteractiveServer
@inject IBackupApiClient BackupApi
@inject IJSRuntime JS
@implements IDisposable

@*
    Backups — Head-only (SuperAdmin) on-demand database backups.
    Everything is proxied through api/backup/*: the page triggers the GitHub Actions backup workflow,
    lists recent runs, and downloads the latest artifact. The GitHub token lives strictly server-side
    and is never sent to or reachable by the browser. No in-app restore/upload — restore is a
    documented, controlled ops procedure only.
*@

<PageTitle>EEMO Admin — Backups</PageTitle>

<header class="topbar">
    <div class="topbar-left">
        <div class="topbar-title">Backups</div>
        <div class="topbar-breadcrumb">
            <span>EEMO Admin</span>
            <span class="breadcrumb-sep">/</span>
            <span>Settings</span>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Backups</span>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @_now.ToString("MMMM d, yyyy")
        </div>
        <AccountChip />
    </div>
</header>

<div class="content-area">

    <!-- ── How backups work ── -->
    <section class="set-card">
        <div class="set-card-head">
            <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" /><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3" /></svg></div>
            <div class="set-card-titles">
                <div class="set-card-title">Database backups</div>
                <div class="set-card-sub">How your data is protected</div>
            </div>
        </div>
        <div class="bk-info-grid">
            <div class="bk-info">
                <div class="bk-info-key">Automated daily</div>
                <div class="bk-info-val">A full backup runs every day at <strong>01:00 Philippine time</strong> via CI.</div>
            </div>
            <div class="bk-info">
                <div class="bk-info-key">Point-in-time recovery</div>
                <div class="bk-info-val"><strong>7-day Azure PITR</strong> lets ops restore to any moment in the last week.</div>
            </div>
            <div class="bk-info">
                <div class="bk-info-key">This page</div>
                <div class="bk-info-val">Run an <strong>on-demand backup</strong> now and download the latest backup file.</div>
            </div>
        </div>
    </section>

    <!-- ── On-demand actions ── -->
    <section class="set-card">
        <div class="set-card-head">
            <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7" /><polyline points="21 3 21 9 15 9" /></svg></div>
            <div class="set-card-titles">
                <div class="set-card-title">On-demand backup</div>
                <div class="set-card-sub">Trigger a backup or download the most recent one</div>
            </div>
            <button class="bk-info-btn" type="button" @onclick="() => _showRestore = true"
                    title="How to restore a backup" aria-label="Restore instructions">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg>
                <span>Restore help</span>
            </button>
        </div>

        <div class="bk-actions">
            <button class="bk-btn bk-btn-primary" @onclick="RunBackupAsync" disabled="@(_running || _downloading)">
                @if (_running)
                {
                    <span class="bk-spin" aria-hidden="true"></span>
                    <span>Starting backup…</span>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7" /><polyline points="21 3 21 9 15 9" /></svg>
                    <span>Run backup now</span>
                }
            </button>

            <button class="bk-btn bk-btn-ghost" @onclick="DownloadLatestAsync" disabled="@(_running || _downloading)">
                @if (_downloading)
                {
                    <span class="bk-spin bk-spin-dark" aria-hidden="true"></span>
                    <span>Preparing download…</span>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                    <span>Download latest backup</span>
                }
            </button>
        </div>
    </section>

    <!-- ── Recent backups ── -->
    <section class="set-card">
        <div class="set-card-head">
            <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg></div>
            <div class="set-card-titles">
                <div class="set-card-title">Recent backups</div>
                <div class="set-card-sub">The latest backup runs</div>
            </div>
            <button class="set-link bk-refresh" @onclick="LoadRunsAsync" disabled="@_loadingRuns">Refresh<span class="set-link-arrow">↻</span></button>
        </div>

        @if (_loadingRuns)
        {
            <div class="bk-rows">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="bk-run bk-run-sk">
                        <div class="sk bk-sk-pill"></div>
                        <div class="sk bk-sk-line"></div>
                        <div class="sk bk-sk-short"></div>
                    </div>
                }
            </div>
        }
        else if (_runsError is not null)
        {
            <div class="bk-empty">
                <div class="bk-empty-title">Couldn't load recent backups</div>
                <div class="bk-empty-text">@_runsError</div>
                <button class="set-retry" @onclick="LoadRunsAsync">Try again</button>
            </div>
        }
        else if (_runs is null || _runs.Count == 0)
        {
            <div class="bk-empty">
                <div class="bk-empty-title">No backups yet</div>
                <div class="bk-empty-text">Once a backup runs, it will appear here.</div>
            </div>
        }
        else
        {
            <table class="set-table bk-table">
                <thead>
                    <tr><th>When (PH time)</th><th>Trigger</th><th>Status</th><th class="set-th-r">Details</th></tr>
                </thead>
                <tbody>
                    @foreach (var run in _runs)
                    {
                        <tr>
                            <td>@PhilippineTime.ToPhilippineTime(run.CreatedAt).ToString("MMM d, yyyy · h:mm tt")</td>
                            <td>@TriggerLabel(run.Event)</td>
                            <td><span class="bk-pill @PillClass(run)">@StatusLabel(run)</span></td>
                            <td class="set-td-r">
                                <button class="set-link bk-viewlog" @onclick="() => OpenLog(run)">View log<span class="set-link-arrow">→</span></button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <!-- ── Danger zone: destructive restore ── -->
    <section class="bk-danger">
        <div class="bk-danger-head">
            <div class="bk-danger-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
            </div>
            <div class="bk-danger-titles">
                <div class="bk-danger-title">Danger zone</div>
                <div class="bk-danger-sub">Irreversible operation — restores the entire database</div>
            </div>
        </div>
        <div class="bk-danger-body">
            <div class="bk-danger-copy">
                <div class="bk-danger-copy-title">Restore latest backup</div>
                <div class="bk-danger-copy-text">
                    Replaces <strong>all current data</strong> with the most recent backup. A safety backup is
                    taken automatically first. Best run when the system is idle. Requires re-authentication.
                </div>
            </div>
            <button class="bk-btn bk-btn-danger" type="button" @onclick="OpenRestoreConfirm">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M3 2v6h6" /><path d="M3 13a9 9 0 1 0 3-7.7L3 8" /></svg>
                <span>Restore latest backup</span>
            </button>
        </div>
    </section>

    <!-- ── Restore confirmation (hard-confirm danger modal) ── -->
    @if (_showRestoreConfirm)
    {
        <div class="bk-modal-overlay" @onclick="CloseRestoreConfirm">
            <div class="bk-modal bk-modal-danger" role="dialog" aria-modal="true" aria-label="Confirm database restore" @onclick:stopPropagation="true">
                <div class="bk-modal-head">
                    <div class="bk-modal-titles">
                        <div class="bk-modal-title">Restore latest backup</div>
                        <div class="bk-modal-sub">This action cannot be undone</div>
                    </div>
                    <button class="bk-modal-close" @onclick="CloseRestoreConfirm" aria-label="Close" disabled="@_restoreSubmitting">
                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                    </button>
                </div>
                <div class="bk-modal-body">
                    <div class="bk-warn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                        <div class="bk-warn-text">
                            This <strong>replaces all current data</strong> with the most recent backup — anything
                            recorded since that backup will be <strong>permanently lost</strong>. A safety backup is
                            taken automatically first. Best run when the system is idle.
                        </div>
                    </div>

                    <div class="bk-field">
                        <label class="bk-label" for="bk-restore-phrase">Type <code>RESTORE</code> to confirm</label>
                        <input id="bk-restore-phrase" class="bk-input" type="text" autocomplete="off"
                               placeholder="RESTORE" @bind="_restorePhrase" @bind:event="oninput"
                               disabled="@_restoreSubmitting" />
                    </div>

                    <div class="bk-field">
                        <label class="bk-label" for="bk-restore-pass">Confirm your admin password</label>
                        <input id="bk-restore-pass" class="bk-input" type="password" autocomplete="off"
                               placeholder="Password" @bind="_restorePassword" @bind:event="oninput"
                               disabled="@_restoreSubmitting" />
                    </div>

                    @if (_restoreError is not null)
                    {
                        <div class="bk-alert bk-alert-err" role="alert">@_restoreError</div>
                    }
                </div>
                <div class="bk-modal-foot">
                    <button class="bk-btn bk-btn-ghost bk-modal-closebtn" @onclick="CloseRestoreConfirm" disabled="@_restoreSubmitting">Cancel</button>
                    <button class="bk-btn bk-btn-danger" @onclick="SubmitRestoreAsync" disabled="@(!CanConfirmRestore || _restoreSubmitting)">
                        @if (_restoreSubmitting)
                        {
                            <span class="bk-spin" aria-hidden="true"></span>
                            <span>Starting restore…</span>
                        }
                        else
                        {
                            <span>Restore now</span>
                        }
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- ── Restore instructions (opened from the On-demand card's "Restore help" icon) ── -->
    @if (_showRestore)
    {
        <div class="bk-modal-overlay" @onclick="() => _showRestore = false">
            <div class="bk-modal" role="dialog" aria-modal="true" aria-label="Restoring a backup" @onclick:stopPropagation="true">
                <div class="bk-modal-head">
                    <div class="bk-modal-titles">
                        <div class="bk-modal-title">Restoring a backup</div>
                        <div class="bk-modal-sub">A controlled ops procedure — not performed in-app</div>
                    </div>
                    <button class="bk-modal-close" @onclick="() => _showRestore = false" aria-label="Close">
                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                    </button>
                </div>
                <div class="bk-modal-body">
                    <p class="bk-restore-text">
                        Restores are deliberate, high-impact operations run by an operator, never from this dashboard.
                        There are two supported paths:
                    </p>
                    <div class="bk-restore-step">
                        <div class="bk-restore-step-title">1 · Restore a downloaded backup</div>
                        <div class="bk-restore-step-text">Download the latest backup above, then run <code>pg_restore</code> against the target database:</div>
                        <pre class="bk-code"><code>pg_restore --no-owner --no-privileges --clean --if-exists -d "postgresql://user:pass@@host:5432/dbname?sslmode=require" backup.dump</code></pre>
                    </div>
                    <div class="bk-restore-step">
                        <div class="bk-restore-step-title">2 · Azure point-in-time recovery</div>
                        <div class="bk-restore-step-text">For recovery to a specific moment within the last 7 days, use Azure PITR to provision a restored server, then repoint the app's connection string.</div>
                    </div>
                </div>
                <div class="bk-modal-foot">
                    <button class="bk-btn bk-btn-ghost bk-modal-closebtn" @onclick="() => _showRestore = false">Close</button>
                </div>
            </div>
        </div>
    }
</div>

@* ── Run pipeline modal ── *@
@if (_logRun is not null)
{
    <div class="bk-modal-overlay" @onclick="CloseLog">
        <div class="bk-modal" role="dialog" aria-modal="true" aria-label="Backup run details" @onclick:stopPropagation="true">

            <div class="bk-modal-head">
                <div class="bk-modal-titles">
                    <div class="bk-modal-title">Backup run</div>
                    <div class="bk-modal-sub">
                        <span>@TriggerLabel(_logRun.Event)</span>
                        <span class="bk-modal-dot">•</span>
                        <span>@PhilippineTime.ToPhilippineTime(_logRun.CreatedAt).ToString("MMM d, yyyy · h:mm tt")</span>
                    </div>
                </div>
                @if (LogIsLive)
                {
                    <span class="bk-live" title="Updating live"><span class="bk-live-dot"></span>Live</span>
                }
                <span class="bk-pill @LivePillClass() bk-modal-pill">@LiveStatusLabel()</span>
                <button class="bk-modal-close" @onclick="CloseLog" aria-label="Close">
                    <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                </button>
            </div>

            <div class="bk-modal-body">
                @if (_logLoading)
                {
                    <div class="bk-steps">
                        @for (var i = 0; i < 5; i++)
                        {
                            <div class="bk-step bk-step-sk">
                                <span class="bk-step-rail"></span>
                                <span class="sk bk-step-dot-sk"></span>
                                <span class="sk bk-sk-line"></span>
                                <span class="sk bk-sk-short"></span>
                            </div>
                        }
                    </div>
                }
                else if (_logError is not null)
                {
                    <div class="bk-empty">
                        <div class="bk-empty-title">Couldn't load this run</div>
                        <div class="bk-empty-text">@_logError</div>
                    </div>
                }
                else if (_logDetail is null || _logDetail.Steps.Count == 0)
                {
                    <div class="bk-empty">
                        <div class="bk-empty-title">No steps to show</div>
                        <div class="bk-empty-text">This run hasn't reported any steps yet.</div>
                    </div>
                }
                else
                {
                    <ol class="bk-steps">
                        @foreach (var step in _logDetail.Steps)
                        {
                            <li class="bk-step">
                                <span class="bk-step-rail"></span>
                                <span class="bk-step-dot @StepDotClass(step)">
                                    @if (StepIsSuccess(step))
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                    }
                                    else if (StepIsFailure(step))
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                                    }
                                </span>
                                <span class="bk-step-name">@step.Name</span>
                                <span class="bk-step-dur">@StepDuration(step)</span>
                            </li>
                        }
                    </ol>
                }
            </div>

            <div class="bk-modal-foot">
                @if (!string.IsNullOrWhiteSpace(_logRun.HtmlUrl))
                {
                    <a class="bk-modal-github" href="@_logRun.HtmlUrl" target="_blank" rel="noopener">Open on GitHub<span class="set-link-arrow">→</span></a>
                }
                <button class="bk-btn bk-btn-ghost bk-modal-closebtn" @onclick="CloseLog">Close</button>
            </div>
        </div>
    </div>
}

@* ── Toast (top-right notifications for backup actions) ── *@
@if (_message is not null)
{
    <div class="bk-toast-wrap">
        <div class="bk-toast @(_messageOk ? "bk-toast-ok" : "bk-toast-err")" role="status" aria-live="polite">
            <span class="bk-toast-ico">
                @if (_messageOk)
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                }
                else
                {
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                }
            </span>
            <span class="bk-toast-msg">@_message</span>
            <button class="bk-toast-x" @onclick="DismissToast" aria-label="Dismiss">
                <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
            </button>
        </div>
    </div>
}

@code {
    private readonly DateTime _now = PhilippineTime.Now;

    private IReadOnlyList<BackupRunDto>? _runs;
    private bool _loadingRuns = true;
    private string? _runsError;

    private bool _running;
    private bool _downloading;
    private string? _message;
    private bool _messageOk;
    private bool _showRestore;                        // restore-instructions modal
    private CancellationTokenSource? _toastCts;       // auto-dismiss timer for the toast

    // Destructive restore confirmation modal
    private bool _showRestoreConfirm;
    private string _restorePhrase = string.Empty;
    private string _restorePassword = string.Empty;
    private bool _restoreSubmitting;
    private string? _restoreError;

    private bool CanConfirmRestore =>
        string.Equals(_restorePhrase.Trim(), "RESTORE", StringComparison.Ordinal)
        && !string.IsNullOrEmpty(_restorePassword);

    // Run pipeline modal
    private BackupRunDto? _logRun;
    private BackupRunDetailDto? _logDetail;
    private bool _logLoading;
    private string? _logError;
    private CancellationTokenSource? _logPollCts;   // drives live auto-refresh while a run is in progress

    protected override async Task OnInitializedAsync() => await LoadRunsAsync();

    private async Task LoadRunsAsync()
    {
        _loadingRuns = true;
        _runsError = null;
        await InvokeAsync(StateHasChanged);

        var result = await BackupApi.GetRecentRunsAsync();
        if (result.IsSuccess && result.Value is not null)
        {
            _runs = result.Value;
        }
        else
        {
            _runsError = string.IsNullOrWhiteSpace(result.Error)
                ? "Recent backups could not be retrieved."
                : result.Error;
        }

        _loadingRuns = false;
    }

    private async Task RunBackupAsync()
    {
        _running = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        var result = await BackupApi.TriggerBackupAsync();
        if (result.IsSuccess)
        {
            await ShowToastAsync(true, "Backup started. It may take a minute to appear below.");
            _running = false;
            // Give GitHub a moment to register the run, then refresh the list.
            await Task.Delay(4000);
            await LoadRunsAsync();
            return;
        }

        await ShowToastAsync(false, string.IsNullOrWhiteSpace(result.Error)
            ? "The backup could not be started. Please try again."
            : result.Error);
        _running = false;
    }

    private async Task DownloadLatestAsync()
    {
        _downloading = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        var result = await BackupApi.GetLatestAsync();
        if (result.IsSuccess && result.Value is not null)
        {
            var artifact = result.Value;
            await JS.InvokeVoidAsync("downloadFileFromBytes",
                artifact.FileName, Convert.ToBase64String(artifact.Content), artifact.ContentType);
            await ShowToastAsync(true, $"Downloading {artifact.FileName}.");
        }
        else
        {
            await ShowToastAsync(false, string.IsNullOrWhiteSpace(result.Error)
                ? "No backup is available to download yet."
                : result.Error);
        }

        _downloading = false;
    }

    // ── Destructive restore ──
    private void OpenRestoreConfirm()
    {
        _restorePhrase = string.Empty;
        _restorePassword = string.Empty;
        _restoreError = null;
        _restoreSubmitting = false;
        _showRestoreConfirm = true;
    }

    private void CloseRestoreConfirm()
    {
        if (_restoreSubmitting) return;   // don't close mid-flight
        _showRestoreConfirm = false;
        _restoreError = null;
        _restorePassword = string.Empty;  // always clear the password when the modal closes
    }

    private async Task SubmitRestoreAsync()
    {
        if (!CanConfirmRestore || _restoreSubmitting) return;

        _restoreSubmitting = true;
        _restoreError = null;
        await InvokeAsync(StateHasChanged);

        // The confirmation phrase and password are ALSO re-verified server-side; this is just the UX gate.
        var result = await BackupApi.TriggerRestoreAsync(_restorePhrase, _restorePassword);

        if (result.IsSuccess)
        {
            _showRestoreConfirm = false;
            _restorePassword = string.Empty;      // clear the password on success
            _restoreSubmitting = false;
            await ShowToastAsync(true, "Restore started — the run will appear below.");
            await LoadRunsAsync();                 // surface the restore run in the list (it polls live)
            return;
        }

        // Failure: keep the modal open, show the error inline, do NOT clear the password.
        _restoreError = string.IsNullOrWhiteSpace(result.Error)
            ? "The restore could not be started. Please try again."
            : result.Error;
        _restoreSubmitting = false;
    }

    private async Task OpenLog(BackupRunDto run)
    {
        _logPollCts?.Cancel();          // stop any previous run's polling
        _logRun = run;
        _logDetail = null;
        _logError = null;
        _logLoading = true;
        await InvokeAsync(StateHasChanged);

        await RefreshLogAsync(run.Id);
        _logLoading = false;
        await InvokeAsync(StateHasChanged);

        // Live: if the run is still queued/in-progress, auto-refresh until it finishes.
        if (_logRun is not null && !IsTerminal(_logDetail))
            _ = PollLogAsync(run.Id);
    }

    // Re-fetch the run detail. Keeps showing the last good data if a single poll transiently fails.
    private async Task RefreshLogAsync(long runId)
    {
        var result = await BackupApi.GetRunDetailAsync(runId);
        if (result.IsSuccess && result.Value is not null)
        {
            _logDetail = result.Value;
            _logError = null;
        }
        else if (_logDetail is null)
        {
            _logError = string.IsNullOrWhiteSpace(result.Error)
                ? "The run details could not be retrieved."
                : result.Error;
        }
    }

    // Poll every 3s while the modal shows this run and it hasn't concluded. Safety-capped at ~10 min.
    private async Task PollLogAsync(long runId)
    {
        var cts = new CancellationTokenSource();
        _logPollCts = cts;
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(3));
            var ticks = 0;
            while (await timer.WaitForNextTickAsync(cts.Token))
            {
                if (_logRun is null || _logRun.Id != runId) break;   // modal closed or switched runs
                await RefreshLogAsync(runId);
                await InvokeAsync(StateHasChanged);

                if (IsTerminal(_logDetail))
                {
                    await LoadRunsAsync();               // reflect the final status in the list too
                    await InvokeAsync(StateHasChanged);
                    break;
                }
                if (++ticks >= 200) break;               // ~10 min hard stop
            }
        }
        catch (OperationCanceledException) { /* closed / switched */ }
        catch { /* transient failure — stop polling quietly, last data stays shown */ }
    }

    private static bool IsTerminal(BackupRunDetailDto? d) =>
        d is not null && string.Equals(d.Status, "completed", StringComparison.OrdinalIgnoreCase);

    private bool LogIsLive => _logRun is not null && _logDetail is not null && !IsTerminal(_logDetail);

    private void CloseLog()
    {
        _logPollCts?.Cancel();
        _logPollCts = null;
        _logRun = null;
        _logDetail = null;
        _logError = null;
        _logLoading = false;
    }

    // Toast: show a top-right notification and auto-dismiss it after a few seconds.
    private async Task ShowToastAsync(bool ok, string message)
    {
        _messageOk = ok;
        _message = message;
        _toastCts?.Cancel();
        var cts = new CancellationTokenSource();
        _toastCts = cts;
        await InvokeAsync(StateHasChanged);
        _ = DismissAfterAsync(cts.Token);
    }

    private async Task DismissAfterAsync(CancellationToken ct)
    {
        try
        {
            await Task.Delay(TimeSpan.FromSeconds(5), ct);
            _message = null;
            await InvokeAsync(StateHasChanged);
        }
        catch (OperationCanceledException) { /* replaced or dismissed */ }
    }

    private void DismissToast()
    {
        _toastCts?.Cancel();
        _message = null;
    }

    public void Dispose()
    {
        _logPollCts?.Cancel();
        _logPollCts?.Dispose();
        _toastCts?.Cancel();
        _toastCts?.Dispose();
    }

    private static bool StepIsSuccess(BackupStepDto step) =>
        string.Equals(step.Conclusion, "success", StringComparison.OrdinalIgnoreCase);

    private static bool StepIsFailure(BackupStepDto step) =>
        step.Conclusion is "failure" or "cancelled" or "timed_out";

    private static string StepDotClass(BackupStepDto step)
    {
        if (StepIsSuccess(step)) return "bk-step-ok";
        if (StepIsFailure(step)) return "bk-step-err";
        if (string.Equals(step.Status, "completed", StringComparison.OrdinalIgnoreCase))
            return "bk-step-neutral"; // skipped / neutral
        return "bk-step-run"; // queued / in_progress
    }

    private static string StepDuration(BackupStepDto step)
    {
        if (step.StartedAt is null || step.CompletedAt is null)
            return string.Empty;

        var span = step.CompletedAt.Value - step.StartedAt.Value;
        if (span < TimeSpan.Zero) return string.Empty;

        var totalSeconds = (int)Math.Round(span.TotalSeconds);
        if (totalSeconds < 60)
            return $"{totalSeconds}s";

        var minutes = totalSeconds / 60;
        var seconds = totalSeconds % 60;
        return $"{minutes}m {seconds:D2}s";
    }

    private static string TriggerLabel(string? evt) => evt switch
    {
        "schedule" => "Scheduled",
        "workflow_dispatch" => "Manual",
        null or "" => "—",
        _ => char.ToUpper(evt[0]) + evt[1..]
    };

    private static string StatusLabel(BackupRunDto run) => StatusLabelFor(run.Status, run.Conclusion);

    private static string StatusLabelFor(string status, string? conclusion)
    {
        if (string.Equals(status, "completed", StringComparison.OrdinalIgnoreCase))
            return conclusion switch
            {
                "success" => "Success",
                "failure" => "Failed",
                "cancelled" => "Cancelled",
                null or "" => "Completed",
                _ => char.ToUpper(conclusion[0]) + conclusion[1..]
            };

        return status switch
        {
            "in_progress" => "In progress",
            "queued" => "Queued",
            "" => "Unknown",
            _ => char.ToUpper(status[0]) + status[1..]
        };
    }

    private static string PillClass(BackupRunDto run) => PillClassFor(run.Status, run.Conclusion);

    private static string PillClassFor(string status, string? conclusion)
    {
        if (string.Equals(status, "completed", StringComparison.OrdinalIgnoreCase))
            return conclusion switch
            {
                "success" => "bk-pill-ok",
                "failure" or "cancelled" or "timed_out" => "bk-pill-err",
                _ => "bk-pill-warn"
            };

        // queued / in_progress / anything not yet concluded.
        return "bk-pill-warn";
    }

    // Modal pill/label — prefer the live detail (updated by polling) over the initial list row.
    private string LiveStatusLabel() =>
        _logDetail is not null ? StatusLabelFor(_logDetail.Status, _logDetail.Conclusion)
        : _logRun is not null ? StatusLabel(_logRun) : "";

    private string LivePillClass() =>
        _logDetail is not null ? PillClassFor(_logDetail.Status, _logDetail.Conclusion)
        : _logRun is not null ? PillClass(_logRun) : "bk-pill-warn";
}
