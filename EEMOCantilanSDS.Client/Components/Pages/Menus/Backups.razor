    private static bool RunIsTerminal(BackupRunDto r) =>
        string.Equals(r.Status, "completed", StringComparison.OrdinalIgnoreCase);

    private bool AnyRunActive() =>
        (_runs?.Any(r => !RunIsTerminal(r)) ?? false) || (_restoreRuns?.Any(r => !RunIsTerminal(r)) ?? false);

    // While any backup/restore run is still queued or in progress, silently re-fetch both lists every
    // 5s so their status updates on their own (no need to open the log or hit Refresh). Stops when all
    // runs have settled, after ~10 minutes, or on dispose.
    private void MaybeStartListPolling()
    {
        if (_listPollCts is not null || (!AnyRunActive() && _restoreWatchSince is null)) return;
        var cts = new CancellationTokenSource();
        _listPollCts = cts;
        _ = PollListsAsync(cts.Token);
    }

    private async Task PollListsAsync(CancellationToken ct)
    {
        try
        {
            using var timer = new PeriodicTimer(TimeSpan.FromSeconds(5));
            var ticks = 0;
            while (await timer.WaitForNextTickAsync(ct))
            {
                await LoadRunsAsync(silent: true);
                await LoadRestoreRunsAsync(silent: true);
                // Once the triggered restore's run has appeared (now tracked by AnyRunActive), drop the
                // pre-appearance watch so the poll settles normally when the run finishes.
                if (_restoreWatchSince is not null && AnyRunActive()) _restoreWatchSince = null;
                await InvokeAsync(StateHasChanged);
                if ((!AnyRunActive() && _restoreWatchSince is null) || ++ticks >= 240) break;
            }
        }
        catch (OperationCanceledException) { }
        catch { /* stop quietly */ }
        finally { _listPollCts = null; }
    }

    private async Task RunBackupAsync()
    {
        _running = true;
        _message = null;
        await InvokeAsync(StateHasChanged);

        var result = await BackupApi.TriggerBackupAsync();
        if (result.IsSuccess)
        {
            await ShowToastAsync(true, "Backup started. It may take a minute to appear below.");
            _running = false;
            // Give GitHub a moment to register the run, then refresh the list.
            await Task.Delay(4000);
            await LoadRunsAsync();
            return;
        }

        await ShowToastAsync(false, string.IsNullOrWhiteSpace(result.Error)
            ? "The backup could not be started. Please try again."
            : result.Error);
        _running = false;
    }

