    private async Task OnMineFileSelected(InputFileChangeEventArgs e)
    {
        _mineError = null;
        _mineUpload = null;
        _mineUploadName = null;
        var file = e.File;
        if (file is null) return;
        if (file.Size > MineMaxUpload) { _mineError = "That file is too large to be a valid restore point."; return; }
        try
        {
            using var ms = new MemoryStream();
            await file.OpenReadStream(MineMaxUpload).CopyToAsync(ms);
            _mineUpload = ms.ToArray();
            _mineUploadName = file.Name;
        }
        catch { _mineError = "Couldn't read the selected file."; }
    }

    private async Task RestoreMineAsync()
    {
        if (!CanRestoreMine) return;
        _mineRestoring = true;
        _mineError = null;
        try
        {
            // Safety net: always download the CURRENT state before overwriting it.
            var safety = await TenantUsageApi.DownloadRestoreSnapshotAsync();
            if (safety.IsSuccess && safety.Value is not null)
                await JS.InvokeVoidAsync("downloadFileFromBytes",
                    "before-restore-" + safety.Value.FileName,
                    Convert.ToBase64String(safety.Value.Content), safety.Value.ContentType);

            var req = new TenantRestoreRequest(Convert.ToBase64String(_mineUpload!), _minePhrase.Trim(), _minePassword);
            var res = await TenantUsageApi.RestoreAsync(req);
            if (res.IsSuccess && res.Value is not null)
            {
                _minePhrase = string.Empty;
                _minePassword = string.Empty;
                _mineUpload = null;
                _mineUploadName = null;
                _showMineRestore = false;
                await ShowToastAsync(true, $"Restored {res.Value.RowsRestored:N0} record(s) across {res.Value.TablesRestored} table(s).");
            }
            else
            {
                _mineError = res.Error ?? "The restore could not be completed.";
            }
        }
        finally { _mineRestoring = false; }
    }

