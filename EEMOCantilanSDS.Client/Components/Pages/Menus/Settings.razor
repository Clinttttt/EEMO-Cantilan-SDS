@page "/settings"
@using Microsoft.AspNetCore.Authorization
@using EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using EEMOCantilanSDS.Application.Dtos.Settings
@using EEMOCantilanSDS.Domain.Common
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@inject ISettingsApiClient SettingsApi
@inject AuthService AuthService
@inject AuthenticationStateProvider AuthState
@inject EEMOCantilanSDS.Client.Services.FacilityState FacilityCatalog

@*
    Settings — read-only system configuration overview.
    Every value is loaded from the API (GetSystemSettings query), which sources them from the live
    domain constants (FeeRates / DomainRules), the office-profile constants and the host environment.
    Nothing here is hardcoded in markup, so the page can never drift from the system's real rules.
    No secrets are exposed; the page does not duplicate Dashboard/Reports/Accounts/facility pages.
*@

<PageTitle>@Branding.OfficeAcronym Admin — Settings</PageTitle>

<header class="topbar">
    <div class="topbar-left">
        <div class="topbar-title">Settings</div>
        <div class="topbar-breadcrumb">
            <span>@Branding.OfficeAcronym Admin</span>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Settings</span>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @_now.ToString("MMMM d, yyyy")
        </div>
        <AccountChip />
    </div>
</header>

<div class="content-area">

    @{
        var loaded = _model is not null;
        var settingsPeriod = _model?.System.ServerDate ?? _now;
    }

    <!-- ── Hero (shell is always visible; only the stat values skeletonize) ── -->
    <div class="vs-hero">
        <div class="vs-hero-left">
            <div class="vs-hero-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="3" />
                    <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 11-2.83 2.83l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 11-2.83-2.83l.06-.06a1.65 1.65 0 00.33-1.82 1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 112.83-2.83l.06.06a1.65 1.65 0 001.82.33H9a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 112.83 2.83l-.06.06a1.65 1.65 0 00-.33 1.82V9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" />
                </svg>
            </div>
            <div>
                <div class="vs-hero-eyebrow">@Branding.OfficeAcronym Admin · System</div>
                <div class="vs-hero-title">Settings</div>
                <div class="vs-hero-sub">System configuration · read-only</div>
            </div>
        </div>
        <div class="vs-hero-stats">
            <div class="vs-hero-stat">
                <div class="vs-hero-val">@(_model?.Facilities.Count ?? 0)</div>
                <div class="vs-hero-key">Facilities</div>
                <div class="vs-hero-sub2">Configured</div>
            </div>
            <div class="vs-hero-divider"></div>
            <div class="vs-hero-stat">
                <div class="vs-hero-val">@(_model?.Security.Roles.Count ?? 0)</div>
                <div class="vs-hero-key">User Roles</div>
                <div class="vs-hero-sub2">@(loaded ? string.Join(" · ", _model!.Security.Roles) : "Role policy")</div>
            </div>
            <div class="vs-hero-divider"></div>
            <div class="vs-hero-stat">
                <div class="vs-hero-val">@settingsPeriod.ToString("MMM yyyy")</div>
                <div class="vs-hero-key">Collection Period</div>
                <div class="vs-hero-sub2">Open</div>
            </div>
            <div class="vs-hero-divider"></div>
            <div class="vs-hero-stat">
                <div class="vs-hero-val">v@(_model?.System.Version ?? "1.0")</div>
                <div class="vs-hero-key">Version</div>
                <div class="vs-hero-sub2">@(_model?.System.ApplicationName ?? "StallTrack")</div>
            </div>
        </div>
    </div>

    @if (_error is not null)
    {
        <div class="set-state">
            <div class="set-state-title">Couldn't load settings</div>
            <div class="set-state-text">@_error</div>
            <button class="set-retry" @onclick="LoadAsync">Try again</button>
        </div>
    }
    else
    {
        <div class="set-grid">

            <!-- ── Office / LGU Profile ── -->
            <section class="set-card">
                <div class="set-card-head">
                    <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18" /><path d="M5 21V8l7-5 7 5v13" /><path d="M9 21v-6h6v6" /></svg></div>
                    <div class="set-card-titles">
                        <div class="set-card-title">Office &amp; LGU Profile</div>
                        <div class="set-card-sub">Identity used on the portal, reports &amp; receipts</div>
                    </div>
                </div>
                <div class="set-rows">
                    @if (loaded)
                    {
                        <div class="set-row"><span class="set-key">Office</span><span class="set-val">@_model!.Office.Office</span></div>
                        <div class="set-row"><span class="set-key">Municipality</span><span class="set-val">@_model.Office.Municipality</span></div>
                        <div class="set-row"><span class="set-key">Province</span><span class="set-val">@_model.Office.Province</span></div>
                        <div class="set-row"><span class="set-key">System name</span><span class="set-val">@_model.Office.SystemName</span></div>
                        <div class="set-row"><span class="set-key">Receipts issued by</span><span class="set-val">@_model.Office.ReceiptsIssuedBy</span></div>
                    }
                    else
                    {
                        @for (var i = 0; i < 5; i++)
                        {
                            <div class="set-row"><Skeleton Width="35%" Height="12px" Radius="6px" /><Skeleton Width="42%" Height="12px" Radius="6px" /></div>
                        }
                    }
                </div>
                @if (loaded)
                {
                    <div class="set-note">Becomes editable via per-LGU configuration in the CARCANMADCARLAN release.</div>
                }
                else
                {
                    <div class="set-note"><Skeleton Width="82%" Height="12px" Radius="6px" /></div>
                }
            </section>

            <!-- ── Security & Access Policy ── -->
            <section class="set-card">
                <div class="set-card-head">
                    <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" /><path d="m9 12 2 2 4-4" /></svg></div>
                    <div class="set-card-titles">
                        <div class="set-card-title">Security &amp; Access Policy</div>
                        <div class="set-card-sub">Authentication rules · not account lists</div>
                    </div>
                </div>
                <div class="set-rows">
                    @if (loaded)
                    {
                        <div class="set-row"><span class="set-key">Access token</span><span class="set-val">@_model!.Security.AccessTokenMinutes minutes</span></div>
                        <div class="set-row"><span class="set-key">Refresh token</span><span class="set-val">@_model.Security.RefreshTokenDays days · hashed, single-use</span></div>
                        <div class="set-row"><span class="set-key">Account lockout</span><span class="set-val">@_model.Security.MaxFailedLoginAttempts attempts → @_model.Security.LockoutMinutes-min lock</span></div>
                        <div class="set-row"><span class="set-key">Password reset</span><span class="set-val">By the @Branding.OfficeAcronym Head</span></div>
                        <div class="set-row"><span class="set-key">Roles</span><span class="set-val">@string.Join(" · ", _model.Security.Roles)</span></div>
                    }
                    else
                    {
                        @for (var i = 0; i < 5; i++)
                        {
                            <div class="set-row"><Skeleton Width="35%" Height="12px" Radius="6px" /><Skeleton Width="42%" Height="12px" Radius="6px" /></div>
                        }
                    }
                </div>
                <div class="set-links">
                    <a class="set-link" href="/accounts">Accounts<span class="set-link-arrow">→</span></a>
                    <a class="set-link" href="/collectors">Collectors<span class="set-link-arrow">→</span></a>
                </div>
            </section>

            <!-- ── Collection & Billing Rules ── -->
            <section class="set-card">
                <div class="set-card-head">
                    <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="9" y1="13" x2="15" y2="13" /><line x1="9" y1="17" x2="13" y2="17" /></svg></div>
                    <div class="set-card-titles">
                        <div class="set-card-title">Collection &amp; Billing Rules</div>
                        <div class="set-card-sub">Policies the system enforces</div>
                    </div>
                </div>
                <div class="set-rows">
                    @if (loaded)
                    {
                        <div class="set-row"><span class="set-key">Current period</span><span class="set-val">@_model!.System.ServerDate.ToString("MMMM yyyy") <span class="set-pill pill-ok">Open</span></span></div>
                        <div class="set-row"><span class="set-key">Delinquent</span><span class="set-val">≥ @_model.Collection.DelinquentThresholdMonths unpaid months</span></div>
                        <div class="set-row"><span class="set-key">Arrears</span><span class="set-val">@_model.Collection.ArrearsMinMonths–@_model.Collection.ArrearsMaxMonths unpaid months</span></div>
                        <div class="set-row"><span class="set-key">Delinquency window</span><span class="set-val">Rolling @_model.Collection.DelinquencyWindowMonths months</span></div>
                        <div class="set-row"><span class="set-key">Contract expiry warning</span><span class="set-val">Within @_model.Collection.ContractExpiryWarningMonths months</span></div>
                        <div class="set-row"><span class="set-key">Excused / closure days</span><span class="set-val">₱0 owed · never unpaid</span></div>
                        <div class="set-row"><span class="set-key">Business clock</span><span class="set-val">@_model.Collection.TimeZone</span></div>
                    }
                    else
                    {
                        @for (var i = 0; i < 7; i++)
                        {
                            <div class="set-row"><Skeleton Width="35%" Height="12px" Radius="6px" /><Skeleton Width="42%" Height="12px" Radius="6px" /></div>
                        }
                    }
                </div>
            </section>
 <!-- ── Facility Configuration — the LGU Head manages their own facilities (any tenant) ── -->
            @if (_isHead)
            {
                <section class="set-card">
                    <div class="set-card-head">
                        <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18" /><path d="M5 21V7l8-4v18" /><path d="M19 21V11l-6-4" /><path d="M9 9v.01M9 12v.01M9 15v.01" /></svg></div>
                        <div class="set-card-titles">
                            <div class="set-card-title">Facility Configuration</div>
                            <div class="set-card-sub">Your facilities, billing models &amp; rates</div>
                        </div>
                    </div>
                    <div class="set-rows">
                        <div class="set-row"><span class="set-key">Configured</span><span class="set-val">@(_model?.Facilities.Count ?? 0) facilities</span></div>
                        <div class="set-row"><span class="set-key">Scope</span><span class="set-val">Your municipality only</span></div>
                        <div class="set-row"><span class="set-key">Managed by</span><span class="set-val">The @Branding.OfficeAcronym Head</span></div>
                    </div>
                    <div class="set-links">
                        <a class="set-link" href="/settings/facilities">Manage facilities<span class="set-link-arrow">→</span></a>
                    </div>
                </section>
            }
 <!-- ── Database health (live PostgreSQL metrics) — platform operator (default LGU) only ── -->
            @if (_isPlatformOperator)
            {
                <DatabaseHealthPanel />

                <!-- ── Backups & Restore — platform-wide (spans every LGU); operator only ── -->
                <section class="set-card">
                    <div class="set-card-head">
                        <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3" /><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5" /><path d="M3 12c0 1.66 4 3 9 3s9-1.34 9-3" /></svg></div>
                        <div class="set-card-titles">
                            <div class="set-card-title">Backups &amp; Restore</div>
                            <div class="set-card-sub">Database backups and recovery</div>
                        </div>
                    </div>
                    <div class="set-rows">
                        <div class="set-row"><span class="set-key">Automated</span><span class="set-val">Daily · 01:00 PH time</span></div>
                        <div class="set-row"><span class="set-key">Point-in-time recovery</span><span class="set-val">7-day Azure PITR</span></div>
                        <div class="set-row"><span class="set-key">On-demand</span><span class="set-val">Run &amp; download backups</span></div>
                    </div>
                    <div class="set-links">
                        <a class="set-link" href="/settings/backups">Open backups<span class="set-link-arrow">→</span></a>
                    </div>
                </section>
            }
    <!-- ── System Information ── -->
            <section class="set-card">
                <div class="set-card-head">
                    <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><line x1="12" y1="16" x2="12" y2="12" /><line x1="12" y1="8" x2="12.01" y2="8" /></svg></div>
                    <div class="set-card-titles">
                        <div class="set-card-title">System Information</div>
                        <div class="set-card-sub">About this installation</div>
                    </div>
                </div>
                <div class="set-rows">
                    @if (loaded)
                    {
                        <div class="set-row"><span class="set-key">Application</span><span class="set-val">@_model!.System.ApplicationName</span></div>
                        <div class="set-row"><span class="set-key">Version</span><span class="set-val mono">v@(_model.System.Version)</span></div>
                        <div class="set-row"><span class="set-key">Environment</span><span class="set-val">@_model.System.Environment</span></div>
                        <div class="set-row"><span class="set-key">Time zone</span><span class="set-val">@_model.System.TimeZone</span></div>
                        <div class="set-row"><span class="set-key">Server date</span><span class="set-val">@_model.System.ServerDate.ToString("MMMM d, yyyy")</span></div>
                    }
                    else
                    {
                        @for (var i = 0; i < 5; i++)
                        {
                            <div class="set-row"><Skeleton Width="35%" Height="12px" Radius="6px" /><Skeleton Width="42%" Height="12px" Radius="6px" /></div>
                        }
                    }
                </div>
            </section>
           

        </div>

        <!-- ── Facility Collection Rules (table) ── -->
        <section class="set-card">
            <div class="set-card-head">
                <div class="set-card-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" /><rect x="14" y="3" width="7" height="7" /><rect x="14" y="14" width="7" height="7" /><rect x="3" y="14" width="7" height="7" /></svg></div>
                <div class="set-card-titles">
                    <div class="set-card-title">Facility Collection Rules</div>
                    <div class="set-card-sub">@(loaded ? $"How each of the {_model!.Facilities.Count} facilities is billed" : "How each facility is billed")</div>
                </div>
                <a class="set-link" href="/reports/collections">Closures &amp; exceptions<span class="set-link-arrow">→</span></a>
            </div>
            <table class="set-table">
                <thead>
                    <tr><th>Facility</th><th>Collection model</th><th>Rate</th><th class="set-th-r">Cadence</th></tr>
                </thead>
                <tbody>
                    @if (loaded)
                    {
                        @foreach (var f in _model!.Facilities)
                        {
                            <tr>
                                <td><span class="set-fac">@f.Name</span><span class="set-code">@(System.Enum.TryParse<FacilityCode>(f.Code, out var _sc) ? FacilityCatalog.ShortNameOf(_sc) : f.Code)</span></td>
                                <td>@f.Model</td>
                                <td>@f.Rate</td>
                                <td class="set-td-r">@f.Cadence</td>
                            </tr>
                        }
                    }
                    else
                    {
                        @for (var i = 0; i < 5; i++)
                        {
                            <tr>
                                <td><Skeleton Width="160px" Height="13px" Radius="6px" /></td>
                                <td><Skeleton Width="110px" Height="12px" Radius="6px" /></td>
                                <td><Skeleton Width="110px" Height="12px" Radius="6px" /></td>
                                <td class="set-td-r"><Skeleton Width="86px" Height="12px" Radius="6px" Class="set-sk-right" /></td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </section>

       
    }

    <!-- Session / sign out (always available while authenticated) -->
    <div class="set-session">
        <div class="set-session-left">
            <div class="set-session-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
            </div>
            <div>
                <div class="set-session-title">Session</div>
                <div class="set-session-sub">Sign out of @Branding.OfficeAcronym Admin on this device.</div>
            </div>
        </div>
        <div class="set-session-right">
            @if (_confirmLogout)
            {
                <span class="set-session-ask">Sign out now?</span>
                <button class="set-signout-yes" @onclick="SignOutAsync" disabled="@_loggingOut">@(_loggingOut ? "Signing out…" : "Yes, sign out")</button>
                <button class="set-signout-no" @onclick="() => _confirmLogout = false" disabled="@_loggingOut">Cancel</button>
            }
            else
            {
                <button class="set-signout" @onclick="() => _confirmLogout = true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                    Sign out
                </button>
            }
        </div>
    </div>
</div>

@code {
    private readonly DateTime _now = PhilippineTime.Now;
    private SystemSettingsDto? _model;
    private string? _error;
    private bool _confirmLogout;
    private bool _loggingOut;
    private bool _isPlatformOperator;
    private bool _isHead;

    private async Task SignOutAsync()
    {
        _loggingOut = true;
        // Existing pipeline: revokes the refresh token server-side, clears local tokens,
        // marks the state logged-out, and force-navigates to /login.
        await AuthService.LogoutAsync();
    }

    [PersistentState(AllowUpdates = true)]
    public SystemSettingsDto? CachedSettings { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Platform operator = SuperAdmin of the DEFAULT (Cantilan) LGU. Database-health + backups are
        // whole-database (cross-LGU) tools the API restricts to that operator, so a per-LGU Head never sees
        // them (avoids the 403 "couldn't load" state and hides destructive platform-wide controls).
        await Branding.EnsureLoadedAsync();
        await FacilityCatalog.EnsureLoadedAsync();
        var authState = await AuthState.GetAuthenticationStateAsync();
        var isSuperAdmin = authState.User.IsInRole("SuperAdmin")
            || authState.User.Claims.Any(c =>
                string.Equals(c.Value, "SuperAdmin", StringComparison.OrdinalIgnoreCase)
                && c.Type.Contains("role", StringComparison.OrdinalIgnoreCase));
        _isPlatformOperator = isSuperAdmin && Branding.IsDefaultTenant;
        // The LGU Head (SuperAdmin of ANY tenant) manages their own facilities — unlike the platform-only
        // database/backup tools, this is available to every LGU's Head.
        _isHead = isSuperAdmin;

        if (CachedSettings is not null)
        {
            _model = CachedSettings;
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _error = null;
        await PaintLoadingStateAsync();

        var result = await SettingsApi.GetSystemSettingsAsync();
        if (result.IsSuccess && result.Value is not null)
        {
            _model = result.Value;
            CachedSettings = _model;
        }
        else
        {
            _error = string.IsNullOrWhiteSpace(result.Error)
                ? "The system configuration could not be retrieved."
                : result.Error;
        }
    }

    private async Task PaintLoadingStateAsync()
    {
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
    }
}
