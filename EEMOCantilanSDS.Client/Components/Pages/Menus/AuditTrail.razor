@page "/audit-trail"
@using Microsoft.AspNetCore.Authorization
@using EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using EEMOCantilanSDS.Application.Dtos.Audit
@using EEMOCantilanSDS.Client.Components.Shared
@attribute [Authorize(Roles = "SuperAdmin")]
@inject IAuditApiClient AuditApi
@implements IDisposable
<PageTitle>EEMO Admin — Audit Trail</PageTitle>

<header class="topbar">
    <div class="topbar-left">
        <div class="topbar-title">Audit Trail</div>
        <div class="topbar-breadcrumb">
            <span>EEMO Admin</span>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Audit Trail</span>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @PhilippineTime.Now.ToString("MMMM d, yyyy")
        </div>
        <AccountChip />
    </div>
</header>

<div class="content-area">

    <!-- ── Stat cards ── -->
    <div class="audit-stats">
        <button type="button" class="audit-stat @(_action is null ? "is-active" : "")" @onclick="() => SetAction(null)">
            <div class="audit-stat-icon stat-total">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
            </div>
            <div class="audit-stat-body">
                <div class="audit-stat-val">@(_data?.TotalEvents ?? 0)</div>
                <div class="audit-stat-key">Total Events</div>
                <div class="audit-stat-sub">All recorded activity</div>
            </div>
        </button>

        <button type="button" class="audit-stat @(_action == "Created" ? "is-active" : "")" @onclick='() => SetAction("Created")'>
            <div class="audit-stat-icon stat-created">
                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            </div>
            <div class="audit-stat-body">
                <div class="audit-stat-val">@(_data?.CreatedCount ?? 0)</div>
                <div class="audit-stat-key">Created</div>
                <div class="audit-stat-sub">New records created</div>
            </div>
        </button>

        <button type="button" class="audit-stat @(_action == "Updated" ? "is-active" : "")" @onclick='() => SetAction("Updated")'>
            <div class="audit-stat-icon stat-updated">
                <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
            </div>
            <div class="audit-stat-body">
                <div class="audit-stat-val">@(_data?.UpdatedCount ?? 0)</div>
                <div class="audit-stat-key">Updated</div>
                <div class="audit-stat-sub">Records modified</div>
            </div>
        </button>

        <button type="button" class="audit-stat @(_action == "Deleted" ? "is-active" : "")" @onclick='() => SetAction("Deleted")'>
            <div class="audit-stat-icon stat-deleted">
                <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 01-2 2H8a2 2 0 01-2-2L5 6" /><path d="M10 11v6M14 11v6" /><path d="M9 6V4a1 1 0 011-1h4a1 1 0 011 1v2" /></svg>
            </div>
            <div class="audit-stat-body">
                <div class="audit-stat-val">@(_data?.DeletedCount ?? 0)</div>
                <div class="audit-stat-key">Deleted</div>
                <div class="audit-stat-sub">Records removed</div>
            </div>
        </button>
    </div>

    <!-- ── Filter bar ── -->
    <div class="audit-filters">
        <div class="af-field af-search">
            <label>Search</label>
            <div class="af-search-box">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search actor, entity, action…"
                       value="@_search" @oninput="OnSearchInput" />
            </div>
        </div>

        <div class="af-field">
            <label>Period</label>
            <select class="af-input af-period" value="@_rangePreset" @onchange="OnRangeChanged">
                <option value="all">All time</option>
                <option value="today">Today</option>
                <option value="7d">Last 7 days</option>
                <option value="30d">Last 30 days</option>
                <option value="month">This month</option>
                <option value="custom">Custom range…</option>
            </select>
        </div>

        @if (_rangePreset == "custom")
        {
            <div class="af-field">
                <label>From</label>
                <input type="date" class="af-input" value="@_fromDate?.ToString("yyyy-MM-dd")" @onchange="OnFromChanged" max="@_todayIso" />
            </div>
            <div class="af-field">
                <label>To</label>
                <input type="date" class="af-input" value="@_toDate?.ToString("yyyy-MM-dd")" @onchange="OnToChanged" max="@_todayIso" />
            </div>
        }

        <div class="af-field">
            <label>Actor</label>
            <select class="af-input" value="@_actor" @onchange="OnActorChanged">
                <option value="">All Actors</option>
                @foreach (var a in _actorOptions)
                {
                    <option value="@a.Value">@a.Label</option>
                }
            </select>
        </div>

        <div class="af-field">
            <label>Entity</label>
            <select class="af-input" value="@_entity" @onchange="OnEntityChanged">
                <option value="">All Entities</option>
                @foreach (var e in _entityTypes)
                {
                    <option value="@e">@EntityLabel(e)</option>
                }
            </select>
        </div>

        <div class="af-actions">
            @if (_hasActiveFilters)
            {
                <button type="button" class="af-clear" @onclick="ClearFilters" title="Clear all filters">Clear</button>
            }
            <a class="af-export @(CanExport ? "" : "is-disabled")" download="audit-trail.csv" href="@_csvHref" title="Export current results to CSV">
                <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" /><polyline points="7 10 12 15 17 10" /><line x1="12" y1="15" x2="12" y2="3" /></svg>
                Export
            </a>
        </div>
    </div>

    <!-- ── Table ── -->
    <div class="audit-panel">
        <div class="audit-row audit-row-head">
            <div class="ac-time">Timestamp</div>
            <div class="ac-actor">Actor</div>
            <div class="ac-action">Action</div>
            <div class="ac-entity">Entity</div>
            <div class="ac-details">Details</div>
        </div>

        @if (_loading)
        {
            <div class="audit-skeleton">
                @for (var i = 0; i < 8; i++)
                {
                    <div class="audit-row">
                        <div class="ac-time"><Skeleton Width="120px" Height="14px" /></div>
                        <div class="ac-actor sk-inline">
                            <Skeleton Width="32px" Height="32px" Radius="999px" />
                            <div class="sk-grow sk-stack-sm">
                                <Skeleton Width="120px" Height="13px" />
                                <Skeleton Width="60px" Height="10px" />
                            </div>
                        </div>
                        <div class="ac-action"><Skeleton Width="74px" Height="22px" Radius="999px" /></div>
                        <div class="ac-entity"><Skeleton Width="130px" Height="14px" /></div>
                        <div class="ac-details"><Skeleton Width="80%" Height="13px" /></div>
                    </div>
                }
            </div>
        }
        else if (_error is not null)
        {
            <div class="audit-state">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                <div class="audit-state-title">Couldn't load the audit trail</div>
                <div class="audit-state-sub">@_error</div>
                <button class="af-clear" @onclick="() => ReloadAsync()">Try again</button>
            </div>
        }
        else if (_data is null || _data.Items.Count == 0)
        {
            <div class="audit-state">
                <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                <div class="audit-state-title">No audit entries found</div>
                <div class="audit-state-sub">Nothing matches the current filters. Adjust or clear them to see more.</div>
            </div>
        }
        else
        {
            @foreach (var group in GroupedItems)
            {
                <div class="audit-daygroup">@group.Key</div>
                @foreach (var log in group.Value)
                {
                    var ph = ToPh(log.LoggedAtUtc);
                    <div class="audit-row">
                        <div class="ac-time">
                            <div class="ac-time-main">@ph.ToString("hh:mm tt")</div>
                            <div class="ac-time-sub">@ph.ToString("MMM d, yyyy")</div>
                        </div>
                        <div class="ac-actor">
                            <div class="ac-avatar">@Initials(log.ActorDisplayName)</div>
                            <div class="ac-actor-text">
                                <div class="ac-actor-name">@log.ActorDisplayName</div>
                                <div class="ac-actor-role">@log.ActorRole</div>
                            </div>
                        </div>
                        <div class="ac-action">
                            <span class="ac-badge ac-badge-@log.Action.ToLower()">@log.Action.ToUpper()</span>
                        </div>
                        <div class="ac-entity">
                            <div class="ac-entity-name">@EntityLabel(log.EntityType)</div>
                            <div class="ac-entity-code">@ShortId(log.EntityId)</div>
                        </div>
                        <div class="ac-details">@DetailsText(log)</div>
                    </div>
                }
            }

            <!-- ── Footer / pagination ── -->
            <div class="audit-foot">
                <div class="audit-foot-info">@RangeLabel</div>
                <div class="audit-foot-pager">
                    <label class="audit-pagesize">
                        Rows
                        <select value="@_pageSize" @onchange="OnPageSizeChanged">
                            <option value="10">10</option>
                            <option value="25">25</option>
                            <option value="50">50</option>
                            <option value="100">100</option>
                        </select>
                    </label>
                    <div class="audit-pages">
                        <button class="pg-btn" disabled="@(_page <= 1)" @onclick="() => GoToPage(1)" title="First">«</button>
                        <button class="pg-btn" disabled="@(_page <= 1)" @onclick="() => GoToPage(_page - 1)" title="Previous">‹</button>
                        <span class="pg-current">Page @_page of @Math.Max(1, _data.TotalPages)</span>
                        <button class="pg-btn" disabled="@(_page >= _data.TotalPages)" @onclick="() => GoToPage(_page + 1)" title="Next">›</button>
                        <button class="pg-btn" disabled="@(_page >= _data.TotalPages)" @onclick="() => GoToPage(_data.TotalPages)" title="Last">»</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@code {
    private AuditTrailDto? _data;
    private bool _loading = true;
    private string? _error;

    // Filter-dropdown options, cached across pages so pagination doesn't re-scan them server-side.
    private IReadOnlyList<AuditActorOptionDto> _actorOptions = Array.Empty<AuditActorOptionDto>();
    private IReadOnlyList<string> _entityTypes = Array.Empty<string>();

    private string _search = string.Empty;
    private string? _action;                 // null = All
    private string _entity = string.Empty;   // "" = All
    private string _actor = string.Empty;    // "" = All
    private DateOnly? _fromDate;
    private DateOnly? _toDate;
    private string _rangePreset = "all";
    private int _page = 1;
    private int _pageSize = 25;

    private string _csvHref = string.Empty;
    private readonly string _todayIso = PhilippineTime.Today.ToString("yyyy-MM-dd");
    private System.Threading.CancellationTokenSource? _searchDebounce;

    [PersistentState(AllowUpdates = true)]
    public AuditTrailPageState? CachedAuditTrail { get; set; }

    // Any non-default filter active (used to show the Clear button).
    private bool _hasActiveFilters =>
        !string.IsNullOrEmpty(_search) || _action is not null
        || !string.IsNullOrEmpty(_entity) || !string.IsNullOrEmpty(_actor)
        || _fromDate is not null || _toDate is not null;

    private bool CanExport => _data is not null && _data.Items.Count > 0;

    protected override async Task OnInitializedAsync()
    {
        if (TryApplyCachedAuditTrail())
            return;

        await ReloadAsync();
    }

    private async Task ReloadAsync(bool includeOptions = true)
    {
        _loading = true;
        _error = null;
        await PaintLoadingStateAsync();

        // PH date range → UTC bounds (stored timestamps are UTC; PH = UTC+8, no DST).
        DateTime? fromUtc = _fromDate is { } f ? f.ToDateTime(TimeOnly.MinValue).AddHours(-8) : null;
        DateTime? toUtc = _toDate is { } t ? t.ToDateTime(TimeOnly.MaxValue).AddHours(-8) : null;

        var result = await AuditApi.GetAuditTrailAsync(
            string.IsNullOrWhiteSpace(_search) ? null : _search,
            _action,
            string.IsNullOrWhiteSpace(_entity) ? null : _entity,
            string.IsNullOrWhiteSpace(_actor) ? null : _actor,
            fromUtc, toUtc, _page, _pageSize, includeOptions);

        if (result.IsSuccess && result.Value is not null)
        {
            _data = result.Value;
            // Options are only returned when requested; cache them so paging keeps the dropdowns filled.
            if (includeOptions)
            {
                _actorOptions = _data.Actors;
                _entityTypes = _data.EntityTypes;
            }
            BuildCsv();
            CachedAuditTrail = new AuditTrailPageState(
                _search,
                _action,
                _entity,
                _actor,
                _fromDate,
                _toDate,
                _page,
                _pageSize,
                _data,
                _actorOptions.ToList(),
                _entityTypes.ToList());
        }
        else
        {
            _error = result.Error ?? "The audit service is unavailable right now.";
        }

        _loading = false;
        StateHasChanged();
    }

    private bool TryApplyCachedAuditTrail()
    {
        if (CachedAuditTrail is not { } state
            || state.Search != _search
            || state.Action != _action
            || state.Entity != _entity
            || state.Actor != _actor
            || state.FromDate != _fromDate
            || state.ToDate != _toDate
            || state.Page != _page
            || state.PageSize != _pageSize)
        {
            return false;
        }

        _data = state.Data;
        _actorOptions = state.ActorOptions;
        _entityTypes = state.EntityTypes;
        BuildCsv();
        _loading = false;
        return true;
    }

    private async Task PaintLoadingStateAsync()
    {
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _search = e.Value?.ToString() ?? string.Empty;
        // Debounce: only reload ~350ms after typing stops.
        _searchDebounce?.Cancel();
        _searchDebounce = new System.Threading.CancellationTokenSource();
        var token = _searchDebounce.Token;
        try
        {
            await Task.Delay(350, token);
            _page = 1;
            await ReloadAsync();
        }
        catch (TaskCanceledException) { }
    }

    private async Task SetAction(string? action)
    {
        _action = action;
        _page = 1;
        await ReloadAsync();
    }

    private async Task OnActorChanged(ChangeEventArgs e)
    {
        _actor = e.Value?.ToString() ?? string.Empty;
        _page = 1;
        await ReloadAsync();
    }

    private async Task OnEntityChanged(ChangeEventArgs e)
    {
        _entity = e.Value?.ToString() ?? string.Empty;
        _page = 1;
        await ReloadAsync();
    }

    private async Task OnRangeChanged(ChangeEventArgs e)
    {
        _rangePreset = e.Value?.ToString() ?? "all";
        var today = PhilippineTime.Today;
        switch (_rangePreset)
        {
            case "today": _fromDate = today; _toDate = today; break;
            case "7d": _fromDate = today.AddDays(-6); _toDate = today; break;
            case "30d": _fromDate = today.AddDays(-29); _toDate = today; break;
            case "month": _fromDate = new DateOnly(today.Year, today.Month, 1); _toDate = today; break;
            case "all": _fromDate = null; _toDate = null; break;
            case "custom": break; // keep current dates; reveal the manual pickers
        }
        _page = 1;

        if (_rangePreset == "custom")
            StateHasChanged();
        else
            await ReloadAsync();
    }

    private async Task OnFromChanged(ChangeEventArgs e)
    {
        _fromDate = DateOnly.TryParse(e.Value?.ToString(), out var d) ? d : null;
        _page = 1;
        await ReloadAsync();
    }

    private async Task OnToChanged(ChangeEventArgs e)
    {
        _toDate = DateOnly.TryParse(e.Value?.ToString(), out var d) ? d : null;
        _page = 1;
        await ReloadAsync();
    }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        _pageSize = int.TryParse(e.Value?.ToString(), out var n) ? n : 25;
        _page = 1;
        await ReloadAsync();
    }

    private async Task GoToPage(int page)
    {
        if (_data is null) return;
        var target = Math.Clamp(page, 1, Math.Max(1, _data.TotalPages));
        if (target == _page) return;
        _page = target;
        await ReloadAsync(includeOptions: false);
    }

    private async Task ClearFilters()
    {
        _search = string.Empty;
        _action = null;
        _entity = string.Empty;
        _actor = string.Empty;
        _fromDate = null;
        _toDate = null;
        _rangePreset = "all";
        _page = 1;
        await ReloadAsync();
    }

    // Group the current page's items by their PH calendar day (already date-desc from the server).
    private IEnumerable<KeyValuePair<string, List<AuditLogDto>>> GroupedItems
    {
        get
        {
            var groups = new List<KeyValuePair<string, List<AuditLogDto>>>();
            foreach (var item in _data!.Items)
            {
                var key = ToPh(item.LoggedAtUtc).ToString("MMMM d, yyyy");
                if (groups.Count == 0 || groups[^1].Key != key)
                    groups.Add(new(key, new List<AuditLogDto>()));
                groups[^1].Value.Add(item);
            }
            return groups;
        }
    }

    private string RangeLabel
    {
        get
        {
            if (_data is null || _data.TotalCount == 0) return "No results";
            var first = (_page - 1) * _pageSize + 1;
            var last = Math.Min(_page * _pageSize, _data.TotalCount);
            return $"Showing {first} to {last} of {_data.TotalCount} results";
        }
    }

    private void BuildCsv()
    {
        if (_data is null || _data.Items.Count == 0) { _csvHref = string.Empty; return; }

        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Timestamp (PH),Actor,Role,Action,Entity,EntityId,Details");
        foreach (var log in _data.Items)
        {
            var ph = ToPh(log.LoggedAtUtc).ToString("yyyy-MM-dd HH:mm");
            sb.AppendLine(string.Join(",",
                Csv(ph), Csv(log.ActorDisplayName), Csv(log.ActorRole), Csv(log.Action),
                Csv(EntityLabel(log.EntityType)), Csv(log.EntityId?.ToString() ?? ""), Csv(DetailsText(log))));
        }
        _csvHref = "data:text/csv;charset=utf-8," + Uri.EscapeDataString(sb.ToString());
    }

    private static string Csv(string value)
    {
        if (string.IsNullOrEmpty(value)) return string.Empty;
        var needsQuote = value.Contains(',') || value.Contains('"') || value.Contains('\n');
        var escaped = value.Replace("\"", "\"\"");
        return needsQuote ? $"\"{escaped}\"" : escaped;
    }

    // Stored audit timestamps are UTC; the UI shows Philippine time (UTC+8, no DST).
    private static DateTime ToPh(DateTime utc) => utc.AddHours(8);

    private static string Initials(string name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "?";
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1) return parts[0][..Math.Min(2, parts[0].Length)].ToUpper();
        return string.Concat(parts[0][0], parts[^1][0]).ToUpper();
    }

    // Brief, professional labels for the audited entity types (the filter value stays the class name).
    private static readonly Dictionary<string, string> EntityLabels = new()
    {
        ["PaymentRecord"] = "Payment Record",
        ["DailyCollection"] = "Daily Collection",
        ["OnlinePaymentTransaction"] = "Online Payment",
        ["SlaughterTransaction"] = "Slaughter",
        ["TpmAttendance"] = "Tabo-an Attendance",
        ["TrmTrip"] = "Terminal Trip",
        ["AdminUser"] = "Admin Account",
        ["CollectorUser"] = "Collector Account",
        ["PayorUser"] = "Payor Account",
        ["PayorActivationCode"] = "Payor Activation",
        ["PayorStallLink"] = "Payor Link",
        ["Stall"] = "Stall",
    };

    private static string EntityLabel(string entityType) =>
        EntityLabels.TryGetValue(entityType, out var label) ? label : Humanize(entityType);

    // "PaymentRecord" → "Payment Record"
    private static string Humanize(string pascal)
    {
        if (string.IsNullOrEmpty(pascal)) return pascal;
        return System.Text.RegularExpressions.Regex.Replace(pascal, "(?<=[a-z0-9])([A-Z])", " $1");
    }

    private static string ShortId(Guid? id) => id is null ? "—" : $"#{id.Value.ToString("N")[..8]}";

    // No human description is stored; surface the note if present, else a generated summary.
    private static string DetailsText(AuditLogDto log) =>
        !string.IsNullOrWhiteSpace(log.Notes) ? log.Notes! : $"{log.Action} {EntityLabel(log.EntityType)}";

    public sealed record AuditTrailPageState(
        string Search,
        string? Action,
        string Entity,
        string Actor,
        DateOnly? FromDate,
        DateOnly? ToDate,
        int Page,
        int PageSize,
        AuditTrailDto Data,
        List<AuditActorOptionDto> ActorOptions,
        List<string> EntityTypes);

    public void Dispose()
    {
        _searchDebounce?.Cancel();
        _searchDebounce?.Dispose();
    }
}
