@page "/account-setup-admin"
@attribute [AllowAnonymous]


@using EEMOCantilanSDS.Application.Command.Auth.AdminAuth.CreateFirstAdmin
@using EEMOCantilanSDS.Application.Dtos.Tenancy
@using Microsoft.AspNetCore.WebUtilities
@inject ISetupApiClient SetupApi
@inject IMunicipalitiesApiClient MunicipalitiesApi
@inject NavigationManager Navigation
<PageTitle>EEMO — Initial System Setup</PageTitle>

<div class="setup-root">

    <!-- Left Panel — Branding (data-driven per ?lgu; Cantilan defaults until resolved) -->
    <div class="setup-left @(_isDefaultBrand ? "" : "setup-left--neutral")">
        <div class="setup-left-inner">
            <div class="setup-seal government-seals">
                <div class="government-logo-card">
                    <img src="@SealPath" alt="@MunicipalityName seal" />
                </div>
                <div class="government-logo-card stalltrack-logo">
                    <img src="/images/stalltrack-final-logo-transparent.png" alt="StallTrack Seal" />
                </div>
            </div>
            <div class="setup-brand">
                <div class="setup-brand-label">Republic of the Philippines</div>
                <div class="setup-brand-city">Municipality of @MunicipalityName</div>
                <div class="setup-brand-title">@OfficeAcronym</div>
                <div class="setup-brand-sub">@OfficeName</div>
            </div>
            <div class="login-secure-access">
                <div class="login-secure-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                        <rect x="9" y="10" width="6" height="5" rx="1" />
                        <path d="M10.5 10V8.5a1.5 1.5 0 013 0V10" />
                    </svg>
                </div>
                <div>
                    <div class="login-secure-title">Secure Access Portal</div>
                    <p>This system is for authorized @OfficeAcronym personnel only.</p>
                </div>
            </div>
            <div class="setup-left-footer">
                <div class="setup-system-name">Revenue Collection System</div>
                <div class="setup-version">Version 1.0 — Initial Setup</div>
            </div>
        </div>
    </div>

    <!-- Right Panel — Form -->
    <div class="setup-right">
        <div class="setup-form-wrap">
            <section class="login-card">

            <!-- Step indicator -->
            <div class="setup-step-row">
                <div class="setup-step active">
                    <span class="step-dot"></span>
                    <span class="step-label">Head Setup</span>
                </div>
                <div class="setup-step-line"></div>
                <div class="setup-step">
                    <span class="step-dot"></span>
                    <span class="step-label">Login</span>
                </div>
                <div class="setup-step-line"></div>
                <div class="setup-step">
                    <span class="step-dot"></span>
                    <span class="step-label">Dashboard</span>
                </div>
            </div>

            <!-- Header -->
            <div class="setup-form-header">
                <div class="login-header-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                        <circle cx="12" cy="8" r="3.5" />
                        <path d="M5.5 20c.5-3.5 2.8-5.5 6.5-5.5s6 2 6.5 5.5" />
                    </svg>
                </div>
                <div class="setup-form-title">Create Head Account</div>
                <div class="setup-form-desc">This account will have full access to the @OfficeAcronym Revenue Collection System. Please keep your credentials secure.</div>
            </div>

            <!-- Form -->
            <div class="setup-form">

                <!-- Full Name -->
                <div class="form-group">
                    <label class="form-label">Full Name</label>
                    <div class="form-input-wrap @(GetFieldError("FullName") != string.Empty ? "form-input-error" : "")">
                        <svg class="form-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                        <input @bind="Form.FullName"
                               type="text"
                               class="form-input"
                               placeholder="e.g. Juan D. Dela Cruz" />
                    </div>
                    @if (GetFieldError("FullName") != string.Empty)
                    {
                        <span class="form-error">@GetFieldError("FullName")</span>
                    }
                </div>

                <!-- Username + Email (two columns) -->
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Username</label>
                        <div class="form-input-wrap @(GetFieldError("Username") != string.Empty ? "form-input-error" : "")">
                            <svg class="form-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                                <circle cx="12" cy="7" r="4" />
                            </svg>
                            <input @bind="Form.Username"
                                   type="text"
                                   class="form-input"
                                   placeholder="e.g. head.admin" />
                        </div>
                        @if (GetFieldError("Username") != string.Empty)
                        {
                            <span class="form-error">@GetFieldError("Username")</span>
                        }
                        else
                        {
                            <span class="form-hint">Used to log in. No spaces allowed.</span>
                        }
                    </div>

                    <div class="form-group">
                        <label class="form-label">Email Address</label>
                        <div class="form-input-wrap @(GetFieldError("Email") != string.Empty ? "form-input-error" : "")">
                            <svg class="form-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                                <polyline points="22,6 12,13 2,6" />
                            </svg>
                            <input @bind="Form.Email"
                                   type="email"
                                   class="form-input"
                                   placeholder="e.g. name@lgu.gov.ph" />
                        </div>
                        @if (GetFieldError("Email") != string.Empty)
                        {
                            <span class="form-error">@GetFieldError("Email")</span>
                        }
                    </div>
                </div>

                <!-- Two col — Password -->
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Password</label>
                        <div class="form-input-wrap-password">
                            <div class="form-input-wrap @(GetFieldError("Password") != string.Empty ? "form-input-error" : "")">
                                <svg class="form-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                    <path d="M7 11V7a5 5 0 0110 0v4" />
                                </svg>
                                <input @key="@ShowPassword"
                                       value="@Form.Password"
                                       @oninput="@((e) => Form.Password = e.Value?.ToString() ?? string.Empty)"
                                       type="@(ShowPassword ? "text" : "password")"
                                       class="form-input form-input-password"
                                       placeholder="Min. 8 characters" />
                                <button type="button" 
                                        class="form-eye-btn" 
                                        @onclick="TogglePassword"
                                        @onclick:stopPropagation="true">
                                    @if (ShowPassword)
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                            <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24"/>
                                            <line x1="1" y1="1" x2="23" y2="23"/>
                                        </svg>
                                    }
                                    else
                                    {
                                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                                            <circle cx="12" cy="12" r="3"/>
                                        </svg>
                                    }
                                </button>
                            </div>
                        </div>
                        @if (GetFieldError("Password") != string.Empty)
                        {
                            <span class="form-error">@GetFieldError("Password")</span>
                        }
                    </div>

                    <div class="form-group">
                        <label class="form-label">Confirm Password</label>
                        <div class="form-input-wrap @(GetFieldError("ConfirmPassword") != string.Empty ? "form-input-error" : "")">
                            <svg class="form-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0110 0v4" />
                            </svg>
                            <input @key="@ShowPassword"
                                   value="@Form.ConfirmPassword"
                                   @oninput="@((e) => Form.ConfirmPassword = e.Value?.ToString() ?? string.Empty)"
                                   type="@(ShowPassword ? "text" : "password")"
                                   class="form-input"
                                   placeholder="Re-enter password" />
                        </div>
                        @if (GetFieldError("ConfirmPassword") != string.Empty)
                        {
                            <span class="form-error">@GetFieldError("ConfirmPassword")</span>
                        }
                    </div>
                </div>

                <!-- Password strength -->
                @if (!string.IsNullOrEmpty(Form.Password))
                {
                    var strength = GetPasswordStrength(Form.Password);
                    <div class="pw-strength">
                        <div class="pw-strength-bars">
                            <div class="pw-bar @(strength >= 1 ? "pw-bar-fill pw-" + GetStrengthClass(strength) : "")"></div>
                            <div class="pw-bar @(strength >= 2 ? "pw-bar-fill pw-" + GetStrengthClass(strength) : "")"></div>
                            <div class="pw-bar @(strength >= 3 ? "pw-bar-fill pw-" + GetStrengthClass(strength) : "")"></div>
                            <div class="pw-bar @(strength >= 4 ? "pw-bar-fill pw-" + GetStrengthClass(strength) : "")"></div>
                        </div>
                        <span class="pw-strength-label pw-@GetStrengthClass(strength)">@GetStrengthLabel(strength)</span>
                    </div>
                }

                <!-- Error -->
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="setup-error">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="15" y1="9" x2="9" y2="15" />
                            <line x1="9" y1="9" x2="15" y2="15" />
                        </svg>
                        @ErrorMessage
                    </div>
                }

                <!-- Submit -->
                <button class="setup-submit @(IsLoading ? "setup-submit-loading" : "")"
                        @onclick="HandleSubmit"
                        disabled="@IsLoading">
                    @if (IsLoading)
                    {
                        <span class="setup-spinner"></span>
                        <span>Creating account...</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                            <path d="m9 12 2 2 4-4" />
                        </svg>
                        <span>Create Head Account</span>
                    }
                </button>

                <!-- Security reassurance -->
                <div class="setup-secure-note">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                        <path d="m9 12 2 2 4-4" />
                    </svg>
                    <span>Please keep your credentials secure and do not share them with anyone.</span>
                </div>

            </div><!-- end form -->

            </section>

        </div>
    </div>

</div>

@code {

    class SetupForm
    {
        public string FullName { get; set; } = string.Empty;
        public string Username { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    SetupForm Form = new();
    Dictionary<string, string> FieldErrors = new();
    bool ShowPassword = false;
    bool IsLoading = false;
    string ErrorMessage = string.Empty;

    // ── Per-LGU branding (data-driven, mirrors Login) ─────────────────────────
    // Defaults are Cantilan's, so the default LGU renders byte-for-byte unchanged. A scoped setup link
    // (…/account-setup-admin?lgu={code}) themes the panel to that municipality. Any failure keeps defaults.
    const string DefaultSealPath = "/images/LGU_CANTILAN_LOGO.jpg";
    const string NeutralSealPath = "/images/stalltrack-seal.png";
    string SealPath = DefaultSealPath;
    string MunicipalityName = "Cantilan";
    string OfficeAcronym = "EEMO";
    string OfficeName = "Economic Enterprise and Management Office";
    bool _isDefaultBrand = true;
    string? _lgu;

    // Carry prerender-resolved branding into the interactive pass so the panel doesn't flash Cantilan's
    // branding on another municipality's setup link (same technique as Login).
    // Seal is NOT persisted (non-Cantilan seals are large base64 data URIs that can exceed the SignalR
    // message size and drop the circuit). It's re-resolved by the branding fetch; only small fields persist.
    [PersistentState] public string? PBrandName { get; set; }
    [PersistentState] public string? PBrandAcronym { get; set; }
    [PersistentState] public string? PBrandOffice { get; set; }
    [PersistentState] public bool? PBrandIsDefault { get; set; }

    protected override async Task OnInitializedAsync()
    {
        // Apply prerender-resolved branding up-front (correct first interactive frame, no flash).
        if (!string.IsNullOrEmpty(PBrandName))
        {
            _isDefaultBrand = PBrandIsDefault ?? true;
            if (PBrandIsDefault == false) SealPath = NeutralSealPath;   // real seal comes from the fetch below
            MunicipalityName = PBrandName;
            if (PBrandAcronym is not null) OfficeAcronym = PBrandAcronym;
            if (PBrandOffice is not null) OfficeName = PBrandOffice;
        }

        // Data-driven branding from ?lgu (the scoped setup link).
        var query = QueryHelpers.ParseQuery(Navigation.ToAbsoluteUri(Navigation.Uri).Query);
        if (query.TryGetValue("lgu", out var lguValues))
        {
            var lgu = lguValues.ToString().Trim();
            if (!string.IsNullOrEmpty(lgu))
            {
                _lgu = lgu;
                try
                {
                    var branding = await MunicipalitiesApi.GetBrandingByIdentifierAsync(lgu);
                    if (branding.IsSuccess && branding.Value is not null)
                    {
                        ApplyBranding(branding.Value);
                        PersistBrand();
                    }
                }
                catch { /* keep defaults on any failure */ }
            }
        }

        var setupStatusResult = await SetupApi.GetSetupStatusAsync();

        if (setupStatusResult.IsSuccess && !setupStatusResult.Value!.IsSetupRequired)
        {
            // Preserve the LGU scope when bouncing back to login.
            Navigation.NavigateTo("/login" + (string.IsNullOrEmpty(_lgu) ? "" : $"?lgu={_lgu}"), replace: true);
        }
    }

    void ApplyBranding(MunicipalityBrandingDto b)
    {
        var isCantilan = string.Equals(b.Code, "CANTILAN", StringComparison.OrdinalIgnoreCase);
        _isDefaultBrand = isCantilan;
        SealPath = !string.IsNullOrWhiteSpace(b.SealPath) ? b.SealPath!
            : isCantilan ? DefaultSealPath : NeutralSealPath;
        MunicipalityName = string.IsNullOrWhiteSpace(b.Name) ? "Cantilan" : b.Name;
        OfficeAcronym = !string.IsNullOrWhiteSpace(b.OfficeAcronym) ? b.OfficeAcronym!
            : isCantilan ? "EEMO" : MunicipalityName;
        OfficeName = string.IsNullOrWhiteSpace(b.OfficeName) ? "Economic Enterprise and Management Office" : b.OfficeName;
    }

    void PersistBrand()
    {
        PBrandName = MunicipalityName;
        PBrandAcronym = OfficeAcronym;
        PBrandOffice = OfficeName;
        PBrandIsDefault = _isDefaultBrand;
    }

    string PasswordInputType => ShowPassword ? "text" : "password";

    void TogglePassword(MouseEventArgs e)
    {
        ShowPassword = !ShowPassword;
        StateHasChanged();
    }

    async Task HandleSubmit()
    {
        ErrorMessage = string.Empty;
        FieldErrors.Clear();

        if (Form.Password != Form.ConfirmPassword) 
        { 
            FieldErrors["ConfirmPassword"] = "Passwords do not match.";
            return; 
        }

        IsLoading = true;
        StateHasChanged();

        try
        {
            var command = new CreateFirstAdminCommand(
                Form.FullName,
                Form.Username,
                Form.Email,
                Form.Password
            );

            var result = await SetupApi.CreateFirstAdminAsync(command);

            if (result.IsSuccess)
            {
                Navigation.NavigateTo("/login?setup=true");
            }
            else
            {
                if (result.ValidationErrors != null && result.ValidationErrors.Any())
                {
                    foreach (var error in result.ValidationErrors)
                    {
                        FieldErrors[error.Key] = error.Value.FirstOrDefault() ?? string.Empty;
                    }
                }
                else
                {
                    ErrorMessage = result.Error ?? "Failed to create Head account.";
                }
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    string GetFieldError(string fieldName) => FieldErrors.ContainsKey(fieldName) ? FieldErrors[fieldName] : string.Empty;

    int GetPasswordStrength(string pw)
    {
        int score = 0;
        if (pw.Length >= 8) score++;
        if (pw.Any(char.IsUpper)) score++;
        if (pw.Any(char.IsDigit)) score++;
        if (pw.Any(c => !char.IsLetterOrDigit(c))) score++;
        return score;
    }

    string GetStrengthClass(int strength) => strength switch
    {
        1 => "weak",
        2 => "fair",
        3 => "good",
        4 => "strong",
        _ => ""
    };

    string GetStrengthLabel(int strength) => strength switch
    {
        1 => "Weak",
        2 => "Fair",
        3 => "Good",
        4 => "Strong",
        _ => ""
    };
}

