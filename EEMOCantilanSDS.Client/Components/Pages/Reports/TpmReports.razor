@page "/tpm/reports"
@attribute [Authorize]
@rendermode InteractiveServer
@using EEMOCantilanSDS.Application.Dtos.TaboanMarket
@inject ITpmApiClient TpmApi

<PageTitle>EEMO Admin — TPM Reports</PageTitle>

<header class="rpt-topbar">
    <div class="rpt-topbar-left">
        <a href="/tpm" class="rpt-back-btn" title="Back to TPM">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
        </a>
        <div class="rpt-topbar-icon">
            <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <div>
            <div class="rpt-eyebrow">FACILITY · TPM · REPORTS</div>
            <div class="rpt-title">Tabo-an Public Market Reports</div>
            <div class="rpt-subtitle">@GetPeriodLabel()</div>
        </div>
    </div>
    <div class="rpt-topbar-right">
        <button class="rpt-action-btn">
            <svg viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export PDF
        </button>
        <button class="rpt-action-btn">
            <svg viewBox="0 0 24 24"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Print
        </button>
    </div>
    <div class="rpt-header-progress">
        <div class="rpt-header-progress-fill" style="width:@CollectionRate%"></div>
    </div>
</header>

<div class="rpt-period-bar">
    <div class="rpt-period-tabs">
        @foreach (var p in new[]{"Weekly","Monthly","Yearly"})
        { <button class="rpt-period-tab @(ActivePeriod==p?"active":"")" @onclick="()=>SetPeriod(p)">@p</button> }
    </div>
    <div class="rpt-date-nav">
        <button class="rpt-nav-btn" @onclick="PrevPeriod"><svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg></button>
        <span class="rpt-current-period">@GetPeriodLabel()</span>
        <button class="rpt-nav-btn" @onclick="NextPeriod"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></button>
    </div>
</div>

<div class="rpt-content">

    <div class="rpt-kpi-strip">
        <div class="rpt-kpi-card kpi-revenue">
            <div class="kpi-icon"><svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Market Fees Collected</div>
                <div class="kpi-value">₱@TotalCollected.ToString("N2")</div>
                <div class="kpi-change positive">@RevenueGrowthText</div>
            </div>
        </div>
        <div class="rpt-kpi-card kpi-rate">
            <div class="kpi-icon"><svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Vendor Collection Rate</div>
                <div class="kpi-value">@CollectionRate%</div>
                <div class="kpi-change positive">@CollectionGrowthText</div>
            </div>
        </div>
        <div class="rpt-kpi-card kpi-pending">
            <div class="kpi-icon"><svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Unpaid Vendors</div>
                <div class="kpi-value">@UnpaidVendors</div>
                <div class="kpi-change negative">₱@PendingAmount.ToString("N2") uncollected</div>
            </div>
        </div>
        <div class="rpt-kpi-card kpi-stalls">
            <div class="kpi-icon"><svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Vendor Entries</div>
                <div class="kpi-value">@TotalEntries</div>
                <div class="kpi-change neutral">across @MarketDaysCount Fridays</div>
            </div>
        </div>
    </div>

    <div class="rpt-charts-row">
        <div class="rpt-chart-card rpt-chart-wide">
            <div class="chart-header">
                <h3 class="chart-title">Friday Collection Trend</h3>
                <div class="chart-legend">
                    <span class="legend-dot" style="background:var(--green)"></span><span>Collected</span>
                    <span class="legend-dot" style="background:var(--gold);margin-left:12px"></span><span>Current</span>
                </div>
            </div>
            <div class="rpt-bar-chart">
                @foreach (var pt in TrendPoints)
                {
                    <div class="rpt-bar-group @(pt.IsCurrent?"current":"")">
                        <div class="rpt-bar-wrap">
                            <div class="rpt-bar-3d">
                                <div class="bar3d-face bar3d-front" style="height:@pt.HeightPct%"></div>
                                <div class="bar3d-face bar3d-top"   style="bottom:@pt.HeightPct%"></div>
                                <div class="bar3d-face bar3d-side"  style="height:@pt.HeightPct%"></div>
                            </div>
                        </div>
                        <div class="rpt-bar-label">@pt.Label</div>
                        <div class="rpt-bar-val">₱@pt.ShortValue</div>
                    </div>
                }
            </div>
        </div>

        <div class="rpt-chart-card rpt-chart-narrow">
            <div class="chart-header"><h3 class="chart-title">Vendor Payment Status</h3></div>
            <div class="rpt-donut-wrap">
                <svg class="rpt-donut-svg" viewBox="0 0 120 120">
                    <circle cx="60" cy="60" r="46" fill="none" stroke="var(--bg)" stroke-width="16" />
                    @{ var arcs = BuildDonutArcs(new[]{(PaidVendors,"#2d7a5f"),(UnpaidVendors,"#8b3a3a")},46,60,60); }
                    @foreach (var arc in arcs){ <path d="@arc.D" fill="none" stroke="@arc.Color" stroke-width="16" stroke-linecap="butt" /> }
                    <circle cx="60" cy="60" r="37" fill="white" />
                    <text x="60" y="55" class="donut-center-pct">@CollectionRate%</text>
                    <text x="60" y="68" class="donut-center-lbl">FULLY PAID</text>
                </svg>
                <div class="rpt-donut-legend">
                    <div class="donut-leg-item"><span class="donut-leg-dot paid"></span><span>Paid</span><strong>@PaidVendors</strong></div>
                    <div class="donut-leg-item"><span class="donut-leg-dot unpaid"></span><span>Unpaid</span><strong>@UnpaidVendors</strong></div>
                </div>
            </div>
        </div>
    </div>

    <div class="rpt-section-heading"><span class="rpt-section-rule"></span><h2>Audit Breakdown</h2></div>

    <div class="rpt-breakdown-grid">

        <!-- Friday market days breakdown -->
        <div class="rpt-breakdown-card">
            <h4 class="breakdown-title">Friday Market Days</h4>
            <div class="breakdown-list">
                @foreach (var f in FridayBreakdown)
                {
                    <div class="breakdown-item">
                        <div class="breakdown-label"><span class="sec-dot" style="background:@f.Color"></span>@f.Label</div>
                        <div class="breakdown-value">@f.Vendors vendors</div>
                        <div class="breakdown-bar"><div class="bar-fill" style="width:@f.Pct%;background:@f.Color"></div></div>
                    </div>
                }
            </div>
            <div class="mini-panel">
                <div class="mini-panel-title">Fee Rate</div>
                <div class="fee-row"><span>Per vendor per Friday</span><div class="mini-meter"><div class="mini-meter-fill" style="width:100%;background:var(--green)"></div></div><strong>₱100</strong></div>
            </div>
        </div>

        <!-- Compliance -->
        <div class="rpt-breakdown-card">
            <h4 class="breakdown-title">Vendor Compliance</h4>
            <div class="breakdown-list">
                <div class="breakdown-item">
                    <div class="breakdown-label"><span class="status-badge paid">Paid</span></div>
                    <div class="breakdown-value">@PaidVendors entries</div>
                    <div class="breakdown-bar"><div class="bar-fill paid" style="width:@CollectionRate%"></div></div>
                </div>
                <div class="breakdown-item">
                    <div class="breakdown-label"><span class="status-badge unpaid">Unpaid</span></div>
                    <div class="breakdown-value">@UnpaidVendors entries</div>
                    <div class="breakdown-bar"><div class="bar-fill unpaid" style="width:@UnpaidPct%"></div></div>
                </div>
            </div>
            <div class="mini-panel">
                <div class="mini-panel-title">Uncollected</div>
                <div class="fee-row"><span>@UnpaidVendors vendors × ₱100</span><div class="mini-meter"><div class="mini-meter-fill" style="width:@UnpaidPct%;background:var(--red)"></div></div><strong>₱@PendingAmount.ToString("N0")</strong></div>
            </div>
        </div>

        <!-- Friday calendar -->
        <div class="rpt-breakdown-card rpt-streak-card">
            <h4 class="breakdown-title">Market Day Activity — @GetPeriodLabel()</h4>
            @if (ActivePeriod == "Yearly")
            {
                <div class="streak-calendar-area">
                    <div class="streak-yearly-grid">
                        @foreach (var mo in YearlyMonths)
                        { <div class="streak-month-cell @mo.Css" title="@mo.Label"><span class="streak-month-name">@mo.Name</span><span class="streak-month-rate">@mo.Rate</span></div> }
                    </div>
                </div>
            }
            else if (ActivePeriod == "Weekly")
            {
                <div class="streak-calendar-area">
                    <div class="streak-dow-row">@foreach(var d in new[]{"Su","Mo","Tu","We","Th","Fr","Sa"}){<span>@d</span>}</div>
                    <div class="streak-grid streak-grid-week">
                        @foreach(var day in WeekDays){<span class="streak-day @day.Css" title="@day.Label">@day.Num</span>}
                    </div>
                </div>
            }
            else
            {
                <div class="streak-calendar-area">
                    <div class="streak-dow-row">@foreach(var d in new[]{"Su","Mo","Tu","We","Th","Fr","Sa"}){<span>@d</span>}</div>
                    <div class="streak-grid">
                        @for(int b=0;b<CalendarLeadBlanks;b++){<span class="streak-day empty"></span>}
                        @foreach(var day in CalendarDays){<span class="streak-day @day.Css" title="@day.Label">@day.Num</span>}
                    </div>
                </div>
            }
            <div class="streak-legend">
                <span><i class="leg-swatch collected"></i>Market day (@ActiveFridays)</span>
                <span><i class="leg-swatch future"></i>Upcoming</span>
            </div>
        </div>
    </div>

    <div class="rpt-section-heading"><span class="rpt-section-rule"></span><h2>Vendor Attendance Log — @GetPeriodLabel()</h2></div>
    <div class="rpt-compliance-table-wrap">
        <table class="rpt-compliance-table">
            <thead><tr><th>Market Date</th><th>Vendor</th><th>Status</th><th>Fee</th><th>OR Number</th></tr></thead>
            <tbody>
                @foreach (var v in VendorLog)
                {
                    <tr class="@(v.IsPaid?"":"row-unpaid")">
                        <td class="text-muted">@v.Date</td>
                        <td>@v.VendorName</td>
                        <td><span class="status-badge @(v.IsPaid?"paid":"unpaid")">@(v.IsPaid?"Paid":"Unpaid")</span></td>
                        <td style="font-weight:600">₱@v.Fee.ToString("N0")</td>
                        <td class="text-muted">@(string.IsNullOrEmpty(v.ORNumber)?"—":v.ORNumber)</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>

@code {
    string ActivePeriod = "Monthly";
    DateTime CurrentDate = DateTime.Now;
    private TpmOverviewDto? Overview;
    private TpmOverviewDto? PrevOverview;
    private List<TpmMarketDayDto> MarketDays = new();
    private List<TpmVendorAttendanceDto> Att = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();
    async Task LoadAsync()
    {
        var ovr = await TpmApi.GetOverviewAsync(CurrentDate.Year, CurrentDate.Month);
        Overview = ovr.IsSuccess ? ovr.Value : null;
        var prevDate = CurrentDate.AddMonths(-1);
        var prev = await TpmApi.GetOverviewAsync(prevDate.Year, prevDate.Month);
        PrevOverview = prev.IsSuccess ? prev.Value : null;

        var md = await TpmApi.GetMarketDaysAsync(CurrentDate.Year, CurrentDate.Month);
        MarketDays = md.IsSuccess && md.Value != null ? md.Value.OrderBy(m => m.MarketDate).ToList() : new();

        Att = new();
        foreach (var day in MarketDays)
        {
            var a = await TpmApi.GetVendorAttendanceAsync(day.MarketDate);
            if (a.IsSuccess && a.Value != null) Att.AddRange(a.Value);
        }
    }
    async Task SetPeriod(string p) { ActivePeriod = p; await LoadAsync(); }
    async Task PrevPeriod() { CurrentDate = ActivePeriod switch { "Weekly" => CurrentDate.AddDays(-7), "Yearly" => CurrentDate.AddYears(-1), _ => CurrentDate.AddMonths(-1) }; await LoadAsync(); }
    async Task NextPeriod() { CurrentDate = ActivePeriod switch { "Weekly" => CurrentDate.AddDays(7),  "Yearly" => CurrentDate.AddYears(1),  _ => CurrentDate.AddMonths(1)  }; await LoadAsync(); }
    string GetPeriodLabel() => ActivePeriod switch { "Weekly" => $"Week of {CurrentDate:MMM d, yyyy}", "Yearly" => CurrentDate.ToString("yyyy"), _ => CurrentDate.ToString("MMMM yyyy") };

    decimal TotalCollected  => Overview?.CollectedThisMonth ?? 0m;
    int     CollectionRate  => Overview?.CollectionRate ?? 0;
    int     PaidVendors     => Att.Count(a => a.IsPaid);
    int     UnpaidVendors   => Att.Count(a => !a.IsPaid);
    int     TotalEntries    => Att.Count;
    int     MarketDaysCount => MarketDays.Count;
    int     ActiveFridays   => MarketDays.Count;
    decimal PendingAmount   => Att.Where(a => !a.IsPaid).Sum(a => a.Fee);
    int     UnpaidPct        => TotalEntries > 0 ? (int)((double)UnpaidVendors / TotalEntries * 100) : 0;
    string  RevenueGrowthText
    {
        get
        {
            var prev = PrevOverview?.CollectedThisMonth ?? 0m;
            var g = prev > 0 ? (TotalCollected - prev) / prev * 100 : 0m;
            return $"{g:+0.0;-0.0;0}% vs previous {ActivePeriod.ToLower()}";
        }
    }
    string  CollectionGrowthText
    {
        get
        {
            var g = CollectionRate - (PrevOverview?.CollectionRate ?? 0);
            return $"{g:+0;-0;0} pts vs previous {ActivePeriod.ToLower()}";
        }
    }

    record ArcSegment(string D, string Color);
    static IEnumerable<ArcSegment> BuildDonutArcs((int Count, string Color)[] segs, double r, double cx, double cy)
    {
        int total = segs.Sum(s => s.Count); if (total == 0) yield break;
        double start = -Math.PI / 2;
        foreach (var (count, color) in segs)
        {
            if (count == 0) continue;
            double sweep = 2 * Math.PI * count / total;
            double end = start + Math.Min(sweep, 2 * Math.PI - 0.0001);
            double x1 = cx + r * Math.Cos(start), y1 = cy + r * Math.Sin(start);
            double x2 = cx + r * Math.Cos(end),   y2 = cy + r * Math.Sin(end);
            yield return new ArcSegment($"M {x1:F3} {y1:F3} A {r} {r} 0 {(sweep > Math.PI ? 1 : 0)} 1 {x2:F3} {y2:F3}", color);
            start = end;
        }
    }

    record TrendPoint(string Label, decimal Amount, bool IsCurrent, int HeightPct)
    {
        public string ShortValue => Amount >= 1000 ? $"{Amount / 1000:N0}k" : Amount.ToString("N0");
    }
    IEnumerable<TrendPoint> TrendPoints
    {
        get
        {
            var max = MarketDays.Any() ? MarketDays.Max(m => m.TotalCollected) : 0m;
            return MarketDays.Select((m, i) => new TrendPoint(m.MarketDate.ToString("MMM d"), m.TotalCollected,
                i == MarketDays.Count - 1, max > 0 ? (int)(m.TotalCollected / max * 100) : 0));
        }
    }

    record FridayRow(string Label, int Vendors, int Pct, string Color);
    IEnumerable<FridayRow> FridayBreakdown
    {
        get
        {
            var colors = new[] { "#2d7a5f", "#c8a84b", "#4a9eff", "#8b3a3a", "#6a8aa0" };
            var max = MarketDays.Any() ? MarketDays.Max(m => m.VendorsPaid) : 0;
            return MarketDays.Select((m, i) => new FridayRow(m.MarketDate.ToString("MMM d"), m.VendorsPaid,
                max > 0 ? (int)((double)m.VendorsPaid / max * 100) : 0, colors[i % colors.Length]));
        }
    }

    // Calendar — only Fridays matter; highlight market days from data
    record CalDay(string Num, string Css, string Label);
    HashSet<int> MarketDayNums => MarketDays.Where(m => m.MarketDate.Year == CurrentDate.Year && m.MarketDate.Month == CurrentDate.Month)
        .Select(m => m.MarketDate.Day).ToHashSet();
    int CalendarLeadBlanks => (int)new DateTime(CurrentDate.Year, CurrentDate.Month, 1).DayOfWeek;
    int DaysInMonth => DateTime.DaysInMonth(CurrentDate.Year, CurrentDate.Month);
    IEnumerable<CalDay> CalendarDays => Enumerable.Range(1, DaysInMonth).Select(i =>
    {
        var dt = new DateTime(CurrentDate.Year, CurrentDate.Month, i);
        if (MarketDayNums.Contains(i)) return new CalDay(i.ToString(), "collected", $"Market day — {dt:MMM d}");
        if (dt.DayOfWeek == DayOfWeek.Friday && dt.Date > DateTime.Today) return new CalDay(i.ToString(), "future", $"Upcoming — {dt:MMM d}");
        return new CalDay(i.ToString(), "empty", "");
    });
    IEnumerable<CalDay> WeekDays
    {
        get
        {
            var sun = CurrentDate.AddDays(-(int)CurrentDate.DayOfWeek);
            return Enumerable.Range(0, 7).Select(i =>
            {
                var d = sun.AddDays(i);
                var css = d.Month == CurrentDate.Month && MarketDayNums.Contains(d.Day) ? "collected"
                    : d.DayOfWeek == DayOfWeek.Friday && d.Date > DateTime.Today ? "future" : "empty";
                return new CalDay(d.Day.ToString(), css, $"{d:ddd MMM d}");
            });
        }
    }
    record MonthCell(string Name, int Rate, string Css, string Label);
    IEnumerable<MonthCell> YearlyMonths => Array.Empty<MonthCell>();

    record VendorRow(string Date, string VendorName, bool IsPaid, decimal Fee, string ORNumber);
    IEnumerable<VendorRow> VendorLog => Att
        .OrderBy(a => a.MarketDate).ThenBy(a => a.VendorName)
        .Select(a => new VendorRow(a.MarketDate.ToString("MMM dd"), a.VendorName, a.IsPaid, a.Fee, a.ORNumber ?? ""));
}
