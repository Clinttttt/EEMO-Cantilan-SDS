@page "/tpm/reports"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using EEMOCantilanSDS.Application.Dtos.TaboanMarket
@using EEMOCantilanSDS.Application.Dtos.Facilities
@using EEMOCantilanSDS.Domain.Constants
@inject ITpmApiClient TpmApi
@inject IJSRuntime JS

<PageTitle>@Branding.OfficeAcronym Admin — TPM Reports</PageTitle>

<!-- ══ Topbar ══ -->
<div class="rpt-topbar">
    <div class="rpt-topbar-left">
        <a href="/tpm" class="rpt-back-btn" title="Back to TPM">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
        </a>
        <div class="rpt-topbar-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
        </div>
        <div>
            <div class="rpt-eyebrow">FACILITY · TPM · REPORTS</div>
            <div class="rpt-title">Tabo-an Public Market Reports</div>
            <div class="rpt-subtitle">@(ShowPrintReport ? PrintReportPeriodLabel : ShowHistory ? HistoryPeriodLabel : GetPeriodLabel())</div>
        </div>
    </div>
    <div class="rpt-topbar-right">
        <LiveClock />
    </div>
</div>

<!-- ══ Period Selector ══ -->
<div class="rpt-period-bar">
    <div class="rpt-period-tabs">
        @foreach (var p in new[] { "Weekly", "Monthly", "Yearly" })
        {
            <button type="button" class="rpt-period-tab @(!ShowPrintReport && !ShowHistory && ActivePeriod == p ? "active" : "")"
                    aria-pressed="@(!ShowPrintReport && !ShowHistory && ActivePeriod == p)"
                    @onclick="() => SetPeriod(p)">@p</button>
        }
        <button type="button" class="rpt-period-tab rpt-document-tab @(ShowPrintReport ? "active" : "")"
                aria-pressed="@ShowPrintReport" @onclick="ShowPrintReportView">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="8" y1="13" x2="16" y2="13" /><line x1="8" y1="17" x2="16" y2="17" /></svg>
            <span>Status Report</span>
        </button>
        <button type="button" class="rpt-period-tab rpt-document-tab @(ShowHistory ? "active" : "")"
                aria-pressed="@ShowHistory" @onclick="ShowHistoryView">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>History</span>
        </button>
    </div>
    <ReportPeriodNav Year="CurrentDate.Year" Month="CurrentDate.Month"
                     Yearly="@(!ShowPrintReport && (ShowHistory || ActivePeriod == "Yearly"))"
                     Label="@(ShowPrintReport ? PrintReportPeriodLabel : ShowHistory ? HistoryPeriodLabel : GetPeriodLabel())"
                     UtilityMode="@(ShowPrintReport || ShowHistory)"
                     OnPrev="PrevPeriod" OnNext="NextPeriod"
                     OnPick="PickPeriod" OnToday="JumpToCurrent" />
</div>

@if (ShowPrintReport)
{
    <!-- ══ Phase 2: Status Report ══ -->
    <div class="rpt-content print-document-content">
        <section class="print-report-sheet status-sheet">
            <header class="print-report-header">
                <img class="print-report-logo" src="@Branding.SealPath" alt="LGU Cantilan logo" />
                <div class="print-republic">Republic of the Philippines</div>
                <h2>@Branding.OfficeName</h2>
                <p>Municipality of @Branding.Municipality, @Branding.Province</p>
                <div class="print-report-title">Tabo-an Public Market — Collection Status Report</div>
            </header>
            <div class="print-report-meta">
                <div><span>Facility</span><strong>Tabo-an Public Market</strong></div>
                <div><span>Report Period</span><strong>@CurrentDate.ToString("MMMM yyyy")</strong></div>
                <div><span>Prepared By</span><strong>@Branding.OfficeAcronym Office</strong></div>
                <div><span>Date Prepared</span><strong>@PhilippineTime.Now.ToString("MMM d, yyyy")</strong></div>
            </div>
            <div class="print-report-summary">
                <div><span>Vendor Entries</span><strong>@MonthAtt.Count</strong></div>
                <div><span>Market Days</span><strong>@MonthAtt.Select(a => a.MarketDate).Distinct().Count()</strong></div>
                <div><span>Fees Collected</span><strong>&#8369;@MonthAtt.Where(a => a.IsPaid).Sum(a => a.Fee).ToString("N2")</strong></div>
            </div>
            @if (!MonthAtt.Any())
            {
                <p class="print-empty">No vendor attendance recorded for @CurrentDate.ToString("MMMM yyyy").</p>
            }
            else
            {
                <div class="print-table-wrap">
                    <table class="print-status-table status-sheet">
                        <thead>
                            <tr>
                                <th>Market Date</th>
                                <th>Vendor</th>
                                <th>Goods</th>
                                <th>Fee</th>
                                <th>OR No.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in MonthAtt)
                            {
                                <tr>
                                    <td>@a.MarketDate.ToString("MMM d")</td>
                                    <td>@a.VendorName</td>
                                    <td>@a.Goods</td>
                                    <td>&#8369;@a.Fee.ToString("N2")</td>
                                    <td class="text-muted-cell">@(string.IsNullOrEmpty(a.ORNumber) ? "—" : a.ORNumber)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            <div class="print-report-signatures">
                <div><span>Prepared by</span><strong>Administrative Staff</strong></div>
                <div><span>Reviewed by</span><strong>Head, @Branding.OfficeAcronym Office</strong></div>
                <div><span>Received by</span><strong>Authorized Representative</strong></div>
            </div>
        </section>
    </div>
}
else if (ShowHistory)
{
    <!-- ══ Phase 3: History ══ -->
    <div class="rpt-content print-document-content">
        <section class="print-report-sheet history-sheet">
            <header class="print-report-header">
                <img class="print-report-logo" src="@Branding.SealPath" alt="LGU Cantilan logo" />
                <div class="print-republic">Republic of the Philippines</div>
                <h2>@Branding.OfficeName</h2>
                <p>Municipality of @Branding.Municipality, @Branding.Province</p>
                <div class="print-report-title">Tabo-an Public Market — Collection History</div>
            </header>
            <div class="print-report-meta">
                <div><span>Facility</span><strong>Tabo-an Public Market</strong></div>
                <div><span>Year</span><strong>@CurrentDate.Year</strong></div>
                <div><span>Prepared By</span><strong>@Branding.OfficeAcronym Office</strong></div>
                <div><span>Date Prepared</span><strong>@PhilippineTime.Now.ToString("MMM d, yyyy")</strong></div>
            </div>

            <div class="print-section-block">
                <div class="print-section-heading">Monthly Collection — @CurrentDate.Year</div>
                <div class="print-table-wrap">
                    <table class="print-status-table history-table">
                        <thead>
                            <tr><th>Month</th><th>Market Days</th><th>Vendor Entries</th><th>Collected</th></tr>
                        </thead>
                        <tbody>
                            @if (!HistoryMonthly.Any())
                            {
                                <tr><td colspan="4" class="history-empty">@(HistoryLoading ? "Loading…" : "No collection records for this year.")</td></tr>
                            }
                            @foreach (var row in HistoryMonthly)
                            {
                                <tr>
                                    <td>@row.Label</td>
                                    <td>@row.MarketDays</td>
                                    <td>@row.VendorEntries</td>
                                    <td>@(row.Collected > 0 ? "₱" + row.Collected.ToString("N2") : "—")</td>
                                </tr>
                            }
                        </tbody>
                        @if (HistoryMonthly.Any())
                        {
                            <tfoot>
                                <tr class="history-total-row">
                                    <td><strong>Total</strong></td>
                                    <td><strong>@HistoryMonthly.Sum(r => r.MarketDays)</strong></td>
                                    <td><strong>@HistoryMonthly.Sum(r => r.VendorEntries)</strong></td>
                                    <td><strong>₱@HistoryMonthly.Sum(r => r.Collected).ToString("N2")</strong></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>

            <div class="print-section-block">
                <div class="print-section-heading">Yearly Collection Summary</div>
                <div class="print-table-wrap">
                    <table class="print-status-table history-table">
                        <thead>
                            <tr><th>Year</th><th>Market Days</th><th>Vendor Entries</th><th>Collected</th></tr>
                        </thead>
                        <tbody>
                            @if (!HistoryYearly.Any())
                            {
                                <tr><td colspan="4" class="history-empty">@(HistoryLoading ? "Loading…" : "No yearly records.")</td></tr>
                            }
                            @foreach (var row in HistoryYearly)
                            {
                                <tr>
                                    <td><strong>@row.Label</strong></td>
                                    <td>@row.MarketDays</td>
                                    <td>@row.VendorEntries</td>
                                    <td>@(row.Collected > 0 ? "₱" + row.Collected.ToString("N2") : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="print-report-signatures">
                <div><span>Prepared by</span><strong>Administrative Staff</strong></div>
                <div><span>Reviewed by</span><strong>Head, @Branding.OfficeAcronym Office</strong></div>
                <div><span>Received by</span><strong>Authorized Representative</strong></div>
            </div>
        </section>
    </div>
}
else
{
    <!-- ══ Phase 1: Monthly / Yearly ══ -->
    <div class="rpt-kpi-strip">
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-green"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h7a4 4 0 0 1 0 8H6z" /><line x1="4" y1="9" x2="16" y2="9" /><line x1="4" y1="13" x2="16" y2="13" /><line x1="6" y1="4" x2="6" y2="20" /></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Market Fees Collected</div>
                <div class="kpi-value">&#8369;@TotalCollected.ToString("N2")</div>
                <div class="kpi-change">@ActivePeriod.ToLower() total</div>
            </div>
        </div>
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-gold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Avg Vendors / Market Day</div>
                <div class="kpi-value">@AvgVendorsPerMarketDay.ToString("0.#")</div>
                <div class="kpi-change">across @MarketDays market day@(MarketDays != 1 ? "s" : "")</div>
            </div>
        </div>
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-neutral"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Top Goods</div>
                <div class="kpi-value kpi-value-text">@TopGoods</div>
                <div class="kpi-change">@(TopGoodsEntries > 0 ? $"{TopGoodsEntries} entr{(TopGoodsEntries == 1 ? "y" : "ies")}" : "no entries yet")</div>
            </div>
        </div>
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-neutral"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Vendor Entries</div>
                <div class="kpi-value">@VendorEntries</div>
                <div class="kpi-change">across @MarketDays market day@(MarketDays != 1 ? "s" : "")</div>
            </div>
        </div>
    </div>

    <div class="rpt-content">

        <!-- Charts Row -->
        <div class="rpt-charts-row">
            <div class="rpt-chart-card rpt-chart-wide">
                <div class="chart-header">
                    <div class="chart-header-left">
                        <h3 class="chart-title">Collection Trend</h3>
                        <p class="chart-subtitle">@(ActivePeriod switch { "Yearly" => "Collected fees by year", "Weekly" => "Collected fees by Friday (market day)", _ => "Collected fees by month" })</p>
                    </div>
                    <div class="chart-legend">
                        <div class="legend-item"><span class="legend-dot" style="background:#2d7a5f"></span><span class="legend-label">Collected</span></div>
                        <div class="legend-item"><span class="legend-dot" style="background:#c8a84b"></span><span class="legend-label">Current Period</span></div>
                    </div>
                </div>
                <CollectionTrendChart Trend="_revenueTrend" RentLabel="Collected" EmptyPeriodLabel="@GetPeriodLabel()" />
            </div>

            <!-- Vendors by Goods donut -->
            <div class="rpt-chart-card rpt-chart-narrow rpt-status-card">
                <div class="chart-header">
                    <div class="chart-header-left">
                        <h3 class="chart-title">Vendors by Goods</h3>
                        <p class="chart-subtitle">@(GoodsBreakdown.Count > 5 ? $"Top 5 of {GoodsBreakdown.Count} categories" : "Share of entries per goods")</p>
                    </div>
                </div>
                <div class="rpt-donut-wrap">
                    <div class="rpt-donut-container">
                        <svg class="rpt-donut-svg" viewBox="0 0 120 120">
                            <defs>
                                @foreach (var c in GoodsSegments.Select(s => s.Color).Distinct())
                                {
                                    <linearGradient id="@TpmGradId(c)" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="@c" /><stop offset="100%" stop-color="@Darken(c)" />
                                    </linearGradient>
                                }
                                <radialGradient id="tpm-donut-hole" cx="50%" cy="40%" r="62%">
                                    <stop offset="0%" stop-color="#ffffff" /><stop offset="100%" stop-color="#eef2f6" />
                                </radialGradient>
                                <filter id="tpm-donut-depth" x="-30%" y="-30%" width="160%" height="160%">
                                    <feDropShadow dx="0" dy="5" stdDeviation="4" flood-color="#0d2137" flood-opacity="0.18" />
                                </filter>
                            </defs>
                            <circle cx="60" cy="60" r="46" fill="none" stroke="#eef2f6" stroke-width="18" />
                            @{ var gArcs = BuildDonutArcs(GoodsSegments.Select(s => (s.Count, $"url(#{TpmGradId(s.Color)})")).ToArray(), 46, 60, 60); }
                            <g filter="url(#tpm-donut-depth)">
                                @foreach (var arc in gArcs)
                                {
                                    <path d="@arc.D" fill="none" stroke="@arc.Color" stroke-width="18" stroke-linecap="butt" class="donut-segment" />
                                }
                            </g>
                            <circle cx="60" cy="60" r="35" fill="url(#tpm-donut-hole)" />
                            <circle cx="60" cy="60" r="35" fill="none" stroke="rgba(13,33,55,0.07)" stroke-width="1" />
                            <text x="60" y="56" class="donut-center-val">@VendorEntries</text>
                            <text x="60" y="70" class="donut-center-lbl">ENTRIES</text>
                        </svg>
                    </div>
                    <div class="rpt-donut-legend">
                        @foreach (var seg in GoodsSegments)
                        {
                            var legPct = VendorEntries > 0 ? (int)Math.Round((double)seg.Count / VendorEntries * 100) : 0;
                            <div class="donut-leg-item">
                                <div class="donut-leg-left"><span class="donut-leg-dot" style="background:linear-gradient(180deg, @seg.Color 0%, @Darken(seg.Color) 100%)"></span><span class="donut-leg-label">@seg.Label</span></div>
                                <strong class="donut-leg-value">@seg.Count <span class="donut-leg-pct">· @legPct%</span></strong>
                            </div>
                        }
                        @if (!GoodsSegments.Any())
                        {
                            <div class="delinq-empty">No vendor entries for @GetPeriodLabel().</div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Audit Breakdown -->
        <div class="rpt-section-heading"><span class="rpt-section-rule"></span><h2>Audit Breakdown</h2></div>

        <div class="rpt-audit-row">
            <!-- Vendors by Goods -->
            <div class="audit-card tpm-breakdown-card">
                <div class="audit-card-head">
                    <span>Vendors by Goods</span>
                    <small class="audit-subtitle">Entries &amp; fees per goods category</small>
                </div>
                @if (GoodsBreakdown.Any())
                {
                    <div class="tpm-tally-scroll">
                        @foreach (var g in GoodsBreakdown)
                        {
                            var pct = VendorEntries > 0 ? Math.Min(100, (int)Math.Round((double)g.Entries / VendorEntries * 100)) : 0;
                            <div class="tpm-tally-row">
                                <div class="tpm-tally-top">
                                    <span class="tpm-tally-name">@g.Goods</span>
                                    <span class="tpm-tally-pct">@pct%</span>
                                </div>
                                <div class="tpm-tally-meter"><div class="tpm-tally-fill" style="width:@pct%"></div></div>
                                <div class="tpm-tally-vals"><span><strong>@g.Entries</strong> entr@(g.Entries != 1 ? "ies" : "y")</span><span class="tpm-tally-sep">·</span><span>&#8369;@g.Collected.ToString("N0") collected</span></div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="delinq-empty">No vendor entries for @GetPeriodLabel().</div>
                }
            </div>

            <!-- Attendance / summary log beside the breakdown -->
            <div class="audit-card tpm-log-card">
                <div class="audit-card-head">
                    <span>@(IsYearly ? $"Monthly Summary — {CurrentDate.Year}" : $"Vendor Attendance Log — {GetPeriodLabel()}")</span>
                </div>
                <div class="tpm-log-scroll">
                    @if (IsYearly)
                    {
                        <table class="rpt-compliance-table">
                            <thead><tr><th>Month</th><th>Market Days</th><th>Vendor Entries</th><th>Collected</th></tr></thead>
                            <tbody>
                                @foreach (var row in HistoryMonthly)
                                {
                                    <tr>
                                        <td class="stall-no">@row.Label</td>
                                        <td>@row.MarketDays</td>
                                        <td>@row.VendorEntries</td>
                                        <td>@(row.Collected > 0 ? "₱" + row.Collected.ToString("N2") : "—")</td>
                                    </tr>
                                }
                                @if (!HistoryMonthly.Any())
                                {
                                    <tr><td colspan="4" class="delinq-empty">No records for @CurrentDate.Year.</td></tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <table class="rpt-compliance-table">
                            <thead><tr><th>Market Date</th><th>Vendor</th><th>Goods</th><th>Fee</th><th>OR Number</th></tr></thead>
                            <tbody>
                                @foreach (var a in MonthAtt)
                                {
                                    <tr>
                                        <td class="text-muted">@a.MarketDate.ToString("MMM d")</td>
                                        <td>@a.VendorName</td>
                                        <td>@a.Goods</td>
                                        <td class="tpm-fee">&#8369;@a.Fee.ToString("N0")</td>
                                        <td class="text-muted">@(string.IsNullOrEmpty(a.ORNumber) ? "—" : a.ORNumber)</td>
                                    </tr>
                                }
                                @if (!MonthAtt.Any())
                                {
                                    <tr><td colspan="5" class="delinq-empty">No vendor attendance for @GetPeriodLabel().</td></tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
            </div>
        </div>

    </div><!-- end rpt-content -->
}

@code {

    // ── Period / view state ───────────────────────────────────────
    string ActivePeriod = "Monthly";
    bool ShowPrintReport = false;
    bool ShowHistory = false;
    DateTime CurrentDate = PhilippineTime.Now;

    private List<TpmVendorAttendanceDto> MonthAtt = new();
    private TpmHistoryDto? Hist;
    private bool HistoryLoading;

    // Trailing 6-month collected totals for the Monthly trend chart (oldest → newest).
    private List<(int Year, int Month, decimal Collected)> _trendMonthly = new();

    // Full month's attendance kept for the Weekly trend's per-Friday (market-day) series.
    private List<TpmVendorAttendanceDto> _weekTrendSource = new();

    [PersistentState(AllowUpdates = true)]
    public TpmReportsPageState? CachedReport { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (TryApplyCachedReport())
            return;

        await LoadAsync();
    }

    async Task LoadAsync()
    {
        if (ShowHistory)
        {
            HistoryLoading = true;
            var h = await TpmApi.GetHistoryAsync(CurrentDate.Year);
            Hist = h.IsSuccess ? h.Value : null;
            HistoryLoading = false;
        }
        else if (ActivePeriod == "Yearly" && !ShowPrintReport)
        {
            var h = await TpmApi.GetHistoryAsync(CurrentDate.Year);
            Hist = h.IsSuccess ? h.Value : null;
        }
        else
        {
            // Monthly/Weekly (Phase 1) and the Status Report all start from the month's attendance.
            var r = await TpmApi.GetMonthAttendanceAsync(CurrentDate.Year, CurrentDate.Month);
            var att = r.IsSuccess && r.Value != null ? r.Value.ToList() : new();

            // Weekly view: keep the full month for the per-Friday trend, but scope the KPIs/table
            // to the selected week-of-month.
            if (ActivePeriod == "Weekly" && !ShowPrintReport)
            {
                _weekTrendSource = att;
                var (fromDay, toDay) = WeekDayRange();
                att = att.Where(a => a.MarketDate.Day >= fromDay && a.MarketDate.Day <= toDay).ToList();
            }

            MonthAtt = att;

            // The Monthly view's trend is a trailing 6-month window (like NPM), sourced from history.
            if (ActivePeriod == "Monthly" && !ShowPrintReport)
                _trendMonthly = await BuildMonthlyTrendHistoryAsync();
        }

        RecomputeDerived();
        CachedReport = new TpmReportsPageState(
            ActivePeriod,
            ShowPrintReport,
            ShowHistory,
            CurrentDate.Year,
            CurrentDate.Month,
            WeekIndex,
            MonthAtt.ToList(),
            Hist,
            _trendMonthly.Select(t => new ReportTrendState(t.Year, t.Month, t.Collected)).ToList(),
            _weekTrendSource.ToList());
    }

    private bool TryApplyCachedReport()
    {
        if (CachedReport is not { } state
            || state.ActivePeriod != ActivePeriod
            || state.ShowPrintReport != ShowPrintReport
            || state.ShowHistory != ShowHistory
            || state.Year != CurrentDate.Year
            || state.Month != CurrentDate.Month
            || state.WeekIndex != WeekIndex)
        {
            return false;
        }

        MonthAtt = state.MonthAttendance.ToList();
        Hist = state.History;
        _trendMonthly = state.MonthlyTrend.Select(t => (t.Year, t.Month, t.Collected)).ToList();
        _weekTrendSource = state.WeekTrendSource.ToList();
        RecomputeDerived();
        return true;
    }

    void RecomputeDerived()
    {
        _goodsBreakdown = BuildGoodsBreakdown();
        _goodsSegments = BuildGoodsSegments(_goodsBreakdown);
        _revenueTrend = BuildRevenueTrend();
    }

    // Trailing 6-month collected totals (oldest → newest) ending at the selected month, from history.
    // Spans at most two years, so it loads 1-2 history calls.
    async Task<List<(int Year, int Month, decimal Collected)>> BuildMonthlyTrendHistoryAsync()
    {
        var anchor = new DateTime(CurrentDate.Year, CurrentDate.Month, 1);
        var targets = Enumerable.Range(0, 6).Select(i => anchor.AddMonths(i - 5)).ToList();

        var collectedByMonth = new Dictionary<(int Year, int Month), decimal>();
        foreach (var year in targets.Select(d => d.Year).Distinct())
        {
            var h = await TpmApi.GetHistoryAsync(year);
            if (h.IsSuccess && h.Value is not null)
                foreach (var m in h.Value.Monthly.Where(m => m.Month.HasValue))
                    collectedByMonth[(m.Year, m.Month!.Value)] = m.Collected;
        }

        return targets
            .Select(d => (d.Year, d.Month, collectedByMonth.TryGetValue((d.Year, d.Month), out var c) ? c : 0m))
            .ToList();
    }

    // All Fridays (market days) of the given month, in date order.
    static IEnumerable<DateOnly> FridaysOfMonth(int year, int month)
    {
        var days = DateTime.DaysInMonth(year, month);
        for (var d = 1; d <= days; d++)
        {
            var date = new DateOnly(year, month, d);
            if (date.DayOfWeek == DayOfWeek.Friday) yield return date;
        }
    }

    async Task SetPeriod(string p) { ShowPrintReport = false; ShowHistory = false; ActivePeriod = p; await LoadAsync(); }
    async Task ShowPrintReportView() { ShowPrintReport = true; ShowHistory = false; await LoadAsync(); }
    async Task ShowHistoryView() { ShowHistory = true; ShowPrintReport = false; await LoadAsync(); }
    async Task PrintPage() => await JS.InvokeVoidAsync("print");

    async Task PrevPeriod()
    {
        if (ShowHistory) { CurrentDate = CurrentDate.AddYears(-1); await LoadAsync(); return; }
        if (ShowPrintReport) { CurrentDate = CurrentDate.AddMonths(-1); await LoadAsync(); return; }
        CurrentDate = ActivePeriod switch
        {
            "Weekly" => CurrentDate.AddDays(-7),
            "Yearly" => CurrentDate.AddYears(-1),
            _        => CurrentDate.AddMonths(-1)
        };
        await LoadAsync();
    }
    async Task NextPeriod()
    {
        if (ShowHistory) { CurrentDate = CurrentDate.AddYears(1); await LoadAsync(); return; }
        if (ShowPrintReport) { CurrentDate = CurrentDate.AddMonths(1); await LoadAsync(); return; }
        CurrentDate = ActivePeriod switch
        {
            "Weekly" => CurrentDate.AddDays(7),
            "Yearly" => CurrentDate.AddYears(1),
            _        => CurrentDate.AddMonths(1)
        };
        await LoadAsync();
    }

    string GetPeriodLabel() => ActivePeriod switch
    {
        "Weekly" => $"Week of {WeekStartDate:MMM d}\u2013{WeekEndDate:%d}, {WeekStartDate:yyyy}",
        "Yearly" => CurrentDate.ToString("yyyy"),
        _        => CurrentDate.ToString("MMMM yyyy")
    };

    // Week-of-month model (days 1-7, 8-14, …) — mirrors NPM so a week stays within one month.
    int WeekIndex => ((CurrentDate.Day - 1) / 7) + 1;
    (int FromDay, int ToDay) WeekDayRange()
    {
        var daysInMonth = DateTime.DaysInMonth(CurrentDate.Year, CurrentDate.Month);
        return ((WeekIndex - 1) * 7 + 1, Math.Min(WeekIndex * 7, daysInMonth));
    }
    DateTime WeekStartDate => new(CurrentDate.Year, CurrentDate.Month, WeekDayRange().FromDay);
    DateTime WeekEndDate => new(CurrentDate.Year, CurrentDate.Month, WeekDayRange().ToDay);
    string PrintReportPeriodLabel => $"Status Report — {CurrentDate:MMMM yyyy}";
    string HistoryPeriodLabel => $"History — {CurrentDate.Year}";

    async Task PickPeriod((int Year, int Month) p)
    {
        CurrentDate = new DateTime(p.Year, p.Month, 1);
        await LoadAsync();
    }
    async Task JumpToCurrent()
    {
        CurrentDate = PhilippineTime.Now;
        await LoadAsync();
    }

    bool IsYearly => ActivePeriod == "Yearly";
    private TpmPeriodSummaryDto? YearRow => Hist?.Yearly.FirstOrDefault(y => y.Year == CurrentDate.Year);

    // ── KPI values (period-aware) ─────────────────────────────────
    decimal TotalCollected => IsYearly ? (YearRow?.Collected ?? 0m) : MonthAtt.Where(a => a.IsPaid).Sum(a => a.Fee);
    int     VendorEntries  => IsYearly ? (YearRow?.VendorEntries ?? 0) : MonthAtt.Count;
    int     MarketDays     => IsYearly ? (YearRow?.MarketDays ?? 0) : MonthAtt.Select(a => a.MarketDate).Distinct().Count();
    decimal AvgVendorsPerMarketDay => MarketDays > 0 ? Math.Round((decimal)VendorEntries / MarketDays, 1) : 0m;
    string  TopGoods       => GoodsBreakdown.Count > 0 ? GoodsBreakdown[0].Goods : "—";
    int     TopGoodsEntries => GoodsBreakdown.Count > 0 ? GoodsBreakdown[0].Entries : 0;

    // ── Goods breakdown (period-aware, memoized) ──────────────────
    record TallyRow(string Goods, int Entries, decimal Collected);
    private IReadOnlyList<TallyRow> _goodsBreakdown = Array.Empty<TallyRow>();
    IReadOnlyList<TallyRow> GoodsBreakdown => _goodsBreakdown;

    IReadOnlyList<TallyRow> BuildGoodsBreakdown()
    {
        if (IsYearly)
            return (YearRow?.Goods ?? new List<TpmGoodsTallyDto>())
                .Select(g => new TallyRow(g.Goods, g.Entries, g.Collected)).ToList();
        return MonthAtt
            .GroupBy(a => string.IsNullOrWhiteSpace(a.Goods) ? "—" : a.Goods)
            .Select(g => new TallyRow(g.Key, g.Count(), g.Where(a => a.IsPaid).Sum(a => a.Fee)))
            .OrderByDescending(g => g.Entries)
            .ToList();
    }

    // ── Goods donut segments (top 5 + Other) — mirrors TRM's route donut ──
    record DonutSeg(string Label, int Count, string Color);
    static readonly string[] GoodsPalette = { "#1e3a5f", "#2d7a5f", "#c8a84b", "#6a8aa0", "#b5894e" };
    private IReadOnlyList<DonutSeg> _goodsSegments = Array.Empty<DonutSeg>();
    IReadOnlyList<DonutSeg> GoodsSegments => _goodsSegments;

    IReadOnlyList<DonutSeg> BuildGoodsSegments(IReadOnlyList<TallyRow> ranked)
    {
        var segs = ranked.Take(5)
            .Select((g, i) => new DonutSeg(g.Goods, g.Entries, GoodsPalette[i % GoodsPalette.Length]))
            .ToList();
        var rest = ranked.Skip(5).ToList();
        var other = rest.Sum(g => g.Entries);
        if (other > 0)
            segs.Add(new DonutSeg($"Other ({rest.Count} categor{(rest.Count == 1 ? "y" : "ies")})", other, "#c3ced8"));
        return segs;
    }

    // ── Trend (per Friday for Monthly, per month for Yearly; memoized) ──
    private List<RevenueTrendDto> _revenueTrend = new();

    List<RevenueTrendDto> BuildRevenueTrend()
    {
        var today = PhilippineTime.Today;
        List<(string Label, decimal Amount, bool IsCurrent)> pts;
        if (ActivePeriod == "Yearly")
        {
            // Yearly: trailing years (server returns a rolling last-5-years window), like NPM.
            pts = (Hist?.Yearly ?? new List<TpmPeriodSummaryDto>())
                .OrderBy(y => y.Year)
                .Select(y => (
                    Label: y.Year.ToString(),
                    Amount: y.Collected,
                    IsCurrent: y.Year == today.Year))
                .ToList();
        }
        else if (ActivePeriod == "Weekly")
        {
            // Tabo-an is a Friday-only market, so the weekly trend plots each Friday (market day) of
            // the month by date; the Friday in the selected week is highlighted as the current bar.
            var (fromDay, toDay) = WeekDayRange();
            var feeByDate = _weekTrendSource
                .Where(a => a.IsPaid)
                .GroupBy(a => a.MarketDate)
                .ToDictionary(g => g.Key, g => g.Sum(a => a.Fee));
            pts = FridaysOfMonth(CurrentDate.Year, CurrentDate.Month)
                .Select(d => (
                    Label: d.ToString("MMM d"),
                    Amount: feeByDate.TryGetValue(d, out var amt) ? amt : 0m,
                    IsCurrent: d.Day >= fromDay && d.Day <= toDay))
                .ToList();
        }
        else
        {
            // Monthly: trailing 6 months ending at the selected month (from history), like NPM.
            pts = _trendMonthly
                .Select(m => (
                    Label: new DateOnly(m.Year, m.Month, 1).ToString("MMM yyyy"),
                    Amount: m.Collected,
                    IsCurrent: m.Year == today.Year && m.Month == today.Month))
                .ToList();
        }
        // Map to the shared chart's DTO (single-segment: TPM has no fish fee).
        return pts
            .Select(x => new RevenueTrendDto(x.Label, x.Amount, ExpectedRevenue: x.Amount, IsCurrentPeriod: x.IsCurrent))
            .ToList();
    }

    // ── History rows (Phase 3 + yearly monthly-summary) ───────────
    IReadOnlyList<TpmPeriodSummaryDto> HistoryMonthly => Hist?.Monthly ?? new List<TpmPeriodSummaryDto>();
    IReadOnlyList<TpmPeriodSummaryDto> HistoryYearly => Hist?.Yearly ?? new List<TpmPeriodSummaryDto>();

    public sealed record TpmReportsPageState(
        string ActivePeriod,
        bool ShowPrintReport,
        bool ShowHistory,
        int Year,
        int Month,
        int WeekIndex,
        List<TpmVendorAttendanceDto> MonthAttendance,
        TpmHistoryDto? History,
        List<ReportTrendState> MonthlyTrend,
        List<TpmVendorAttendanceDto> WeekTrendSource);

    public sealed record ReportTrendState(int Year, int Month, decimal Collected);

    // ── Donut arc builder ─────────────────────────────────────────
    // Per-segment vertical gradient id + a darker shade for the bottom stop (matches NPM's donut depth).
    static string TpmGradId(string color) => "tpmg-" + color.TrimStart('#');
    static string Darken(string hex, double f = 0.68)
    {
        hex = hex.TrimStart('#');
        if (hex.Length != 6) return "#" + hex;
        var r = (int)(Convert.ToInt32(hex.Substring(0, 2), 16) * f);
        var g = (int)(Convert.ToInt32(hex.Substring(2, 2), 16) * f);
        var b = (int)(Convert.ToInt32(hex.Substring(4, 2), 16) * f);
        return $"#{r:X2}{g:X2}{b:X2}";
    }

    record ArcSegment(string D, string Color);
    static IEnumerable<ArcSegment> BuildDonutArcs((int Count, string Color)[] segments, double r, double cx, double cy)
    {
        int total = segments.Sum(s => s.Count);
        if (total == 0) yield break;
        double start = -Math.PI / 2;
        foreach (var (count, color) in segments)
        {
            if (count == 0) continue;
            double sweep = 2 * Math.PI * count / total;
            double end = start + Math.Min(sweep, 2 * Math.PI - 0.0001);
            double x1 = cx + r * Math.Cos(start), y1 = cy + r * Math.Sin(start);
            double x2 = cx + r * Math.Cos(end),   y2 = cy + r * Math.Sin(end);
            yield return new ArcSegment($"M {x1:F3} {y1:F3} A {r} {r} 0 {(sweep > Math.PI ? 1 : 0)} 1 {x2:F3} {y2:F3}", color);
            start = end;
        }
    }
}
