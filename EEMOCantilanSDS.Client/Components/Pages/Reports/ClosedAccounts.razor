@page "/reports/closed-accounts"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using EEMOCantilanSDS.Domain.Common
@using EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Application.Dtos.Stalls
@using EEMOCantilanSDS.Application.Requests.Stalls
@inject IStallsApiClient StallsApi
@inject IJSRuntime JS
@inject EEMOCantilanSDS.Client.Services.FacilityState FacilityCatalog

@* ───────────────────────────────────────────────────────────────────────────────
   Closed / Inactive Accounts — transparency register of CLOSED (frozen) and EXPIRED
   (contract lapsed) stall accounts with lifetime collected + uncollected-at-end.
   Read-only printable sheet; on-screen it also offers Reopen (closed) / Renew (expired).
   Scope: stall facilities only (NPM/TCC/NCC/BBQ/ICE). Data: GET /api/stalls/closed-accounts.
   ─────────────────────────────────────────────────────────────────────────────── *@

<PageTitle>@Branding.OfficeAcronym Admin — Closed Accounts</PageTitle>

<header class="topbar no-print">
    <div class="topbar-left">
        <div class="topbar-title">Closed Accounts</div>
        <div class="topbar-breadcrumb">
            <a href="/menu" class="breadcrumb-link">@Branding.OfficeAcronym Admin</a>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Closed Accounts</span>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-period">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
            As of <strong>@PhilippineTime.Today.ToString("MMM d, yyyy")</strong>
        </div>
        <AccountChip />
    </div>
</header>

<div class="content-area">

    <!-- Controls: year + state + facility + search + print -->
    <div class="ca-controls no-print">
        <div class="ca-filter" role="group" aria-label="Year">
            <span class="ca-filter-cap">Year</span>
            <ReportPeriodNav YearFilterMode="true" SelectedYear="_year" FilterYears="Years" AlignRight="false"
                             Label="@(_year?.ToString() ?? "All years")"
                             OnSelectYear="OnPickYear" />
        </div>

        <div class="ca-filter" role="group" aria-label="Status">
            <button class="ca-chip @(_state is null ? "ca-chip-active" : "")" type="button" @onclick="() => _state = null">All Status</button>
            <button class="ca-chip @(_state == InactiveAccountState.Closed ? "ca-chip-active" : "")" type="button" @onclick="() => _state = InactiveAccountState.Closed">Closed</button>
            <button class="ca-chip @(_state == InactiveAccountState.Expired ? "ca-chip-active" : "")" type="button" @onclick="() => _state = InactiveAccountState.Expired">Expired</button>
        </div>

        <div class="ca-filter" role="group" aria-label="Facility">
            <button class="ca-chip @(_facility is null ? "ca-chip-active" : "")" type="button" @onclick="() => _facility = null">All Facilities</button>
            @foreach (var fc in Facilities)
            {
                <button class="ca-chip @(_facility == fc ? "ca-chip-active" : "")" type="button" @onclick="() => _facility = fc">@(System.Enum.TryParse<FacilityCode>(fc, out var _cc) ? FacilityCatalog.ShortNameOf(_cc) : fc)</button>
            }
        </div>

        <div class="ca-actions">
            <div class="ca-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="search" placeholder="Search occupant, contract, or stall no.…" value="@_search" @oninput="OnSearch" aria-label="Search closed accounts" />
                @if (HasSearch)
                {
                    <button class="ca-search-clear" type="button" @onclick="@(() => _search = "")" aria-label="Clear search">&times;</button>
                }
            </div>
            <button class="ca-print-btn" type="button" @onclick="Print">
                <svg viewBox="0 0 24 24"><polyline points="6 9 6 2 18 2 18 9" /><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2" /><rect x="6" y="14" width="12" height="8" /></svg>
                Print
            </button>
        </div>
    </div>

    @if (_loading)
    {
        <div class="ca-loading no-print" aria-busy="true" aria-label="Loading closed accounts">
            <!-- Summary KPI card skeletons -->
            <div class="ca-summary">
                @for (var i = 0; i < 4; i++)
                {
                    <div class="ca-sum-card">
                        <Skeleton Width="56%" Height="21px" Radius="7px" Class="ca-sk-center" />
                        <Skeleton Width="70%" Height="11px" Radius="5px" Class="ca-sk-center ca-sk-gap" />
                    </div>
                }
            </div>

            <!-- Document sheet skeleton -->
            <section class="ca-sheet">
                <header class="ca-rpt-head">
                    <Skeleton Width="54px" Height="54px" Radius="999px" Class="ca-sk-center" />
                    <Skeleton Width="190px" Height="9px" Radius="5px" Class="ca-sk-center ca-sk-gap" />
                    <Skeleton Width="320px" Height="16px" Radius="6px" Class="ca-sk-center ca-sk-gap" />
                    <Skeleton Width="240px" Height="11px" Radius="5px" Class="ca-sk-center ca-sk-gap" />
                </header>

                @for (var grp = 0; grp < 2; grp++)
                {
                    <div class="ca-year">
                        <div class="ca-year-head">
                            <Skeleton Width="70px" Height="16px" Radius="6px" />
                            <Skeleton Width="220px" Height="12px" Radius="5px" />
                        </div>
                        <div class="ca-table-skeleton">
                            <Skeleton Height="34px" Radius="6px" />
                            @for (var row = 0; row < 4; row++)
                            {
                                <Skeleton Height="32px" Radius="6px" />
                            }
                        </div>
                    </div>
                }
            </section>
        </div>
    }
    else
    {
        var rows = Filtered();
        var withBalance = rows.Where(r => r.Uncollected > 0).ToList();
        var groups = rows.GroupBy(r => EndOf(r).Year).OrderByDescending(g => g.Key).ToList();

        <!-- Summary KPI cards — top of page (screen only) -->
        <div class="ca-summary no-print">
            <div class="ca-sum-card">
                <div class="ca-sum-val">@rows.Count</div>
                <div class="ca-sum-lbl">Inactive Accounts</div>
            </div>
            <div class="ca-sum-card ca-sum-warn">
                <div class="ca-sum-val">@withBalance.Count</div>
                <div class="ca-sum-lbl">With Balance</div>
            </div>
            <div class="ca-sum-card">
                <div class="ca-sum-val">@Money(rows.Sum(r => r.Uncollected))</div>
                <div class="ca-sum-lbl">Total Uncollected</div>
            </div>
            <div class="ca-sum-card">
                <div class="ca-sum-val">@Money(rows.Sum(r => r.LifetimeCollected))</div>
                <div class="ca-sum-lbl">Lifetime Collected</div>
            </div>
        </div>

        <section class="ca-sheet">
            <table class="ca-frame">
                <thead><tr><td><div class="ca-frame-space"></div></td></tr></thead>
                <tfoot><tr><td><div class="ca-frame-space"></div></td></tr></tfoot>
                <tbody><tr><td>
            <header class="ca-rpt-head">
                <img class="ca-seal" src="@Branding.SealPath" alt="@Branding.Municipality seal" />
                <div class="ca-gov">Republic of the Philippines</div>
                <div class="ca-org">@Branding.OfficeName</div>
                <div class="ca-muni">Municipality of @Branding.Municipality, @Branding.Province</div>
                <div class="ca-doc">Register of Closed &amp; Expired Stall Accounts</div>
                <div class="ca-doc-scope">@(_year?.ToString() ?? "All Years")@(_state is null ? "" : " · " + _state)@(_facility is null ? "" : " · " + _facility)</div>
                <div class="ca-doc-period">As of @PhilippineTime.Today.ToString("MMMM d, yyyy")</div>
            </header>

            <div class="ca-note">
                Inactive accounts are retained for transparency and audit. They are <strong>excluded from current billing
                and delinquency</strong>; uncollected amounts shown are historical balances at the time of closure/expiry.
            </div>

            @if (_error is not null)
            {
                <div class="ca-state">@_error</div>
            }
            else if (rows.Count == 0)
            {
                <div class="ca-state">No inactive accounts match the current filter@(HasSearch ? " and search" : "").</div>
            }

            @foreach (var grp in groups)
            {
                var yr = grp.ToList();
                var facGroups = yr.GroupBy(r => r.FacilityName, StringComparer.OrdinalIgnoreCase)
                                  .OrderBy(g => g.Key, StringComparer.OrdinalIgnoreCase).ToList();
                var singleFacility = facGroups.Count == 1;
                <div class="ca-year">
                    <div class="ca-year-head">
                        <span class="ca-year-label">@grp.Key@(singleFacility ? " · " + facGroups[0].Key : "")</span>
                        <span class="ca-year-stats">
                            <strong>@yr.Count</strong> account@(yr.Count != 1 ? "s" : "") ·
                            <strong>@Money(yr.Sum(r => r.Uncollected))</strong> uncollected
                        </span>
                    </div>

                    @foreach (var facGrp in facGroups)
                    {
                        var facRows = facGrp.OrderByDescending(r => EndOf(r)).ToList();
                        <div class="ca-fac-group">
                            @if (!singleFacility)
                            {
                                <div class="ca-fac-head">
                                    <span class="ca-fac-title">@facGrp.Key</span>
                                    <span class="ca-fac-stats">
                                        <strong>@facRows.Count</strong> account@(facRows.Count != 1 ? "s" : "") ·
                                        <strong>@Money(facRows.Sum(r => r.Uncollected))</strong> uncollected
                                    </span>
                                </div>
                            }

                            <table class="ca-table">
                                <thead>
                                    <tr>
                                        <th class="ca-c">#</th>
                                        <th class="ca-c">Status</th>
                                        <th class="ca-c">Stall</th>
                                        <th>Last Occupant</th>
                                        <th>Name on Contract</th>
                                        <th class="ca-c">Period (Effectivity → End)</th>
                                        <th class="ca-r">Lifetime Collected</th>
                                        <th class="ca-r">Uncollected</th>
                                        <th>Recorded By</th>
                                        <th class="ca-act no-print">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{ var n = 1; }
                                    @foreach (var r in facRows)
                                    {
                                        <tr>
                                            <td class="ca-c">@n</td>
                                            <td class="ca-c ca-status-text">@r.State</td>
                                            <td class="ca-c">@r.StallNo</td>
                                            <td class="ca-fw">@r.Occupant</td>
                                            <td class="ca-muted">@(string.IsNullOrWhiteSpace(r.ContractName) ? "—" : r.ContractName)</td>
                                            <td class="ca-c ca-period">@r.EffectivityDate.ToString("MMM yyyy") <span>→</span> @EndOf(r).ToString("MMM d, yyyy")</td>
                                            <td class="ca-r">@Money(r.LifetimeCollected)</td>
                                            <td class="ca-r">
                                                @if (r.Uncollected > 0)
                                                {
                                                    <span class="ca-amt-due">@Money(r.Uncollected)</span>
                                                }
                                                else
                                                {
                                                    <span class="ca-amt-clear">@Money(0)</span>
                                                }
                                            </td>
                                            <td class="ca-muted">@(string.IsNullOrWhiteSpace(r.ClosedBy) ? "—" : r.ClosedBy)</td>
                                            <td class="ca-act no-print">
                                                @if (r.State == InactiveAccountState.Closed)
                                                {
                                                    <button class="ca-row-btn ca-row-reopen" type="button" @onclick="() => OpenReopen(r)">Reopen</button>
                                                }
                                                else
                                                {
                                                    <button class="ca-row-btn ca-row-renew" type="button" @onclick="() => OpenRenew(r)">Renew</button>
                                                }
                                                <AuthorizeView Roles="SuperAdmin" Context="authCtx">
                                                    <button class="ca-row-btn ca-row-remove" type="button" @onclick="() => OpenRemove(r)" title="Remove this inactive account (frees the stall number)">Remove</button>
                                                </AuthorizeView>
                                            </td>
                                        </tr>
                                        n++;
                                    }
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="6"><strong>Subtotal — @facRows.Count account@(facRows.Count != 1 ? "s" : "")</strong></td>
                                        <td class="ca-r"><strong>@Money(facRows.Sum(r => r.LifetimeCollected))</strong></td>
                                        <td class="ca-r"><strong>@Money(facRows.Sum(r => r.Uncollected))</strong></td>
                                        <td></td>
                                        <td class="ca-act no-print"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    }
                </div>
            }

            <div class="ca-rpt-foot">
                <div><span>Prepared by</span><strong>Administrative Staff</strong></div>
                <div><span>Reviewed by</span><strong>Head, @Branding.OfficeAcronym Office</strong></div>
                <div><span>Date Prepared</span><strong>@PhilippineTime.Now.ToString("MMM d, yyyy")</strong></div>
            </div>
                </td></tr></tbody>
            </table>
        </section>
    }
</div>

@* ── Reopen confirm modal ── *@
@if (_reopenTarget is not null)
{
    <div class="eemo-modal-overlay" @onclick="CloseModals">
        <div class="eemo-modal eemo-modal-sm" @onclick:stopPropagation="true">
            <div class="eemo-modal-header"><div class="eemo-modal-title">Reopen Stall?</div></div>
            <div class="eemo-modal-body">
                <p class="confirm-text">
                    Reopen stall @_reopenTarget.StallNo (@_reopenTarget.Occupant)? It resumes the same contract and
                    the closed period is recorded as excused — it will not be back-billed.
                </p>
                @if (_actionError is not null)
                {
                    <p class="ca-form-err">@_actionError</p>
                }
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="CloseModals" disabled="@_busy">Cancel</button>
                <button class="btn-primary" @onclick="ConfirmReopen" disabled="@_busy">@(_busy ? "Working…" : "Yes, Reopen")</button>
            </div>
        </div>
    </div>
}

@* ── Renew modal (Proceed / Edit) ── *@
@if (_renewTarget is not null)
{
    <div class="eemo-modal-overlay" @onclick="CloseModals">
        <div class="eemo-modal eemo-modal-sm" @onclick:stopPropagation="true">
            <div class="eemo-modal-header"><div class="eemo-modal-title">Renew Stall @_renewTarget.StallNo</div></div>
            <div class="eemo-modal-body">
                @if (!_renewEditing)
                {
                    <p class="confirm-text">
                        Start a new contract term for <strong>@_renewTarget.Occupant</strong> — beginning
                        <strong>@_renewEffectivity.ToString("MMM d, yyyy")</strong> for <strong>@_renewDuration year(s)</strong>,
                        same details as before. The lapsed period is not back-billed.
                    </p>
                }
                else
                {
                    <div class="ca-form">
                        <label>Start date
                            <input type="date" @bind="_renewEffectivity" />
                        </label>
                        <label>Duration (years)
                            <input type="number" min="1" max="50" @bind="_renewDuration" />
                        </label>
                        <label>Occupant
                            <input type="text" @bind="_renewOccupant" />
                        </label>
                        <label>Name on contract
                            <input type="text" @bind="_renewName" />
                        </label>
                    </div>
                }
                @if (_actionError is not null)
                {
                    <p class="ca-form-err">@_actionError</p>
                }
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="CloseModals" disabled="@_busy">Cancel</button>
                @if (!_renewEditing)
                {
                    <button class="btn-ghost" @onclick="() => _renewEditing = true" disabled="@_busy">Edit</button>
                    <button class="btn-primary" @onclick="ConfirmRenew" disabled="@_busy">@(_busy ? "Working…" : "Proceed")</button>
                }
                else
                {
                    <button class="btn-primary" @onclick="ConfirmRenew" disabled="@_busy">@(_busy ? "Working…" : "Confirm Renew")</button>
                }
            </div>
        </div>
    </div>
}

@* ── Remove confirm modal (SuperAdmin) ── *@
@if (_removeTarget is not null)
{
    <div class="eemo-modal-overlay" @onclick="CloseModals">
        <div class="eemo-modal eemo-modal-sm" @onclick:stopPropagation="true">
            <div class="eemo-modal-header"><div class="eemo-modal-title">Remove Account?</div></div>
            <div class="eemo-modal-body">
                <p class="confirm-text">
                    Remove @(_removeTarget.State == InactiveAccountState.Closed ? "closed" : "expired") stall
                    <strong>@_removeTarget.StallNo</strong> (@_removeTarget.Occupant) from the roster?
                    Its collection history is kept for audit, but the stall <strong>number @_removeTarget.StallNo is freed</strong>
                    for reuse. Only closed/expired accounts can be removed — a currently active stall never can.
                </p>
                @if (_actionError is not null)
                {
                    <p class="ca-form-err">@_actionError</p>
                }
            </div>
            <div class="eemo-modal-footer">
                <button class="btn-ghost" @onclick="CloseModals" disabled="@_busy">Cancel</button>
                <button class="btn-danger" @onclick="ConfirmRemove" disabled="@_busy">@(_busy ? "Working…" : "Yes, Remove")</button>
            </div>
        </div>
    </div>
}

@code {
    // ── Data ──
    private List<ClosedStallAccountDto> _accounts = new();
    private bool _loading = true;
    private string? _error;

    [PersistentState(AllowUpdates = true)]
    public List<ClosedStallAccountDto>? CachedClosedAccounts { get; set; }

    // ── Filters ──
    private int? _year;
    private string? _facility;
    private InactiveAccountState? _state;
    private string _search = "";

    private bool HasSearch => !string.IsNullOrWhiteSpace(_search);
    private void OnSearch(ChangeEventArgs e) => _search = e.Value?.ToString() ?? "";
    private async Task Print() => await JS.InvokeVoidAsync("print");

    private IEnumerable<string> Facilities => FacilityCatalog.Rental.Select(c => c.ToString());
    private int[] Years = Array.Empty<int>();

    private void OnPickYear(int? year) => _year = year;

    // ── Action state ──
    private ClosedStallAccountDto? _reopenTarget;
    private ClosedStallAccountDto? _renewTarget;
    private ClosedStallAccountDto? _removeTarget;
    private bool _renewEditing;
    private DateOnly _renewEffectivity;
    private int _renewDuration;
    private string _renewOccupant = "";
    private string? _renewName;
    private bool _busy;
    private string? _actionError;

    protected override async Task OnInitializedAsync()
    {
        await FacilityCatalog.EnsureLoadedAsync();

        if (CachedClosedAccounts is not null)
        {
            ApplyClosedAccounts(CachedClosedAccounts);
            _loading = false;
            return;
        }

        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        _error = null;
        await PaintLoadingStateAsync();

        var result = await StallsApi.GetClosedStallAccountsAsync();
        if (result.IsSuccess && result.Value is not null)
        {
            ApplyClosedAccounts(result.Value.ToList());
            CachedClosedAccounts = _accounts;
        }
        else
        {
            _error = result.Error ?? "Failed to load closed accounts.";
            _accounts = new();
        }
        _loading = false;
    }

    private void ApplyClosedAccounts(IReadOnlyList<ClosedStallAccountDto> accounts)
    {
        _accounts = accounts as List<ClosedStallAccountDto> ?? accounts.ToList();
        Years = _accounts.Select(a => EndOf(a).Year).Distinct().OrderByDescending(y => y).ToArray();
    }

    private async Task PaintLoadingStateAsync()
    {
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
    }

    // The lifecycle end point used for grouping/sorting: close date (closed) or expiry (expired).
    private static DateOnly EndOf(ClosedStallAccountDto r) => r.ClosedOn ?? r.ExpiryDate;

    private IReadOnlyList<ClosedStallAccountDto> Filtered()
    {
        IEnumerable<ClosedStallAccountDto> q = _accounts;
        if (_year is int y) q = q.Where(r => EndOf(r).Year == y);
        if (_state is InactiveAccountState st) q = q.Where(r => r.State == st);
        if (_facility is not null) q = q.Where(r => r.FacilityCode.ToString() == _facility);
        if (HasSearch)
        {
            var s = _search.Trim();
            q = q.Where(r =>
                r.Occupant.Contains(s, StringComparison.OrdinalIgnoreCase) ||
                (r.ContractName ?? "").Contains(s, StringComparison.OrdinalIgnoreCase) ||
                r.StallNo.Contains(s, StringComparison.OrdinalIgnoreCase));
        }
        return q.OrderByDescending(r => EndOf(r)).ToList();
    }

    // ── Reopen ──
    private void OpenReopen(ClosedStallAccountDto r) { _reopenTarget = r; _actionError = null; }

    private async Task ConfirmReopen()
    {
        if (_reopenTarget is null) return;
        _busy = true; _actionError = null;
        var result = await StallsApi.ToggleStallStatusAsync(_reopenTarget.StallId, close: false);
        _busy = false;
        if (result.IsSuccess) { CloseModals(); await Load(); }
        else _actionError = result.Error ?? "Failed to reopen the stall.";
    }

    // ── Renew ──
    private void OpenRenew(ClosedStallAccountDto r)
    {
        _renewTarget = r;
        _renewEditing = false;
        _renewEffectivity = PhilippineTime.Today;     // Proceed default: fresh start today (no back-billing of the gap)
        _renewDuration = r.DurationYears > 0 ? r.DurationYears : 1;
        _renewOccupant = r.Occupant;
        _renewName = r.ContractName;
        _actionError = null;
    }

    private async Task ConfirmRenew()
    {
        if (_renewTarget is null) return;
        if (string.IsNullOrWhiteSpace(_renewOccupant)) { _actionError = "Occupant is required."; return; }
        if (_renewDuration < 1) { _actionError = "Duration must be at least 1 year."; return; }

        _busy = true; _actionError = null;
        var req = new RenewStallContractRequest(_renewEffectivity, _renewDuration, _renewOccupant.Trim(), _renewName);
        var result = await StallsApi.RenewStallContractAsync(_renewTarget.StallId, req);
        _busy = false;
        if (result.IsSuccess) { CloseModals(); await Load(); }
        else _actionError = result.Error ?? "Failed to renew the contract.";
    }

    private void CloseModals()
    {
        _reopenTarget = null;
        _renewTarget = null;
        _removeTarget = null;
        _renewEditing = false;
        _actionError = null;
    }

    // ── Remove (soft-delete an inactive account; frees the stall number) ──
    private void OpenRemove(ClosedStallAccountDto r) { _removeTarget = r; _actionError = null; }

    private async Task ConfirmRemove()
    {
        if (_removeTarget is null) return;
        _busy = true; _actionError = null;
        var result = await StallsApi.SoftDeleteStallAsync(_removeTarget.StallId);
        _busy = false;
        if (result.IsSuccess) { CloseModals(); await Load(); }
        else _actionError = result.Error ?? "Failed to remove the account.";
    }

    private static string Money(decimal v) => "₱" + v.ToString("N0");
}
