@page "/trm/reports"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@rendermode InteractiveServer
@using EEMOCantilanSDS.Application.Dtos.TransportTerminal
@inject ITrmApiClient TrmApi
@inject IJSRuntime JS

<PageTitle>EEMO Admin — TRM Reports</PageTitle>

<!-- ══ Topbar ══ -->
<div class="rpt-topbar">
    <div class="rpt-topbar-left">
        <a href="/trm" class="rpt-back-btn" title="Back to TRM">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
        </a>
        <div class="rpt-topbar-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <div>
            <div class="rpt-eyebrow">FACILITY · TRM · REPORTS</div>
            <div class="rpt-title">Transport Terminal Reports</div>
            <div class="rpt-subtitle">@(ShowPrintReport ? PrintReportPeriodLabel : ShowHistory ? HistoryPeriodLabel : GetPeriodLabel())</div>
        </div>
    </div>
    <div class="rpt-topbar-right">
        <button type="button" class="rpt-action-btn" title="Export PDF" aria-label="Export PDF" @onclick="PrintPage">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
            Export PDF
        </button>
        <button type="button" class="rpt-action-btn" title="Print" aria-label="Print report" @onclick="PrintPage">
            <svg aria-hidden="true" viewBox="0 0 24 24"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Print
        </button>
    </div>
</div>

<!-- ══ Period Selector ══ -->
<div class="rpt-period-bar">
    <div class="rpt-period-tabs">
        @foreach (var p in new[] { "Weekly", "Monthly", "Yearly" })
        {
            <button type="button" class="rpt-period-tab @(!ShowPrintReport && !ShowHistory && ActivePeriod == p ? "active" : "")"
                    aria-pressed="@(!ShowPrintReport && !ShowHistory && ActivePeriod == p)"
                    @onclick="() => SetPeriod(p)">@p</button>
        }
        <button type="button" class="rpt-period-tab rpt-document-tab @(ShowPrintReport ? "active" : "")"
                aria-pressed="@ShowPrintReport" @onclick="ShowPrintReportView">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="8" y1="13" x2="16" y2="13" /><line x1="8" y1="17" x2="16" y2="17" /></svg>
            <span>Status Report</span>
        </button>
        <button type="button" class="rpt-period-tab rpt-document-tab @(ShowHistory ? "active" : "")"
                aria-pressed="@ShowHistory" @onclick="ShowHistoryView">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>History</span>
        </button>
    </div>
    <div class="rpt-date-nav @(ShowPrintReport || ShowHistory ? "utility-mode" : "")">
        <button type="button" class="rpt-nav-btn" @onclick="PrevPeriod" aria-label="Previous period">
            <svg aria-hidden="true" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <span class="rpt-current-period">@(ShowPrintReport ? PrintReportPeriodLabel : ShowHistory ? HistoryPeriodLabel : GetPeriodLabel())</span>
        <button type="button" class="rpt-nav-btn" @onclick="NextPeriod" aria-label="Next period">
            <svg aria-hidden="true" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
    </div>
</div>

@if (ShowPrintReport)
{
    <!-- ══ Phase 2: Status Report ══ -->
    <div class="rpt-content print-document-content">
        <section class="print-report-sheet status-sheet">
            <header class="print-report-header">
                <img class="print-report-logo" src="/images/LGU_CANTILAN_LOGO.jpg" alt="LGU Cantilan logo" />
                <div class="print-republic">Republic of the Philippines</div>
                <h2>Economic Enterprise &amp; Management Office</h2>
                <p>Municipality of Cantilan, Surigao del Sur</p>
                <div class="print-report-title">Transport Terminal — Collection Status Report</div>
            </header>
            <div class="print-report-meta">
                <div><span>Facility</span><strong>Transport Terminal</strong></div>
                <div><span>Report Period</span><strong>@CurrentDate.ToString("MMMM yyyy")</strong></div>
                <div><span>Prepared By</span><strong>EEMO Office</strong></div>
                <div><span>Date Prepared</span><strong>@PhilippineTime.Now.ToString("MMM d, yyyy")</strong></div>
            </div>
            <div class="print-report-summary">
                <div><span>Total Trips</span><strong>@MonthTrips.Count</strong></div>
                <div><span>Registered</span><strong>@MonthTrips.Where(t => t.TransporterId.HasValue).Select(t => t.TransporterId).Distinct().Count()</strong></div>
                <div><span>Walk-in Trips</span><strong>@MonthTrips.Count(t => !t.TransporterId.HasValue)</strong></div>
                <div><span>Fees Collected</span><strong>&#8369;@MonthTrips.Sum(t => t.Fee).ToString("N2")</strong></div>
                <div><span>Routes Served</span><strong>@MonthTrips.Select(t => t.Route).Where(r => !string.IsNullOrWhiteSpace(r)).Distinct().Count()</strong></div>
            </div>
            @if (!MonthTrips.Any())
            {
                <p class="print-empty">No trips recorded for @CurrentDate.ToString("MMMM yyyy").</p>
            }
            else
            {
                <div class="print-table-wrap">
                    <table class="print-status-table status-sheet">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Driver</th>
                                <th>Organization</th>
                                <th>Route</th>
                                <th>Plate</th>
                                <th>Fee</th>
                                <th>OR No.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in MonthTrips.OrderBy(t => t.RecordedAt))
                            {
                                <tr>
                                    <td>@PhilippineTime.ToPhilippineTime(t.RecordedAt).ToString("MMM d")</td>
                                    <td>@t.DriverName</td>
                                    <td>@t.Organization</td>
                                    <td>@t.Route</td>
                                    <td>@t.PlateNumber</td>
                                    <td>&#8369;@t.Fee.ToString("N2")</td>
                                    <td class="text-muted-cell">@(string.IsNullOrEmpty(t.ORNumber) ? "—" : t.ORNumber)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            <div class="print-report-signatures">
                <div><span>Prepared by</span><strong>Administrative Staff</strong></div>
                <div><span>Reviewed by</span><strong>Head, EEMO Office</strong></div>
                <div><span>Received by</span><strong>Authorized Representative</strong></div>
            </div>
        </section>
    </div>
}
else if (ShowHistory)
{
    <!-- ══ Phase 3: History ══ -->
    <div class="rpt-content print-document-content">
        <section class="print-report-sheet history-sheet">
            <header class="print-report-header">
                <img class="print-report-logo" src="/images/LGU_CANTILAN_LOGO.jpg" alt="LGU Cantilan logo" />
                <div class="print-republic">Republic of the Philippines</div>
                <h2>Economic Enterprise &amp; Management Office</h2>
                <p>Municipality of Cantilan, Surigao del Sur</p>
                <div class="print-report-title">Transport Terminal — Collection History</div>
            </header>
            <div class="print-report-meta">
                <div><span>Facility</span><strong>Transport Terminal</strong></div>
                <div><span>Year</span><strong>@CurrentDate.Year</strong></div>
                <div><span>Prepared By</span><strong>EEMO Office</strong></div>
                <div><span>Date Prepared</span><strong>@PhilippineTime.Now.ToString("MMM d, yyyy")</strong></div>
            </div>

            <div class="print-section-block">
                <div class="print-section-heading">Monthly Collection — @CurrentDate.Year</div>
                <div class="print-table-wrap">
                    <table class="print-status-table history-table">
                        <thead>
                            <tr><th>Month</th><th>Trips</th><th>Registered</th><th>Walk-in</th><th>Fees Collected</th></tr>
                        </thead>
                        <tbody>
                            @if (!HistoryMonthly.Any())
                            {
                                <tr><td colspan="5" class="history-empty">@(HistoryLoading ? "Loading…" : "No collection records for this year.")</td></tr>
                            }
                            @foreach (var row in HistoryMonthly)
                            {
                                <tr>
                                    <td>@row.Label</td>
                                    <td>@row.Trips</td>
                                    <td>@row.Transporters</td>
                                    <td>@row.AdHocTrips</td>
                                    <td>@(row.Collected > 0 ? "₱" + row.Collected.ToString("N2") : "—")</td>
                                </tr>
                            }
                        </tbody>
                        @if (HistoryMonthly.Any())
                        {
                            <tfoot>
                                <tr class="history-total-row">
                                    <td><strong>Total</strong></td>
                                    <td><strong>@HistoryMonthly.Sum(r => r.Trips)</strong></td>
                                    <td>—</td>
                                    <td><strong>@HistoryMonthly.Sum(r => r.AdHocTrips)</strong></td>
                                    <td><strong>₱@HistoryMonthly.Sum(r => r.Collected).ToString("N2")</strong></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>

            <div class="print-section-block">
                <div class="print-section-heading">Yearly Collection Summary</div>
                <div class="print-table-wrap">
                    <table class="print-status-table history-table">
                        <thead>
                            <tr><th>Year</th><th>Trips</th><th>Registered</th><th>Walk-in</th><th>Fees Collected</th></tr>
                        </thead>
                        <tbody>
                            @if (!HistoryYearly.Any())
                            {
                                <tr><td colspan="5" class="history-empty">@(HistoryLoading ? "Loading…" : "No yearly records.")</td></tr>
                            }
                            @foreach (var row in HistoryYearly)
                            {
                                <tr>
                                    <td><strong>@row.Label</strong></td>
                                    <td>@row.Trips</td>
                                    <td>@row.Transporters</td>
                                    <td>@row.AdHocTrips</td>
                                    <td>@(row.Collected > 0 ? "₱" + row.Collected.ToString("N2") : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="print-report-signatures">
                <div><span>Prepared by</span><strong>Administrative Staff</strong></div>
                <div><span>Reviewed by</span><strong>Head, EEMO Office</strong></div>
                <div><span>Received by</span><strong>Authorized Representative</strong></div>
            </div>
        </section>
    </div>
}
else
{
    <!-- ══ Phase 1: Monthly / Yearly ══ -->
    <div class="rpt-kpi-strip">
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-green"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h7a4 4 0 0 1 0 8H6z" /><line x1="4" y1="9" x2="16" y2="9" /><line x1="4" y1="13" x2="16" y2="13" /><line x1="6" y1="4" x2="6" y2="20" /></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Terminal Fees Collected</div>
                <div class="kpi-value">&#8369;@TotalCollected.ToString("N2")</div>
                <div class="kpi-change">@ActivePeriod.ToLower() total</div>
            </div>
        </div>
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-gold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 5v3h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Total Trips</div>
                <div class="kpi-value">@TotalTrips</div>
                <div class="kpi-change">@ActivePeriod.ToLower() total</div>
            </div>
        </div>
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-neutral"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Registered Transporters</div>
                <div class="kpi-value">@ActiveTransporters</div>
                <div class="kpi-change">@(AdHocTrips > 0 ? $"+{AdHocTrips} walk-in trip{(AdHocTrips == 1 ? "" : "s")}" : $"this {PeriodNoun}")</div>
            </div>
        </div>
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-gold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="10" r="3"/><path d="M12 21s-6-5.686-6-10a6 6 0 1112 0c0 4.314-6 10-6 10z"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Routes Served</div>
                <div class="kpi-value">@RoutesServed</div>
                <div class="kpi-change">@(TopRoute is null ? "no trips yet" : $"busiest: {TopRoute}")</div>
            </div>
        </div>
    </div>

    <div class="rpt-content">

        <!-- Charts Row -->
        <div class="rpt-charts-row">
            <div class="rpt-chart-card rpt-chart-wide">
                <div class="chart-header">
                    <div class="chart-header-left">
                        <h3 class="chart-title">Fee Collection Trend</h3>
                        <p class="chart-subtitle">@(ActivePeriod switch { "Yearly" => "Collected fees by year", "Weekly" => "Collected fees by day", _ => "Collected fees by month" })</p>
                    </div>
                    <div class="chart-legend">
                        <div class="legend-item"><span class="legend-dot" style="background:#2d7a5f"></span><span class="legend-label">Collected</span></div>
                        <div class="legend-item"><span class="legend-dot" style="background:#c8a84b"></span><span class="legend-label">Current Period</span></div>
                    </div>
                </div>
                <div class="rpt-bar-chart">
                    @if (TrendPoints.Any(p => p.Amount > 0))
                    {
                        @foreach (var pt in TrendPoints)
                        {
                            <div class="rpt-bar-group @(pt.IsCurrent ? "current" : "") @(pt.IsZero ? "is-zero" : "")" title="@pt.Label — ₱@pt.Amount.ToString("N2")">
                                <div class="rpt-bar-wrap">
                                    <div class="rpt-bar-3d">
                                        <div class="bar3d-face bar3d-front" style="height:@pt.HeightPct%"></div>
                                        <div class="bar3d-face bar3d-top"   style="bottom:@pt.HeightPct%"></div>
                                        <div class="bar3d-face bar3d-side"  style="height:@pt.HeightPct%"></div>
                                    </div>
                                </div>
                                <div class="rpt-bar-label">@pt.Label</div>
                                <div class="rpt-bar-val">&#8369;@pt.ShortValue</div>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="rpt-empty">
                            <div class="rpt-empty-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v18h18"/><path d="M7 15l4-4 3 3 5-6"/></svg></div>
                            <div class="rpt-empty-title">No fees recorded</div>
                            <div class="rpt-empty-text">No terminal fees were collected for @GetPeriodLabel().</div>
                        </div>
                    }
                </div>
            </div>

            <!-- Trips by Route donut -->
            <div class="rpt-chart-card rpt-chart-narrow rpt-status-card">
                <div class="chart-header">
                    <div class="chart-header-left">
                        <h3 class="chart-title">Trips by Route</h3>
                        <p class="chart-subtitle">@(RoutesServed > 5 ? $"Top 5 of {RoutesServed} routes" : "Share of trips per route")</p>
                    </div>
                </div>
                <div class="rpt-donut-wrap">
                    <div class="rpt-donut-container">
                        <svg class="rpt-donut-svg" viewBox="0 0 120 120">
                            <circle cx="60" cy="60" r="46" fill="none" stroke="#f0f2f5" stroke-width="18" />
                            @{ var rsegs = RouteSegments; var arcs = BuildDonutArcs(rsegs.Select(s => (s.Count, s.Color)).ToArray(), 46, 60, 60); }
                            @foreach (var arc in arcs)
                            {
                                <path d="@arc.D" fill="none" stroke="@arc.Color" stroke-width="18" stroke-linecap="butt" class="donut-segment" />
                            }
                            <circle cx="60" cy="60" r="35" fill="white" />
                            <text x="60" y="56" class="donut-center-val">@TotalTrips</text>
                            <text x="60" y="70" class="donut-center-lbl">TRIPS</text>
                        </svg>
                    </div>
                    <div class="rpt-donut-legend">
                        @if (rsegs.Any())
                        {
                            @foreach (var seg in rsegs)
                            {
                                var legPct = TotalTrips > 0 ? (int)Math.Round((double)seg.Count / TotalTrips * 100) : 0;
                                <div class="donut-leg-item">
                                    <div class="donut-leg-left"><span class="donut-leg-dot" style="background:@seg.Color"></span><span class="donut-leg-label">@seg.Label</span></div>
                                    <strong class="donut-leg-value">@seg.Count <span class="donut-leg-pct">· @legPct%</span></strong>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="donut-leg-item"><div class="donut-leg-left"><span class="donut-leg-label">No trips for @GetPeriodLabel().</span></div></div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Audit Breakdown -->
        <div class="rpt-section-heading"><span class="rpt-section-rule"></span><h2>Audit Breakdown</h2></div>

        <div class="rpt-audit-row">
            <!-- Organization breakdown -->
            <div class="audit-card trm-breakdown-card">
                <div class="audit-card-head">
                    <span>Trips by Organization</span>
                    <small class="audit-subtitle">Trips &amp; fees per transport group</small>
                </div>
                @if (OrgBreakdown.Any())
                {
                    <div class="trm-tally-scroll">
                        @foreach (var o in OrgBreakdown)
                        {
                            var pct = TotalTrips > 0 ? Math.Min(100, (int)Math.Round((double)o.Trips / TotalTrips * 100)) : 0;
                            <div class="trm-tally-row">
                                <div class="trm-tally-top">
                                    <span class="trm-tally-name">@o.Label</span>
                                    <span class="trm-tally-pct">@pct%</span>
                                </div>
                                <div class="trm-tally-meter"><div class="trm-tally-fill" style="width:@pct%"></div></div>
                                <div class="trm-tally-vals"><span><strong>@o.Trips</strong> trip@(o.Trips != 1 ? "s" : "")</span><span class="trm-tally-sep">·</span><span>&#8369;@o.Collected.ToString("N0")</span></div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="delinq-empty">No trips for @GetPeriodLabel().</div>
                }
            </div>

            <!-- Route breakdown -->
            <div class="audit-card trm-breakdown-card">
                <div class="audit-card-head">
                    <span>Trips by Route</span>
                    <small class="audit-subtitle">Dispatch volume per route</small>
                </div>
                @if (RouteBreakdown.Any())
                {
                    <div class="trm-tally-scroll">
                        @foreach (var rt in RouteBreakdown)
                        {
                            var pct = TotalTrips > 0 ? Math.Min(100, (int)Math.Round((double)rt.Trips / TotalTrips * 100)) : 0;
                            <div class="trm-tally-row">
                                <div class="trm-tally-top">
                                    <span class="trm-tally-name">@rt.Route</span>
                                    <span class="trm-tally-pct trm-tally-pct-gold">@pct%</span>
                                </div>
                                <div class="trm-tally-meter"><div class="trm-tally-fill trm-tally-fill-gold" style="width:@pct%"></div></div>
                                <div class="trm-tally-vals"><span><strong>@rt.Trips</strong> trip@(rt.Trips != 1 ? "s" : "")</span><span class="trm-tally-sep">·</span><span>&#8369;@rt.Collected.ToString("N0")</span></div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="delinq-empty">No trips for @GetPeriodLabel().</div>
                }
            </div>

            <!-- KPI stack -->
            <div class="audit-card audit-kpi-stack">
                <div class="audit-number-card">
                    <strong>&#8369;@TotalCollected.ToString("N0")</strong>
                    <span>Total Fees</span>
                </div>
                <div class="audit-number-card">
                    <strong>@TotalTrips</strong>
                    <span>Total Trips</span>
                </div>
            </div>
        </div>

        @if (ActivePeriod == "Yearly")
        {
            <!-- Yearly: monthly summary -->
            <div class="rpt-section-heading"><span class="rpt-section-rule"></span><h2>Monthly Summary — @CurrentDate.Year</h2></div>
            <div class="rpt-compliance-table-wrap">
                <table class="rpt-compliance-table">
                    <thead><tr><th>Month</th><th>Trips</th><th>Registered</th><th>Walk-in</th><th>Fees Collected</th></tr></thead>
                    <tbody>
                        @foreach (var row in HistoryMonthly)
                        {
                            <tr>
                                <td class="stall-no">@row.Label</td>
                                <td>@row.Trips</td>
                                <td>@row.Transporters</td>
                                <td>@row.AdHocTrips</td>
                                <td>@(row.Collected > 0 ? "₱" + row.Collected.ToString("N2") : "—")</td>
                            </tr>
                        }
                        @if (!HistoryMonthly.Any())
                        {
                            <tr><td colspan="5" class="delinq-empty">No records for @CurrentDate.Year.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <!-- Monthly: trip log -->
            <div class="rpt-section-heading"><span class="rpt-section-rule"></span><h2>Trip Log — @GetPeriodLabel()</h2></div>
            <div class="rpt-compliance-table-wrap">
                <table class="rpt-compliance-table">
                    <thead><tr><th>Date</th><th>Driver</th><th>Organization</th><th>Route</th><th>Plate</th><th>Fee</th><th>OR Number</th></tr></thead>
                    <tbody>
                        @foreach (var t in MonthTrips.OrderBy(t => t.RecordedAt))
                        {
                            <tr>
                                <td class="text-muted">@PhilippineTime.ToPhilippineTime(t.RecordedAt).ToString("MMM d")</td>
                                <td>@t.DriverName</td>
                                <td>@t.Organization</td>
                                <td>@t.Route</td>
                                <td class="text-muted">@t.PlateNumber</td>
                                <td class="trm-fee">&#8369;@t.Fee.ToString("N0")</td>
                                <td class="text-muted">@(string.IsNullOrEmpty(t.ORNumber) ? "—" : t.ORNumber)</td>
                            </tr>
                        }
                        @if (!MonthTrips.Any())
                        {
                            <tr><td colspan="7" class="delinq-empty">No trips for @GetPeriodLabel().</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }

    </div><!-- end rpt-content -->
}

@code {

    // ── Period / view state ───────────────────────────────────────
    string ActivePeriod = "Monthly";
    bool ShowPrintReport = false;
    bool ShowHistory = false;
    DateTime CurrentDate = PhilippineTime.Now;

    private List<TrmTripDto> MonthTrips = new();
    private TrmHistoryDto? Hist;
    private bool HistoryLoading;

    // Trailing 6-month collected totals for the Monthly trend chart (oldest → newest).
    private List<(int Year, int Month, decimal Collected)> _trendMonthly = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        if (ShowHistory)
        {
            HistoryLoading = true;
            var h = await TrmApi.GetHistoryAsync(CurrentDate.Year);
            Hist = h.IsSuccess ? h.Value : null;
            HistoryLoading = false;
        }
        else if (ActivePeriod == "Yearly" && !ShowPrintReport)
        {
            var h = await TrmApi.GetHistoryAsync(CurrentDate.Year);
            Hist = h.IsSuccess ? h.Value : null;
        }
        else
        {
            // Monthly/Weekly (Phase 1) and the Status Report all start from the month's trips.
            var r = await TrmApi.GetTripsAsync(CurrentDate.Year, CurrentDate.Month);
            var trips = r.IsSuccess && r.Value != null ? r.Value.ToList() : new();

            // Weekly view: narrow the month's trips to the selected week-of-month (days 1-7, 8-14, …),
            // mirroring NPM's weekly model so each week stays within one month. The Status Report
            // remains a full-month official snapshot.
            if (ActivePeriod == "Weekly" && !ShowPrintReport)
            {
                var (fromDay, toDay) = WeekDayRange();
                trips = trips
                    .Where(t =>
                    {
                        var day = PhilippineTime.ToPhilippineTime(t.RecordedAt).Day;
                        return day >= fromDay && day <= toDay;
                    })
                    .ToList();
            }

            MonthTrips = trips;

            // The Monthly view's trend is a trailing 6-month window (like NPM), sourced from history.
            if (ActivePeriod == "Monthly" && !ShowPrintReport)
                _trendMonthly = await BuildMonthlyTrendHistoryAsync();
        }

        RecomputeDerived();
    }

    /// <summary>
    /// Builds the Phase 1 breakdowns/trend once per load so each is computed a single time
    /// instead of on every property access during render.
    /// </summary>
    void RecomputeDerived()
    {
        _routeBreakdown = BuildRouteBreakdown();
        _orgBreakdown = BuildOrgBreakdown();
        _trendPoints = BuildTrendPoints();
        _routeSegments = BuildRouteSegments(_routeBreakdown);
    }

    // Builds the trailing 6-month collected totals (oldest → newest) ending at the selected month,
    // pulling per-month collected from history. Spans at most two years, so it loads 1-2 history calls.
    async Task<List<(int Year, int Month, decimal Collected)>> BuildMonthlyTrendHistoryAsync()
    {
        var anchor = new DateTime(CurrentDate.Year, CurrentDate.Month, 1);
        var targets = Enumerable.Range(0, 6).Select(i => anchor.AddMonths(i - 5)).ToList();

        var collectedByMonth = new Dictionary<(int Year, int Month), decimal>();
        foreach (var year in targets.Select(d => d.Year).Distinct())
        {
            var h = await TrmApi.GetHistoryAsync(year);
            if (h.IsSuccess && h.Value is not null)
                foreach (var m in h.Value.Monthly.Where(m => m.Month.HasValue))
                    collectedByMonth[(m.Year, m.Month!.Value)] = m.Collected;
        }

        return targets
            .Select(d => (d.Year, d.Month, collectedByMonth.TryGetValue((d.Year, d.Month), out var c) ? c : 0m))
            .ToList();
    }

    async Task SetPeriod(string p) { ShowPrintReport = false; ShowHistory = false; ActivePeriod = p; await LoadAsync(); }
    async Task ShowPrintReportView() { ShowPrintReport = true; ShowHistory = false; await LoadAsync(); }
    async Task ShowHistoryView() { ShowHistory = true; ShowPrintReport = false; await LoadAsync(); }
    async Task PrintPage() => await JS.InvokeVoidAsync("print");

    async Task PrevPeriod()
    {
        if (ShowHistory) { CurrentDate = CurrentDate.AddYears(-1); await LoadAsync(); return; }
        if (ShowPrintReport) { CurrentDate = CurrentDate.AddMonths(-1); await LoadAsync(); return; }
        CurrentDate = ActivePeriod switch
        {
            "Weekly" => CurrentDate.AddDays(-7),
            "Yearly" => CurrentDate.AddYears(-1),
            _        => CurrentDate.AddMonths(-1)
        };
        await LoadAsync();
    }
    async Task NextPeriod()
    {
        if (ShowHistory) { CurrentDate = CurrentDate.AddYears(1); await LoadAsync(); return; }
        if (ShowPrintReport) { CurrentDate = CurrentDate.AddMonths(1); await LoadAsync(); return; }
        CurrentDate = ActivePeriod switch
        {
            "Weekly" => CurrentDate.AddDays(7),
            "Yearly" => CurrentDate.AddYears(1),
            _        => CurrentDate.AddMonths(1)
        };
        await LoadAsync();
    }

    string GetPeriodLabel() => ActivePeriod switch
    {
        "Weekly" => $"Week of {WeekStartDate:MMM d}\u2013{WeekEndDate:%d}, {WeekStartDate:yyyy}",
        "Yearly" => CurrentDate.ToString("yyyy"),
        _        => CurrentDate.ToString("MMMM yyyy")
    };

    // Week-of-month model (days 1-7, 8-14, 15-21, 22-28, 29-end) — mirrors NPM so a week stays in one month.
    int WeekIndex => ((CurrentDate.Day - 1) / 7) + 1;
    (int FromDay, int ToDay) WeekDayRange()
    {
        var daysInMonth = DateTime.DaysInMonth(CurrentDate.Year, CurrentDate.Month);
        return ((WeekIndex - 1) * 7 + 1, Math.Min(WeekIndex * 7, daysInMonth));
    }
    DateTime WeekStartDate => new(CurrentDate.Year, CurrentDate.Month, WeekDayRange().FromDay);
    DateTime WeekEndDate => new(CurrentDate.Year, CurrentDate.Month, WeekDayRange().ToDay);
    string PrintReportPeriodLabel => $"Status Report — {CurrentDate:MMMM yyyy}";
    string HistoryPeriodLabel => $"History — {CurrentDate.Year}";

    bool IsYearly => ActivePeriod == "Yearly";
    string PeriodNoun => ActivePeriod switch { "Yearly" => "year", "Weekly" => "week", _ => "month" };
    private TrmPeriodSummaryDto? YearRow => Hist?.Yearly.FirstOrDefault(y => y.Year == CurrentDate.Year);

    // ── KPI values (period-aware) ─────────────────────────────────
    decimal TotalCollected   => IsYearly ? (YearRow?.Collected ?? 0m) : MonthTrips.Sum(t => t.Fee);
    int     TotalTrips       => IsYearly ? (YearRow?.Trips ?? 0) : MonthTrips.Count;
    int     ActiveTransporters => IsYearly ? (YearRow?.Transporters ?? 0) : MonthTrips.Where(t => t.TransporterId.HasValue).Select(t => t.TransporterId).Distinct().Count();
    int     AdHocTrips       => IsYearly ? (YearRow?.AdHocTrips ?? 0) : MonthTrips.Count(t => !t.TransporterId.HasValue);
    int     RoutesServed     => _routeBreakdown.Count;
    string? TopRoute         => _routeBreakdown.Count > 0 ? _routeBreakdown[0].Route : null;

    // ── Memoized Phase 1 breakdowns (rebuilt once per load) ───────
    record TallyRow(string Label, int Trips, decimal Collected);
    record RouteRow(string Route, int Trips, decimal Collected);
    record DonutSeg(string Label, int Count, string Color);

    private IReadOnlyList<TallyRow> _orgBreakdown = Array.Empty<TallyRow>();
    private IReadOnlyList<RouteRow> _routeBreakdown = Array.Empty<RouteRow>();
    private IReadOnlyList<TrendPoint> _trendPoints = Array.Empty<TrendPoint>();
    private IReadOnlyList<DonutSeg> _routeSegments = Array.Empty<DonutSeg>();

    IReadOnlyList<TallyRow> OrgBreakdown => _orgBreakdown;
    IReadOnlyList<RouteRow> RouteBreakdown => _routeBreakdown;
    IReadOnlyList<TrendPoint> TrendPoints => _trendPoints;
    IReadOnlyList<DonutSeg> RouteSegments => _routeSegments;

    IReadOnlyList<TallyRow> BuildOrgBreakdown()
    {
        if (IsYearly)
            return (YearRow?.Organizations ?? new List<TrmOrgTallyDto>())
                .Select(o => new TallyRow(o.Organization, o.Trips, o.Collected)).ToList();
        return MonthTrips
            .GroupBy(t => string.IsNullOrWhiteSpace(t.Organization) ? "—" : t.Organization)
            .Select(g => new TallyRow(g.Key, g.Count(), g.Sum(t => t.Fee)))
            .OrderByDescending(o => o.Trips)
            .ToList();
    }

    IReadOnlyList<RouteRow> BuildRouteBreakdown()
    {
        if (IsYearly)
            return (YearRow?.Routes ?? new List<TrmRouteTallyDto>())
                .Select(r => new RouteRow(r.Route, r.Trips, r.Collected)).ToList();
        return MonthTrips
            .GroupBy(t => string.IsNullOrWhiteSpace(t.Route) ? "—" : t.Route)
            .Select(g => new RouteRow(g.Key, g.Count(), g.Sum(t => t.Fee)))
            .OrderByDescending(r => r.Trips)
            .ToList();
    }

    // Route donut segments (top 5 + Other) — segment counts sum to TotalTrips.
    static readonly string[] RoutePalette = { "#1e3a5f", "#2d7a5f", "#c8a84b", "#6a8aa0", "#b5894e" };
    IReadOnlyList<DonutSeg> BuildRouteSegments(IReadOnlyList<RouteRow> ranked)
    {
        var segs = ranked.Take(5)
            .Select((r, i) => new DonutSeg(r.Route, r.Trips, RoutePalette[i % RoutePalette.Length]))
            .ToList();
        var rest = ranked.Skip(5).ToList();
        var other = rest.Sum(r => r.Trips);
        if (other > 0)
            segs.Add(new DonutSeg($"Other ({rest.Count} route{(rest.Count == 1 ? "" : "s")})", other, "#c3ced8"));
        return segs;
    }

    // ── Trend (daily for Monthly, monthly for Yearly) ─────────────
    record TrendPoint(string Label, decimal Amount, bool IsCurrent, int HeightPct, bool IsZero)
    {
        public string ShortValue => Amount >= 1000 ? $"{Amount / 1000:N1}k" : Amount.ToString("N0");
    }
    IReadOnlyList<TrendPoint> BuildTrendPoints()
    {
        var today = PhilippineTime.Today;
        List<(string Label, decimal Amount, bool IsCurrent)> pts;
        if (ActivePeriod == "Yearly")
        {
            // Yearly: trailing years (server returns a rolling last-5-years window), like NPM.
            pts = (Hist?.Yearly ?? new List<TrmPeriodSummaryDto>())
                .OrderBy(y => y.Year)
                .Select(y => (
                    Label: y.Year.ToString(),
                    Amount: y.Collected,
                    IsCurrent: y.Year == today.Year))
                .ToList();
        }
        else if (ActivePeriod == "Weekly")
        {
            // Weekly: show every day of the selected week, zero-filling days with no trips so the
            // chart reads as a full, clean 7-day strip.
            var (fromDay, toDay) = WeekDayRange();
            var feeByDay = MonthTrips
                .GroupBy(t => PhilippineTime.ToPhilippineTime(t.RecordedAt).Day)
                .ToDictionary(g => g.Key, g => g.Sum(t => t.Fee));
            pts = new List<(string Label, decimal Amount, bool IsCurrent)>();
            for (var day = fromDay; day <= toDay; day++)
            {
                var date = new DateTime(CurrentDate.Year, CurrentDate.Month, day);
                pts.Add((
                    date.ToString("MMM d"),
                    feeByDay.TryGetValue(day, out var amt) ? amt : 0m,
                    DateOnly.FromDateTime(date) == today));
            }
        }
        else
        {
            // Monthly: trailing 6 months ending at the selected month (from history), like NPM.
            pts = _trendMonthly
                .Select(m => (
                    Label: new DateOnly(m.Year, m.Month, 1).ToString("MMM yyyy"),
                    Amount: m.Collected,
                    IsCurrent: m.Year == today.Year && m.Month == today.Month))
                .ToList();
        }
        var max = pts.Any() ? pts.Max(x => x.Amount) : 0m;
        var ceiling = max > 0m ? max * 1.15m : 0m;
        return pts.Select(x => new TrendPoint(
            x.Label, x.Amount, x.IsCurrent,
            x.Amount > 0m && ceiling > 0m ? Math.Max(3, (int)(x.Amount / ceiling * 100)) : 0,
            x.Amount <= 0m)).ToList();
    }

    // ── History rows (Phase 3 + yearly monthly-summary) ───────────
    IReadOnlyList<TrmPeriodSummaryDto> HistoryMonthly => Hist?.Monthly ?? new List<TrmPeriodSummaryDto>();
    IReadOnlyList<TrmPeriodSummaryDto> HistoryYearly => Hist?.Yearly ?? new List<TrmPeriodSummaryDto>();

    // ── Donut arc builder ─────────────────────────────────────────
    record ArcSegment(string D, string Color);
    static IEnumerable<ArcSegment> BuildDonutArcs((int Count, string Color)[] segments, double r, double cx, double cy)
    {
        int total = segments.Sum(s => s.Count);
        if (total == 0) yield break;
        double start = -Math.PI / 2;
        foreach (var (count, color) in segments)
        {
            if (count == 0) continue;
            double sweep = 2 * Math.PI * count / total;
            double end = start + Math.Min(sweep, 2 * Math.PI - 0.0001);
            double x1 = cx + r * Math.Cos(start), y1 = cy + r * Math.Sin(start);
            double x2 = cx + r * Math.Cos(end),   y2 = cy + r * Math.Sin(end);
            yield return new ArcSegment($"M {x1:F3} {y1:F3} A {r} {r} 0 {(sweep > Math.PI ? 1 : 0)} 1 {x2:F3} {y2:F3}", color);
            start = end;
        }
    }
}
