@page "/reports/slaughterhouse"

@using EEMOCantilanSDS.Application.Dtos.Slaughterhouse
@using EEMOCantilanSDS.Domain.Enums
@attribute [Authorize(Roles = "Admin,SuperAdmin")]
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ISlaughterApiClient SlaughterApi

<PageTitle>EEMO Admin — Slaughterhouse List</PageTitle>

<!-- Topbar -->
<header class="topbar">
    <div class="topbar-left flex gap-2">
        <a href="/facility/slh" class="slr-back-btn">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
        </a>
        <div>
            <div class="topbar-title">Slaughterhouse Report</div>
            <div class="topbar-breadcrumb">
                <a href="/menu" class="breadcrumb-link">Dashboard</a>
                <span class="breadcrumb-sep">/</span>
                <a href="/facility/slh" class="breadcrumb-link">Slaughterhouse</a>
                <span class="breadcrumb-sep">/</span>
                <span class="breadcrumb-active">Report</span>
            </div>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @PhilippineTime.Now.ToString("MMMM d, yyyy")
        </div>
        <div class="topbar-admin">
            <div class="admin-avatar">A</div>
            <div class="admin-info">
                <div class="admin-name">Administrator</div>
                <div class="admin-role">EEMO Office</div>
            </div>
        </div>
    </div>
</header>

<div class="content-area">

    @if (isLoading)
    {
        <div class="spinner">Loading...</div>
    }
    else
    {
        <!-- ── Hero Banner ── -->
        <div class="slr-hero">
            <div class="slr-hero-left">
                <div class="slr-hero-icon">
                    <svg viewBox="0 0 24 24"><path d="M14.5 2.5c0 1.5-1.5 5-1.5 5h-2S9.5 4 9.5 2.5a2.5 2.5 0 0 1 5 0z" /><path d="M12 7.5V22" /><path d="M5 12h14" /></svg>
                </div>
                <div>
                    <div class="slr-hero-eyebrow">FACILITY · SLH</div>
                    <div class="slr-hero-title">Slaughterhouse List</div>
                    <div class="slr-hero-sub">Municipality of Cantilan, Surigao del Sur</div>
                </div>
            </div>
            <div class="slr-hero-stats">
                <div class="slr-hero-stat">
                    <div class="slr-hero-val">@TotalTransactions</div>
                    <div class="slr-hero-key">Transactions</div>
                </div>
                <div class="slr-hero-divider"></div>
                <div class="slr-hero-stat">
                    <div class="slr-hero-val">@TotalHeads</div>
                    <div class="slr-hero-key">Total Heads</div>
                </div>
                <div class="slr-hero-divider"></div>
                <div class="slr-hero-stat">
                    <div class="slr-hero-val">₱@TotalCollected.ToString("N0")</div>
                    <div class="slr-hero-key">Collected</div>
                </div>
                <div class="slr-hero-divider"></div>
                <div class="slr-hero-stat">
                    <div class="slr-hero-val">@CurrentMonth.ToString("MMM yyyy")</div>
                    <div class="slr-hero-key">Period</div>
                </div>
            </div>
            <div class="slr-hero-progress">
                <div class="slr-hero-progress-fill" style="width:100%"></div>
            </div>
        </div>

        <!-- ── Toolbar ── -->
        <div class="page-toolbar">
            <div class="toolbar-left">
                <div class="search-box">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    <input type="text" placeholder="Search owner or OR no…"
                           @bind="SearchQuery" @bind:event="oninput" />
                    @if (!string.IsNullOrEmpty(SearchQuery))
                    {
                        <span class="search-clear" @onclick="() => SearchQuery = string.Empty">×</span>
                    }
                </div>
                <div class="filter-tabs">
                    @foreach (var filter in AnimalFilters)
                    {
                        <div class="filter-tab @(ActiveFilter == filter ? "active" : "")"
                             @onclick="() => ActiveFilter = filter">
                            @filter
                        </div>
                    }
                </div>
                <div>
                    <button class="btn-outline" @onclick="ToggleGroupView">
                        <svg viewBox="0 0 24 24" style="width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;vertical-align:middle;margin-right:4px;">
                            <rect x="3" y="3" width="7" height="7" />
                            <rect x="14" y="3" width="7" height="7" />
                            <rect x="3" y="14" width="7" height="7" />
                            <rect x="14" y="14" width="7" height="7" />
                        </svg>
                        @(IsGroupedView ? "Ungroup" : "Group by Owner")
                    </button>
                </div>
            </div>
            <div style="display:flex;gap:8px;">
                <button class="btn-outline" onclick="window.print()">
                    <svg viewBox="0 0 24 24" style="width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;vertical-align:middle;margin-right:4px;">
                        <polyline points="6 9 6 2 18 2 18 9" />
                        <path d="M6 18H4a2 2 0 01-2-2v-5a2 2 0 012-2h16a2 2 0 012 2v5a2 2 0 01-2 2h-2" />
                        <rect x="6" y="14" width="12" height="8" />
                    </svg>
                    Print / Export
                </button>
                <a href="/facility/slh" class="btn-outline">
                    <svg viewBox="0 0 24 24" style="width:13px;height:13px;stroke:currentColor;fill:none;stroke-width:2;stroke-linecap:round;stroke-linejoin:round;vertical-align:middle;margin-right:4px;">
                        <polyline points="15 18 9 12 15 6" />
                    </svg>
                    Back
                </a>
            </div>
        </div>

        <!-- ── Document Panel ── -->
        <div class="slr-doc-panel">

            <!-- Document Header -->
            <div class="slr-doc-header">
                <img class="slr-doc-logo" src="/images/LGU_CANTILAN_LOGO.jpg" alt="LGU Cantilan logo" />
                <div class="slr-doc-republic">Republic of the Philippines</div>
                <div class="slr-doc-office">Economic Enterprise &amp; Management Office</div>
                <div class="slr-doc-gov">Municipality of Cantilan, Surigao del Sur</div>
                <div class="slr-doc-title">Slaughterhouse List</div>
                <div class="slr-doc-facility">@CurrentMonth.ToString("MMMM yyyy").ToUpper()</div>
            </div>

            @foreach (var animalType in VisibleAnimalTypes)
            {
                var transactions = IsGroupedView 
                    ? GetGroupedTransactions(animalType).Where(t => MatchSearchGrouped(t)).ToList()
                    : GetAnimalTransactions(animalType).Where(MatchSearch).ToList();
                    
                if (!transactions.Any()) continue;

                <div class="slr-section-block">
                    <div class="slr-section-label-row">
                        <span class="slr-section-label">@animalType.ToUpper()</span>
                        <span class="slr-section-count">@transactions.Count @(IsGroupedView ? "owner" : "transaction")@(transactions.Count != 1 ? "s" : "")</span>
                    </div>

                    <table class="slr-table">
                        <thead>
                            <tr>
                                <th class="col-no">#</th>
                                <th class="col-date">@(IsGroupedView ? "Latest Date" : "Date")</th>
                                <th class="col-owner">Owner / Client</th>
                                <th class="col-animal">Animal Type</th>
                                <th class="col-heads">No. of<br />Heads</th>
                                <th class="col-rate">Rate /<br />Head</th>
                                <th class="col-amount">Total<br />Amount</th>
                                <th class="col-or">OR No.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int rowNum = 1;
                            }
                            @if (IsGroupedView)
                            {
                                @foreach (var t in transactions)
                                {
                                    <tr>
                                        <td class="c">@rowNum</td>
                                        <td class="c">@t.TransactionDate.ToString("M/d/yyyy")</td>
                                        <td class="tl fw">@t.OwnerName</td>
                                        <td class="c">@GetAnimalTypeName(t.AnimalType, t.CustomAnimalType)</td>
                                        <td class="c">@t.NumberOfHeads</td>
                                        <td class="r">@(t.NumberOfHeads > 0 ? "₱" + t.RatePerHead.ToString("N2") : "—")</td>
                                        <td class="r">₱@t.TotalAmount.ToString("N2")</td>
                                        <td class="c mono">—</td>
                                    </tr>
                                    rowNum++;
                                }
                            }
                            else
                            {
                                @foreach (var t in transactions.Cast<SlaughterTransactionDto>())
                                {
                                    <tr>
                                        <td class="c">@rowNum</td>
                                        <td class="c">@t.TransactionDate.ToString("M/d/yyyy")</td>
                                        <td class="tl fw">@t.OwnerName</td>
                                        <td class="c">@GetAnimalTypeName(t.AnimalType, t.CustomAnimalType)</td>
                                        <td class="c">@t.NumberOfHeads</td>
                                        <td class="r">₱@t.RatePerHead.ToString("N2")</td>
                                        <td class="r">₱@t.TotalAmount.ToString("N2")</td>
                                        <td class="c mono">@t.ORNumber</td>
                                    </tr>
                                    rowNum++;
                                }
                            }
                        </tbody>
                        <tfoot>
                            <tr class="tfoot-row">
                                <td colspan="4" class="tfoot-label">
                                    @animalType Total — @transactions.Sum(t => t.NumberOfHeads) head@(transactions.Sum(t => t.NumberOfHeads) != 1 ? "s" : "")
                                </td>
                                <td class="c tfoot-val">@transactions.Sum(t => t.NumberOfHeads)</td>
                                <td class="r tfoot-val">—</td>
                                <td class="r tfoot-val">₱@transactions.Sum(t => t.TotalAmount).ToString("N2")</td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }

            @if (ActiveFilter == "All")
            {
                <div class="slr-grand-total">
                    <div class="slr-grand-label">Grand Total — @CurrentMonth.ToString("MMMM yyyy")</div>
                    <div class="slr-grand-stats">
                        <div class="slr-grand-stat">
                            <div class="slr-grand-val">@TotalTransactions</div>
                            <div class="slr-grand-key">Total Transactions</div>
                        </div>
                        <div class="slr-grand-stat">
                            <div class="slr-grand-val">@TotalHeads</div>
                            <div class="slr-grand-key">Total Heads Slaughtered</div>
                        </div>
                        <div class="slr-grand-stat">
                            <div class="slr-grand-val">₱@TotalCollected.ToString("N2")</div>
                            <div class="slr-grand-key">Total Amount Collected</div>
                        </div>
                    </div>
                </div>
            }

        </div>
    }

</div>

@code {
    private bool isLoading = true;
    private DateTime CurrentMonth = PhilippineTime.Now;
    private string SearchQuery = string.Empty;
    private string ActiveFilter = "All";
    private bool IsGroupedView = false;
    private List<SlaughterTransactionDto> AllTransactions = new();

    private readonly string[] AnimalFilters = ["All", "Hog", "Carabao", "Cow", "Others"];

    private int TotalTransactions => AllTransactions.Count;
    private int TotalHeads => AllTransactions.Sum(t => t.NumberOfHeads);
    private decimal TotalCollected => AllTransactions.Sum(t => t.TotalAmount);

    private IEnumerable<string> VisibleAnimalTypes => ActiveFilter == "All"
        ? new[] { "Hog", "Carabao", "Cow", "Others" }
        : new[] { ActiveFilter };

    private void ToggleGroupView()
    {
        IsGroupedView = !IsGroupedView;
    }

    private IEnumerable<SlaughterTransactionDto> GetAnimalTransactions(string animalType)
    {
        return animalType switch
        {
            "Hog" => AllTransactions.Where(t => t.AnimalType == AnimalType.Hog),
            "Carabao" => AllTransactions.Where(t => t.AnimalType == AnimalType.Carabao),
            "Cow" => AllTransactions.Where(t => t.AnimalType == AnimalType.Cow),
            "Others" => AllTransactions.Where(t => t.AnimalType == AnimalType.Other),
            _ => AllTransactions
        };
    }

    private IEnumerable<SlaughterTransactionDto> GetGroupedTransactions(string animalType)
    {
        var baseTransactions = GetAnimalTransactions(animalType);
        
        return baseTransactions
            .GroupBy(t => new { t.OwnerName, t.AnimalType, t.CustomAnimalType })
            .Select(g => new SlaughterTransactionDto(
                Guid.NewGuid(),
                g.Key.OwnerName,
                g.Key.AnimalType,
                g.Key.CustomAnimalType,
                g.Sum(t => t.NumberOfHeads),
                g.First().RatePerHead,
                g.Sum(t => t.TotalAmount),
                "---",
                g.Max(t => t.TransactionDate)
            ))
            .OrderBy(t => t.OwnerName);
    }

    private bool MatchSearch(SlaughterTransactionDto t) =>
        string.IsNullOrWhiteSpace(SearchQuery) ||
        t.OwnerName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase) ||
        (t.ORNumber != null && t.ORNumber.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

    private bool MatchSearchGrouped(SlaughterTransactionDto t) =>
        string.IsNullOrWhiteSpace(SearchQuery) ||
        t.OwnerName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);

    private string GetAnimalTypeName(AnimalType animalType, string? customAnimalType)
    {
        return animalType switch
        {
            AnimalType.Hog => "Hog",
            AnimalType.Carabao => "Carabao",
            AnimalType.Cow => "Cow",
            AnimalType.Other => customAnimalType ?? "Other",
            _ => "Unknown"
        };
    }

    private string GetRowClass(AnimalType animalType, string? customAnimalType)
    {
        return animalType switch
        {
            AnimalType.Hog => "row-hog",
            AnimalType.Carabao => "row-carabao",
            AnimalType.Cow => "row-cow",
            AnimalType.Other => "row-other",
            _ => ""
        };
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;

        var result = await SlaughterApi.GetTransactionsAsync(CurrentMonth.Year, CurrentMonth.Month);
        if (result.IsSuccess && result.Value != null)
        {
            AllTransactions = result.Value.ToList();
        }

        isLoading = false;
    }
}
