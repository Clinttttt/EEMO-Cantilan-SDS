            </thead>
            <tbody>
                @if (!RegisterRows.Any())
                {
                    <tr><td colspan="9" class="register-empty">No active stallholders for @FacilityCatalog.NameOf(FacilityCode.NPM).</td></tr>
                }
                else
                {
                    @foreach (var r in RegisterRows)
                    {
                        <tr class="@(r.IsMismatch ? "row-mismatch" : "")">
                            <td class="stall-no">@r.StallNo</td>
                            <td>@r.Occupant</td>
                            <td>@r.ContractName</td>
                            <td>@r.Effectivity</td>
                            <td>@r.Years yrs</td>
                            <td>@r.AreaSqm.ToString("0.##")</td>
                            <td>₱@r.Monthly.ToString("N2")</td>
                            <td>₱@r.Monthly.ToString("N2")</td>
                            <td class="register-year">₱@r.WholeYear.ToString("N2")</td>
