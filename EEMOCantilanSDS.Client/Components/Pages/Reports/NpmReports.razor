@page "/npm/reports"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using EEMOCantilanSDS.Application.Dtos.Facilities
@inject IFacilitiesApiClient FacilitiesApi
@inject IUtilitiesApiClient UtilitiesApi
@inject IJSRuntime JS
@inject EEMOCantilanSDS.Client.Services.FacilityState FacilityCatalog
@using EEMOCantilanSDS.Application.Dtos.Utilities

<PageTitle>@Branding.OfficeAcronym Admin — NPM Reports</PageTitle>

<!-- ══ Page Header ══ -->
<header class="rpt-topbar">
    <div class="rpt-topbar-left">
        <a href="/npm" class="rpt-back-btn" title="Back to NPM" aria-label="Back to NPM">
            <svg aria-hidden="true" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
        </a>
        <div class="rpt-topbar-icon">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z" /></svg>
        </div>
        <div>
            <div class="rpt-eyebrow">FACILITY · @FacilityCatalog.ShortNameOf(FacilityCode.NPM) · REPORTS</div>
            <h1 class="rpt-title">@FacilityCatalog.NameOf(FacilityCode.NPM) Reports</h1>
            <div class="rpt-subtitle">@GetPeriodLabel()</div>
        </div>
    </div>
    <div class="rpt-topbar-right">
        <LiveClock />
    </div>
    <div class="rpt-header-progress">
        <div class="rpt-header-progress-fill" style="width: @CollectionRate%"></div>
    </div>
</header>

<!-- ══ Period Selector ══ -->
<div class="rpt-period-bar">
    <div class="rpt-period-tabs">
        @foreach (var p in new[] { "Weekly", "Monthly", "Yearly" })
        {
            <button type="button" class="rpt-period-tab @(!ShowUtilityBilling && !ShowPrintReport && !ShowHistory && ActivePeriod == p ? "active" : "")"
                    aria-pressed="@(!ShowUtilityBilling && !ShowPrintReport && !ShowHistory && ActivePeriod == p)"
                    @onclick="() => SetPeriod(p)">@p</button>
        }
        <button type="button" class="rpt-period-tab rpt-document-tab @(ShowPrintReport ? "active" : "")"
                aria-pressed="@ShowPrintReport"
                @onclick="ShowPrintReportView">
            <svg aria-hidden="true" viewBox="0 0 24 24">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <line x1="8" y1="13" x2="16" y2="13" />
                <line x1="8" y1="17" x2="16" y2="17" />
            </svg>
            <span>Status Report</span>
        </button>
        <button type="button" class="rpt-period-tab rpt-document-tab @(ShowHistory ? "active" : "")"
                aria-pressed="@ShowHistory"
                @onclick="ShowHistoryView">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            </svg>
            <span>History</span>
        </button>
        <button type="button" class="rpt-period-tab rpt-utility-tab @(ShowUtilityBilling ? "active" : "")"
                aria-pressed="@ShowUtilityBilling"
                @onclick="ShowUtilityBillingView">
            <svg aria-hidden="true" viewBox="0 0 24 24">
                <path d="M13 2L6 14h6l-1 8 7-12h-6l1-8z" />
            </svg>
            <span>Utility Billing</span>
        </button>
    </div>
    <ReportPeriodNav Year="CurrentDate.Year" Month="CurrentDate.Month"
                     Yearly="@(!ShowUtilityBilling && !ShowPrintReport && (ShowHistory || ActivePeriod == "Yearly"))"
                     Label="@(ShowUtilityBilling ? UtilityBillingPeriodLabel : ShowPrintReport ? PrintReportPeriodLabel : ShowHistory ? HistoryPeriodLabel : GetPeriodLabel())"
                     UtilityMode="@(ShowUtilityBilling || ShowPrintReport || ShowHistory)"
                     OnPrev="PrevPeriod" OnNext="NextPeriod"
                     OnPick="PickPeriod" OnToday="JumpToCurrent" />
</div>

<!-- ══ KPI Cards ══ -->
@if (ShowPrintReport)
{
    <div class="rpt-content print-document-content">
        <section class="print-report-sheet status-sheet">

            <header class="print-report-header">
                <img class="print-report-logo" src="@Branding.SealPath" alt="@Branding.Municipality seal" />
                <div class="print-republic">Republic of the Philippines</div>
                <h2>@Branding.OfficeName</h2>
                <p>Municipality of @Branding.Municipality, @Branding.Province</p>
                <div class="print-report-title">@FacilityCatalog.NameOf(FacilityCode.NPM) Current Status Report</div>
            </header>

            <div class="print-report-meta">
                <div><span>Facility</span><strong>@FacilityCatalog.NameOf(FacilityCode.NPM)</strong></div>
                <div><span>Report Period</span><strong>@CurrentDate.ToString("MMMM yyyy")</strong></div>
                <div><span>Prepared By</span><strong>@Branding.OfficeAcronym Office</strong></div>
                <div><span>Date Prepared</span><strong>@PhilippineTime.Now.ToString("MMM d, yyyy")</strong></div>
            </div>

            <div class="print-report-summary">
                <div><span>Total Stalls</span><strong>@PrintRows.Count</strong></div>
                <div><span>Collected</span><strong>&#8369;@PrintRows.Sum(r => r.AmountPaid).ToString("N2")</strong></div>
                <div><span>Outstanding</span><strong>&#8369;@PrintRows.Sum(r => r.Balance).ToString("N2")</strong></div>
                <div><span>For Follow-up</span><strong>@PrintRows.Count(r => r.Balance > 0) payor@(PrintRows.Count(r => r.Balance > 0) != 1 ? "s" : "")</strong></div>
            </div>

            @if (!PrintRows.Any())
            {
                <p class="print-empty">No stallholders under an active contract for @CurrentDate.ToString("MMMM yyyy").</p>
            }

            @{
                var sections = new[] { "Fish Area", "Meat Area", "Vegetable Area" };
            }
            @foreach (var sec in sections)
            {
                var rows = PrintRows.Where(r => r.Section == sec).ToList();
                if (!rows.Any()) continue;
                var secCollected = rows.Sum(r => r.AmountPaid);
                var secBalance   = rows.Sum(r => r.Balance);
                var secFollowUp  = rows.Count(r => r.Balance > 0);
                <div class="print-section-block">
                    <div class="print-section-heading">@sec</div>
                    <div class="print-section-summary">
                        <div><span>Stalls</span><strong>@rows.Count</strong></div>
                        <div><span>Collected</span><strong>&#8369;@secCollected.ToString("N2")</strong></div>
                        <div><span>Outstanding</span><strong>&#8369;@secBalance.ToString("N2")</strong></div>
                        <div><span>For Follow-up</span><strong>@secFollowUp payor@(secFollowUp != 1 ? "s" : "")</strong></div>
                    </div>
                    <div class="print-table-wrap">
                        <table class="print-status-table">
                            <thead>
                                <tr>
                                    <th>Stall No.</th>
                                    <th>Payor / Occupant</th>
                                    <th>Stall Type</th>
                                    <th>Monthly Due</th>
                                    <th>Status</th>
                                    <th>Amount Paid</th>
                                    <th>Balance</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var row in rows)
                                {
                                    <tr>
                                        <td>@row.StallNo</td>
                                        <td>@row.Payor</td>
                                        <td>@row.Classification</td>
                                        <td>&#8369;@row.MonthlyDue.ToString("N2")</td>
                                        <td class="status-@row.Status.ToLower()">@row.Status</td>
                                        <td>@(row.AmountPaid > 0 ? "₱" + row.AmountPaid.ToString("N2") : "-")</td>
                                        <td>@(row.Balance > 0 ? "₱" + row.Balance.ToString("N2") : "-")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="print-report-signatures">
                <div>
                    <span>Prepared by</span>
                    <strong>Administrative Staff</strong>
                </div>
                <div>
                    <span>Reviewed by</span>
                    <strong>Head, @Branding.OfficeAcronym Office</strong>
                </div>
                <div>
                    <span>Received by</span>
                    <strong>Authorized Representative</strong>
                </div>
            </div>
        </section>
    </div>
}
else if (ShowHistory)
{
    <div class="rpt-content print-document-content">
        <section class="print-report-sheet history-sheet">
            <header class="print-report-header">
                <img class="print-report-logo" src="@Branding.SealPath" alt="@Branding.Municipality seal" />
                <div class="print-republic">Republic of the Philippines</div>
                <h2>@Branding.OfficeName</h2>
                <p>Municipality of @Branding.Municipality, @Branding.Province</p>
                <div class="print-report-title">@FacilityCatalog.NameOf(FacilityCode.NPM) — Collection History</div>
            </header>

            <div class="print-report-meta">
                <div><span>Facility</span><strong>@FacilityCatalog.NameOf(FacilityCode.NPM)</strong></div>
                <div><span>Year</span><strong>@CurrentDate.Year</strong></div>
                <div><span>Prepared By</span><strong>@Branding.OfficeAcronym Office</strong></div>
                <div><span>Date Prepared</span><strong>@PhilippineTime.Now.ToString("MMM d, yyyy")</strong></div>
            </div>

            <!-- Monthly History -->
            <div class="print-section-block">
                <div class="print-section-heading">Monthly Collection — @CurrentDate.Year</div>                <div class="print-table-wrap">
                    <table class="print-status-table history-table">
                        <thead>
                            <tr>
                                <th>Month</th>
                                <th>Total Stalls</th>
                                <th>Collected</th>
                                <th>Outstanding</th>
                                <th>For Follow-up</th>
                                <th>Collection Rate</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!HistoryMonthlyRows.Any())
                            {
                                <tr><td colspan="6" class="history-empty">@(HistoryLoading ? "Loading…" : "No collection records for this year.")</td></tr>
                            }
                            @foreach (var row in HistoryMonthlyRows)
                            {
                                <tr>
                                    <td>@row.Label</td>
                                    <td>@row.TotalStalls</td>
                                    <td>@(row.Collected > 0 ? "₱" + row.Collected.ToString("N2") : "—")</td>
                                    <td class="@(row.Outstanding > 0 ? "balance-due" : "")">@(row.Outstanding > 0 ? "₱" + row.Outstanding.ToString("N2") : "—")</td>
                                    <td>@(row.FollowUp > 0 ? row.FollowUp + " payor" + (row.FollowUp != 1 ? "s" : "") : "—")</td>
                                    <td class="@(row.CollectionRate >= 80 ? "rate-good" : row.CollectionRate >= 40 ? "rate-partial" : "rate-low")">@row.CollectionRate.ToString("N0")%</td>
                                </tr>
                            }
                        </tbody>
                        @if (HistoryMonthlyRows.Any())
                        {
                            <tfoot>
                                <tr class="history-total-row">
                                    <td><strong>Total</strong></td>
                                    <td>—</td>
                                    <td><strong>₱@HistoryMonthlyRows.Sum(r => r.Collected).ToString("N2")</strong></td>
                                    <td><strong>₱@HistoryMonthlyRows.Max(r => r.Outstanding).ToString("N2")</strong></td>
                                    <td><strong>@HistoryMonthlyRows.Max(r => r.FollowUp) payors</strong></td>
                                    <td>—</td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>

            <!-- Yearly History -->
            <div class="print-section-block">
                <div class="print-section-heading">Yearly Collection Summary</div>
                <div class="print-table-wrap">
                    <table class="print-status-table history-table">
                        <thead>
                            <tr>
                                <th>Year</th>
                                <th>Total Stalls</th>
                                <th>Collected</th>
                                <th>Outstanding</th>
                                <th>For Follow-up</th>
                                <th>Collection Rate</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!HistoryYearlyRows.Any())
                            {
                                <tr><td colspan="6" class="history-empty">@(HistoryLoading ? "Loading…" : "No yearly records.")</td></tr>
                            }
                            @foreach (var row in HistoryYearlyRows)
                            {
                                <tr>
                                    <td><strong>@row.Label</strong></td>
                                    <td>@row.TotalStalls</td>
                                    <td>@(row.Collected > 0 ? "₱" + row.Collected.ToString("N2") : "—")</td>
                                    <td class="@(row.Outstanding > 0 ? "balance-due" : "")">@(row.Outstanding > 0 ? "₱" + row.Outstanding.ToString("N2") : "—")</td>
                                    <td>@(row.FollowUp > 0 ? row.FollowUp + " payors" : "—")</td>
                                    <td class="@(row.CollectionRate >= 80 ? "rate-good" : row.CollectionRate >= 40 ? "rate-partial" : "rate-low")">@row.CollectionRate.ToString("N0")%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="print-report-signatures">
                <div><span>Prepared by</span><strong>Administrative Staff</strong></div>
                <div><span>Reviewed by</span><strong>Head, @Branding.OfficeAcronym Office</strong></div>
                <div><span>Received by</span><strong>Authorized Representative</strong></div>
            </div>
        </section>
    </div>
}
else if (ShowUtilityBilling)
{
    <div class="rpt-content">
        <div class="utility-billing-board">
            <section class="utility-hero">
                <div>
                    <div class="utility-eyebrow">END-OF-MONTH CONSUMPTION BILLING</div>
                    <h2>Electricity &amp; Water Billing Reports</h2>
                </div>
                <div class="utility-preview-pill">@CurrentDate.ToString("MMMM yyyy")</div>
            </section>

            <div class="utility-summary-grid">
                <div class="utility-summary-card">
                    <span>Total Utility Due</span>
                    <strong>&#8369;@UtilityTotalDue.ToString("N2")</strong>
                    <small>Electricity and water charges only</small>
                </div>
                <div class="utility-summary-card">
                    <span>Unpaid Utilities</span>
                    <strong>&#8369;@UtilityUnpaidTotal.ToString("N2")</strong>
                    <small>@UtilityRows.Count(r => r.Status == "Unpaid") accounts for follow-up</small>
                </div>
                <div class="utility-summary-card">
                    <span>Paid Utilities</span>
                    <strong>&#8369;@UtilityPaidTotal.ToString("N2")</strong>
                    <small>@UtilityRows.Count(r => r.Status == "Paid") accounts settled</small>
                </div>
                <div class="utility-summary-card">
                    <span>Billing Period</span>
                    <strong>@CurrentDate.ToString("MMM yyyy")</strong>
                    <small>Due at month end</small>
                </div>
            </div>

            <section class="utility-panel">
                <div class="utility-panel-head">
                    <div class="utility-search">
                        <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                        <input type="search" placeholder="Search payor or stall no." value="@_utilSearch" @oninput="e => _utilSearch = e.Value?.ToString() ?? string.Empty" />
                    </div>
                    <div class="utility-panel-head-actions">
                        <div class="utility-section-tabs">
                            @foreach (var sec in UtilitySections)
                            {
                                <button type="button" class="utility-section-tab @(_utilSection == sec ? "active" : "")" @onclick="() => _utilSection = sec">@sec</button>
                            }
                        </div>
                        <button type="button" class="utility-secondary-btn" disabled>Generate Billing Statement</button>
                    </div>
                </div>

                <div class="utility-table-wrap">
                    <table class="utility-table">
                        <thead>
                            <tr>
                                <th>Stall</th>
                                <th>Payor</th>
                                <th>Section</th>
                                <th>Electricity Reading</th>
                                <th>Water Reading</th>
                                <th>Utility Due</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in FilteredUtilityRows)
                            {
                                <tr class="utility-row-click" @onclick="() => OpenStallHistory(row)" title="View full utility history">
                                    <td class="stall-no">@row.StallNo</td>
                                    <td>
                                        <strong class="utility-payor-name">@row.Payor</strong>
                                        <span class="utility-payor-note">@row.Note</span>
                                    </td>
                                    <td>@row.Section</td>
                                    <td>
                                        <span class="utility-reading">@row.ElectricPrevious.ToString("N0") to @row.ElectricCurrent.ToString("N0") kWh</span>
                                        <small>&#8369;@row.ElectricAmount.ToString("N2") due</small>
                                    </td>
                                    <td>
                                        <span class="utility-reading">@row.WaterPrevious.ToString("N0") to @row.WaterCurrent.ToString("N0") cu.m</span>
                                        <small>&#8369;@row.WaterAmount.ToString("N2") due</small>
                                    </td>
                                    <td class="utility-due">&#8369;@row.TotalDue.ToString("N2")</td>
                                    <td>
                                        <div class="utility-status-pair">
                                            <span class="utility-status @row.ElecStatusCss" title="Electricity charge status">E · @row.ElecStatus</span>
                                            <span class="utility-status @row.WaterStatusCss" title="Water charge status">W · @row.WaterStatus</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>

            @if (ShowUtilHistory && HistoryRow is not null)
            {
                <div class="utility-hist-overlay" @onclick="CloseUtilHistory">
                    <div class="utility-hist-modal" @onclick:stopPropagation="true">
                        <div class="utility-hist-head">
                            <div>
                                <h3>Utility History · @HistoryRow.Payor</h3>
                                <p>Stall @HistoryRow.StallNo · @HistoryRow.Section</p>
                            </div>
                            <button type="button" class="utility-hist-x" @onclick="CloseUtilHistory" aria-label="Close">&times;</button>
                        </div>
                        @if (UtilHistLoading)
                        {
                            <div class="utility-hist-state">Loading history…</div>
                        }
                        else if (HistoryRows is null || HistoryRows.Count == 0)
                        {
                            <div class="utility-hist-state">No utility bills recorded for this stall yet.</div>
                        }
                        else
                        {
                            <div class="utility-hist-wrap">
                                <table class="utility-hist-table">
                                    <thead>
                                        <tr>
                                            <th>Period</th>
                                            <th>Electricity (prev → cur)</th><th>kWh</th><th>Rate</th><th>Charge</th>
                                            <th>Water (prev → cur)</th><th>cu.m</th><th>Rate</th><th>Charge</th>
                                            <th>Total</th><th>Status</th><th>Paid</th><th>OR No.</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var h in HistoryRows)
                                        {
                                            <tr>
                                                <td class="uh-period">@(new DateTime(h.Year, h.Month, 1).ToString("MMM yyyy"))</td>
                                                <td>@h.ElecPreviousReading.ToString("N0") → @h.ElecCurrentReading.ToString("N0")</td>
                                                <td>@h.ElecConsumption.ToString("N0")</td>
                                                <td>&#8369;@h.ElecRatePerKwh.ToString("N2")</td>
                                                <td>&#8369;@h.ElecCharge.ToString("N2")</td>
                                                <td>@h.WaterPreviousReading.ToString("N0") → @h.WaterCurrentReading.ToString("N0")</td>
                                                <td>@h.WaterConsumption.ToString("N0")</td>
                                                <td>&#8369;@h.WaterRatePerCubicMeter.ToString("N2")</td>
                                                <td>&#8369;@h.WaterCharge.ToString("N2")</td>
                                                <td class="uh-total">&#8369;@h.TotalCharge.ToString("N2")</td>
                                                <td>
                                                    <div class="utility-status-pair">
                                                        <span class="utility-status @HistoryStatusCss(h.ElecStatus)">E · @h.ElecStatus</span>
                                                        <span class="utility-status @HistoryStatusCss(h.WaterStatus)">W · @h.WaterStatus</span>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="utility-status-pair">
                                                        <span class="uh-or">E · @(h.ElecPaidAt?.AddHours(8).ToString("MMM d, yyyy") ?? "—")</span>
                                                        <span class="uh-or">W · @(h.WaterPaidAt?.AddHours(8).ToString("MMM d, yyyy") ?? "—")</span>
                                                    </div>
                                                </td>
                                                <td>
                                                    <div class="utility-status-pair">
                                                        <span class="uh-or">E · @(string.IsNullOrEmpty(h.ElecORNumber) ? "—" : h.ElecORNumber)</span>
                                                        <span class="uh-or">W · @(string.IsNullOrEmpty(h.WaterORNumber) ? "—" : h.WaterORNumber)</span>
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            }

        </div>
    </div>
}
else
{
<div class="rpt-content">
    <div class="rpt-kpi-strip">

        <div class="rpt-kpi-card kpi-revenue">
            <div class="kpi-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h7a4 4 0 0 1 0 8H6z" /><line x1="4" y1="9" x2="16" y2="9" /><line x1="4" y1="13" x2="16" y2="13" /><line x1="6" y1="4" x2="6" y2="20" /></svg>
            </div>
            <div class="kpi-body">
                <div class="kpi-label">Collected Revenue</div>
                <div class="kpi-value">₱@TotalCollected.ToString("N2")</div>
                <div class="kpi-change positive">@RevenueGrowthText</div>
            </div>
        </div>

        <div class="rpt-kpi-card kpi-rate">
            <div class="kpi-icon">
                <svg viewBox="0 0 24 24"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
            </div>
            <div class="kpi-body">
                <div class="kpi-label">Collection Rate</div>
                <div class="kpi-value">@CollectionRate%</div>
                <div class="kpi-change positive">@CollectionGrowthText</div>
            </div>
        </div>

        <div class="rpt-kpi-card kpi-pending">
            <div class="kpi-icon">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            </div>
            <div class="kpi-body">
                <div class="kpi-label">Payors With Balance</div>
                <div class="kpi-value">@(UnpaidCount + PartialCount)</div>
                <div class="kpi-change negative">₱@PendingAmount.ToString("N2") outstanding</div>
            </div>
        </div>

        <div class="rpt-kpi-card kpi-stalls">
            <div class="kpi-icon">
                <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </div>
            <div class="kpi-body">
                <div class="kpi-label">Occupied Stalls</div>
                <div class="kpi-value">@OccupiedStalls/@TotalStalls</div>
                <div class="kpi-change neutral">@OccupancyRate% of active stalls</div>
            </div>
        </div>

    </div>


    <!-- ══ Charts Row ══ -->
    <div class="rpt-charts-row">

        <!-- Collection Trend Bar Chart -->
        <div class="rpt-chart-card rpt-chart-wide">
            <div class="chart-header">
                <div class="chart-header-left">
                    <h3 class="chart-title">Collection Trend</h3>
                    <p class="chart-subtitle">Recorded collections by reporting period</p>
                </div>
                <div class="chart-legend">
                    <div class="legend-item">
                        <span class="legend-dot" style="background:#2d7a5f"></span>
                        <span class="legend-label">Daily rent</span>
                    </div>
                    <div class="legend-item">
                        <span class="legend-dot" style="background:#4a9eff"></span>
                        <span class="legend-label">Fish fee</span>
                    </div>
                    <div class="legend-item">
                        <span class="legend-dot" style="background:#c8a84b"></span>
                        <span class="legend-label">Current Period</span>
                    </div>
                </div>
            </div>
            <CollectionTrendChart Trend="R?.RevenueTrend"
                                  RentLabel="Daily rent"
                                  EmptyPeriodLabel="@GetPeriodLabel()" />
        </div>

        <!-- Status Donut -->
        <div class="rpt-chart-card rpt-chart-narrow rpt-status-card">
            <div class="chart-header">
                <div class="chart-header-left">
                    <h3 class="chart-title">Payor Status</h3>
                    <p class="chart-subtitle">Payor count by payment status</p>
                </div>
            </div>
            <PayorStatusDonut PaidCount="@PaidCount" PartialCount="@PartialCount" UnpaidCount="@UnpaidCount" />
        </div>

    </div>


    <!-- ══ Audit Breakdown ══ -->
    <div class="rpt-section-heading">
        <span class="rpt-section-rule"></span>
        <h2>Audit Breakdown</h2>
    </div>

    <div class="audit-board">

        <div class="audit-card audit-card-donut">
            <div class="audit-card-head">
                <div class="audit-head-metric">
                    <span>Revenue by Market Section</span>
                </div>
                <small class="audit-subtitle">Section revenue mix for @GetPeriodLabel()</small>
            </div>
            @if (SectionData.Any(s => s.Revenue > 0))
            {
                <div class="audit-donut-row">
                    <div class="audit-donut-container">
                        <svg class="audit-donut" viewBox="0 0 120 120">
                            <defs>
                                @foreach (var c in SectionData.Where(s => s.Revenue > 0).Select(s => s.Color).Distinct())
                                {
                                    <linearGradient id="@SecGradId(c)" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="@c" /><stop offset="100%" stop-color="@Darken(c)" />
                                    </linearGradient>
                                }
                                <radialGradient id="audit-hole" cx="50%" cy="40%" r="62%">
                                    <stop offset="0%" stop-color="#ffffff" /><stop offset="100%" stop-color="#eef2f6" />
                                </radialGradient>
                                <filter id="audit-depth" x="-30%" y="-30%" width="160%" height="160%">
                                    <feDropShadow dx="0" dy="5" stdDeviation="4" flood-color="#0d2137" flood-opacity="0.18" />
                                </filter>
                            </defs>
                            <circle cx="60" cy="60" r="42" fill="none" stroke="#eef2f6" stroke-width="20" />
                            @{ var auditSecArcs = BuildDonutArcs(SectionData.Select(s => ((int)Math.Round(s.Revenue), $"url(#{SecGradId(s.Color)})")).ToArray(), 42, 60, 60); }
                            <g filter="url(#audit-depth)">
                                @foreach (var arc in auditSecArcs)
                                {
                                    <path d="@arc.D" fill="none" stroke="@arc.Color" stroke-width="20" stroke-linecap="butt" class="donut-segment" />
                                }
                            </g>
                            <circle cx="60" cy="60" r="28" fill="url(#audit-hole)" />
                            <circle cx="60" cy="60" r="28" fill="none" stroke="rgba(13,33,55,0.07)" stroke-width="1" />
                            <text x="60" y="54" class="audit-donut-label">TOTAL</text>
                            <text x="60" y="71" class="audit-donut-value">&#8369;@SectionRevenueTotal.ToString("N0")</text>
                        </svg>
                    </div>
                    <div class="audit-section-list">
                        @foreach (var s in SectionData)
                        {
                            <div class="audit-section-item">
                                <span class="audit-dot" style="background:linear-gradient(180deg, @s.Color 0%, @Darken(s.Color) 100%)"></span>
                                <div class="audit-section-info">
                                    <span class="audit-section-name">@s.ShortName</span>
                                    <strong class="audit-section-value">&#8369;@s.Revenue.ToString("N0")</strong>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="audit-empty">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 3v18h18"/><path d="M19 9l-5 5-4-4-3 3"/></svg>
                    No section revenue recorded for @GetPeriodLabel().
                </div>
            }
            <div class="audit-caption">Grouped by NPM section; daily entries are not double-counted when a monthly payment exists.</div>
        </div>

        <div class="audit-card audit-card-wide audit-card-payor">
            <div class="audit-card-head">
                <div class="audit-head-metric">
                    <span>Revenue Share by Section</span>
                </div>
                <small class="audit-subtitle">Recorded collection share by market section</small>
            </div>
            @if (AuditPayorBars.Any())
            {
                <div class="audit-insight-strip">
                    <span><strong>&#8369;@SectionRevenueTotal.ToString("N0")</strong> total recorded</span>
                    <span><strong>@AuditPayorCollectedCount</strong> sections with collection</span>
                    <span><strong>@AuditPayorShownCount</strong> sections shown</span>
                </div>
                <div class="audit-bar-plot">
                    @foreach (var b in AuditPayorBars)
                    {
                        <div class="audit-payor-bar" title="@b.Section — &#8369;@b.Amount.ToString("N2")">
                            <strong class="audit-payor-value">&#8369;@b.ShortValue</strong>
                            <div class="audit-payor-track">
                                <div class="audit-payor-stack @(b.IsZero ? "is-zero" : "")">
                                    @if (b.FishHeightPct > 0)
                                    {
                                        <div class="audit-seg3d seg-fish" style="height:@b.FishHeightPct%" title="Fish-kilo fee &#183; &#8369;@b.FishAmount.ToString("N0")">
                                            <span class="aud-face-top"></span><span class="aud-face-side"></span>
                                        </div>
                                        <div class="audit-seg3d seg-rent" style="height:@b.RentHeightPct%" title="Stall rent &#183; &#8369;@b.RentAmount.ToString("N0")">
                                            <span class="aud-face-side"></span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="audit-seg3d seg-rent" style="height:@b.RentHeightPct%" title="Stall rent &#183; &#8369;@b.RentAmount.ToString("N0")">
                                            <span class="aud-face-top"></span><span class="aud-face-side"></span>
                                        </div>
                                    }
                                </div>
                            </div>
                            <span class="audit-payor-label">@GetShort(NormalizeSectionName(b.Section))</span>
                            <small class="audit-payor-meta">@b.SharePct% rent collected vs assessed</small>
                        </div>
                    }
                </div>
                <div class="audit-stack-legend">
                    <span class="audit-legend-item"><i class="seg-rent"></i> Stall rent</span>
                    <span class="audit-legend-item"><i class="seg-fish"></i> Fish-kilo fee</span>
                </div>
            }
            else
            {
                <div class="audit-empty">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                    No section collections recorded for this period.
                </div>
            }
        </div>

        <div class="audit-card audit-card-wide audit-card-mix">
            <div class="audit-card-head">
                <div class="audit-head-metric">
                    <span>Section Performance Mix</span>
                </div>
                <small class="audit-subtitle">Collection rate, active stalls, and open balance rate</small>
            </div>
            <div class="audit-grouped-bars">
                @foreach (var sec in AuditSectionMetrics)
                {
                    <div class="audit-group">
                        <div class="audit-group-bars">
                            <div class="audit-vbar-wrapper">
                                <small class="audit-vbar-value">@sec.CollectionRatePct%</small>
                                <span class="audit-vbar revenue @(sec.CollectionRatePct == 0 ? "is-zero" : "")" style="height:@sec.CollectionHeightPct%" title="@sec.Name collection rate @sec.CollectionRatePct%">
                                    <span class="audit-vbar-shine"></span>
                                </span>
                            </div>
                            <div class="audit-vbar-wrapper">
                                <small class="audit-vbar-value">@sec.ActiveSharePct%</small>
                                <span class="audit-vbar occupancy @(sec.ActiveSharePct == 0 ? "is-zero" : "")" style="height:@sec.ActiveHeightPct%" title="@sec.Name active stall share @sec.ActiveSharePct%">
                                    <span class="audit-vbar-shine"></span>
                                </span>
                            </div>
                            <div class="audit-vbar-wrapper">
                                <small class="audit-vbar-value">@sec.BalanceRatePct%</small>
                                <span class="audit-vbar balance @(sec.BalanceRatePct == 0 ? "is-zero" : "")" style="height:@sec.BalanceHeightPct%" title="@sec.Name open balance rate @sec.BalanceRatePct%">
                                    <span class="audit-vbar-shine"></span>
                                </span>
                            </div>
                        </div>
                        <span class="audit-group-label">@sec.ShortName</span>
                    </div>
                }
            </div>
            <div class="audit-mini-legend">
                <div class="audit-legend-item">
                    <i class="audit-legend revenue"></i>
                    <span>Collection rate</span>
                </div>
                <div class="audit-legend-item">
                    <i class="audit-legend occupancy"></i>
                    <span>Active stalls</span>
                </div>
                <div class="audit-legend-item">
                    <i class="audit-legend balance"></i>
                    <span>Open balance</span>
                </div>
            </div>
        </div>

        <div class="audit-card audit-card-compare">
            <div class="audit-card-head audit-card-head-compact">
                <div class="audit-head-metric">
                    <span>Fee Mix & Risk Gap</span>
                </div>
                <small class="audit-subtitle">Collected fee types versus open receivables</small>
            </div>
            <div class="audit-compare-row">
                <span>Daily stall fee</span>
                <div><i style="width:@DailyFeeMixPct%; background:var(--green)"></i></div>
                <strong class="audit-compare-value">
                    <span>&#8369;@DailyFeeTotal.ToString("N0")</span>
                    <small>@DailyFeeMixPct%</small>
                </strong>
            </div>
            <div class="audit-compare-row">
                <span>Fish kilo fee</span>
                <div><i style="width:@FishFeeMixPct%; background:#4a9eff"></i></div>
                <strong class="audit-compare-value">
                    <span>&#8369;@FishFeeTotal.ToString("N0")</span>
                    <small>@FishFeeMixPct%</small>
                </strong>
            </div>
            <div class="audit-compare-row">
                <span>Open balance</span>
                <div><i style="width:@OutstandingMixPct%; background:var(--red)"></i></div>
                <strong class="audit-compare-value is-risk">
                    <span>&#8369;@PendingAmount.ToString("N0")</span>
                    <small>@OutstandingMixPct%</small>
                </strong>
            </div>
            <div class="audit-section-palette audit-risk-key">
                <span><i style="background:var(--green)"></i>Daily stall fee collected</span>
                <span><i style="background:#4a9eff"></i>Fish kilo fee collected</span>
                <span class="risk"><i style="background:var(--red)"></i>Open balance for follow-up</span>
            </div>
        </div>

        <div class="audit-card audit-card-risk">
            <div class="audit-card-head">
                <div class="audit-head-metric">
                    <span>Receivable Risk Profile</span>
                </div>
                <small class="audit-subtitle">Paid, partial, and unpaid mix by section</small>
            </div>
            @if (RiskProfileGroups.Any())
            {
                <div class="audit-risk-totals">
                    <div class="risk-total unpaid">
                        <span>Unpaid total</span>
                        <strong>&#8369;@UnpaidBalanceTotal.ToString("N0")</strong>
                    </div>
                    <div class="risk-total partial">
                        <span>Partial total</span>
                        <strong>&#8369;@PartialBalanceTotal.ToString("N0")</strong>
                    </div>
                    <div class="risk-total all">
                        <span>Open items</span>
                        <strong>@OpenReceivableCount</strong>
                    </div>
                </div>
                <div class="audit-risk-ledger">
                    @foreach (var group in RiskProfileGroups)
                    {
                        <div class="audit-risk-row @group.RiskClass" title="@group.Section - paid &#8369;@group.PaidAmount.ToString("N2"), partial balance &#8369;@group.PartialAmount.ToString("N2"), unpaid balance &#8369;@group.UnpaidAmount.ToString("N2")">
                            <div class="audit-risk-row-main">
                                <strong>@group.Section</strong>
                                <span>@group.OpenItems open item@(group.OpenItems == 1 ? "" : "s")</span>
                            </div>
                            <div class="audit-risk-meter stacked">
                                @if (group.PaidPct > 0)
                                {
                                    <span class="paid" style="width:@group.PaidPct%"></span>
                                }
                                @if (group.PartialPct > 0)
                                {
                                    <span class="partial" style="width:@group.PartialPct%"></span>
                                }
                                @if (group.UnpaidPct > 0)
                                {
                                    <span class="unpaid" style="width:@group.UnpaidPct%"></span>
                                }
                            </div>
                            <div class="audit-risk-row-value">
                                <strong>&#8369;@group.OpenAmount.ToString("N0")</strong>
                                <small>@group.PaidPct% paid &middot; @group.UnpaidItems unpaid / @group.PartialItems partial</small>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="audit-empty-inline">No open receivables for @GetPeriodLabel().</p>
            }
        </div>

        <div class="audit-kpi-stack">
            <div class="audit-card audit-number-card">
                <strong>@CoverageRate%</strong>
                <span>Days with Collection</span>
            </div>
            <div class="audit-card audit-number-card">
                <strong>&#8369;@PendingAmount.ToString("N0")</strong>
                <span>Outstanding Balance</span>
            </div>
        </div>

        <!-- Section Revenue -->
        <div class="rpt-breakdown-card">
            <div class="breakdown-header">
                <h4 class="breakdown-title">Section Revenue</h4>
                <p class="breakdown-subtitle">Distribution across market sections</p>
            </div>
            @if (SectionData.Any(s => s.Revenue > 0))
            {
                <div class="rpt-donut-wrap">
                    <div class="rpt-donut-container">
                        <svg class="rpt-donut-svg" viewBox="0 0 120 120">
                            <defs>
                                @foreach (var c in SectionData.Where(s => s.Revenue > 0).Select(s => s.Color).Distinct())
                                {
                                    <linearGradient id="@SecGradId(c, "sgb")" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="@c" /><stop offset="100%" stop-color="@Darken(c)" />
                                    </linearGradient>
                                }
                                <radialGradient id="secrev-hole" cx="50%" cy="40%" r="62%">
                                    <stop offset="0%" stop-color="#ffffff" /><stop offset="100%" stop-color="#eef2f6" />
                                </radialGradient>
                                <filter id="secrev-depth" x="-30%" y="-30%" width="160%" height="160%">
                                    <feDropShadow dx="0" dy="5" stdDeviation="4" flood-color="#0d2137" flood-opacity="0.18" />
                                </filter>
                            </defs>
                            <circle cx="60" cy="60" r="46" fill="none" stroke="#eef2f6" stroke-width="18" />
                            @{ var secArcs = BuildDonutArcs(SectionData.Select(s => ((int)s.Revenue, $"url(#{SecGradId(s.Color, "sgb")})")).ToArray(), 46, 60, 60); }
                            <g filter="url(#secrev-depth)">
                                @foreach (var arc in secArcs)
                                {
                                    <path d="@arc.D" fill="none" stroke="@arc.Color" stroke-width="18" stroke-linecap="butt" class="donut-segment" />
                                }
                            </g>
                            <circle cx="60" cy="60" r="35" fill="url(#secrev-hole)" />
                            <circle cx="60" cy="60" r="35" fill="none" stroke="rgba(13,33,55,0.07)" stroke-width="1" />
                            <text x="60" y="55" class="donut-center-lbl">REVENUE</text>
                            <text x="60" y="72" class="donut-center-sub">₱@SectionData.Sum(s => s.Revenue).ToString("N0")</text>
                        </svg>
                    </div>
                    <div class="rpt-donut-legend">
                        @{ var secTotal = SectionData.Sum(s => s.Revenue); }
                        @foreach (var s in SectionData)
                        {
                            <div class="donut-leg-item">
                                <div class="donut-leg-left">
                                    <span class="donut-leg-dot" style="background:linear-gradient(180deg, @s.Color 0%, @Darken(s.Color) 100%)"></span>
                                    <span class="donut-leg-label">@s.Name</span>
                                </div>
                                <strong class="donut-leg-value">₱@s.Revenue.ToString("N0") · @(secTotal > 0 ? (int)Math.Round(s.Revenue / secTotal * 100) : 0)%</strong>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="rpt-empty">
                    <div class="rpt-empty-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M19 9l-5 5-4-4-3 3"/></svg>
                    </div>
                    <div class="rpt-empty-title">No section revenue</div>
                    <div class="rpt-empty-text">No revenue was collected for @GetPeriodLabel().</div>
                </div>
            }
            <div class="mini-panel">
                <div class="mini-panel-title">Collection Rate by Section</div>
                @foreach (var sec in SectionData)
                {
                    <div class="mini-metric-row">
                        <span class="mini-metric-label">@sec.ShortName</span>
                        <div class="mini-meter">
                            <div class="mini-meter-fill" style="width:@sec.Pct%; background:@sec.Color"></div>
                        </div>
                        <strong class="mini-metric-value">@sec.Pct%</strong>
                    </div>
                }
            </div>
        </div>

        <!-- Payor Compliance -->
        <div class="rpt-breakdown-card">
            <div class="breakdown-header">
                <h4 class="breakdown-title">Payor Compliance</h4>
                <p class="breakdown-subtitle">Payment status distribution</p>
            </div>
            <div class="cmp-stats">
                <div class="cmp-stat">
                    <strong class="cov-collected">@PaidCount</strong>
                    <span class="cmp-stat-label">Fully Paid</span>
                </div>
                <div class="cmp-stat">
                    <strong class="cov-partial">@PartialCount</strong>
                    <span class="cmp-stat-label">Partial</span>
                </div>
                <div class="cmp-stat">
                    <strong class="cov-missed">@UnpaidCount</strong>
                    <span class="cmp-stat-label">Unpaid</span>
                </div>
            </div>
            <div class="cmp-bar-container">
                <div class="cmp-bar">
                    @if (PaidPct > 0) { <div class="cmp-seg paid" style="width:@PaidPct%"></div> }
                    @if (PartialPct > 0) { <div class="cmp-seg partial" style="width:@PartialPct%"></div> }
                    @if (UnpaidPct > 0) { <div class="cmp-seg unpaid" style="width:@UnpaidPct%"></div> }
                </div>
            </div>
            <div class="cmp-legend">
                <div class="cmp-legend-item">
                    <i class="leg-swatch collected"></i>
                    <span>Paid @PaidPct%</span>
                </div>
                <div class="cmp-legend-item">
                    <i class="leg-swatch partial"></i>
                    <span>Partial @PartialPct%</span>
                </div>
                <div class="cmp-legend-item">
                    <i class="leg-swatch missed"></i>
                    <span>Unpaid @UnpaidPct%</span>
                </div>
            </div>
            <div class="mini-panel">
                <div class="mini-panel-title">Fee Type Breakdown</div>
                <div class="fee-row">
                    <span class="fee-label">Daily stall fee (₱30/day)</span>
                    <div class="mini-meter"><div class="mini-meter-fill" style="width:100%; background:#2d7a5f"></div></div>
                    <strong class="fee-value">₱@DailyFeeTotal.ToString("N0")</strong>
                </div>
                <div class="fee-row">
                    <span class="fee-label">Fish kilo fee (₱1/kg)</span>
                    <div class="mini-meter"><div class="mini-meter-fill" style="width:@FishFeePct%; background:#4a9eff"></div></div>
                    <strong class="fee-value">₱@FishFeeTotal.ToString("N0")</strong>
                </div>
            </div>
        </div>

        <!-- Daily Collection Streak Calendar -->
        <div class="rpt-breakdown-card rpt-streak-card">
            <h4 class="breakdown-title">Collection Coverage — @GetPeriodLabel()</h4>

            <div class="cov-summary">
                <div class="cov-rate-val">@CoverageRate%</div>
                <div class="cov-rate-lbl">Payor coverage</div>
                <div class="cov-bar"><div class="cov-bar-fill" style="width:@CoverageRate%"></div></div>
            </div>
            <div class="cov-chips">
                <div class="cov-chip"><strong class="cov-collected">@CollectedDays</strong><span>Collected</span></div>
                <div class="cov-chip"><strong class="cov-missed">@MissedDays</strong><span>Missed</span></div>
                @if (AbsentDays > 0)
                {
                    <div class="cov-chip"><strong class="cov-absent">@AbsentDays</strong><span>Absent</span></div>
                }
                <div class="cov-chip"><strong class="cov-streak">@CurrentStreak</strong><span>Day Streak</span></div>
            </div>

            @if (ActivePeriod == "Yearly")
            {
                <!-- Yearly: 12-month heatmap -->
                <div class="streak-calendar-area">
                    <div class="streak-yearly-grid">
                        @foreach (var mo in YearlyMonths)
                        {
                            <div class="streak-month-cell @mo.Css" title="@mo.Label">
                                <span class="streak-month-name">@mo.Name</span>
                                <span class="streak-month-rate">@mo.Rate%</span>
                            </div>
                        }
                    </div>
                </div>
            }
            else if (ActivePeriod == "Weekly")
            {
                <!-- Weekly: 7 day cells for the selected week -->
                <div class="streak-calendar-area">
                    <div class="streak-dow-row">
                        @foreach (var d in new[] { "Su","Mo","Tu","We","Th","Fr","Sa" })
                        { <span>@d</span> }
                    </div>
                    <div class="streak-grid streak-grid-week">
                        @foreach (var day in WeekDays)
                        {
                            <span class="streak-day @day.Css" title="@day.Label">@day.Num</span>
                        }
                    </div>
                </div>
            }
            else
            {
                <!-- Monthly: full month grid -->
                <div class="streak-calendar-area">
                    <div class="streak-dow-row">
                        @foreach (var d in new[] { "Su","Mo","Tu","We","Th","Fr","Sa" })
                        { <span>@d</span> }
                    </div>
                    <div class="streak-grid">
                        @for (int b = 0; b < CalendarLeadBlanks; b++)
                        { <span class="streak-day empty"></span> }
                        @foreach (var day in CalendarDays)
                        {
                            <span class="streak-day @day.Css" title="@day.Label">@day.Num</span>
                        }
                    </div>
                </div>
            }

            <div class="streak-legend">
                <span><i class="leg-swatch collected"></i>Collected (@CollectedDays)</span>
                <span><i class="leg-swatch missed"></i>Missed (@MissedDays)</span>
                @if (AbsentDays > 0)
                {
                    <span><i class="leg-swatch absent"></i>Absent (@AbsentDays)</span>
                }
                <span><i class="leg-swatch future"></i>Upcoming</span>
            </div>
        </div>

    </div>

    <!-- ══ Fish Area Kilo Tracker (only when fish-section stalls exist) ══ -->
    @if (FishStallCount > 0)
    {
    <div class="rpt-section-heading">
        <span class="rpt-section-rule"></span>
        <h2>Fish Area — Kilo Tracking</h2>
    </div>

    <div class="rpt-fish-panel">
        <p class="fish-caption">Throughput fee at ₱1/kg — tracked separately from the ₱30/day stall rent.</p>
        <div class="fish-kpi-row">
            <div class="fish-kpi">
                <div class="fish-kpi-val">@TotalFishKilos.ToString("N0") <span class="fish-kpi-unit">kg</span></div>
                <div class="fish-kpi-lbl">Total Kilos This Period</div>
            </div>
            <div class="fish-kpi">
                <div class="fish-kpi-val">₱@FishFeeTotal.ToString("N0")</div>
                <div class="fish-kpi-lbl">Fish Fee Collected (₱1/kg)</div>
            </div>
            <div class="fish-kpi">
                <div class="fish-kpi-val">@FishStallCount</div>
                <div class="fish-kpi-lbl">Active Fish Stalls</div>
            </div>
            <div class="fish-kpi">
                <div class="fish-kpi-val">@FishPeakLabel</div>
                <div class="fish-kpi-lbl">Peak Day · @FishPeakKilos.ToString("N0") kg</div>
            </div>
            <div class="fish-kpi">
                <div class="fish-kpi-val">@FishAvgPerActiveDay.ToString("N1") <span class="fish-kpi-unit">kg</span></div>
                <div class="fish-kpi-lbl">Avg / Active Day</div>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(FishComparison))
        {
            <div class="fish-insight">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 17l6-6 4 4 8-8"/><path d="M17 7h4v4"/></svg>
                <span>@FishComparison</span>
            </div>
        }
        @if (TotalFishKilos > 0)
        {
            <div class="rpt-fish-chart">
                @foreach (var pt in FishTrendPoints)
                {
                    <div class="rpt-fish-col @(pt.IsZero ? "is-zero" : "")" title="@pt.Label — @pt.Kilos.ToString("N1") kg">
                        <div class="rpt-fish-val">@(pt.IsZero ? "" : pt.Kilos.ToString("N0"))</div>
                        <div class="rpt-fish-track">
                            <div class="rpt-fish-fill" style="height:@pt.HeightPct%"></div>
                        </div>
                        <div class="rpt-fish-xlabel">@pt.Label</div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="rpt-empty">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12c0 0 3-5 8-5s8 2 8 2l3-4v10l-3-4s-3 2-8 2-8-5-8-5z"/><circle cx="14" cy="11" r="1" fill="currentColor" stroke="none"/></svg>
                <div class="rpt-empty-title">No fish area activity</div>
                <div class="rpt-empty-text">No fish kilos were recorded for @GetPeriodLabel().</div>
            </div>
        }
    </div>
    }

    <!-- ══ Delinquency Analytics ══ -->
    <div class="rpt-section-heading">
        <span class="rpt-section-rule"></span>
        <h2>Delinquency Analytics</h2>
    </div>

    <div class="rpt-delinquency-panel">
        <div class="delinq-exposure">
            <div class="delinq-exp-val">₱@PendingAmount.ToString("N2")</div>
            <div class="delinq-exp-lbl">Total Outstanding Balance — @(UnpaidCount + PartialCount) payors need follow-up</div>
        </div>
        <table class="delinq-table">
            <thead>
                <tr>
                    <th>Stall No</th>
                    <th>Occupant</th>
                    <th>Section</th>
                    <th>Status</th>
                    <th>Missed (mo)</th>
                    <th>Balance Due</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in DelinquentStalls)
                {
                    <tr>
                        <td class="stall-no">@row.StallNo</td>
                        <td>@row.Occupant</td>
                        <td>@row.Section</td>
                        <td><span class="status-badge @row.StatusCss">@row.Status</span></td>
                        <td>
                            <span class="missed-badge @(row.MissedMonths >= 3 ? "critical" : "warn")">
                                @row.MissedMonths mo
                            </span>
                        </td>
                        <td class="balance-due">₱@row.Balance.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ══ Full Payor Compliance Table ══ -->
    <div class="rpt-section-heading">
        <span class="rpt-section-rule"></span>
        <h2>All Stalls — @GetPeriodLabel()</h2>
    </div>

    <div class="rpt-compliance-table-wrap">
        <table class="rpt-compliance-table">
            <thead>
                <tr>
                    <th>Stall No</th>
                    <th>Occupant</th>
                    <th>Contract Name</th>
                    <th>Section</th>
                    <th>Daily Rate</th>
                    <th>Status</th>
                    <th>Amount Paid</th>
                    <th>Balance</th>
                    @if (ActivePeriod == "Weekly")
                    {
                        <th>OR Number</th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var s in AllStalls)
                {
                    <tr class="@(s.IsAbsent ? "row-absent" : s.IsPaid ? "" : s.IsPartial ? "row-partial" : "row-unpaid")">
                        <td class="stall-no">@s.StallNo</td>
                        <td>@s.Occupant</td>
                        <td class="text-muted">@s.ContractName</td>
                        <td>@s.Section</td>
                        <td>₱@s.DailyRate.ToString("N0")</td>
                        <td><span class="status-badge @s.StatusCss">@s.StatusLabel</span></td>
                        <td>@(s.AmountPaid > 0 ? "₱" + s.AmountPaid.ToString("N2") : "—")</td>
                        <td class="@(s.Balance > 0 ? "balance-due" : "")">@(s.Balance > 0 ? "₱" + s.Balance.ToString("N2") : "—")</td>
                        @if (ActivePeriod == "Weekly")
                        {
                            <td class="text-muted">@(string.IsNullOrEmpty(s.ORNumber) ? "—" : s.ORNumber)</td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- ══ Stallholder Register ══ -->
    <div class="rpt-section-heading">
        <span class="rpt-section-rule"></span>
        <h2>Stallholder Register — @FacilityCatalog.NameOf(FacilityCode.NPM)</h2>
    </div>

    <div class="rpt-compliance-table-wrap">
      
        <table class="rpt-compliance-table rpt-register-table">
            <thead>
                <tr>
                    <th>Stall No</th>
                    <th>Occupant</th>
                    <th>Name on Contract</th>
                    <th>Effectivity</th>
                    <th>Years</th>
                    <th>Area (sqm)</th>
                    <th>Monthly / Contract</th>
