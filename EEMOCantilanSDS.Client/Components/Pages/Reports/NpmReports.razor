                    }
                }
            </tbody>
        </table>
    </div>

</div><!-- end rpt-content -->
}


@code {

    // ── Period state ──────────────────────────────────────────────
    string ActivePeriod = "Monthly";
    bool ShowUtilityBilling = false;
    bool ShowPrintReport = false;
    bool ShowHistory = false;
    DateTime CurrentDate = PhilippineTime.Now;
    private UtilityRegisterDto? UtilityRegister;
    private FacilityReportsDto? R;
    private FacilityHistoryDto? History;
    private bool HistoryLoading;

    [PersistentState(AllowUpdates = true)]
    public NpmReportsPageState? CachedReport { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await FacilityCatalog.EnsureLoadedAsync();
        if (TryApplyCachedReport())
            return;

        await LoadAsync();
    }

    async Task LoadAsync()
    {
        // The Status Report is an official monthly snapshot, so it always loads Monthly data
        // for the selected month regardless of the period tab last used.
        var period = ShowPrintReport
            ? ReportPeriod.Monthly
            : ActivePeriod switch
            {
                "Weekly" => ReportPeriod.Weekly,
                "Yearly" => ReportPeriod.Yearly,
                _ => ReportPeriod.Monthly
            };
        int? month = period == ReportPeriod.Yearly ? null : CurrentDate.Month;
        int? week = period == ReportPeriod.Weekly ? ((CurrentDate.Day - 1) / 7) + 1 : null;

        var result = await FacilitiesApi.GetFacilityReportsAsync(FacilityCode.NPM, period, CurrentDate.Year, month, week);
        if (result.IsSuccess)
        {
            R = result.Value;
            if (R is not null)
                CachedReport = new NpmReportsPageState(period, CurrentDate.Year, month, week, R);
        }
    }

    private bool TryApplyCachedReport()
    {
        if (ShowUtilityBilling)
            return false;

        var period = ShowPrintReport
            ? ReportPeriod.Monthly
            : ActivePeriod switch
            {
                "Weekly" => ReportPeriod.Weekly,
                "Yearly" => ReportPeriod.Yearly,
                _ => ReportPeriod.Monthly
            };
        int? month = period == ReportPeriod.Yearly ? null : CurrentDate.Month;
        int? week = period == ReportPeriod.Weekly ? ((CurrentDate.Day - 1) / 7) + 1 : null;

        if (CachedReport is not { } state
            || state.Period != period
            || state.Year != CurrentDate.Year
            || state.Month != month
            || state.Week != week)
        {
            return false;
        }

        R = state.Report;
        return true;
    }

    async Task SetPeriod(string p)
    {
        ShowUtilityBilling = false;
        ShowPrintReport = false;
        ShowHistory = false;
        ActivePeriod = p;
        await LoadAsync();
    }
    async Task ShowUtilityBillingView()
    {
        ShowUtilityBilling = true;
        ShowPrintReport = false;
        ShowHistory = false;
        await LoadUtilityRegisterAsync();
    }

    async Task LoadUtilityRegisterAsync()
    {
        var result = await UtilitiesApi.GetRegisterAsync(CurrentDate.Year, CurrentDate.Month);
        UtilityRegister = result.IsSuccess ? result.Value : null;
        StateHasChanged();
    }
    async Task ShowPrintReportView()
    {
        ShowPrintReport = true;
        ShowUtilityBilling = false;
        ShowHistory = false;
        await LoadAsync();
    }
    async Task ShowHistoryView()
    {
        ShowHistory = true;
        ShowPrintReport = false;
        ShowUtilityBilling = false;
        await LoadHistoryAsync();
    }

    async Task LoadHistoryAsync()
    {
        HistoryLoading = true;
        var result = await FacilitiesApi.GetFacilityHistoryAsync(FacilityCode.NPM, CurrentDate.Year);
        if (result.IsSuccess) History = result.Value;
        HistoryLoading = false;
    }
    async Task PrintPage() => await JS.InvokeVoidAsync("print");
    async Task PrevPeriod()
    {
        if (ShowHistory)   { CurrentDate = CurrentDate.AddYears(-1); await LoadHistoryAsync(); return; }
        if (ShowPrintReport) { CurrentDate = CurrentDate.AddMonths(-1); await LoadAsync(); return; }
        if (ShowUtilityBilling) { CurrentDate = CurrentDate.AddMonths(-1); await LoadUtilityRegisterAsync(); return; }
        CurrentDate = ActivePeriod switch
        {
            "Weekly"  => CurrentDate.AddDays(-7),
            "Yearly"  => CurrentDate.AddYears(-1),
            _         => CurrentDate.AddMonths(-1)
        };
        await LoadAsync();
    }
    async Task NextPeriod()
    {
        if (ShowHistory)   { CurrentDate = CurrentDate.AddYears(1); await LoadHistoryAsync(); return; }
        if (ShowPrintReport) { CurrentDate = CurrentDate.AddMonths(1); await LoadAsync(); return; }
        if (ShowUtilityBilling) { CurrentDate = CurrentDate.AddMonths(1); await LoadUtilityRegisterAsync(); return; }
        CurrentDate = ActivePeriod switch
        {
            "Weekly"  => CurrentDate.AddDays(7),
            "Yearly"  => CurrentDate.AddYears(1),
            _         => CurrentDate.AddMonths(1)
        };
        await LoadAsync();
    }
    string GetPeriodLabel() => ActivePeriod switch
    {
        "Weekly"  => $"Week of {CurrentDate:MMM d, yyyy}",
        "Yearly"  => CurrentDate.ToString("yyyy"),
        _         => CurrentDate.ToString("MMMM yyyy")
    };

    // ── KPI values (from API) ─────────────────────────────────────
    string UtilityBillingPeriodLabel => $"Utilities - {CurrentDate:MMMM yyyy}";
    string PrintReportPeriodLabel => $"Status Report - {CurrentDate:MMMM yyyy}";
    string HistoryPeriodLabel => $"History — {CurrentDate.Year}";

    async Task PickPeriod((int Year, int Month) p)
    {
        CurrentDate = new DateTime(p.Year, p.Month, 1);
        if (ShowHistory) await LoadHistoryAsync();
        else if (ShowUtilityBilling) await LoadUtilityRegisterAsync();
        else await LoadAsync();
    }
    async Task JumpToCurrent()
    {
        CurrentDate = PhilippineTime.Now;
        if (ShowHistory) await LoadHistoryAsync();
        else if (ShowUtilityBilling) await LoadUtilityRegisterAsync();
        else await LoadAsync();
    }

    IReadOnlyList<FacilityHistoryPeriodDto> HistoryMonthlyRows => History?.Monthly ?? new List<FacilityHistoryPeriodDto>();
    IReadOnlyList<FacilityHistoryPeriodDto> HistoryYearlyRows => History?.Yearly ?? new List<FacilityHistoryPeriodDto>();

    public sealed record NpmReportsPageState(
        ReportPeriod Period,
        int Year,
        int? Month,
        int? Week,
        FacilityReportsDto Report);

    // Status Report rows — driven by the same server-computed compliance data as the
    // "All Stalls" table (R.StallCompliance), grouped by section in the print view.
    // Monthly Due = AmountPaid + Balance (the period's assessed obligation), so the
    // document is internally consistent: Due = Paid + Outstanding.
    record PrintStatusRow(
        string StallNo,
        string Payor,
        string Section,
        string Classification,
        decimal MonthlyDue,
        string Status,
        decimal AmountPaid,
        decimal Balance);

    IReadOnlyList<PrintStatusRow> PrintRows => (R?.StallCompliance ?? new List<StallComplianceDto>())
        .Select(s => new PrintStatusRow(
            s.StallNo,
            s.Occupant,
            NormalizeSectionName(s.Section),
            s.StallType,
            s.AmountPaid + s.Balance,
            s.Status,
            s.AmountPaid,
            s.Balance))
        .ToList();

    record UtilityBillingRow(
        Guid StallId,
        string StallNo,
        string Payor,
        string Section,
        decimal ElectricPrevious,
        decimal ElectricCurrent,
        decimal ElectricAmount,
        decimal WaterPrevious,
        decimal WaterCurrent,
        decimal WaterAmount,
        string Status,
        string Note,
        string ElecStatus,
        string WaterStatus)
    {
        public decimal TotalDue => ElectricAmount + WaterAmount;
        public string StatusCss => Css(Status);
        public string ElecStatusCss => Css(ElecStatus);
        public string WaterStatusCss => Css(WaterStatus);
        static string Css(string s) => s.Equals("Paid", StringComparison.OrdinalIgnoreCase) ? "paid"
            : s.Equals("Partial", StringComparison.OrdinalIgnoreCase) ? "partial"
            : "unpaid";
    }

    IReadOnlyList<UtilityBillingRow> UtilityRows =>
        (UtilityRegister?.Rows ?? Array.Empty<UtilityRegisterRowDto>())
        .Select(r => new UtilityBillingRow(
            r.StallId, r.StallNo, r.Occupant, r.Section,
            r.ElecPreviousReading, r.ElecCurrentReading, r.ElecCharge,
            r.WaterPreviousReading, r.WaterCurrentReading, r.WaterCharge,
            r.HasBill ? r.Status : "Unbilled",
            r.HasBill
                ? (r.Status == "Paid" ? "Settled for the period"
                   : r.BalanceDue > 0 ? $"Balance \u20b1{r.BalanceDue:N2}" : "Recorded")
                : "No reading recorded yet",
            r.ElecStatus, r.WaterStatus))
        .ToList();

    // ── Utility register filter + search + per-payor history ──
    string _utilSection = "All";
    string _utilSearch = "";
    static readonly string[] UtilitySections = { "All", "Vegetable Area", "Fish Area", "Meat Area" };

    IReadOnlyList<UtilityBillingRow> FilteredUtilityRows =>
        UtilityRows.Where(r =>
            (_utilSection == "All" || r.Section == _utilSection)
            && (string.IsNullOrWhiteSpace(_utilSearch)
                || r.Payor.Contains(_utilSearch, StringComparison.OrdinalIgnoreCase)
                || r.StallNo.Contains(_utilSearch, StringComparison.OrdinalIgnoreCase)))
        .ToList();

    bool ShowUtilHistory = false;
    UtilityBillingRow? HistoryRow = null;
    IReadOnlyList<UtilityHistoryRowDto>? HistoryRows = null;
    bool UtilHistLoading = false;

    async Task OpenStallHistory(UtilityBillingRow row)
    {
        HistoryRow = row; ShowUtilHistory = true; UtilHistLoading = true; HistoryRows = null;
        StateHasChanged();
        var res = await UtilitiesApi.GetStallHistoryAsync(row.StallId);
        HistoryRows = res.IsSuccess ? res.Value : Array.Empty<UtilityHistoryRowDto>();
        UtilHistLoading = false;
    }

    void CloseUtilHistory() { ShowUtilHistory = false; HistoryRow = null; HistoryRows = null; }

    static string HistoryStatusCss(string status) =>
        status.Equals("Paid", StringComparison.OrdinalIgnoreCase) ? "paid"
        : status.Equals("Partial", StringComparison.OrdinalIgnoreCase) ? "partial"
        : "unpaid";

    decimal UtilityTotalDue => UtilityRows.Sum(r => r.TotalDue);
    decimal UtilityPaidTotal => UtilityRows.Where(r => r.Status == "Paid").Sum(r => r.TotalDue);
    decimal UtilityUnpaidTotal => UtilityRows.Where(r => r.Status != "Paid").Sum(r => r.TotalDue);

    decimal TotalCollected => R?.TotalRevenue ?? 0m;
    int     CollectionRate => (int)Math.Round(R?.CollectionRate ?? 0m);
    decimal PendingAmount  => R?.PendingPaymentAmount ?? 0m;
    int     OccupiedStalls => R?.OccupiedStalls ?? 0;
    int     TotalStalls    => R?.TotalStalls ?? 0;
    int     OccupancyRate  => TotalStalls > 0 ? (int)Math.Round(OccupiedStalls * 100.0 / TotalStalls) : 0;
    int     PaidCount      => R?.CollectionPerformance?.FullyPaidCount ?? 0;
    int     PartialCount   => R?.CollectionPerformance?.PartiallyPaidCount ?? 0;
    int     UnpaidCount    => R?.CollectionPerformance?.UnpaidCount ?? 0;
    string  RevenueGrowthText    => $"{(R?.RevenueGrowthPercentage ?? 0m):+0.0;-0.0;0}% vs previous {ActivePeriod.ToLower()}";
    string  CollectionGrowthText => $"{(R?.CollectionGrowthPercentage ?? 0m):+0.0;-0.0;0}% vs previous {ActivePeriod.ToLower()}";

    // ── Donut arc builder — explicit SVG paths, no inter-segment gaps ────
    record ArcSegment(string D, string Color);

    static IEnumerable<ArcSegment> BuildDonutArcs(
        (int Count, string Color)[] segments, double r, double cx, double cy)
    {
        int total = segments.Sum(s => s.Count);
        if (total == 0) yield break;

        double startAngle = -Math.PI / 2; // top
        foreach (var (count, color) in segments)
        {
            if (count == 0) continue;
            double sweep = 2 * Math.PI * count / total;
            // clamp full circle to avoid degenerate arc
            double endAngle = startAngle + Math.Min(sweep, 2 * Math.PI - 0.0001);
            double x1 = cx + r * Math.Cos(startAngle);
            double y1 = cy + r * Math.Sin(startAngle);
            double x2 = cx + r * Math.Cos(endAngle);
            double y2 = cy + r * Math.Sin(endAngle);
            int largeArc = sweep > Math.PI ? 1 : 0;
            string d = $"M {x1:F3} {y1:F3} A {r} {r} 0 {largeArc} 1 {x2:F3} {y2:F3}";
            yield return new ArcSegment(d, color);
            startAngle = endAngle;
        }
    }
    int Total      => PaidCount + PartialCount + UnpaidCount;
    int PaidPct    => Total > 0 ? (int)Math.Round((double)PaidCount    / Total * 100) : 0;
    int PartialPct => Total > 0 ? (int)Math.Round((double)PartialCount / Total * 100) : 0;
    int UnpaidPct  => Total > 0 ? Math.Max(0, 100 - PaidPct - PartialPct) : 0;

    // ── Fee totals (from API) ─────────────────────────────────────
    decimal DailyFeeTotal  => R?.FeeTypeBreakdown?.DailyFeeAmount ?? 0m;
    decimal FishFeeTotal   => R?.FeeTypeBreakdown?.FishFeeAmount ?? 0m;
    decimal FishFeePct     => DailyFeeTotal > 0 ? Math.Min(100, FishFeeTotal / DailyFeeTotal * 100) : 0;

    // ── Fish tracker (from API) ───────────────────────────────────
    decimal TotalFishKilos => R?.FishKiloTrend?.Sum(f => f.Kilos) ?? 0m;
    int     FishStallCount => R?.SectionBreakdown?.FirstOrDefault(s => s.SectionName == "Fish Area")?.ActiveStalls ?? 0;
    string? FishComparison => R?.FeeTypeBreakdown?.FishKiloComparison;
    int     FishActiveDays => (R?.FishKiloTrend ?? new List<FishKiloTrendDto>()).Count(f => f.Kilos > 0m);
    decimal FishAvgPerActiveDay => FishActiveDays > 0 ? TotalFishKilos / FishActiveDays : 0m;
    FishKiloTrendDto? FishPeak => (R?.FishKiloTrend ?? new List<FishKiloTrendDto>())
        .OrderByDescending(f => f.Kilos).FirstOrDefault();
    string  FishPeakLabel => (FishPeak?.Kilos ?? 0m) > 0m ? FishPeak!.PeriodLabel : "—";
    decimal FishPeakKilos => FishPeak?.Kilos ?? 0m;

    record FishPoint(string Label, decimal Kilos, int HeightPct, bool IsZero);
    IEnumerable<FishPoint> FishTrendPoints
    {
        get
        {
            var t = R?.FishKiloTrend ?? new List<FishKiloTrendDto>();
            var max = t.Any() ? t.Max(x => x.Kilos) : 0m;
            // ~15% headroom so the tallest bar never touches the top; zero-kilo days
            // collapse to a baseline tick (IsZero) instead of a misleading stub bar.
            var ceiling = max > 0m ? max * 1.15m : 0m;
            return t.Select(x => new FishPoint(
                x.PeriodLabel,
                x.Kilos,
                x.Kilos > 0m && ceiling > 0m ? Math.Max(6, (int)(x.Kilos / ceiling * 100)) : 0,
                x.Kilos <= 0m));
        }
    }

    // ── Collection trend bar chart (from API) ─────────────────────
    // ── Section breakdown (from API) ──────────────────────────────
    record SectionRow(string Name, string ShortName, decimal Revenue, int Pct, string Color);
    IEnumerable<SectionRow> SectionData => (R?.SectionBreakdown ?? new List<SectionBreakdownDto>())
        .Select(s =>
        {
            var name = NormalizeSectionName(s.SectionName);
            return new SectionRow(name, GetShort(name), s.Revenue, ClampPct(s.Percentage), SectionColor(name));
        });
    decimal SectionRevenueTotal => SectionData.Sum(s => s.Revenue);

    static int NormalizeBarHeightPct(decimal value, decimal maxValue, decimal maxVisualPct = 92m)
        => value <= 0 || maxValue <= 0 ? 0 : ClampPct(value / maxValue * maxVisualPct);

    // 0–100% metric bars. Scaled to ~88% of the plot so a full (100%) bar still leaves room for its
    // 3D top cap and the value label above it — otherwise the bar overflows the chart top. The label
    // always shows the true percentage.
    static int PercentBarHeightPct(int pct) => pct <= 0 ? 6 : Math.Max(8, ClampPct(pct * 0.88m));

    static int ClampPct(decimal value) => (int)Math.Clamp(Math.Round(value), 0m, 100m);
    static string NormalizeSectionName(string n) => n switch
    {
        "VegetableArea" => "Vegetable Area",
        "FishSection" => "Fish Area",
        "MeatSection" => "Meat Area",
        _ => n
    };
    static string GetShort(string n) => n.Replace(" Section", "").Replace(" Area", "");
    static string SectionColor(string n) => NormalizeSectionName(n) switch
    {
        "Vegetable Area" => "#2d7a5f",
        "Fish Area"   => "#4a9eff",
        "Meat Area"   => "#c8a84b",
        _                => "#2d7a5f"
    };

    // Section-donut 3D helpers: a per-colour gradient id + a darker bottom stop for depth.
    static string SecGradId(string color, string prefix = "sg") => prefix + "-" + color.TrimStart('#');
    static string Darken(string hex, double f = 0.68)
    {
        hex = hex.TrimStart('#');
        if (hex.Length != 6) return "#" + hex;
        var r = (int)(Convert.ToInt32(hex.Substring(0, 2), 16) * f);
        var g = (int)(Convert.ToInt32(hex.Substring(2, 2), 16) * f);
        var b = (int)(Convert.ToInt32(hex.Substring(4, 2), 16) * f);
        return $"#{r:X2}{g:X2}{b:X2}";
    }

    int AuditPayorCollectedCount => SectionData.Count(s => s.Revenue > 0m);
    int AuditPayorShownCount => SectionData.Count();

    record AuditPayorBar(string StallNo, string Occupant, string Section, decimal Amount, decimal RentAmount, decimal FishAmount, int SharePct, int RentHeightPct, int FishHeightPct, bool IsZero)
    {
        public string ShortValue => Amount >= 1000 ? $"{Amount / 1000:N1}k" : Amount.ToString("N0");
    }
    IEnumerable<AuditPayorBar> AuditPayorBars
    {
        get
        {
            var rows = SectionData
                .OrderByDescending(s => s.Revenue)
                .ThenBy(s => s.Name)
                .ToList();
            var maxRevenue = rows.Any() ? rows.Max(s => s.Revenue) : 0m;
            // The fish-kilo fee only ever comes from the Fish Area, so the whole
            // FeeTypeBreakdown.FishFeeAmount is attributed to that section's bar. Each bar splits
            // into the stall-rent base (what the collection-rate % describes) and the separate
            // fish-kilo fee cap, so a tall bar can no longer be mistaken for a high collection rate.
            return rows.Select(s =>
            {
                var fishAmount = s.Name == "Fish Area" ? Math.Min(FishFeeTotal, s.Revenue) : 0m;
                var rentAmount = s.Revenue - fishAmount;
                return new AuditPayorBar(
                    s.ShortName,
                    s.Name,
                    s.Name,
                    s.Revenue,
                    rentAmount,
                    fishAmount,
                    s.Pct,
                    NormalizeBarHeightPct(rentAmount, maxRevenue, 74m),
                    NormalizeBarHeightPct(fishAmount, maxRevenue, 74m),
                    s.Revenue <= 0m);
            });
        }
    }

    record AuditSectionMetric(
        string Name,
        string ShortName,
        int CollectionRatePct,
        int ActiveSharePct,
        int BalanceRatePct,
        int CollectionHeightPct,
        int ActiveHeightPct,
        int BalanceHeightPct);

    IEnumerable<AuditSectionMetric> AuditSectionMetrics
    {
        get
        {
            var sections = R?.SectionBreakdown ?? new List<SectionBreakdownDto>();
            var activeTotal = sections.Sum(s => s.ActiveStalls);
            var rentComplianceBySection = (R?.StallCompliance ?? new List<StallComplianceDto>())
                .GroupBy(s => NormalizeSectionName(s.Section))
                .ToDictionary(g => g.Key, g => new
                {
                    Paid = g.Sum(s => s.AmountPaid),
                    Balance = g.Sum(s => s.Balance)
                });

            var rows = sections.Select(s =>
            {
                var name = NormalizeSectionName(s.SectionName);
                rentComplianceBySection.TryGetValue(name, out var rentCompliance);
                var paidRent = rentCompliance?.Paid ?? 0m;
                var balance = rentCompliance?.Balance ?? 0m;
                var sectionAssessed = paidRent + balance;
                return new
                {
                    Name = name,
                    ShortName = GetShort(name),
                    CollectionRatePct = ClampPct(s.Percentage),
                    ActiveSharePct = activeTotal > 0 ? ClampPct(s.ActiveStalls * 100m / activeTotal) : 0,
                    BalanceRatePct = sectionAssessed > 0m ? ClampPct(balance / sectionAssessed * 100m) : 0
                };
            }).ToList();

            return rows.Select(r => new AuditSectionMetric(
                r.Name,
                r.ShortName,
                r.CollectionRatePct,
                r.ActiveSharePct,
                r.BalanceRatePct,
                PercentBarHeightPct(r.CollectionRatePct),
                PercentBarHeightPct(r.ActiveSharePct),
                PercentBarHeightPct(r.BalanceRatePct)));
        }
    }

    decimal FeeMixTotal => DailyFeeTotal + FishFeeTotal + PendingAmount;
    int DailyFeeMixPct => FeeMixTotal > 0 ? ClampPct(DailyFeeTotal / FeeMixTotal * 100m) : 0;
    int FishFeeMixPct => FeeMixTotal > 0 ? ClampPct(FishFeeTotal / FeeMixTotal * 100m) : 0;
    int OutstandingMixPct => FeeMixTotal > 0 ? ClampPct(PendingAmount / FeeMixTotal * 100m) : 0;

    decimal PartialBalanceTotal => (R?.StallCompliance ?? new List<StallComplianceDto>())
        .Where(s => s.Balance > 0m && s.Status.Equals("Partial", StringComparison.OrdinalIgnoreCase))
        .Sum(s => s.Balance);
    decimal UnpaidBalanceTotal => (R?.StallCompliance ?? new List<StallComplianceDto>())
        .Where(s => s.Balance > 0m && s.Status.Equals("Unpaid", StringComparison.OrdinalIgnoreCase))
        .Sum(s => s.Balance);
    int OpenReceivableCount => (R?.StallCompliance ?? new List<StallComplianceDto>())
        .Count(s => s.Balance > 0m);

    record RiskProfileGroup(
        string Section,
        decimal PaidAmount,
        decimal PartialAmount,
        decimal UnpaidAmount,
        decimal OpenAmount,
        int OpenItems,
        int UnpaidItems,
        int PartialItems,
        int PaidPct,
        int PartialPct,
        int UnpaidPct,
        string RiskClass)
    {
        public string ShortValue => OpenAmount >= 1000 ? $"{OpenAmount / 1000:N1}k" : OpenAmount.ToString("N0");
    }
    IEnumerable<RiskProfileGroup> RiskProfileGroups
    {
        get
        {
            var rows = (R?.StallCompliance ?? new List<StallComplianceDto>())
                .GroupBy(s => NormalizeSectionName(s.Section))
                .Select(g => new
                {
                    Section = g.Key,
                    PaidAmount = g.Sum(s => s.AmountPaid),
                    PartialAmount = g.Where(s => s.Status.Equals("Partial", StringComparison.OrdinalIgnoreCase)).Sum(s => s.Balance),
                    UnpaidAmount = g.Where(s => s.Status.Equals("Unpaid", StringComparison.OrdinalIgnoreCase)).Sum(s => s.Balance),
                    OpenItems = g.Count(s => s.Balance > 0m),
                    UnpaidItems = g.Count(s => s.Status.Equals("Unpaid", StringComparison.OrdinalIgnoreCase)),
                    PartialItems = g.Count(s => s.Status.Equals("Partial", StringComparison.OrdinalIgnoreCase))
                })
                .Where(g => g.PaidAmount + g.PartialAmount + g.UnpaidAmount > 0m)
                .OrderByDescending(g => g.PartialAmount + g.UnpaidAmount)
                .ThenBy(g => g.Section)
                .ToList();

            return rows.Select(g =>
            {
                var openAmount = g.PartialAmount + g.UnpaidAmount;
                var assessedAmount = g.PaidAmount + openAmount;
                var paidPct = assessedAmount > 0m ? ClampPct(g.PaidAmount / assessedAmount * 100m) : 0;
                var partialPct = assessedAmount > 0m ? ClampPct(g.PartialAmount / assessedAmount * 100m) : 0;
                var unpaidPct = Math.Max(0, 100 - paidPct - partialPct);
                var riskClass = g.UnpaidAmount > 0m ? "unpaid" : g.PartialAmount > 0m ? "partial" : "paid";
                return new RiskProfileGroup(
                    g.Section,
                    g.PaidAmount,
                    g.PartialAmount,
                    g.UnpaidAmount,
                    openAmount,
                    g.OpenItems,
                    g.UnpaidItems,
                    g.PartialItems,
                    paidPct,
                    partialPct,
                    unpaidPct,
                    riskClass);
            });
        }
    }

    // ── Daily collection calendar (from API) ──────────────────────
    record CalDay(string Num, string Css, string Label);
    int CalendarLeadBlanks => R?.DailyCollectionStreak?.Days.FirstOrDefault()?.DayOfWeek ?? 0;
    int CollectedDays => R?.DailyCollectionStreak?.CollectedDays ?? 0;
    int MissedDays    => R?.DailyCollectionStreak?.MissedDays ?? 0;
    int CurrentStreak => R?.DailyCollectionStreak?.CurrentStreakDays ?? 0;
    int CoverageRate  => R?.DailyCollectionStreak?.CoverageRate ?? 0;
    int AbsentDays    => R?.DailyCollectionStreak?.AbsentDays ?? 0;

    static string DayCss(string status) => status.ToLowerInvariant() switch
    {
        "collected" => "collected",
        "partial"   => "partial",
        "missed"    => "missed",
        "absent"    => "absent",
        _           => "future"
    };

    IEnumerable<CalDay> CalendarDays => (R?.DailyCollectionStreak?.Days ?? new List<DailyCollectionDayDto>())
        .Where(d => !d.Status.Equals("OutOfScope", StringComparison.OrdinalIgnoreCase))
        .Select(d => new CalDay(d.DayNumber.ToString(), DayCss(d.Status), $"Day {d.DayNumber} — {d.Status}"));

    // Weekly: 7 cells for the week containing CurrentDate, statuses pulled from the month's data
    IEnumerable<CalDay> WeekDays
    {
        get
        {
            var days = R?.DailyCollectionStreak?.Days ?? new List<DailyCollectionDayDto>();
            var sunday = CurrentDate.AddDays(-(int)CurrentDate.DayOfWeek);
            return Enumerable.Range(0, 7).Select(i =>
            {
                var d = sunday.AddDays(i);
                var match = d.Month == CurrentDate.Month ? days.FirstOrDefault(x => x.DayNumber == d.Day) : null;
                return new CalDay(d.Day.ToString(), match != null ? DayCss(match.Status) : "future", $"{d:ddd MMM d}");
            });
        }
    }

    // Yearly 12-month heatmap is not yet provided by the reports endpoint.
    record MonthCell(string Name, int Rate, string Css, string Label);
    IEnumerable<MonthCell> YearlyMonths => Array.Empty<MonthCell>();

    // ── Delinquency table (from API) ──────────────────────────────
    record DelinqRow(string StallNo, string Occupant, string Section, string Status, string StatusCss, int MissedMonths, decimal Balance);
    IEnumerable<DelinqRow> DelinquentStalls => (R?.StallCompliance ?? new List<StallComplianceDto>())
        .Where(s => s.Balance > 0)
        .Select(s => new DelinqRow(s.StallNo, s.Occupant, s.Section, s.Status, s.Status.ToLowerInvariant(), s.MissedMonths, s.Balance));

    // ── Full stalls compliance table (from API) ───────────────────
    record StallRow(string StallNo, string Occupant, string ContractName, string Section,
                    decimal DailyRate, string Status,
                    decimal AmountPaid, decimal Balance, string ORNumber)
    {
        public bool IsPaid => Status.Equals("Paid", StringComparison.OrdinalIgnoreCase);
        public bool IsPartial => Status.Equals("Partial", StringComparison.OrdinalIgnoreCase);
        public bool IsAbsent => Status.Equals("Absent", StringComparison.OrdinalIgnoreCase);
        // Server emits Paid / Partial / Unpaid / Absent — surface it verbatim with a matching css class.
        public string StatusLabel => Status;
        public string StatusCss   => Status.ToLowerInvariant();
    }
    IEnumerable<StallRow> AllStalls => (R?.StallCompliance ?? new List<StallComplianceDto>())
        .Select(s => new StallRow(s.StallNo, s.Occupant, s.ContractName, s.Section, s.DailyRate,
            s.Status, s.AmountPaid, s.Balance, s.ORNumber ?? ""));

    // ── Stallholder register (mirrors the LGU paper roster) ───────
    // Rentals follow the official ledger: ₱30/day → ₱900/month (flat 30 days) → ₱10,800/year.
    record RegisterRow(string StallNo, string Occupant, string ContractName, string Effectivity,
                       int Years, double AreaSqm, decimal Monthly, decimal WholeYear)
    {
        public bool IsMismatch => !string.IsNullOrWhiteSpace(ContractName)
            && !string.Equals(Occupant?.Trim(), ContractName?.Trim(), StringComparison.OrdinalIgnoreCase);
    }
    IEnumerable<RegisterRow> RegisterRows => (R?.StallCompliance ?? new List<StallComplianceDto>())
        .Select(s =>
        {
            var monthly = s.DailyRate * 30m;        // paper convention: 30 days per month
            return new RegisterRow(
                s.StallNo,
                s.Occupant,
                s.ContractName,
                s.EffectivityDate?.ToString("M/d/yyyy") ?? "—",
                s.DurationYears,
                s.AreaSqm,
                monthly,
                monthly * 12m);                      // ₱10,800 whole year
        });
}
