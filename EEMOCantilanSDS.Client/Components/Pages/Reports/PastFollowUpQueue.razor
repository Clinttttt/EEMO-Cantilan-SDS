@page "/reports/follow-up/history"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using System.Globalization
@using EEMOCantilanSDS.Domain.Common
@using EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Domain.Constants
@using EEMOCantilanSDS.Application.Dtos.Reports
@using EEMOCantilanSDS.Application.Dtos.Payments
@using EEMOCantilanSDS.Application.Dtos.DailyCollections
@using EEMOCantilanSDS.Application.Command.DailyCollections.SaveDailyCollectionOrNumber
@using EEMOCantilanSDS.Application.Command.DailyCollections.SaveDailyCollectionOrForDays
@using EEMOCantilanSDS.Application.Command.Slaughterhouse.SaveSlaughterOrNumber
@using EEMOCantilanSDS.Application.Requests.TransportTerminal
@using EEMOCantilanSDS.Application.Requests.TaboanMarket
@inject EEMOCantilanSDS.Application.Common.Interface.ApiClients.IReportsApiClient ReportsApi
@inject IDailyCollectionApiClient DailyApi
@inject ITrmApiClient TrmApi
@inject ITpmApiClient TpmApi
@inject ISlaughterApiClient SlhApi
@inject EEMOCantilanSDS.Client.Services.FacilityState FacilityCatalog
@inject IJSRuntime JS

@*
    Follow-up History — the SAME layout and tables as the live queue (hero summary, filter bar, urgency
    sections, context-aware columns) but a READ snapshot "as of" a PAST period chosen with the year/month
    dropdowns. Data comes from GET /api/Reports/follow-up/history (GetFollowUpHistoryQuery), which reuses
    the live composer with period-scoped contract-expiry and online-awaiting-OR. "Whole year" loads that
    year's year-end snapshot (its latest available month), which — via the rolling delinquency window —
    reflects the accumulated state across the year.
*@

<PageTitle>@Branding.OfficeAcronym Admin — Follow-up History</PageTitle>

<header class="topbar">
    <div class="topbar-left flex gap-2">
        <a href="/reports/follow-up" class="fh-back" title="Back to the live queue">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
        </a>
        <div>
            <div class="topbar-title">Follow-up History</div>
            <div class="topbar-breadcrumb">
                <a href="/reports/follow-up" class="breadcrumb-link">Follow-up Queue</a>
                <span class="breadcrumb-sep">/</span>
                <span class="breadcrumb-active">History</span>
            </div>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @_now.ToString("MMMM d, yyyy")
        </div>
        <AccountChip />
    </div>
</header>

<div class="content-area">

    @{
        var allItems = AllItems;
        var shown = Filtered(allItems).ToList();
        var periodLabel = _selMonth == 0
            ? $"{_selYear} · Whole year"
            : new DateTime(_selYear, _selMonth, 1).ToString("MMMM yyyy");
        var asOfLabel = _data is null ? periodLabel : $"{periodLabel} · as of {_data.AsOf:MMM d, yyyy}";
    }

    <!-- Hero + section-count summary (same as the live queue) -->
    <div class="fh-hero">
        <div class="fh-hero-left">
            <div class="fh-hero-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 3v5h5" /><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8" /><polyline points="12 7 12 12 15 14" />
                </svg>
            </div>
            <div>
                <div class="fh-hero-eyebrow">Follow-up · History</div>
                <div class="fh-hero-title">Past follow-up</div>
                <div class="fh-hero-sub">@asOfLabel</div>
            </div>
        </div>
        <div class="fh-hero-stats">
            <div class="fh-stat">
                <div class="fh-stat-val fh-stat-critical">@allItems.Count(r => r.Section == 1)</div>
                <div class="fh-stat-key">Immediate</div>
            </div>
            <div class="fh-hero-divider"></div>
            <div class="fh-stat">
                <div class="fh-stat-val">@allItems.Count(r => r.Section == 2)</div>
                <div class="fh-stat-key">This period</div>
            </div>
            <div class="fh-hero-divider"></div>
            <div class="fh-stat">
                <div class="fh-stat-val">@allItems.Count(r => r.Section == 3)</div>
                <div class="fh-stat-key">Verify</div>
            </div>
            <div class="fh-hero-divider"></div>
            <div class="fh-stat">
                <div class="fh-stat-val">@allItems.Count(r => r.Section == 4)</div>
                <div class="fh-stat-key">Operational</div>
            </div>
        </div>
    </div>

    <!-- Filter bar (same as the live queue). Reason chips on the left, period picker pinned right. -->
    <div class="fh-filterbar">
        <div class="fh-reasonrow">
            <div class="fh-filters" role="group" aria-label="Filter by reason">
                @foreach (var f in ReasonFilters)
                {
                    var count = CountFor(allItems, f.Key);
                    <button type="button" class="fh-chip @(_reason == f.Key ? "fh-chip-active" : "")"
                            disabled="@(count == 0 && f.Key != "all")"
                            @onclick="@(() => _reason = f.Key)">
                        @f.Label<span class="fh-chip-count">@count</span>
                    </button>
                }
            </div>
        </div>

        <div class="fh-toolrow">
            <!-- Period picker — professional custom dropdowns, in line with the reason chips (Excused) -->
            <div class="fh-period-select" role="group" aria-label="Choose the period">

                <!-- Year -->
                <div class="fh-dd @(_yearOpen ? "open" : "")">
                    <button type="button" class="fh-dd-trigger @(_yearOpen ? "open" : "")" @onclick="ToggleYear" aria-haspopup="listbox" aria-expanded="@_yearOpen">
                        <span class="fh-dd-body">
                            <span class="fh-dd-cap">Year</span>
                            <span class="fh-dd-val">@_selYear</span>
                        </span>
                        <svg class="fh-dd-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
                    </button>
                    @if (_yearOpen)
                    {
                        <div class="fh-dd-backdrop" @onclick="CloseAll"></div>
                        <div class="fh-dd-menu" role="listbox" aria-label="Year">
                            <div class="fh-dd-header">Year</div>
                            @foreach (var y in Years)
                            {
                                <div class="fh-dd-item @(_selYear == y ? "active" : "")" role="option" aria-selected="@(_selYear == y)" @onclick="() => SelectYear(y)">
                                    <span class="fh-dd-name">@y</span>
                                    @if (_selYear == y)
                                    {
                                        <svg class="fh-dd-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Month (incl. Whole year) -->
                <div class="fh-dd @(_monthOpen ? "open" : "")">
                    <button type="button" class="fh-dd-trigger @(_monthOpen ? "open" : "")" @onclick="ToggleMonth" aria-haspopup="listbox" aria-expanded="@_monthOpen">
                        <span class="fh-dd-body">
                            <span class="fh-dd-cap">Month</span>
                            <span class="fh-dd-val">@(_selMonth == 0 ? "Whole year" : MonthName(_selMonth))</span>
                        </span>
                        <svg class="fh-dd-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9" /></svg>
                    </button>
                    @if (_monthOpen)
                    {
                        <div class="fh-dd-backdrop" @onclick="CloseAll"></div>
                        <div class="fh-dd-menu fh-dd-menu-right" role="listbox" aria-label="Month">
                            <div class="fh-dd-header">Month</div>
                            <div class="fh-dd-item @(_selMonth == 0 ? "active" : "")" role="option" aria-selected="@(_selMonth == 0)" @onclick="() => SelectMonth(0)">
                                <span class="fh-dd-name">Whole year</span>
                                @if (_selMonth == 0)
                                {
                                    <svg class="fh-dd-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                }
                            </div>
                            @foreach (var m in MonthsFor(_selYear))
                            {
                                <div class="fh-dd-item @(_selMonth == m ? "active" : "")" role="option" aria-selected="@(_selMonth == m)" @onclick="() => SelectMonth(m)">
                                    <span class="fh-dd-name">@MonthName(m)</span>
                                    @if (_selMonth == m)
                                    {
                                        <svg class="fh-dd-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12" /></svg>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
            <div class="fh-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="search" placeholder="Search payor, stall, facility, or reason…" value="@_search" @oninput="e => _search = e.Value?.ToString() ?? string.Empty" aria-label="Search history" />
                @if (!string.IsNullOrWhiteSpace(_search))
                {
                    <button class="fh-search-clear" type="button" @onclick="@(() => _search = string.Empty)" aria-label="Clear search">&times;</button>
                }
            </div>
            <div class="fh-filters" role="group" aria-label="Filter by facility">
                <button type="button" class="fh-chip @(_facility is null ? "fh-chip-active" : "")" @onclick="@(() => _facility = null)">All Facilities</button>
                @foreach (var fc in FacilityCatalog.All)
                {
                    <button type="button" class="fh-chip @(_facility == fc ? "fh-chip-active" : "")" @onclick="@(() => _facility = fc)">@FacilityCatalog.ShortNameOf(fc)</button>
                }
            </div>
        </div>
    </div>

    @if (_loading)
    {
        <div class="fh-loading" aria-busy="true" aria-label="Loading @periodLabel">
            @for (var s = 0; s < 3; s++)
            {
                <section class="fh-section fh-loading-section">
                    <div class="fh-sec-head">
                        <span class="fh-sec-rail"></span>
                        <Skeleton Width="24px" Height="24px" Radius="7px" />
                        <div class="fh-loading-sec-info">
                            <Skeleton Width="210px" Height="15px" Radius="6px" />
                            <Skeleton Width="300px" Height="11px" Radius="5px" Class="fh-sk-gap" />
                        </div>
                    </div>
                    <div class="fh-table-wrap">
                        <div class="fh-table-skeleton">
                            <Skeleton Height="34px" Radius="6px" />
                            @for (var row = 0; row < 4; row++)
                            {
                                <Skeleton Height="40px" Radius="6px" />
                            }
                        </div>
                    </div>
                </section>
            }
        </div>
    }
    else if (_data is null)
    {
        <div class="fh-state fh-state-error">
            Unable to load the follow-up history.
            <button class="fh-retry" type="button" @onclick="Load">Try again</button>
        </div>
    }
    else
    {
        var visibleSections = Sections
            .Select(s => new { Section = s, Items = shown.Where(r => r.Section == s.Id).ToList() })
            .Where(x => x.Items.Count > 0)
            .ToList();

        if (visibleSections.Count == 0)
        {
            <div class="fh-empty">
                <div class="fh-empty-icon">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                </div>
                <div class="fh-empty-title">No follow-up items for @periodLabel.</div>
                <div class="fh-empty-sub">Nothing matched the selected scope for this period.</div>
            </div>
        }
        else
        {
            @foreach (var grp in visibleSections)
            {
                <section class="fh-section">
                    <div class="fh-sec-head fh-sec-@grp.Section.Tone">
                        <span class="fh-sec-rail"></span>
                        <span class="fh-sec-count">@grp.Items.Count</span>
                        <div class="fh-sec-info">
                            <div class="fh-sec-title">@grp.Section.Title</div>
                            <div class="fh-sec-sub">@grp.Section.Sub</div>
                        </div>
                    </div>
                    <div class="fh-table-wrap">
                        @{ var cols = ColumnsFor(grp.Section.Id); }
                        <table class="fh-table">
                            <thead>
                                <tr>
                                    @foreach (var col in cols)
                                    {
                                        <th>@col.Header</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in grp.Items)
                                {
                                    <tr class="fh-row fh-pri-@PriClass(r.Priority)">
                                        @foreach (var col in cols)
                                        {
                                            switch (col.Key)
                                            {
                                                case "reason":
                                                    <td><span class="fh-reason fh-rb-@PriClass(r.Priority)">@r.Reason</span></td>
                                                    break;
                                                case "payor":
                                                    <td>
                                                        <div class="fh-person">@r.Person</div>
                                                        <div class="fh-sub">@r.Identifier · @r.Facility · @r.Model</div>
                                                    </td>
                                                    break;
                                                case "periodstatus":
                                                    <td>
                                                        <div class="fh-period">@r.Period</div>
                                                        <div class="fh-sub">@r.Status</div>
                                                    </td>
                                                    break;
                                                case "period":
                                                    <td><div class="fh-period">@r.Period</div></td>
                                                    break;
                                                case "note":
                                                    <td><span class="fh-note">@r.Status</span></td>
                                                    break;
                                                case "amount":
                                                    <td><span class="fh-amount @(r.Amount is null or 0 ? "fh-amount-muted" : "")">@AmountLabel(r)</span></td>
                                                    break;
                                                case "action":
                                                    <td>
                                                        <div class="fh-action-cell">
                                                            @if (r.Action == "Add OR")
                                                            {
                                                                <button type="button" class="fh-action fh-action-btn" @onclick="() => OpenAddOr(r)">@r.Action<span class="fh-action-arrow">→</span></button>
                                                            }
                                                            else if (CanPay(r))
                                                            {
                                                                <button type="button" class="fh-action fh-action-btn" @onclick="() => OpenPayBill(r)">Record payment<span class="fh-action-arrow">→</span></button>
                                                            }
                                                            else
                                                            {
                                                                <a class="fh-action" href="@r.Link">@r.Action<span class="fh-action-arrow">→</span></a>
                                                            }
                                                        </div>
                                                    </td>
                                                    break;
                                            }
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </section>
            }
        }
    }
</div>

@if (_orItem is not null)
{
    <div class="fq-modal-overlay" @onclick="CloseAddOr">
        <div class="fq-modal" @onclick:stopPropagation="true">
            <div class="fq-modal-head">
                <div>
                    <div class="fq-modal-title">Add OR — @_orItem.Person</div>
                    <div class="fq-modal-sub">@_orItem.Identifier · @_orItem.Facility · @_orItem.Period</div>
                </div>
                <button type="button" class="fq-modal-x" @onclick="CloseAddOr" aria-label="Close">&times;</button>
            </div>
            <div class="fq-modal-body">
                @if (_orLoading)
                {
                    <div class="fq-or-state">Loading records…</div>
                }
                else if (_orError is not null)
                {
                    <div class="fq-or-state fq-or-error">@_orError</div>
                }
                else if (_orRows.Count == 0)
                {
                    <div class="fq-or-state">All records for this entry already have an OR number.</div>
                }
                else
                {
                    var npmDaily = _orModel == OrModel.NpmDaily;
                    var unsaved = _orRows.Count(r => !r.Saved);
                    <div class="fq-or-note">
                        Enter the official receipt (OR) number for each record still missing one. Each OR must be unique.
                        @if (npmDaily)
                        {
                            <text> A single OR may cover several days of the same payor — one physical receipt, one OR.</text>
                        }
                        else
                        {
                            <text> For the slaughterhouse, one OR covers a whole visit (all animals on that date).</text>
                        }
                    </div>

                    @if (npmDaily && unsaved > 1)
                    {
                        <div class="fq-or-modes" role="tablist">
                            <button type="button" class="fq-or-mode @(!_orMulti ? "on" : "")" @onclick="() => SetOrMulti(false)" disabled="@_orMultiSaving">One OR per day</button>
                            <button type="button" class="fq-or-mode @(_orMulti ? "on" : "")" @onclick="() => SetOrMulti(true)" disabled="@_orMultiSaving">One OR · multiple days</button>
                        </div>
                    }

                    <div class="fq-or-list">
                        @foreach (var r in _orRows)
                        {
                            @if (_orMulti && npmDaily && !r.Saved)
                            {
                                <label class="fq-or-row fq-or-rowpick">
                                    <input type="checkbox" class="fq-or-pick" checked="@r.Selected"
                                           @onchange="e => r.Selected = (bool)(e.Value ?? false)" disabled="@_orMultiSaving" />
                                    <div class="fq-or-day">
                                        <div class="fq-or-date">@r.Label</div>
                                        <div class="fq-or-amt">₱@r.Amount.ToString("N0")</div>
                                    </div>
                                </label>
                            }
                            else
                            {
                                <div class="fq-or-row @(r.Saved ? "fq-or-rowdone" : "")">
                                    <div class="fq-or-day">
                                        <div class="fq-or-date">@r.Label</div>
                                        <div class="fq-or-amt">₱@r.Amount.ToString("N0")</div>
                                    </div>
                                    @if (r.Saved)
                                    {
                                        <div class="fq-or-done"><span class="fq-or-check">✓</span> OR @r.Input</div>
                                    }
                                    else if (r.Confirming)
                                    {
                                        <div class="fq-or-confirm">
                                            <span class="fq-or-confirm-q">Save OR <strong>@r.Input.Trim()</strong>?</span>
                                            <button type="button" class="fq-or-confirm-yes" @onclick="() => SaveOrDay(r)" disabled="@r.Saving">
                                                @(r.Saving ? "Saving…" : "Confirm")
                                            </button>
                                            <button type="button" class="fq-or-confirm-no" @onclick="() => CancelConfirm(r)" disabled="@r.Saving">Cancel</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <input class="fq-or-input" placeholder="OR number" maxlength="50" @bind="r.Input" @bind:event="oninput" disabled="@r.Saving" />
                                        <button type="button" class="fq-or-save"
                                                @onclick="() => BeginSave(r)"
                                                disabled="@(r.Saving || string.IsNullOrWhiteSpace(r.Input))">
                                            Save
                                        </button>
                                    }
                                    @if (r.Error is not null)
                                    {
                                        <div class="fq-or-rowerr">@r.Error</div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    @if (_orMulti && npmDaily)
                    {
                        var picked = _orRows.Count(r => !r.Saved && r.Selected);
                        <div class="fq-or-multibar">
                            <div class="fq-or-multiinfo">
                                <span class="fq-or-multicount">@picked day@(picked == 1 ? "" : "s") selected</span>
                                @if (picked > 0)
                                {
                                    <span class="fq-or-multitotal">₱@_orRows.Where(r => !r.Saved && r.Selected).Sum(r => r.Amount).ToString("N0")</span>
                                }
                            </div>
                            <div class="fq-or-multirow">
                                <input class="fq-or-input" placeholder="OR number" maxlength="50" @bind="_orMultiOr" @bind:event="oninput" disabled="@_orMultiSaving" />
                                <button type="button" class="fq-or-save"
                                        @onclick="ApplyOrToSelected"
                                        disabled="@(_orMultiSaving || string.IsNullOrWhiteSpace(_orMultiOr) || picked == 0)">
                                    @(_orMultiSaving ? "Saving…" : "Apply OR")
                                </button>
                            </div>
                            @if (_orMultiError is not null)
                            {
                                <div class="fq-or-rowerr">@_orMultiError</div>
                            }
                        </div>
                    }
                }
            </div>
            <div class="fq-modal-foot">
                <button type="button" class="fq-modal-done" @onclick="CloseAddOr">Done</button>
            </div>
        </div>
    </div>
}

<PayBillModal Show="@(_payItem is not null)"
              StallId="@(_payItem?.StallId ?? Guid.Empty)"
              Facility="@(_payItem?.Facility ?? FacilityCode.NPM)"
              StallNo="@PayStallNo"
              Occupant="@(_payItem?.Person ?? string.Empty)"
              OnClose="ClosePayBill"
              OnChanged="OnPaid" />

@code {
    // ── Inline Add-OR (records missing a receipt number) ───────────────────────────
    // Works for every facility model. Reuses each facility's existing OR-save; for SLH one OR
    // covers a whole visit (all animal rows on that date). Period comes from the loaded history
    // snapshot (a past period), not "today".
    private enum OrModel { NpmDaily, Monthly, Trm, Tpm, Slh }

    private sealed class OrRow
    {
        public string Label { get; init; } = "";
        public decimal Amount { get; init; }
        public string Input { get; set; } = "";
        public bool Saving { get; set; }
        public bool Saved { get; set; }
        public bool Confirming { get; set; }
        public bool Selected { get; set; }
        public string? Error { get; set; }
        public DateOnly Date { get; init; }   // NPM day / SLH visit date
        public Guid RecordId { get; init; }    // monthly PaymentId / TRM TripId / TPM AttendanceId
    }

    private FollowUpItemDto? _orItem;
    private OrModel _orModel;
    private bool _orLoading;
    private string? _orError;
    private bool _orSavedAny;
    private List<OrRow> _orRows = new();

    // NPM "one OR for several days" mode: pick multiple unsaved days, enter one OR, apply in one call.
    private bool _orMulti;
    private string _orMultiOr = string.Empty;
    private bool _orMultiSaving;
    private string? _orMultiError;

    private void SetOrMulti(bool on)
    {
        _orMulti = on;
        _orMultiError = null;
        if (!on)
            foreach (var r in _orRows) r.Selected = false;
    }

    private async Task ApplyOrToSelected()
    {
        if (_orMultiSaving) return;
        _orMultiError = null;

        var or = (_orMultiOr ?? string.Empty).Trim();
        if (string.IsNullOrWhiteSpace(or)) { _orMultiError = "Enter an OR number."; return; }
        if (_orItem?.StallId is not { } sid) { _orMultiError = "Missing stall reference."; return; }

        var dates = _orRows.Where(r => !r.Saved && r.Selected).Select(r => r.Date).ToList();
        if (dates.Count == 0) { _orMultiError = "Select at least one day."; return; }

        _orMultiSaving = true;
        var result = await DailyApi.SaveOrForDaysAsync(new SaveDailyCollectionOrForDaysCommand(sid, dates, or));
        _orMultiSaving = false;

        if (result.IsSuccess)
        {
            foreach (var r in _orRows.Where(r => !r.Saved && r.Selected).ToList())
            {
                r.Input = or;
                r.Saved = true;
                r.Selected = false;
            }
            _orSavedAny = true;
            _orMultiOr = string.Empty;
            // Drop back to per-day mode once nothing (or one day) is left to receipt.
            if (_orRows.Count(r => !r.Saved) <= 1) _orMulti = false;
        }
        else
        {
            _orMultiError = result.Error ?? "Couldn't apply the OR number to the selected days.";
        }
    }

    // ── Record payment (reuses the shared PayBillModal → existing collection calendars) ──
    private FollowUpItemDto? _payItem;

    // Any stall-scoped account behind on payments (or an expired contract with a balance) is payable
    // here. NPM opens the daily calendar; monthly facilities open the month grid — both in PayBillModal.
    private static bool CanPay(FollowUpItemDto r) =>
        r.StallId.HasValue
        && r.ReasonKind is "contract" or "current" or "delinquent" or "arrears";

    private string PayStallNo => _payItem is null
        ? string.Empty
        : (_payItem.Identifier.StartsWith("Stall ", StringComparison.OrdinalIgnoreCase)
            ? _payItem.Identifier["Stall ".Length..].Trim()
            : _payItem.Identifier);

    private void OpenPayBill(FollowUpItemDto item) => _payItem = item;
    private void ClosePayBill() => _payItem = null;
    private async Task OnPaid() => await Load();

    private static OrModel ModelFor(FacilityCode f) => f switch
    {
        FacilityCode.NPM => OrModel.NpmDaily,
        FacilityCode.SLH => OrModel.Slh,
        FacilityCode.TRM => OrModel.Trm,
        FacilityCode.TPM => OrModel.Tpm,
        _ => OrModel.Monthly,   // TCC / NCC / BBQ / ICE
    };

    // Mirrors the server's display normalisation so name-keyed rows (SLH/TRM/TPM) match.
    private static string Named(string? v) => string.IsNullOrWhiteSpace(v) ? "Unnamed occupant" : v!;

    // Parses a "MMMM yyyy" period label to (year, month) so a whole-year row opens its OWN month in the
    // Add-OR modal; falls back to the snapshot date for non-month labels (e.g. contract date ranges).
    private static (int Year, int Month) ParsePeriodMonth(string? period, DateOnly fallback)
    {
        if (!string.IsNullOrWhiteSpace(period)
            && DateTime.TryParseExact(period.Trim(), "MMMM yyyy", CultureInfo.InvariantCulture, DateTimeStyles.None, out var dt))
            return (dt.Year, dt.Month);
        return (fallback.Year, fallback.Month);
    }

    private async Task OpenAddOr(FollowUpItemDto item)
    {
        _orItem = item;
        _orModel = ModelFor(item.Facility);
        _orRows = new();
        _orError = null;
        _orSavedAny = false;
        _orMulti = false;
        _orMultiOr = string.Empty;
        _orMultiError = null;
        _orLoading = true;
        // The record's own billing period (from its row) — so a whole-year row opens the RIGHT month,
        // not the snapshot's "as of" month. Falls back to the snapshot period when the label isn't a month.
        var (y, m) = ParsePeriodMonth(item.Period, _data?.AsOf ?? DateOnly.FromDateTime(_now));

        switch (_orModel)
        {
            case OrModel.NpmDaily:
                if (item.StallId is { } npmStall)
                {
                    var r = await DailyApi.GetDailyCollectionMonthAsync(npmStall, y, m);
                    if (r.IsSuccess && r.Value is not null)
                        _orRows = r.Value.Collections.Values
                            .Where(d => d.IsPaid && string.IsNullOrWhiteSpace(d.ORNumber))
                            .OrderBy(d => d.Date)
                            .Select(d => new OrRow
                            {
                                Label = d.Date.ToString("MMM d, yyyy"),
                                Amount = FeeRates.NpmDailyFee + (d.FishKilos.HasValue ? d.FishKilos.Value * FeeRates.NpmFishFeePerKilo : 0m),
                                Date = d.Date
                            }).ToList();
                    else _orError = r.Error ?? "Couldn't load daily receipts.";
                }
                else _orError = "Missing stall reference.";
                break;

            case OrModel.Monthly:
                if (item.StallId is { } monStall)
                {
                    var r = await PaymentsApi.GetPaymentRecordAsync(monStall, y, m);
                    if (r.IsSuccess && r.Value is not null)
                    {
                        if (string.IsNullOrWhiteSpace(r.Value.ORNumber))
                            _orRows = new() { new OrRow { Label = item.Period, Amount = r.Value.TotalPaid, RecordId = r.Value.Id } };
                    }
                    else _orError = r.Error ?? "Couldn't load the payment record.";
                }
                else _orError = "Missing stall reference.";
                break;

            case OrModel.Trm:
                {
                    var r = await TrmApi.GetTripsAsync(y, m);
                    if (r.IsSuccess && r.Value is not null)
                        _orRows = r.Value
                            .Where(t => string.IsNullOrWhiteSpace(t.ORNumber) && Named(t.DriverName) == item.Person)
                            .OrderBy(t => t.RecordedAt)
                            .Select(t => new OrRow { Label = $"Trip #{t.TripNumber} · {t.RecordedAt:MMM d}", Amount = t.Fee, RecordId = t.Id })
                            .ToList();
                    else _orError = r.Error ?? "Couldn't load trips.";
                }
                break;

            case OrModel.Tpm:
                {
                    var r = await TpmApi.GetMonthAttendanceAsync(y, m);
                    if (r.IsSuccess && r.Value is not null)
                        _orRows = r.Value
                            .Where(a => a.IsPaid && string.IsNullOrWhiteSpace(a.ORNumber) && Named(a.VendorName) == item.Person)
                            .OrderBy(a => a.MarketDate)
                            .Select(a => new OrRow { Label = a.MarketDate.ToString("MMM d, yyyy"), Amount = a.Fee, RecordId = a.Id })
                            .ToList();
                    else _orError = r.Error ?? "Couldn't load market days.";
                }
                break;

            case OrModel.Slh:
                {
                    var r = await SlhApi.GetTransactionsAsync(y, m);
                    if (r.IsSuccess && r.Value is not null)
                        // One OR per VISIT (owner + date), covering every animal row on that date.
                        _orRows = r.Value
                            .Where(t => string.IsNullOrWhiteSpace(t.ORNumber) && Named(t.OwnerName) == item.Person)
                            .GroupBy(t => t.TransactionDate)
                            .OrderBy(g => g.Key)
                            .Select(g => new OrRow
                            {
                                Label = $"{g.Key:MMM d, yyyy} · {g.Sum(x => x.NumberOfHeads)} head{(g.Sum(x => x.NumberOfHeads) == 1 ? "" : "s")}",
                                Amount = g.Sum(x => x.TotalAmount),
                                Date = g.Key
                            }).ToList();
                    else _orError = r.Error ?? "Couldn't load slaughter receipts.";
                }
                break;
        }
        _orLoading = false;
    }

    // Step 1 — validate the entry, then ask the admin to confirm (guards against a mistyped OR
    // before anything is written).
    private void BeginSave(OrRow row)
    {
        row.Error = null;
        var or = row.Input?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(or)) return;

        // Catch the most common admin typo before committing: the same OR entered twice here.
        if (_orRows.Any(o => !ReferenceEquals(o, row) && string.Equals((o.Input ?? string.Empty).Trim(), or, StringComparison.OrdinalIgnoreCase)))
        {
            row.Error = "That OR number is already entered for another item here.";
            return;
        }

        row.Confirming = true;
    }

    private void CancelConfirm(OrRow row) => row.Confirming = false;

    // Step 2 — commit, only after the admin confirms.
    private async Task SaveOrDay(OrRow row)
    {
        var or = row.Input?.Trim() ?? "";
        if (string.IsNullOrWhiteSpace(or)) { row.Confirming = false; return; }

        row.Saving = true;
        row.Error = null;

        Result<bool>? result = null;
        switch (_orModel)
        {
            case OrModel.NpmDaily:
                if (_orItem?.StallId is { } sid)
                    result = await DailyApi.SaveOrNumberAsync(new SaveDailyCollectionOrNumberCommand(sid, row.Date, or));
                break;
            case OrModel.Monthly:
                result = await PaymentsApi.SaveOrNumberAsync(new SaveOrNumberCommand(row.RecordId, or));
                break;
            case OrModel.Trm:
                result = await TrmApi.SaveOrNumberAsync(row.RecordId, new SaveTripOrNumberRequest(or));
                break;
            case OrModel.Tpm:
                result = await TpmApi.SaveOrNumberAsync(row.RecordId, new SaveOrNumberRequest(or));
                break;
            case OrModel.Slh:
                if (_orItem is not null)
                    result = await SlhApi.SaveOrNumberAsync(new SaveSlaughterOrNumberCommand(_orItem.Person, row.Date, or));
                break;
        }

        if (result is null)
            row.Error = "Couldn't save this OR number.";
        else if (result.IsSuccess)
        {
            row.Input = or;
            row.Saved = true;
            _orSavedAny = true;
        }
        else
            row.Error = result.Error ?? "Couldn't save this OR number.";

        row.Saving = false;
        row.Confirming = false;
    }

    private async Task CloseAddOr()
    {
        var reload = _orSavedAny;
        _orItem = null;
        _orRows = new();
        _orSavedAny = false;
        if (reload) await Load();   // receipted records drop off the snapshot → refresh it
    }

    private readonly DateTime _now = PhilippineTime.Now;
    private List<(int Year, int Month)> Periods = new();
    private List<int> Years = new();
    private int _selYear;
    private int _selMonth;

    private FollowUpQueueDto? _data;
    private bool _loading = true;

    [PersistentState(AllowUpdates = true)]
    public FollowUpHistoryPageState? CachedFollowUpHistory { get; set; }

    private string _reason = "all";
    private string _search = "";
    private FacilityCode? _facility;

    private bool _yearOpen;
    private bool _monthOpen;

    private static readonly (string Key, string Label)[] ReasonFilters =
    {
        ("all", "All"), ("delinquent", "Delinquent"), ("arrears", "Arrears"), ("missingor", "Missing OR"),
        ("current", "Current-period"), ("contract", "Contract"), ("npm", "NPM Daily"), ("excused", "Excused"),
        ("misc", "Miscellaneous"),
    };

    private static readonly FacilityCode[] AllFacilities = System.Array.Empty<FacilityCode>();

    // Same urgency bands as the live queue (consistency).
    private sealed record SecDef(int Id, string Title, string Sub, string Tone);

    private static readonly SecDef[] Sections =
    {
        new(1, "Needs immediate action", "Delinquent · missing receipts · expired contracts", "critical"),
        new(2, "Needs follow-up this period", "Unpaid · partial · arrears · expiring contracts", "high"),
        new(3, "Needs verification", "Excused / absent records", "review"),
        new(4, "Facility-specific operational", "Daily · per-trip · market-day exceptions", "normal"),
