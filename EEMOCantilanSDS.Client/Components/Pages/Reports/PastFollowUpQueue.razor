    protected override async Task OnInitializedAsync()
    {
        await FacilityCatalog.EnsureLoadedAsync();
        for (var i = 1; i <= 12; i++)
        {
            var d = _now.AddMonths(-i);
            Periods.Add((d.Year, d.Month));
        }
        Years = Periods.Select(p => p.Year).Distinct().OrderByDescending(y => y).ToList();

        // Default view: the most recent year, whole-year (year-end snapshot) selected.
        _selYear = Years.Count > 0 ? Years[0] : _now.Year;
        _selMonth = 0;

        if (TryApplyCachedFollowUpHistory())
            return;

        await Load();
    }

    private IReadOnlyList<FollowUpItemDto> AllItems => _data?.Items ?? Array.Empty<FollowUpItemDto>();

    private List<int> MonthsFor(int year) =>
        Periods.Where(p => p.Year == year).Select(p => p.Month).OrderByDescending(m => m).ToList();

    // The effective month to load: a chosen month, or (whole-year) the latest available month of the year.
    private int EffectiveMonth()
    {
        if (_selMonth != 0) return _selMonth;
        var months = MonthsFor(_selYear);
        return months.Count > 0 ? months[0] : _now.Month;
    }

    private static string MonthName(int month) => new DateTime(2000, month, 1).ToString("MMMM");

    // ── Dropdown interactions ──
    private void ToggleYear() { _yearOpen = !_yearOpen; _monthOpen = false; }
    private void ToggleMonth() { _monthOpen = !_monthOpen; _yearOpen = false; }
    private void CloseAll() { _yearOpen = false; _monthOpen = false; }

    private async Task SelectYear(int year)
    {
        _selYear = year;
        // Whole-year stays selected across years; otherwise keep a valid month for the year.
        if (_selMonth != 0)
        {
            var months = MonthsFor(_selYear);
            if (months.Count > 0 && !months.Contains(_selMonth)) _selMonth = months[0];
        }
        _yearOpen = false;
        await Load();
    }

    private async Task SelectMonth(int month)
    {
        _selMonth = month;
        _monthOpen = false;
        await Load();
    }

    private async Task Load()
    {
        _loading = true;
        var year = _selYear;
        var month = EffectiveMonth();
        var wholeYear = _selMonth == 0;
        await PaintLoadingStateAsync();

        // Cold-start resilience: tolerate the brief window before the circuit attaches the JWT.
        for (var attempt = 0; attempt < 5; attempt++)
        {
            var result = await ReportsApi.GetFollowUpHistoryAsync(year, month, wholeYear);
            if (result.IsSuccess)
            {
                _data = result.Value;
                if (_data is not null)
                {
                    CachedFollowUpHistory = new FollowUpHistoryPageState(
                        _selYear,
                        _selMonth,
                        month,
                        _data);
                }

                break;
            }
            _data = null;
            if (result.StatusCode is not (401 or 403)) break;
            await Task.Delay(400);
        }
        _loading = false;
    }

    private bool TryApplyCachedFollowUpHistory()
    {
        if (CachedFollowUpHistory is not { } state
            || state.SelectedYear != _selYear
            || state.SelectedMonth != _selMonth
            || state.EffectiveMonth != EffectiveMonth())
        {
            return false;
        }

        _data = state.Data;
        _loading = false;
        return true;
    }

    // ── Client-side filtering (reason / facility / search) over the loaded snapshot ──
    private async Task PaintLoadingStateAsync()
    {
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
    }

    private IEnumerable<FollowUpItemDto> Filtered(IReadOnlyList<FollowUpItemDto> items) => items.Where(r =>
        (_reason == "all" || r.ReasonKind == _reason)
        && (_facility is null || r.Facility == _facility)
        && MatchesSearch(r));

    private int CountFor(IReadOnlyList<FollowUpItemDto> items, string key) => items.Count(r =>
        (key == "all" || r.ReasonKind == key)
        && (_facility is null || r.Facility == _facility)
        && MatchesSearch(r));

    private bool MatchesSearch(FollowUpItemDto r)
    {
        if (string.IsNullOrWhiteSpace(_search)) return true;
        var q = _search.Trim();
        return Has(r.Person, q) || Has(r.Identifier, q) || Has(r.Reason, q)
            || Has(r.Facility.ToString(), q) || Has(r.Model, q) || Has(r.Status, q)
            || Has(r.Period, q) || Has(r.Action, q);
    }

    private static bool Has(string? v, string q) => !string.IsNullOrEmpty(v) && v.Contains(q, StringComparison.OrdinalIgnoreCase);

    // Priority → tone class (matches the live queue's reason badge / row rail colouring).
    private static string PriClass(string priority) => priority switch
    {
        "Critical" => "critical",
        "High" => "high",
        "Review" => "review",
        _ => "normal",
    };

    private static string AmountLabel(FollowUpItemDto r) =>
        r.Excused ? "Excused" : r.Amount is { } a ? "₱" + a.ToString("N0") : "—";

    public sealed record FollowUpHistoryPageState(
        int SelectedYear,
        int SelectedMonth,
        int EffectiveMonth,
        FollowUpQueueDto Data);
}
