@page "/slh/reports"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using EEMOCantilanSDS.Application.Dtos.Slaughterhouse
@using EEMOCantilanSDS.Application.Dtos.Facilities
@using EEMOCantilanSDS.Domain.Enums
@inject ISlaughterApiClient SlaughterApi
@inject IJSRuntime JS

@inject EEMOCantilanSDS.Client.Services.BrandingState Branding

<PageTitle>EEMO Admin — Slaughterhouse Reports</PageTitle>

<!-- ══ Topbar ══ -->
<div class="rpt-topbar">
    <div class="rpt-topbar-left">
        <a href="/slh" class="rpt-back-btn" title="Back to Slaughterhouse">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
        </a>
        <div class="rpt-topbar-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2.5c0 1.5-1.5 5-1.5 5h-2S9.5 4 9.5 2.5a2.5 2.5 0 015 0z"/><path d="M12 7.5V22"/><path d="M5 12h14"/></svg>
        </div>
        <div>
            <div class="rpt-eyebrow">FACILITY · SLH · REPORTS</div>
            <div class="rpt-title">Slaughterhouse Reports</div>
            <div class="rpt-subtitle">@(ShowPrintReport ? PrintReportPeriodLabel : ShowHistory ? HistoryPeriodLabel : GetPeriodLabel())</div>
        </div>
    </div>
    <div class="rpt-topbar-right">
        <LiveClock />
    </div>
    <div class="rpt-header-progress"><div class="rpt-header-progress-fill" style="width:100%"></div></div>
</div>

<!-- ══ Period Selector ══ -->
<div class="rpt-period-bar">
    <div class="rpt-period-tabs">
        @foreach (var p in new[] { "Weekly", "Monthly", "Yearly" })
        {
            <button type="button" class="rpt-period-tab @(!ShowPrintReport && !ShowHistory && ActivePeriod == p ? "active" : "")"
                    aria-pressed="@(!ShowPrintReport && !ShowHistory && ActivePeriod == p)"
                    @onclick="() => SetPeriod(p)">@p</button>
        }
        <button type="button" class="rpt-period-tab rpt-document-tab @(ShowPrintReport ? "active" : "")"
                aria-pressed="@ShowPrintReport" @onclick="ShowPrintReportView">
            <svg aria-hidden="true" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="8" y1="13" x2="16" y2="13" /><line x1="8" y1="17" x2="16" y2="17" /></svg>
            <span>Status Report</span>
        </button>
        <button type="button" class="rpt-period-tab rpt-document-tab @(ShowHistory ? "active" : "")"
                aria-pressed="@ShowHistory" @onclick="ShowHistoryView">
            <svg aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            <span>History</span>
        </button>
    </div>
    <ReportPeriodNav Year="CurrentDate.Year" Month="CurrentDate.Month"
                     Yearly="@(!ShowPrintReport && (ShowHistory || ActivePeriod == "Yearly"))"
                     Label="@(ShowPrintReport ? PrintReportPeriodLabel : ShowHistory ? HistoryPeriodLabel : GetPeriodLabel())"
                     UtilityMode="@(ShowPrintReport || ShowHistory)"
                     OnPrev="PrevPeriod" OnNext="NextPeriod"
                     OnPick="PickPeriod" OnToday="JumpToCurrent" />
</div>

@if (ShowPrintReport)
{
    <!-- ══ Phase 2: Status Report ══ -->
    <div class="rpt-content print-document-content">
        <section class="print-report-sheet status-sheet">
            <header class="print-report-header">
                <img class="print-report-logo" src="@Branding.SealPath" alt="LGU Cantilan logo" />
                <div class="print-republic">Republic of the Philippines</div>
                <h2>@Branding.OfficeName</h2>
                <p>Municipality of @Branding.Municipality, @Branding.Province</p>
                <div class="print-report-title">Slaughterhouse — Collection Status Report</div>
            </header>
            <div class="print-report-meta">
                <div><span>Facility</span><strong>Slaughterhouse</strong></div>
                <div><span>Report Period</span><strong>@CurrentDate.ToString("MMMM yyyy")</strong></div>
                <div><span>Prepared By</span><strong>@Branding.OfficeAcronym Office</strong></div>
                <div><span>Date Prepared</span><strong>@PhilippineTime.Now.ToString("MMM d, yyyy")</strong></div>
            </div>
            <div class="print-report-summary">
                <div><span>Transactions</span><strong>@MonthGroups.Count</strong></div>
                <div><span>Owners Served</span><strong>@MonthTxns.Select(t => t.OwnerName).Distinct().Count()</strong></div>
                <div><span>Heads Slaughtered</span><strong>@MonthTxns.Sum(t => t.NumberOfHeads)</strong></div>
                <div><span>Fees Collected</span><strong>&#8369;@MonthTxns.Sum(t => t.TotalAmount).ToString("N2")</strong></div>
            </div>
            @if (!MonthTxns.Any())
            {
                <p class="print-empty">No slaughter transactions recorded for @CurrentDate.ToString("MMMM yyyy").</p>
            }
            else
            {
                <div class="print-table-wrap">
                    <table class="print-status-table status-sheet">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Owner</th>
                                <th>Animal</th>
                                <th>Heads</th>
                                <th>Fee / Head</th>
                                <th>Total Fee</th>
                                <th>OR No.</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var grp in MonthGroups)
                            {
                                <tr>
                                    <td>@grp.Date.ToString("MMM d")</td>
                                    <td>@grp.Owner</td>
                                    <td>@(grp.Multi ? $"{AnimalLabel(grp.First)} +{grp.Lines.Count - 1}" : AnimalLabel(grp.First))</td>
                                    <td>@grp.TotalHeads</td>
                                    <td>@(grp.Multi ? "—" : "₱" + grp.First.RatePerHead.ToString("N2"))</td>
                                    <td>&#8369;@grp.TotalAmount.ToString("N2")</td>
                                    <td class="text-muted-cell">@(string.IsNullOrEmpty(grp.OrNumber) ? "—" : grp.OrNumber)</td>
                                </tr>
                                @if (grp.Multi)
                                {
                                    @foreach (var line in grp.Lines)
                                    {
                                        <tr class="print-detail-row">
                                            <td></td>
                                            <td></td>
                                            <td>↳ @AnimalLabel(line)</td>
                                            <td>@line.NumberOfHeads</td>
                                            <td>₱@line.RatePerHead.ToString("N2")</td>
                                            <td>₱@line.TotalAmount.ToString("N2")</td>
                                            <td></td>
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
            <div class="print-report-signatures">
                <div><span>Prepared by</span><strong>Administrative Staff</strong></div>
                <div><span>Reviewed by</span><strong>Head, @Branding.OfficeAcronym Office</strong></div>
                <div><span>Received by</span><strong>Authorized Representative</strong></div>
            </div>
        </section>
    </div>
}
else if (ShowHistory)
{
    <!-- ══ Phase 3: History ══ -->
    <div class="rpt-content print-document-content">
        <section class="print-report-sheet history-sheet">
            <header class="print-report-header">
                <img class="print-report-logo" src="@Branding.SealPath" alt="LGU Cantilan logo" />
                <div class="print-republic">Republic of the Philippines</div>
                <h2>@Branding.OfficeName</h2>
                <p>Municipality of @Branding.Municipality, @Branding.Province</p>
                <div class="print-report-title">Slaughterhouse — Collection History</div>
            </header>
            <div class="print-report-meta">
                <div><span>Facility</span><strong>Slaughterhouse</strong></div>
                <div><span>Year</span><strong>@CurrentDate.Year</strong></div>
                <div><span>Prepared By</span><strong>@Branding.OfficeAcronym Office</strong></div>
                <div><span>Date Prepared</span><strong>@PhilippineTime.Now.ToString("MMM d, yyyy")</strong></div>
            </div>

            <div class="print-section-block">
                <div class="print-section-heading">Monthly Collection — @CurrentDate.Year</div>
                <div class="print-table-wrap">
                    <table class="print-status-table history-table">
                        <thead>
                            <tr><th>Month</th><th>Transactions</th><th>Owners</th><th>Heads</th><th>Fees Collected</th></tr>
                        </thead>
                        <tbody>
                            @if (!HistoryMonthly.Any())
                            {
                                <tr><td colspan="5" class="history-empty">@(HistoryLoading ? "Loading…" : "No collection records for this year.")</td></tr>
                            }
                            @foreach (var row in HistoryMonthly)
                            {
                                <tr>
                                    <td>@row.Label</td>
                                    <td>@row.Receipts</td>
                                    <td>@row.OwnersServed</td>
                                    <td>@row.TotalHeads</td>
                                    <td>@(row.TotalCollected > 0 ? "₱" + row.TotalCollected.ToString("N2") : "—")</td>
                                </tr>
                            }
                        </tbody>
                        @if (HistoryMonthly.Any())
                        {
                            <tfoot>
                                <tr class="history-total-row">
                                    <td><strong>Total</strong></td>
                                    <td><strong>@HistoryMonthly.Sum(r => r.Receipts)</strong></td>
                                    <td>—</td>
                                    <td><strong>@HistoryMonthly.Sum(r => r.TotalHeads)</strong></td>
                                    <td><strong>₱@HistoryMonthly.Sum(r => r.TotalCollected).ToString("N2")</strong></td>
                                </tr>
                            </tfoot>
                        }
                    </table>
                </div>
            </div>

            <div class="print-section-block">
                <div class="print-section-heading">Yearly Collection Summary</div>
                <div class="print-table-wrap">
                    <table class="print-status-table history-table">
                        <thead>
                            <tr><th>Year</th><th>Transactions</th><th>Owners</th><th>Heads</th><th>Fees Collected</th></tr>
                        </thead>
                        <tbody>
                            @if (!HistoryYearly.Any())
                            {
                                <tr><td colspan="5" class="history-empty">@(HistoryLoading ? "Loading…" : "No yearly records.")</td></tr>
                            }
                            @foreach (var row in HistoryYearly)
                            {
                                <tr>
                                    <td><strong>@row.Label</strong></td>
                                    <td>@row.Receipts</td>
                                    <td>@row.OwnersServed</td>
                                    <td>@row.TotalHeads</td>
                                    <td>@(row.TotalCollected > 0 ? "₱" + row.TotalCollected.ToString("N2") : "—")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="print-report-signatures">
                <div><span>Prepared by</span><strong>Administrative Staff</strong></div>
                <div><span>Reviewed by</span><strong>Head, @Branding.OfficeAcronym Office</strong></div>
                <div><span>Received by</span><strong>Authorized Representative</strong></div>
            </div>
        </section>

        <!-- Owner & Animal Detail — interactive transparency lookup (hidden on print) -->
        <div class="slh-lookup">
            <div class="slh-lookup-head">
                <div>
                    <h3 class="slh-lookup-title">Owner &amp; Animal Detail — @CurrentDate.Year</h3>
                    <p class="slh-lookup-sub">Full per-owner breakdown for the year — who was served and which animals. Search any client.</p>
                </div>
                <button type="button" class="rpt-action-btn slh-lookup-btn" @onclick="ToggleYearDetail">
                    <svg aria-hidden="true" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    @(ShowYearDetail ? "Hide detail" : "Show owner detail")
                </button>
            </div>

            @if (ShowYearDetail)
            {
                <div class="slh-search">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" placeholder="Search owner / client name…" value="@OwnerSearch" @oninput="OnOwnerSearch" />
                    @if (!string.IsNullOrEmpty(OwnerSearch))
                    {
                        <button type="button" class="slh-search-clear" @onclick="@(() => OwnerSearch = string.Empty)" title="Clear">&times;</button>
                    }
                </div>

                @if (YearDetailLoading)
                {
                    <div class="delinq-empty">Loading the year's transactions…</div>
                }
                else if (!OwnerYearGroups.Any())
                {
                    <div class="delinq-empty">@(YearTxns.Any() ? $"No owners match \"{OwnerSearch}\"." : $"No transactions recorded for {CurrentDate.Year}.")</div>
                }
                else
                {
                    <div class="slh-lookup-summary">@OwnerYearGroups.Count owner@(OwnerYearGroups.Count != 1 ? "s" : "") · @OwnerYearGroups.Sum(o => o.Heads) head@(OwnerYearGroups.Sum(o => o.Heads) != 1 ? "s" : "") · &#8369;@OwnerYearGroups.Sum(o => o.Total).ToString("N2") collected</div>
                    <div class="slh-owner-list">
                        @foreach (var o in OwnerYearGroups)
                        {
                            var exp = IsOwnerExpanded(o.Owner);
                            <div class="slh-owner-card @(exp ? "open" : "")">
                                <button type="button" class="slh-owner-head" @onclick="() => ToggleOwner(o.Owner)">
                                    <svg class="slh-chevron @(exp ? "open" : "")" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" /></svg>
                                    <span class="slh-owner-name">@o.Owner</span>
                                    <span class="slh-owner-meta">@o.Receipts receipt@(o.Receipts != 1 ? "s" : "") · @o.Heads head@(o.Heads != 1 ? "s" : "")</span>
                                    <span class="slh-owner-total">&#8369;@o.Total.ToString("N2")</span>
                                </button>
                                @if (exp)
                                {
                                    <table class="slh-owner-table">
                                        <thead><tr><th>Date</th><th>Animal</th><th>Heads</th><th>Fee / Head</th><th>Total</th><th>OR No.</th></tr></thead>
                                        <tbody>
                                            @foreach (var line in o.Lines)
                                            {
                                                <tr>
                                                    <td class="text-muted">@line.TransactionDate.ToString("MMM d")</td>
                                                    <td><span class="slh-badge" style="background:@AnimalColor(line.AnimalType);">@AnimalLabel(line)</span></td>
                                                    <td>@line.NumberOfHeads</td>
                                                    <td>₱@line.RatePerHead.ToString("N0")</td>
                                                    <td class="slh-total">₱@line.TotalAmount.ToString("N2")</td>
                                                    <td class="text-muted">@(string.IsNullOrEmpty(line.ORNumber) ? "—" : line.ORNumber)</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    </div>
}
else
{
    <!-- ══ Phase 1: Monthly / Yearly ══ -->
    <div class="rpt-kpi-strip">
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-green"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 4h7a4 4 0 0 1 0 8H6z" /><line x1="4" y1="9" x2="16" y2="9" /><line x1="4" y1="13" x2="16" y2="13" /><line x1="6" y1="4" x2="6" y2="20" /></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Fees Collected</div>
                <div class="kpi-value">&#8369;@TotalCollected.ToString("N2")</div>
                <div class="kpi-change">@RevenueGrowthText</div>
            </div>
        </div>
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-gold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 2.5c0 1.5-1.5 5-1.5 5h-2S9.5 4 9.5 2.5a2.5 2.5 0 015 0z"/><path d="M12 7.5V22"/><path d="M5 12h14"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Total Heads Slaughtered</div>
                <div class="kpi-value">@TotalHeads</div>
                <div class="kpi-change">@ActivePeriod.ToLower() total</div>
            </div>
        </div>
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-neutral"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Owners Served</div>
                <div class="kpi-value">@OwnersServed</div>
                <div class="kpi-change">this @ActivePeriod.ToLower()</div>
            </div>
        </div>
        <div class="rpt-kpi-card">
            <div class="kpi-icon-wrap kpi-icon-gold"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></div>
            <div class="kpi-body">
                <div class="kpi-label">Transactions</div>
                <div class="kpi-value">@TransactionCount</div>
                <div class="kpi-change">@ActivePeriod.ToLower() total</div>
            </div>
        </div>
    </div>

    <div class="rpt-content">

        <!-- Charts Row -->
        <div class="rpt-charts-row">
            <div class="rpt-chart-card rpt-chart-wide">
                <div class="chart-header">
                    <div class="chart-header-left">
                        <h3 class="chart-title">Fee Collection Trend</h3>
                        <p class="chart-subtitle">@(ActivePeriod switch { "Yearly" => "Collected fees by year", "Weekly" => "Collected fees by day", _ => "Collected fees by month" })</p>
                    </div>
                    <div class="chart-legend">
                        <div class="legend-item"><span class="legend-dot" style="background:#2d7a5f"></span><span class="legend-label">Collected</span></div>
                        <div class="legend-item"><span class="legend-dot" style="background:#c8a84b"></span><span class="legend-label">Current Period</span></div>
                    </div>
                </div>
                <CollectionTrendChart Trend="RevenueTrend" RentLabel="Collected" EmptyPeriodLabel="@GetPeriodLabel()" />
            </div>

            <!-- Animal Volume donut -->
            <div class="rpt-chart-card rpt-chart-narrow rpt-status-card">
                <div class="chart-header">
                    <div class="chart-header-left">
                        <h3 class="chart-title">Animal Volume</h3>
                        <p class="chart-subtitle">Heads slaughtered by animal type</p>
                    </div>
                </div>
                <div class="rpt-donut-wrap">
                    <div class="rpt-donut-container">
                        <svg class="rpt-donut-svg" viewBox="0 0 120 120">
                            @{ var animalSegs = new (int Count, string Color)[] { (HogHeads, "#2d7a5f"), (CarabaoHeads, "#2e7bb5"), (CowHeads, "#b87333"), (OtherHeads, "#8b5a3c") }; }
                            <defs>
                                @foreach (var c in animalSegs.Select(s => s.Color).Distinct())
                                {
                                    <linearGradient id="@SlhGradId(c)" x1="0" y1="0" x2="0" y2="1">
                                        <stop offset="0%" stop-color="@c" /><stop offset="100%" stop-color="@Darken(c)" />
                                    </linearGradient>
                                }
                                <radialGradient id="slh-donut-hole" cx="50%" cy="40%" r="62%">
                                    <stop offset="0%" stop-color="#ffffff" /><stop offset="100%" stop-color="#eef2f6" />
                                </radialGradient>
                                <filter id="slh-donut-depth" x="-30%" y="-30%" width="160%" height="160%">
                                    <feDropShadow dx="0" dy="5" stdDeviation="4" flood-color="#0d2137" flood-opacity="0.18" />
                                </filter>
                            </defs>
                            <circle cx="60" cy="60" r="46" fill="none" stroke="#eef2f6" stroke-width="18" />
                            @{ var arcs = BuildDonutArcs(animalSegs.Select(s => (s.Count, $"url(#{SlhGradId(s.Color)})")).ToArray(), 46, 60, 60); }
                            <g filter="url(#slh-donut-depth)">
                                @foreach (var arc in arcs)
                                {
                                    <path d="@arc.D" fill="none" stroke="@arc.Color" stroke-width="18" stroke-linecap="butt" class="donut-segment" />
                                }
                            </g>
                            <circle cx="60" cy="60" r="35" fill="url(#slh-donut-hole)" />
                            <circle cx="60" cy="60" r="35" fill="none" stroke="rgba(13,33,55,0.07)" stroke-width="1" />
                            <text x="60" y="56" class="donut-center-val">@TotalHeads</text>
                            <text x="60" y="70" class="donut-center-lbl">HEADS</text>
                        </svg>
                    </div>
                    <div class="rpt-donut-legend">
                        <div class="donut-leg-item"><div class="donut-leg-left"><span class="donut-leg-dot" style="background:linear-gradient(180deg,#2d7a5f 0%,#1f5341 100%)"></span><span class="donut-leg-label">Hog</span></div><strong class="donut-leg-value">@HogHeads</strong></div>
                        <div class="donut-leg-item"><div class="donut-leg-left"><span class="donut-leg-dot" style="background:linear-gradient(180deg,#2e7bb5 0%,#1f537b 100%)"></span><span class="donut-leg-label">Carabao</span></div><strong class="donut-leg-value">@CarabaoHeads</strong></div>
                        <div class="donut-leg-item"><div class="donut-leg-left"><span class="donut-leg-dot" style="background:linear-gradient(180deg,#b87333 0%,#7d4e22 100%)"></span><span class="donut-leg-label">Cow</span></div><strong class="donut-leg-value">@CowHeads</strong></div>
                        <div class="donut-leg-item"><div class="donut-leg-left"><span class="donut-leg-dot" style="background:linear-gradient(180deg,#8b5a3c 0%,#5e3d28 100%)"></span><span class="donut-leg-label">Other</span></div><strong class="donut-leg-value">@OtherHeads</strong></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Audit Breakdown -->
        <div class="rpt-section-heading"><span class="rpt-section-rule"></span><h2>Audit Breakdown</h2></div>

        <div class="rpt-audit-row">
            <!-- Combined animal breakdown (revenue + heads) -->
            <div class="audit-card slh-breakdown-card">
                <div class="audit-card-head">
                    <span>Animal Breakdown</span>
                    <small class="audit-subtitle">Revenue &amp; heads by animal type</small>
                </div>
                <div class="slh-animal-grid">
                    @foreach (var a in AnimalBreakdown)
                    {
                        var revPct = TotalCollected > 0 ? Math.Min(100, (int)Math.Round(a.Revenue / TotalCollected * 100)) : 0;
                        var headPct = TotalHeads > 0 ? Math.Min(100, (int)Math.Round((double)a.Heads / TotalHeads * 100)) : 0;
                        <div class="slh-a-card">
                            <div class="slh-a-header">
                                <span class="slh-a-dot" style="background:@a.Color"></span>
                                <span class="slh-a-name">@a.Type</span>
                                <span class="slh-a-pct" style="color:@a.Color">@revPct%</span>
                            </div>
                            <div class="slh-a-meter"><div class="slh-a-fill" style="width:@revPct%;background:@a.Color"></div></div>
                            <div class="slh-a-values">
                                <div class="slh-a-stat"><span class="slh-a-val">&#8369;@a.Revenue.ToString("N0")</span><span class="slh-a-key">revenue</span></div>
                                <div class="slh-a-divider"></div>
                                <div class="slh-a-stat"><span class="slh-a-val">@a.Heads</span><span class="slh-a-key">head@(a.Heads != 1 ? "s" : "")</span></div>
                            </div>
                        </div>
                    }
                    @if (!AnimalBreakdown.Any())
                    {
                        <div class="delinq-empty">No transactions for @GetPeriodLabel().</div>
                    }
                </div>
                <div class="slh-breakdown-footer">
                    <div class="slh-bf-stats">
                        <span><strong>@TotalHeads</strong> head@(TotalHeads != 1 ? "s" : "")</span>
                        <span class="slh-bf-sep">·</span>
                        <span><strong>@TransactionCount</strong> receipt@(TransactionCount != 1 ? "s" : "")</span>
                        <span class="slh-bf-sep">·</span>
                        <span><strong>&#8369;@AvgPerHead.ToString("N2")</strong> avg / head</span>
                    </div>
                    <div class="slh-bf-note">@OwnersServed owner@(OwnersServed != 1 ? "s" : "") served · @AnimalBreakdown.Count() animal type@(AnimalBreakdown.Count() != 1 ? "s" : "") · @GetPeriodLabel()</div>
                </div>
            </div>

            <!-- Transaction / summary log beside the breakdown -->
            <div class="audit-card slh-log-card">
                <div class="audit-card-head">
                    <span>@(ActivePeriod == "Yearly" ? $"Monthly Summary — {CurrentDate.Year}" : $"Transaction Log — {GetPeriodLabel()}")</span>
                </div>
                <div class="slh-log-scroll">

        @if (ActivePeriod == "Yearly")
        {
            <!-- Yearly: monthly summary table -->
            <div class="rpt-compliance-table-wrap">
                <table class="rpt-compliance-table">
                    <thead><tr><th>Month</th><th>Transactions</th><th>Owners</th><th>Heads</th><th>Fees Collected</th></tr></thead>
                    <tbody>
                        @foreach (var row in HistoryMonthly)
                        {
                            <tr>
                                <td class="stall-no">@row.Label</td>
                                <td>@row.Receipts</td>
                                <td>@row.OwnersServed</td>
                                <td>@row.TotalHeads</td>
                                <td>@(row.TotalCollected > 0 ? "₱" + row.TotalCollected.ToString("N2") : "—")</td>
                            </tr>
                        }
                        @if (!HistoryMonthly.Any())
                        {
                            <tr><td colspan="5" class="delinq-empty">No records for @CurrentDate.Year.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <!-- Monthly: transaction log -->
            <div class="rpt-compliance-table-wrap">
                <table class="rpt-compliance-table">
                    <thead><tr><th>Date</th><th>Owner</th><th>Animal Type</th><th>Heads</th><th>Fee / Head</th><th>Total Fee</th><th>OR Number</th></tr></thead>
                    <tbody>
                        @foreach (var grp in MonthGroups)
                        {
                            var expanded = IsGroupExpanded(grp.GroupKey);
                            <tr class="@(grp.Multi ? "slh-group-row" : "")">
                                <td class="text-muted">@grp.Date.ToString("MMM d")</td>
                                <td>@grp.Owner</td>
                                <td>
                                    @if (grp.Multi)
                                    {
                                        <button type="button" class="slh-animal-group" @onclick="() => ToggleGroup(grp.GroupKey)" title="Show animals in this transaction">
                                            <span class="slh-badge" style="background:@AnimalColor(grp.First.AnimalType);">@AnimalLabel(grp.First)</span>
                                            <span class="slh-more-badge">+@(grp.Lines.Count - 1)</span>
                                            <svg class="slh-chevron @(expanded ? "open" : "")" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" /></svg>
                                        </button>
                                    }
                                    else
                                    {
                                        <span class="slh-badge" style="background:@AnimalColor(grp.First.AnimalType);">@AnimalLabel(grp.First)</span>
                                    }
                                </td>
                                <td class="stall-no">@grp.TotalHeads</td>
                                <td>@(grp.Multi ? "—" : "₱" + grp.First.RatePerHead.ToString("N0"))</td>
                                <td class="slh-total">&#8369;@grp.TotalAmount.ToString("N2")</td>
                                <td class="text-muted">@(string.IsNullOrEmpty(grp.OrNumber) ? "—" : grp.OrNumber)</td>
                            </tr>
                            @if (grp.Multi && expanded)
                            {
                                @foreach (var line in grp.Lines)
                                {
                                    <tr class="slh-detail-row">
                                        <td></td>
                                        <td></td>
                                        <td><span class="slh-detail-animal"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>@AnimalLabel(line)</span></td>
                                        <td>@line.NumberOfHeads</td>
                                        <td>₱@line.RatePerHead.ToString("N0")</td>
                                        <td>₱@line.TotalAmount.ToString("N2")</td>
                                        <td></td>
                                    </tr>
                                }
                            }
                        }
                        @if (!MonthTxns.Any())
                        {
                            <tr><td colspan="7" class="delinq-empty">No transactions for @GetPeriodLabel().</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        }
                </div>
            </div>
        </div>

    </div><!-- end rpt-content -->
}

@code {

    // ── Period / view state ───────────────────────────────────────
    string ActivePeriod = "Monthly";
    bool ShowPrintReport = false;
    bool ShowHistory = false;
    DateTime CurrentDate = PhilippineTime.Now;

    private SlaughterOverviewDto? Overview;       // current month
    private SlaughterOverviewDto? PrevOverview;   // previous month (growth)
    private List<SlaughterTransactionDto> MonthTxns = new();
    private SlaughterHistoryDto? Hist;            // yearly + history
    private bool HistoryLoading;

    // Trailing 6-month collected totals for the Monthly trend chart (oldest → newest).
    private List<(int Year, int Month, decimal Collected)> _trendMonthly = new();

    [PersistentState(AllowUpdates = true)]
    public SlhReportsPageState? CachedReport { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (TryApplyCachedReport())
            return;

        await LoadAsync();
    }

    async Task LoadAsync()
    {
        if (ShowHistory)
        {
            HistoryLoading = true;
            // Reset the year drill-down so navigating years doesn't show stale owner detail.
            ShowYearDetail = false;
            YearTxns = new();
            _expandedOwners.Clear();
            OwnerSearch = string.Empty;
            var h = await SlaughterApi.GetHistoryAsync(CurrentDate.Year);
            Hist = h.IsSuccess ? h.Value : null;
            HistoryLoading = false;
            return;
        }

        if (ActivePeriod == "Yearly" && !ShowPrintReport)
        {
            var h = await SlaughterApi.GetHistoryAsync(CurrentDate.Year);
            Hist = h.IsSuccess ? h.Value : null;
            return;
        }

        // Monthly (Phase 1) and the Status Report both need the month's overview + transactions.
        var ovr = await SlaughterApi.GetOverviewAsync(CurrentDate.Year, CurrentDate.Month);
        Overview = ovr.IsSuccess ? ovr.Value : null;

        var prevDate = CurrentDate.AddMonths(-1);
        var prev = await SlaughterApi.GetOverviewAsync(prevDate.Year, prevDate.Month);
        PrevOverview = prev.IsSuccess ? prev.Value : null;

        var tx = await SlaughterApi.GetTransactionsAsync(CurrentDate.Year, CurrentDate.Month);
        var txns = tx.IsSuccess && tx.Value != null ? tx.Value.ToList() : new();

        // Weekly view: narrow the month's transactions to the selected week-of-month (mirrors NPM).
        if (ActivePeriod == "Weekly" && !ShowPrintReport)
        {
            var (fromDay, toDay) = WeekDayRange();
            txns = txns.Where(t => t.TransactionDate.Day >= fromDay && t.TransactionDate.Day <= toDay).ToList();
        }
        MonthTxns = txns;

        // The Monthly view's trend is a trailing 6-month window (like NPM), sourced from history.
        if (ActivePeriod == "Monthly" && !ShowPrintReport)
            _trendMonthly = await BuildMonthlyTrendHistoryAsync();

        CachedReport = new SlhReportsPageState(
            ActivePeriod,
            ShowPrintReport,
            ShowHistory,
            CurrentDate.Year,
            CurrentDate.Month,
            WeekIndex,
            Overview,
            PrevOverview,
            MonthTxns.ToList(),
            Hist,
            _trendMonthly.Select(t => new ReportTrendState(t.Year, t.Month, t.Collected)).ToList());
    }

    private bool TryApplyCachedReport()
    {
        if (CachedReport is not { } state
            || state.ActivePeriod != ActivePeriod
            || state.ShowPrintReport != ShowPrintReport
            || state.ShowHistory != ShowHistory
            || state.Year != CurrentDate.Year
            || state.Month != CurrentDate.Month
            || state.WeekIndex != WeekIndex)
        {
            return false;
        }

        Overview = state.Overview;
        PrevOverview = state.PrevOverview;
        MonthTxns = state.MonthTransactions.ToList();
        Hist = state.History;
        _trendMonthly = state.MonthlyTrend.Select(t => (t.Year, t.Month, t.Collected)).ToList();
        return true;
    }

    // Trailing 6-month collected totals (oldest → newest) ending at the selected month, from history.
    async Task<List<(int Year, int Month, decimal Collected)>> BuildMonthlyTrendHistoryAsync()
    {
        var anchor = new DateTime(CurrentDate.Year, CurrentDate.Month, 1);
        var targets = Enumerable.Range(0, 6).Select(i => anchor.AddMonths(i - 5)).ToList();

        var collectedByMonth = new Dictionary<(int Year, int Month), decimal>();
        foreach (var year in targets.Select(d => d.Year).Distinct())
        {
            var h = await SlaughterApi.GetHistoryAsync(year);
            if (h.IsSuccess && h.Value is not null)
                foreach (var m in h.Value.Monthly.Where(m => m.Month.HasValue))
                    collectedByMonth[(m.Year, m.Month!.Value)] = m.TotalCollected;
        }

        return targets
            .Select(d => (d.Year, d.Month, collectedByMonth.TryGetValue((d.Year, d.Month), out var c) ? c : 0m))
            .ToList();
    }

    async Task SetPeriod(string p) { ShowPrintReport = false; ShowHistory = false; ActivePeriod = p; await LoadAsync(); }
    async Task ShowPrintReportView() { ShowPrintReport = true; ShowHistory = false; await LoadAsync(); }
    async Task ShowHistoryView() { ShowHistory = true; ShowPrintReport = false; await LoadAsync(); }
    async Task PrintPage() => await JS.InvokeVoidAsync("print");

    async Task PrevPeriod()
    {
        if (ShowHistory) { CurrentDate = CurrentDate.AddYears(-1); await LoadAsync(); return; }
        if (ShowPrintReport) { CurrentDate = CurrentDate.AddMonths(-1); await LoadAsync(); return; }
        CurrentDate = ActivePeriod switch
        {
            "Weekly" => CurrentDate.AddDays(-7),
            "Yearly" => CurrentDate.AddYears(-1),
            _        => CurrentDate.AddMonths(-1)
        };
        await LoadAsync();
    }
    async Task NextPeriod()
    {
        if (ShowHistory) { CurrentDate = CurrentDate.AddYears(1); await LoadAsync(); return; }
        if (ShowPrintReport) { CurrentDate = CurrentDate.AddMonths(1); await LoadAsync(); return; }
        CurrentDate = ActivePeriod switch
        {
            "Weekly" => CurrentDate.AddDays(7),
            "Yearly" => CurrentDate.AddYears(1),
            _        => CurrentDate.AddMonths(1)
        };
        await LoadAsync();
    }

    string GetPeriodLabel() => ActivePeriod switch
    {
        "Weekly" => $"Week of {WeekStartDate:MMM d}\u2013{WeekEndDate:%d}, {WeekStartDate:yyyy}",
        "Yearly" => CurrentDate.ToString("yyyy"),
        _        => CurrentDate.ToString("MMMM yyyy")
    };

    // Week-of-month model (days 1-7, 8-14, …) — mirrors NPM so a week stays within one month.
    int WeekIndex => ((CurrentDate.Day - 1) / 7) + 1;
    (int FromDay, int ToDay) WeekDayRange()
    {
        var daysInMonth = DateTime.DaysInMonth(CurrentDate.Year, CurrentDate.Month);
        return ((WeekIndex - 1) * 7 + 1, Math.Min(WeekIndex * 7, daysInMonth));
    }
    DateTime WeekStartDate => new(CurrentDate.Year, CurrentDate.Month, WeekDayRange().FromDay);
    DateTime WeekEndDate => new(CurrentDate.Year, CurrentDate.Month, WeekDayRange().ToDay);
    string PrintReportPeriodLabel => $"Status Report — {CurrentDate:MMMM yyyy}";
    string HistoryPeriodLabel => $"History — {CurrentDate.Year}";

    async Task PickPeriod((int Year, int Month) p)
    {
        CurrentDate = new DateTime(p.Year, p.Month, 1);
        await LoadAsync();
    }
    async Task JumpToCurrent()
    {
        CurrentDate = PhilippineTime.Now;
        await LoadAsync();
    }

    bool IsYearly => ActivePeriod == "Yearly";
    bool IsWeekly => ActivePeriod == "Weekly";

    // The aggregated row for the selected year (yearly KPIs/donut/animal breakdown).
    private SlaughterPeriodSummaryDto? YearRow => Hist?.Yearly.FirstOrDefault(y => y.Year == CurrentDate.Year);

    // ── KPI values (period-aware) ─────────────────────────────────
    // Monthly KPIs come from the server Overview; the Weekly view computes them from the
    // week-filtered transaction list (Overview is month-scoped and can't answer a single week).
    decimal TotalCollected => IsYearly ? (YearRow?.TotalCollected ?? 0m) : IsWeekly ? MonthTxns.Sum(t => t.TotalAmount) : (Overview?.TotalCollected ?? 0m);
    int     TotalHeads      => IsYearly ? (YearRow?.TotalHeads ?? 0) : IsWeekly ? MonthTxns.Sum(t => t.NumberOfHeads) : (Overview?.TotalHeads ?? 0);
    int     TransactionCount => IsYearly ? (YearRow?.Receipts ?? 0) : MonthGroups.Count;
    int     OwnersServed    => IsYearly ? (YearRow?.OwnersServed ?? 0) : MonthTxns.Select(t => t.OwnerName).Distinct().Count();
    int     HogHeads        => IsYearly ? (YearRow?.HogHeads ?? 0) : IsWeekly ? MonthTxns.Where(t => t.AnimalType == AnimalType.Hog).Sum(t => t.NumberOfHeads) : (Overview?.HogCount ?? 0);
    int     CarabaoHeads    => IsYearly ? (YearRow?.CarabaoHeads ?? 0) : IsWeekly ? MonthTxns.Where(t => t.AnimalType == AnimalType.Carabao).Sum(t => t.NumberOfHeads) : (Overview?.CarabaoCount ?? 0);
    int     CowHeads        => IsYearly ? (YearRow?.CowHeads ?? 0) : IsWeekly ? MonthTxns.Where(t => t.AnimalType == AnimalType.Cow).Sum(t => t.NumberOfHeads) : (Overview?.CowCount ?? 0);
    int     OtherHeads      => IsYearly ? (YearRow?.OtherHeads ?? 0) : IsWeekly ? MonthTxns.Where(t => t.AnimalType == AnimalType.Other).Sum(t => t.NumberOfHeads) : (Overview?.OthersCount ?? 0);
    decimal AvgPerHead      => TotalHeads > 0 ? TotalCollected / TotalHeads : 0m;

    string RevenueGrowthText
    {
        get
        {
            if (IsYearly) return $"{CurrentDate.Year} total";
            if (IsWeekly) return "weekly total";
            var prev = PrevOverview?.TotalCollected ?? 0m;
            var growth = prev > 0 ? (TotalCollected - prev) / prev * 100 : 0m;
            return $"{growth:+0.0;-0.0;0}% vs previous month";
        }
    }

    // ── Animal breakdown (revenue + heads), period-aware ──────────
    record AnimalRow(string Type, decimal Revenue, int Heads, string Color);
    IEnumerable<AnimalRow> AnimalBreakdown
    {
        get
        {
            if (IsYearly)
            {
                var y = YearRow;
                return new[]
                {
                    new AnimalRow("Hog", y?.HogRevenue ?? 0m, y?.HogHeads ?? 0, AnimalColor(AnimalType.Hog)),
                    new AnimalRow("Carabao", y?.CarabaoRevenue ?? 0m, y?.CarabaoHeads ?? 0, AnimalColor(AnimalType.Carabao)),
                    new AnimalRow("Cow", y?.CowRevenue ?? 0m, y?.CowHeads ?? 0, AnimalColor(AnimalType.Cow)),
                    new AnimalRow("Other", y?.OtherRevenue ?? 0m, y?.OtherHeads ?? 0, AnimalColor(AnimalType.Other)),
                }.Where(a => a.Revenue > 0 || a.Heads > 0).OrderByDescending(a => a.Revenue).ToList();
            }

            return MonthTxns
                .GroupBy(t => AnimalName(t.AnimalType))
                .Select(g => new AnimalRow(g.Key, g.Sum(t => t.TotalAmount), g.Sum(t => t.NumberOfHeads), AnimalColor(AnimalEnumFromName(g.Key))))
                .OrderByDescending(a => a.Revenue)
                .ToList();
        }
    }

    // Specific custom animal names within "Other" (period-aware).
    IReadOnlyList<CustomAnimalTallyDto> OtherAnimalsList
    {
        get
        {
            if (IsYearly) return YearRow?.OtherAnimals ?? new List<CustomAnimalTallyDto>();
            return MonthTxns
                .Where(t => t.AnimalType == AnimalType.Other)
                .GroupBy(t => string.IsNullOrWhiteSpace(t.CustomAnimalType) ? "Other" : t.CustomAnimalType!.Trim())
                .Select(g => new CustomAnimalTallyDto(g.Key, g.Sum(t => t.NumberOfHeads), g.Sum(t => t.TotalAmount)))
                .OrderByDescending(a => a.Revenue)
                .ToList();
        }
    }

    // ── Trend (daily for Monthly, monthly for Yearly) ─────────────
    IReadOnlyList<RevenueTrendDto> RevenueTrend
    {
        get
        {
            var today = PhilippineTime.Today;
            List<(string Label, decimal Amount, bool IsCurrent)> pts;
            if (IsYearly)
            {
                // Yearly: trailing years (rolling last-5-years window), like NPM.
                pts = (Hist?.Yearly ?? new List<SlaughterPeriodSummaryDto>())
                    .OrderBy(y => y.Year)
                    .Select(y => (
                        Label: y.Year.ToString(),
                        Amount: y.TotalCollected,
                        IsCurrent: y.Year == today.Year))
                    .ToList();
            }
            else if (IsWeekly)
            {
                // Weekly: every day of the selected week, zero-filled into a clean 7-day strip.
                var (fromDay, toDay) = WeekDayRange();
                var feeByDay = MonthTxns
                    .GroupBy(t => t.TransactionDate.Day)
                    .ToDictionary(g => g.Key, g => g.Sum(t => t.TotalAmount));
                pts = new List<(string Label, decimal Amount, bool IsCurrent)>();
                for (var day = fromDay; day <= toDay; day++)
                {
                    var date = new DateTime(CurrentDate.Year, CurrentDate.Month, day);
                    pts.Add((
                        date.ToString("MMM d"),
                        feeByDay.TryGetValue(day, out var amt) ? amt : 0m,
                        DateOnly.FromDateTime(date) == today));
                }
            }
            else
            {
                // Monthly: trailing 6 months ending at the selected month (from history), like NPM.
                pts = _trendMonthly
                    .Select(m => (
                        Label: new DateOnly(m.Year, m.Month, 1).ToString("MMM yyyy"),
                        Amount: m.Collected,
                        IsCurrent: m.Year == today.Year && m.Month == today.Month))
                    .ToList();
            }
            // Map to the shared chart's DTO (single-segment: SLH has no fish fee).
            return pts
                .Select(x => new RevenueTrendDto(x.Label, x.Amount, ExpectedRevenue: x.Amount, IsCurrentPeriod: x.IsCurrent))
                .ToList();
        }
    }

    // ── History rows (Phase 3 + yearly monthly-summary) ───────────
    IReadOnlyList<SlaughterPeriodSummaryDto> HistoryMonthly => Hist?.Monthly ?? new List<SlaughterPeriodSummaryDto>();
    IReadOnlyList<SlaughterPeriodSummaryDto> HistoryYearly => Hist?.Yearly ?? new List<SlaughterPeriodSummaryDto>();

    // ── History drill-down: who + what animals for the selected year (transparency lookup) ──
    bool ShowYearDetail;
    bool YearDetailLoading;
    string OwnerSearch = string.Empty;
    private List<SlaughterTransactionDto> YearTxns = new();
    private readonly HashSet<string> _expandedOwners = new();

    bool IsOwnerExpanded(string owner) => _expandedOwners.Contains(owner);
    void ToggleOwner(string owner) { if (!_expandedOwners.Add(owner)) _expandedOwners.Remove(owner); }
    void OnOwnerSearch(ChangeEventArgs e) => OwnerSearch = e.Value?.ToString() ?? string.Empty;

    async Task ToggleYearDetail()
    {
        ShowYearDetail = !ShowYearDetail;
        if (ShowYearDetail && YearTxns.Count == 0) await LoadYearDetailAsync();
    }

    async Task LoadYearDetailAsync()
    {
        YearDetailLoading = true;
        var now = PhilippineTime.Now;
        int maxMonth = CurrentDate.Year < now.Year ? 12 : CurrentDate.Year == now.Year ? now.Month : 0;

        // Load every month of the year in parallel, then aggregate client-side (full data, no cap).
        var tasks = Enumerable.Range(1, maxMonth)
            .Select(m => SlaughterApi.GetTransactionsAsync(CurrentDate.Year, m))
            .ToList();
        var results = await Task.WhenAll(tasks);
        YearTxns = results.Where(r => r.IsSuccess && r.Value != null).SelectMany(r => r.Value!).ToList();
        YearDetailLoading = false;
    }

    record OwnerYearGroup(string Owner, int Receipts, int Heads, decimal Total, List<SlaughterTransactionDto> Lines);
    IReadOnlyList<OwnerYearGroup> OwnerYearGroups => YearTxns
        .Where(t => string.IsNullOrWhiteSpace(OwnerSearch) || t.OwnerName.Contains(OwnerSearch.Trim(), StringComparison.OrdinalIgnoreCase))
        .GroupBy(t => t.OwnerName)
        .Select(g => new OwnerYearGroup(
            g.Key,
            g.Select(x => !string.IsNullOrEmpty(x.ORNumber) ? "OR:" + x.ORNumber : $"NX:{x.TransactionDate:yyyyMMdd}").Distinct().Count(),
            g.Sum(x => x.NumberOfHeads),
            g.Sum(x => x.TotalAmount),
            g.OrderBy(x => x.TransactionDate).ToList()))
        .OrderBy(g => g.Owner)
        .ToList();

    // ── Transaction grouping by OR (one OR = one transaction/receipt, possibly several animals) ──
    private readonly HashSet<string> _expandedGroups = new();
    bool IsGroupExpanded(string key) => _expandedGroups.Contains(key);
    void ToggleGroup(string key) { if (!_expandedGroups.Add(key)) _expandedGroups.Remove(key); }

    record TxnGroup(string GroupKey, string Owner, DateOnly Date, string OrNumber, List<SlaughterTransactionDto> Lines)
    {
        public bool Multi => Lines.Count > 1;
        public SlaughterTransactionDto First => Lines[0];
        public int TotalHeads => Lines.Sum(l => l.NumberOfHeads);
        public decimal TotalAmount => Lines.Sum(l => l.TotalAmount);
    }

    // OR numbers are globally unique, so they are a safe group key; transactions without an OR
    // fall back to a per-owner-per-day key so they are not merged with unrelated records.
    IReadOnlyList<TxnGroup> MonthGroups => MonthTxns
        .GroupBy(t => !string.IsNullOrEmpty(t.ORNumber)
            ? "OR:" + t.ORNumber
            : $"NX:{t.OwnerName}:{t.TransactionDate:yyyyMMdd}")
        .Select(g =>
        {
            var lines = g.OrderBy(x => x.AnimalType).ThenBy(x => x.CustomAnimalType).ToList();
            return new TxnGroup(g.Key, lines[0].OwnerName, g.Max(x => x.TransactionDate), lines[0].ORNumber ?? "", lines);
        })
        .OrderBy(g => g.Date)
        .ToList();

    // ── Animal helpers ────────────────────────────────────────────
    static string AnimalName(AnimalType t) => t switch { AnimalType.Hog => "Hog", AnimalType.Carabao => "Carabao", AnimalType.Cow => "Cow", _ => "Other" };
    static AnimalType AnimalEnumFromName(string n) => n switch { "Hog" => AnimalType.Hog, "Carabao" => AnimalType.Carabao, "Cow" => AnimalType.Cow, _ => AnimalType.Other };
    static string AnimalColor(AnimalType t) => t switch { AnimalType.Hog => "#2d7a5f", AnimalType.Carabao => "#2e7bb5", AnimalType.Cow => "#b87333", _ => "#8b5a3c" };
    static string AnimalLabel(SlaughterTransactionDto t) => t.AnimalType == AnimalType.Other && !string.IsNullOrEmpty(t.CustomAnimalType) ? t.CustomAnimalType : AnimalName(t.AnimalType);

    public sealed record SlhReportsPageState(
        string ActivePeriod,
        bool ShowPrintReport,
        bool ShowHistory,
        int Year,
        int Month,
        int WeekIndex,
        SlaughterOverviewDto? Overview,
        SlaughterOverviewDto? PrevOverview,
        List<SlaughterTransactionDto> MonthTransactions,
        SlaughterHistoryDto? History,
        List<ReportTrendState> MonthlyTrend);

    public sealed record ReportTrendState(int Year, int Month, decimal Collected);

    // ── Donut arc builder ─────────────────────────────────────────
    // Per-segment gradient id + darker bottom stop (matches NPM's donut depth).
    static string SlhGradId(string color) => "slhg-" + color.TrimStart('#');
    static string Darken(string hex, double f = 0.68)
    {
        hex = hex.TrimStart('#');
        if (hex.Length != 6) return "#" + hex;
        var r = (int)(Convert.ToInt32(hex.Substring(0, 2), 16) * f);
        var g = (int)(Convert.ToInt32(hex.Substring(2, 2), 16) * f);
        var b = (int)(Convert.ToInt32(hex.Substring(4, 2), 16) * f);
        return $"#{r:X2}{g:X2}{b:X2}";
    }

    record ArcSegment(string D, string Color);
    static IEnumerable<ArcSegment> BuildDonutArcs((int Count, string Color)[] segments, double r, double cx, double cy)
    {
        int total = segments.Sum(s => s.Count);
        if (total == 0) yield break;
        double start = -Math.PI / 2;
        foreach (var (count, color) in segments)
        {
            if (count == 0) continue;
            double sweep = 2 * Math.PI * count / total;
            double end = start + Math.Min(sweep, 2 * Math.PI - 0.0001);
            double x1 = cx + r * Math.Cos(start), y1 = cy + r * Math.Sin(start);
            double x2 = cx + r * Math.Cos(end),   y2 = cy + r * Math.Sin(end);
            yield return new ArcSegment($"M {x1:F3} {y1:F3} A {r} {r} 0 {(sweep > Math.PI ? 1 : 0)} 1 {x2:F3} {y2:F3}", color);
            start = end;
        }
    }
}
