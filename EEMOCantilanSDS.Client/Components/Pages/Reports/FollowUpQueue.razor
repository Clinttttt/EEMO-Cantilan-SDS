                </button>
            </div>
        </div>
    </div>
}

@code {
    private FollowUpQueueDto? _data;
    private bool _loading = true;

    [PersistentState(AllowUpdates = true)]
    public FollowUpQueuePageState? CachedFollowUpQueue { get; set; }

    private string _filter = "all";
    private string _search = "";
    private FacilityCode? _facility;   // null = all facilities

    // ── Manual hide (admin-dismissed "Needs immediate action" items) ──────────────
    // The Head/Admin can dismiss items they don't want escalated here (e.g. an expired contract that
    // is already handled on the Closed Accounts page). Nothing is auto-hidden. Hidden keys persist
    // per-browser via localStorage; a toggle reveals them. Scope: Needs immediate action only.
    private const int SecImmediate = 1;
    private const string HiddenStorageKey = "eemo.followup.hidden";
    private HashSet<string> _hidden = new();

    private static string HideKey(FollowUpItemDto i) => $"{i.Facility}|{i.ReasonKind}|{i.Identifier}|{i.Period}";

    // Count of still-visible "Contract expired" items in Needs immediate action (expired contracts
    // are ReasonKind "contract" in section 1; expiring-soon ones live in section 2).
    private int ImmediateExpiredContractCount =>
        Filtered().Count(i => i.Section == SecImmediate && i.ReasonKind == "contract" && !_hidden.Contains(HideKey(i)));

    private async Task HideAllExpiredContracts()
    {
        foreach (var i in Filtered().Where(i => i.Section == SecImmediate && i.ReasonKind == "contract"))
            _hidden.Add(HideKey(i));
        await SaveHidden();
    }

    private async Task HideItem(FollowUpItemDto item)
    {
        _hidden.Add(HideKey(item));
        await SaveHidden();
    }

    private async Task SaveHidden()
    {
        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(_hidden);
            await JS.InvokeVoidAsync("localStorage.setItem", HiddenStorageKey, json);
        }
        catch { /* storage unavailable — the hide still applies for this session */ }
    }



    private DateOnly AsOf => _data?.AsOf ?? PhilippineTime.Today;
    private string PeriodLabel => _data?.PeriodLabel ?? PhilippineTime.Now.ToString("MMMM yyyy");
    private IReadOnlyList<FollowUpItemDto> AllItems => _data?.Items ?? Array.Empty<FollowUpItemDto>();

    protected override async Task OnInitializedAsync()
    {
        await FacilityCatalog.EnsureLoadedAsync();
        var now = PhilippineTime.Now;
        if (CachedFollowUpQueue is { } state
            && state.Year == now.Year
            && state.Month == now.Month)
        {
            _data = state.Data;
            _loading = false;
            return;
        }

        await Load();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var json = await JS.InvokeAsync<string?>("localStorage.getItem", HiddenStorageKey);
            if (string.IsNullOrWhiteSpace(json)) return;
            var keys = System.Text.Json.JsonSerializer.Deserialize<HashSet<string>>(json);
            if (keys is { Count: > 0 })
            {
                _hidden = keys;
                StateHasChanged();   // re-filter now that dismissed items are known
            }
        }
        catch { /* storage unavailable — start with nothing hidden */ }
    }

    private async Task Load()
    {
        _loading = true;
        await PaintLoadingStateAsync();

        var now = PhilippineTime.Now;
        // Cold-start resilience: tolerate the brief window before the circuit attaches the JWT.
        for (var attempt = 0; attempt < 5; attempt++)
        {
            var result = await ReportsApi.GetFollowUpQueueAsync(now.Year, now.Month);
            if (result.IsSuccess)
            {
                _data = result.Value;
                if (_data is not null)
                    CachedFollowUpQueue = new FollowUpQueuePageState(now.Year, now.Month, _data);

                break;
            }
            _data = null;
            if (result.StatusCode is not (401 or 403)) break;
            await Task.Delay(400);
        }
        _loading = false;
    }

    // ── Inline Add-OR (records missing a receipt number) ───────────────────────────
