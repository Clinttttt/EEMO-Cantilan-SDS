@page "/reports/follow-up"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@rendermode InteractiveServer
@using EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Domain.Common
@using EEMOCantilanSDS.Application.Dtos.Reports
@inject IReportsApiClient ReportsApi

@* ───────────────────────────────────────────────────────────────────────────────
   Follow-up Queue — an ACTION queue for the EEMO Head/Admin, distinct from the
   Dashboard (financial overview) and the Financial/Month-End reports (ledgers). It
   answers "what needs staff attention now?" — grouped by the action required, with a
   priority, a reason, and a deep link to act. Scope is "as of today".

   Data: GET /api/Reports/follow-up (GetFollowUpQueueQuery) composes delinquency,
   per-facility compliance, the NPM daily streak, online + service receipts missing an
   OR, and contract expiry. No money KPIs here — only action items and counts.

   DESIGN: government-restrained. Neutral surfaces; colour only on the thin priority
   rail, the small reason badge, and the amount.
   ─────────────────────────────────────────────────────────────────────────────── *@

<PageTitle>EEMO Admin — Follow-up Queue</PageTitle>

<header class="topbar">
    <div class="topbar-left">
        <div class="topbar-title">Follow-up Queue</div>
        <div class="topbar-breadcrumb">
            <a href="/menu" class="breadcrumb-link">EEMO Admin</a>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Follow-up Queue</span>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            As of @AsOf.ToString("MMMM d, yyyy")
        </div>
        <div class="topbar-period">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
            Collection Period: <strong>@PeriodLabel</strong>
        </div>
        <AccountChip />
    </div>
</header>

<div class="content-area">

    <!-- Hero: what this queue is + scope -->
    <div class="fq-intro">
        <div class="fq-intro-text">
            <div class="fq-intro-title">Work queue</div>
            <div class="fq-intro-sub">Records, accounts, and facilities needing review, completion, or contract action — most urgent first.</div>
        </div>
        <div class="fq-intro-scope">
            <span class="fq-scope-pill">@TotalItems open item@(TotalItems == 1 ? "" : "s")</span>
            <span class="fq-scope-note">As of @AsOf.ToString("MMM d, yyyy")</span>
        </div>
    </div>

    <!-- Filter choices + search -->
    <div class="fq-filterbar">
        <div class="fq-filters" role="group" aria-label="Filter by reason">
            @foreach (var f in Filters)
            {
                var count = CountFor(f.Key);
                <button type="button"
                        class="fq-chip @(_filter == f.Key ? "fq-chip-active" : "")"
                        disabled="@(count == 0 && f.Key != "all")"
                        @onclick="@(() => SelectFilter(f.Key))">
                    @f.Label
                    <span class="fq-chip-count">@count</span>
                </button>
            }
        </div>

        <div class="fq-toolrow">
            <div class="fq-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="search" placeholder="Search payor, stall, facility, or reason…" value="@_search" @oninput="OnSearchInput" aria-label="Search the queue" />
                @if (HasSearch)
                {
                    <button class="fq-search-clear" type="button" @onclick="ClearSearch" aria-label="Clear search">&times;</button>
                }
            </div>
            <div class="fq-filters" role="group" aria-label="Filter by facility">
                <button type="button" class="fq-chip @(_facility is null ? "fq-chip-active" : "")" @onclick="@(() => SelectFacility(null))">All Facilities</button>
                @foreach (var fc in AllFacilities)
                {
                    <button type="button" class="fq-chip @(_facility == fc ? "fq-chip-active" : "")" title="@fc" @onclick="@(() => SelectFacility(fc))">@fc</button>
                }
            </div>
        </div>
    </div>

    @{
        var visibleSections = Sections
            .Select(s => new { Section = s, Items = ItemsFor(s.Id) })
            .Where(x => x.Items.Count > 0)
            .ToList();
    }

    @if (_loading)
    {
        <div class="fq-state">Loading follow-up queue…</div>
    }
    else if (_data is null)
    {
        <div class="fq-state fq-state-error">
            Unable to load the follow-up queue.
            <button class="fq-retry" type="button" @onclick="Load">Try again</button>
        </div>
    }
    else if (visibleSections.Count == 0)
    {
        <div class="fq-empty">
            <div class="fq-empty-icon">
                <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
            </div>
            <div class="fq-empty-title">No follow-up items for the selected scope.</div>
            <div class="fq-empty-sub">All visible records are either paid, excused, or not yet due.</div>
        </div>
    }
    else
    {
        @foreach (var grp in visibleSections)
        {
            <section class="fq-section">
                <div class="fq-sec-head fq-sec-@grp.Section.Tone">
                    <span class="fq-sec-rail"></span>
                    <span class="fq-sec-count">@grp.Items.Count</span>
                    <div class="fq-sec-info">
                        <div class="fq-sec-title">@grp.Section.Title</div>
                        <div class="fq-sec-sub">@grp.Section.Sub</div>
                    </div>
                </div>

                <div class="fq-table-wrap">
                    <table class="fq-table">
                        <thead>
                            <tr>
                                <th>Reason</th>
                                <th>Payor / Stall</th>
                                <th>Period &amp; Status</th>
                                <th class="fq-r">Amount</th>
                                <th class="fq-r">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var it in grp.Items)
                            {
                                <tr class="fq-row fq-pri-@PriClass(it.Priority)">
                                    <td><span class="fq-reason fq-rb-@PriClass(it.Priority)">@it.Reason</span></td>
                                    <td>
                                        <div class="fq-person">@it.Person</div>
                                        <div class="fq-sub">@it.Identifier · @it.Facility · @it.Model</div>
                                    </td>
                                    <td>
                                        <div class="fq-period">@it.Period</div>
                                        <div class="fq-sub">@it.Status</div>
                                    </td>
                                    <td class="fq-r"><span class="fq-amount @AmountClass(it)">@AmountLabel(it)</span></td>
                                    <td class="fq-r"><a class="fq-action" href="@it.Link">@it.Action<span class="fq-action-arrow">→</span></a></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    }

    <div class="fq-foot-note">
        Priorities — <span class="fq-legend fq-rb-critical">Critical</span> overdue / untraceable money ·
        <span class="fq-legend fq-rb-high">High</span> act this week ·
        <span class="fq-legend fq-rb-normal">Normal</span> routine follow-up ·
        <span class="fq-legend fq-rb-review">Review</span> verify before action.
    </div>
</div>

@code {
    private FollowUpQueueDto? _data;
    private bool _loading = true;

    private string _filter = "all";
    private string _search = "";
    private FacilityCode? _facility;   // null = all facilities

    private static readonly FacilityCode[] AllFacilities =
    {
        FacilityCode.NPM, FacilityCode.TCC, FacilityCode.NCC, FacilityCode.BBQ,
        FacilityCode.ICE, FacilityCode.SLH, FacilityCode.TRM, FacilityCode.TPM
    };

    private DateOnly AsOf => _data?.AsOf ?? PhilippineTime.Today;
    private string PeriodLabel => _data?.PeriodLabel ?? PhilippineTime.Now.ToString("MMMM yyyy");
    private IReadOnlyList<FollowUpItemDto> AllItems => _data?.Items ?? Array.Empty<FollowUpItemDto>();

    protected override async Task OnInitializedAsync() => await Load();

    private async Task Load()
    {
        _loading = true;
        var now = PhilippineTime.Now;
        // Cold-start resilience: tolerate the brief window before the circuit attaches the JWT.
        for (var attempt = 0; attempt < 5; attempt++)
        {
            var result = await ReportsApi.GetFollowUpQueueAsync(now.Year, now.Month);
            if (result.IsSuccess) { _data = result.Value; break; }
            _data = null;
            if (result.StatusCode is not (401 or 403)) break;
            await Task.Delay(400);
        }
        _loading = false;
    }

    // ── Section metadata (presentation only; ids match the server's Section field) ──
    private sealed record SectionDef(int Id, string Title, string Sub, string Tone, string Icon);

    private static readonly SectionDef[] Sections =
    {
        new(1, "Needs immediate action",
               "Delinquent accounts, received money still missing its receipt, and expired contracts with active occupants.",
               "critical", "alert"),
        new(2, "Needs follow-up this period",
               "Current-period unpaid balances, partial payments, early arrears, and contracts expiring soon.",
               "high", "wallet"),
        new(3, "Needs verification",
               "Excused / absent records to confirm before they affect the books.",
               "review", "shield"),
        new(4, "Facility-specific operational items",
               "Daily, per-trip, and market-day collection exceptions unique to each facility model.",
               "normal", "sliders"),
    };

    private sealed record FilterDef(string Key, string Label);

    private static readonly FilterDef[] Filters =
    {
        new("all", "All"),
        new("delinquent", "Delinquent"),
        new("arrears", "Arrears"),
        new("missingor", "Missing OR"),
        new("current", "Current-period"),
        new("contract", "Contract"),
        new("npm", "NPM Daily"),
        new("excused", "Excused Review"),
    };

    private bool HasSearch => !string.IsNullOrWhiteSpace(_search);
    private int TotalItems => Filtered().Count;

    private void SelectFilter(string key) => _filter = key;
    private void SelectFacility(FacilityCode? code) => _facility = code;
    private void OnSearchInput(ChangeEventArgs e) => _search = e.Value?.ToString() ?? "";
    private void ClearSearch() => _search = "";

    private int CountFor(string key) => AllItems.Count(i =>
        (key == "all" || i.ReasonKind == key) && MatchesFacility(i) && MatchesSearch(i));

    private IReadOnlyList<FollowUpItemDto> Filtered() =>
        AllItems.Where(i => (_filter == "all" || i.ReasonKind == _filter) && MatchesFacility(i) && MatchesSearch(i)).ToList();

    private bool MatchesFacility(FollowUpItemDto i) => _facility is null || i.Facility == _facility;

    private List<FollowUpItemDto> ItemsFor(int section) =>
        Filtered().Where(i => i.Section == section).ToList();   // server already ordered by priority/amount

    private bool MatchesSearch(FollowUpItemDto i)
    {
        if (!HasSearch) return true;
        var q = _search.Trim();
        return Contains(i.Person, q) || Contains(i.Identifier, q) || Contains(i.Reason, q)
            || Contains(i.Status, q) || Contains(i.Facility.ToString(), q) || Contains(i.Model, q);
    }

    private static bool Contains(string? value, string q) =>
        !string.IsNullOrEmpty(value) && value.Contains(q, StringComparison.OrdinalIgnoreCase);

    private static string PriClass(string priority) => priority switch
    {
        "Critical" => "critical",
        "High" => "high",
        "Normal" => "normal",
        _ => "review"
    };

    private static string IconFor(string reasonKind) => reasonKind switch
    {
        "missingor" => "receipt",
        "contract" => "file",
        "npm" => "calendar",
        "excused" => "user-check",
        _ => "user"   // delinquent / arrears / current
    };

    private static string AmountLabel(FollowUpItemDto i)
    {
        if (i.Excused) return "₱0 · excused";
        return i.Amount is { } a ? "₱" + a.ToString("N0") : "—";
    }

    private static string AmountClass(FollowUpItemDto i)
    {
        if (i.Excused) return "fq-amount-excused";
        if (i.Amount is > 0m) return "fq-amount-red";
        return "fq-amount-muted";
    }

    // Centralised inner-SVG paths (stroke style, matching the app's icon language).
    private static string Svg(string name) => name switch
    {
        "user"       => "<circle cx='12' cy='8' r='4'/><path d='M5.5 20a6.5 6.5 0 0 1 13 0'/>",
        "receipt"    => "<path d='M5 3h14v18l-3-2-2 2-2-2-2 2-2-2-3 2z'/><line x1='9' y1='8' x2='15' y2='8'/><line x1='9' y1='12' x2='15' y2='12'/>",
        "file"       => "<path d='M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z'/><polyline points='14 2 14 8 20 8'/><line x1='8' y1='13' x2='16' y2='13'/><line x1='8' y1='17' x2='13' y2='17'/>",
        "calendar"   => "<rect x='3' y='4' width='18' height='18' rx='2'/><line x1='16' y1='2' x2='16' y2='6'/><line x1='8' y1='2' x2='8' y2='6'/><line x1='3' y1='10' x2='21' y2='10'/>",
        "user-check" => "<path d='M5.5 20a6.5 6.5 0 0 1 11-4.7'/><circle cx='11' cy='8' r='4'/><polyline points='16 17 18 19 22 15'/>",
        "alert"      => "<path d='M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z'/><line x1='12' y1='9' x2='12' y2='13'/><line x1='12' y1='17' x2='12.01' y2='17'/>",
        "wallet"     => "<path d='M21 12V7H5a2 2 0 0 1 0-4h14v4'/><path d='M3 5v14a2 2 0 0 0 2 2h16v-5'/><path d='M18 12a2 2 0 0 0 0 4h3v-4z'/>",
        "shield"     => "<path d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'/><polyline points='9 12 11 14 15 10'/>",
        "sliders"    => "<line x1='4' y1='21' x2='4' y2='14'/><line x1='4' y1='10' x2='4' y2='3'/><line x1='12' y1='21' x2='12' y2='12'/><line x1='12' y1='8' x2='12' y2='3'/><line x1='20' y1='21' x2='20' y2='16'/><line x1='20' y1='12' x2='20' y2='3'/><line x1='1' y1='14' x2='7' y2='14'/><line x1='9' y1='8' x2='15' y2='8'/><line x1='17' y1='16' x2='23' y2='16'/>",
        _            => "<circle cx='12' cy='12' r='9'/>"
    };
}
