    // ── Section metadata (presentation only; ids match the server's Section field) ──
    // Monthly arrears/delinquency payment from follow-up rows.
    private FollowUpItemDto? _monthlyPaymentItem;
    private bool _monthlyPaymentLoading;
    private bool _monthlyPaymentSaving;
    private bool _monthlyPaymentConfirming;
    private string? _monthlyPaymentError;
    private string _monthlyPaymentPeriodKey = string.Empty;
    private PaymentStatus _monthlyPaymentStatus = PaymentStatus.Paid;
    private decimal _monthlyPaymentAmount;
    private string _monthlyPaymentOr = string.Empty;
    private string _monthlyPaymentRemarks = string.Empty;
    private List<MonthlyPaymentRow> _monthlyPaymentRows = new();

    private sealed record MonthlyPaymentRow(
        string Key,
        string Label,
        int Year,
        int Month,
        PaymentStatus Status,
        decimal TotalBill,
        decimal AmountPaid,
        decimal BalanceDue,
        string? ORNumber);

    private MonthlyPaymentRow? SelectedMonthlyPaymentRow =>
        _monthlyPaymentRows.FirstOrDefault(r => r.Key == _monthlyPaymentPeriodKey);

    private static bool CanRecordMonthlyPayment(FollowUpItemDto item) =>
        item.StallId.HasValue
        && item.Facility != FacilityCode.NPM
        && item.Amount.GetValueOrDefault() > 0m
        && item.ReasonKind is "delinquent" or "arrears" or "contract";

    private async Task OpenMonthlyPayment(FollowUpItemDto item)
    {
        if (!CanRecordMonthlyPayment(item) || item.StallId is null)
            return;

        _monthlyPaymentItem = item;
        _monthlyPaymentRows = new();
        _monthlyPaymentPeriodKey = string.Empty;
        _monthlyPaymentStatus = PaymentStatus.Paid;
        _monthlyPaymentAmount = 0m;
        _monthlyPaymentOr = string.Empty;
        _monthlyPaymentRemarks = string.Empty;
        _monthlyPaymentError = null;
        _monthlyPaymentConfirming = false;
        _monthlyPaymentLoading = true;

        var result = await PaymentsApi.GetPaymentHistoryAsync(item.StallId.Value);
        if (!result.IsSuccess || result.Value is null)
        {
            _monthlyPaymentError = result.Error ?? "Unable to load this stall's open billing months.";
            _monthlyPaymentLoading = false;
            return;
        }

        var asOfKey = AsOf.Year * 100 + AsOf.Month;
        _monthlyPaymentRows = result.Value
            .Select(ToMonthlyPaymentRow)
            .Where(r => r is not null)
            .Select(r => r!)
            .Where(r => r.BalanceDue > 0m && r.Status != PaymentStatus.Paid)
            .Where(r =>
            {
                var key = r.Year * 100 + r.Month;
                return item.ReasonKind switch
                {
                    "delinquent" or "arrears" => key < asOfKey,
                    // Expired-contract accounts owe every month up to (and including) the as-of period.
                    "contract" => key <= asOfKey,
                    _ => false
                };
            })
            .OrderBy(r => r.Year)
            .ThenBy(r => r.Month)
            .ToList();

        _monthlyPaymentPeriodKey = _monthlyPaymentRows.FirstOrDefault()?.Key ?? string.Empty;
        SeedMonthlyPaymentInputs();
        _monthlyPaymentLoading = false;
    }

    private static MonthlyPaymentRow? ToMonthlyPaymentRow(PaymentHistoryDto history)
    {
        if (history.IsExcused || string.IsNullOrWhiteSpace(history.Period))
            return null;

        if (!DateOnly.TryParseExact(
                history.Period,
                "yyyy-MM",
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.None,
                out var period))
        {
            return null;
        }

        var label = new DateTime(period.Year, period.Month, 1)
            .ToString("MMMM yyyy", System.Globalization.CultureInfo.InvariantCulture);

        return new MonthlyPaymentRow(
            history.Period,
            label,
            period.Year,
            period.Month,
            history.Status,
            history.TotalBill,
            history.AmountPaid,
            history.BalanceDue,
            history.ORNumber);
    }

    private void OnMonthlyPaymentPeriodChanged(ChangeEventArgs e)
    {
        _monthlyPaymentPeriodKey = e.Value?.ToString() ?? string.Empty;
        SeedMonthlyPaymentInputs();
    }

    private void SetMonthlyPaymentStatus(PaymentStatus status)
    {
        _monthlyPaymentStatus = status == PaymentStatus.Partial ? PaymentStatus.Partial : PaymentStatus.Paid;
        _monthlyPaymentConfirming = false;
        _monthlyPaymentError = null;
        SeedMonthlyPaymentAmount();
    }

    private void SeedMonthlyPaymentInputs()
    {
        _monthlyPaymentStatus = PaymentStatus.Paid;
        _monthlyPaymentOr = string.Empty;
        _monthlyPaymentRemarks = string.Empty;
        _monthlyPaymentConfirming = false;
        _monthlyPaymentError = null;
        SeedMonthlyPaymentAmount();
    }

    private void SeedMonthlyPaymentAmount()
    {
        var row = SelectedMonthlyPaymentRow;
        _monthlyPaymentAmount = row is null
            ? 0m
            : _monthlyPaymentStatus == PaymentStatus.Partial
                ? Math.Max(row.AmountPaid, 0m)
                : row.TotalBill;
    }

    private void OnMonthlyPaymentAmountInput(ChangeEventArgs e)
    {
        _monthlyPaymentConfirming = false;
        _monthlyPaymentError = null;
        if (decimal.TryParse(e.Value?.ToString(), out var value))
            _monthlyPaymentAmount = Math.Max(0m, value);
        else
            _monthlyPaymentAmount = 0m;
    }

    private Task CloseMonthlyPayment()
    {
        _monthlyPaymentItem = null;
        _monthlyPaymentRows = new();
        _monthlyPaymentPeriodKey = string.Empty;
        _monthlyPaymentError = null;
        _monthlyPaymentConfirming = false;
        _monthlyPaymentLoading = false;
        _monthlyPaymentSaving = false;
        return Task.CompletedTask;
    }

    private async Task SaveMonthlyPayment()
    {
        if (_monthlyPaymentItem?.StallId is not { } stallId)
            return;

        var row = SelectedMonthlyPaymentRow;
        if (row is null)
        {
            _monthlyPaymentError = "Select a billing period first.";
            return;
        }

        var orNumber = _monthlyPaymentOr.Trim();
        if (string.IsNullOrWhiteSpace(orNumber))
        {
            _monthlyPaymentError = "Enter the official receipt number before saving.";
            _monthlyPaymentConfirming = false;
            return;
        }

        decimal? partialAmount = null;
        if (_monthlyPaymentStatus == PaymentStatus.Partial)
        {
            if (_monthlyPaymentAmount <= row.AmountPaid)
            {
                _monthlyPaymentError = $"Partial total must be greater than the current recorded amount ({Currency(row.AmountPaid)}).";
                _monthlyPaymentConfirming = false;
                return;
            }

            if (_monthlyPaymentAmount >= row.TotalBill)
            {
                _monthlyPaymentError = "Use Paid in full when the amount reaches the total bill.";
                _monthlyPaymentConfirming = false;
                return;
            }

            partialAmount = _monthlyPaymentAmount;
        }

        if (!_monthlyPaymentConfirming)
        {
            _monthlyPaymentError = null;
            _monthlyPaymentConfirming = true;
            return;
        }

        _monthlyPaymentSaving = true;
        _monthlyPaymentError = null;

        var result = await PaymentsApi.RecordPaymentAsync(new RecordPaymentCommand(
            stallId,
            row.Year,
            row.Month,
            _monthlyPaymentStatus,
            partialAmount,
            string.IsNullOrWhiteSpace(_monthlyPaymentRemarks) ? null : _monthlyPaymentRemarks.Trim(),
            orNumber));

        _monthlyPaymentSaving = false;
        _monthlyPaymentConfirming = false;

        if (!result.IsSuccess)
        {
            _monthlyPaymentError = result.Error ?? "Unable to record this payment.";
            return;
        }

        await CloseMonthlyPayment();
        await Load();
    }

    private static string Currency(decimal value) => $"₱{value:N0}";

    private sealed record SectionDef(int Id, string Title, string Sub, string Tone, string Icon);

    private static readonly SectionDef[] Sections =
    {
        new(1, "Needs immediate action",
               "Delinquent accounts, received money still missing its receipt, and expired contracts with active occupants.",
               "critical", "alert"),
        new(2, "Needs follow-up this period",
               "Current-period unpaid balances, partial payments, early arrears, and contracts expiring soon.",
               "high", "wallet"),
        new(3, "Needs verification",
               "Excused / absent records to confirm before they affect the books.",
               "review", "shield"),
        new(4, "Facility-specific operational items",
               "Daily, per-trip, and market-day collection exceptions unique to each facility model.",
               "normal", "sliders"),
    };

    // ── Per-section table columns (context-aware) ──────────────────────────────────
    // Sections are urgency bands but their content differs enough to warrant different columns:
    //   • Verification (3) is excused/absent only — always ₱0, so a money column would mislead;
    //     show the period and the excuse note instead.
    //   • Operational (4) is always the current period (redundant) — lead with the activity note
    //     and the amount.
    //   • Immediate (1) / this-period (2) are money & timing — keep Period & Status + Amount.
    private sealed record Col(string Key, string Header);

    private static IReadOnlyList<Col> ColumnsFor(int section) => section switch
    {
        3 => new[]
        {
            new Col("reason", "Reason"),
            new Col("payor", "Payor / Stall"),
            new Col("period", "Period"),
            new Col("note", "Status"),
            new Col("action", "Action"),
        },
        4 => new[]
        {
            new Col("reason", "Reason"),
            new Col("payor", "Payor / Stall"),
            new Col("note", "Activity"),
            new Col("amount", "Amount"),
            new Col("action", "Action"),
        },
        _ => new[]
        {
            new Col("reason", "Reason"),
            new Col("payor", "Payor / Stall"),
            new Col("periodstatus", "Period & Status"),
            new Col("amount", "Amount"),
            new Col("action", "Action"),
        },
    };

    private sealed record FilterDef(string Key, string Label);

    private static readonly FilterDef[] Filters =
    {
        new("all", "All"),
        new("delinquent", "Delinquent"),
        new("arrears", "Arrears"),
        new("missingor", "Missing OR"),
        new("current", "Current-period"),
        new("contract", "Contract"),
        new("npm", "NPM Daily"),
        new("excused", "Excused Review"),
        new("misc", "Miscellaneous"),
    };

    private bool HasSearch => !string.IsNullOrWhiteSpace(_search);
    private int TotalItems => Filtered().Count;

    // Overview counts per urgency band for the hero — all open items (minus dismissed), independent
    // of the reason/facility/search filters so the summary stays stable while filtering below.
    private int SectionTotal(int section)
    {
        var q = AllItems.Where(i => i.Section == section);
        if (section == SecImmediate) q = q.Where(i => !_hidden.Contains(HideKey(i)));
        return q.Count();
    }

    private void SelectFilter(string key) => _filter = key;
    private void SelectFacility(FacilityCode? code) => _facility = code;
    private void OnSearchInput(ChangeEventArgs e) => _search = e.Value?.ToString() ?? "";
    private void ClearSearch() => _search = "";

    private int CountFor(string key) => AllItems.Count(i =>
        (key == "all" || i.ReasonKind == key) && MatchesFacility(i) && MatchesSearch(i));

    private IReadOnlyList<FollowUpItemDto> Filtered() =>
        AllItems.Where(i => (_filter == "all" || i.ReasonKind == _filter) && MatchesFacility(i) && MatchesSearch(i)).ToList();

    private bool MatchesFacility(FollowUpItemDto i) => _facility is null || i.Facility == _facility;

    private List<FollowUpItemDto> ItemsFor(int section)
    {
        var items = Filtered().Where(i => i.Section == section);
        // Dismissed items are permanently removed from the live queue (reviewable under Past follow-up).
        if (section == SecImmediate)
            items = items.Where(i => !_hidden.Contains(HideKey(i)));
        return items.ToList();   // server already ordered by priority/amount
    }

    private bool MatchesSearch(FollowUpItemDto i)
    {
        if (!HasSearch) return true;
        var q = _search.Trim();
        return Contains(i.Person, q) || Contains(i.Identifier, q) || Contains(i.Reason, q)
            || Contains(i.Status, q) || Contains(i.Facility.ToString(), q) || Contains(i.Model, q);
    }

    private static bool Contains(string? value, string q) =>
        !string.IsNullOrEmpty(value) && value.Contains(q, StringComparison.OrdinalIgnoreCase);

    private static string PriClass(string priority) => priority switch
    {
        "Critical" => "critical",
        "High" => "high",
        "Normal" => "normal",
        _ => "review"
    };

    private static string IconFor(string reasonKind) => reasonKind switch
    {
        "missingor" => "receipt",
        "contract" => "file",
        "npm" => "calendar",
        "excused" => "user-check",
        "misc" => "receipt",
        _ => "user"   // delinquent / arrears / current
    };

    private static string AmountLabel(FollowUpItemDto i)
    {
        if (i.Excused) return "₱0 · excused";
        return i.Amount is { } a ? "₱" + a.ToString("N0") : "—";
    }

    private static string AmountClass(FollowUpItemDto i)
    {
        if (i.Excused) return "fq-amount-excused";
        if (i.Amount is > 0m) return "fq-amount-red";
        return "fq-amount-muted";
    }

    public sealed record FollowUpQueuePageState(
        int Year,
        int Month,
        FollowUpQueueDto Data);

