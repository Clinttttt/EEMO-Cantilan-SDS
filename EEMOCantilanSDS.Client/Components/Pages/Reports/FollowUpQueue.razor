@page "/reports/follow-up"
@attribute [Authorize(Roles = "SuperAdmin,Admin")]
@using EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Domain.Common
@using EEMOCantilanSDS.Domain.Constants
@using EEMOCantilanSDS.Application.Dtos.Reports
@using EEMOCantilanSDS.Application.Dtos.Payments
@using EEMOCantilanSDS.Application.Dtos.DailyCollections
@using EEMOCantilanSDS.Application.Command.DailyCollections.SaveDailyCollectionOrNumber
@using EEMOCantilanSDS.Application.Command.DailyCollections.SaveDailyCollectionOrForDays
@using EEMOCantilanSDS.Application.Command.Payments.RecordPayment
@using EEMOCantilanSDS.Application.Command.Slaughterhouse.SaveSlaughterOrNumber
@using EEMOCantilanSDS.Application.Requests.TransportTerminal
@using EEMOCantilanSDS.Application.Requests.TaboanMarket
@inject IReportsApiClient ReportsApi
@inject EEMOCantilanSDS.Client.Services.FacilityState FacilityCatalog
@inject IDailyCollectionApiClient DailyApi
@inject IPaymentsApiClient PaymentsApi
@inject ITrmApiClient TrmApi
@inject ITpmApiClient TpmApi
@inject ISlaughterApiClient SlhApi
@inject IJSRuntime JS

@* ───────────────────────────────────────────────────────────────────────────────
   Follow-up Queue — an ACTION queue for the EEMO Head/Admin, distinct from the
   Dashboard (financial overview) and the Financial/Month-End reports (ledgers). It
   answers "what needs staff attention now?" — grouped by the action required, with a
   priority, a reason, and a deep link to act. Scope is "as of today".

   Data: GET /api/Reports/follow-up (GetFollowUpQueueQuery) composes delinquency,
   per-facility compliance, the NPM daily streak, online + service receipts missing an
   OR, and contract expiry. No money KPIs here — only action items and counts.

   DESIGN: government-restrained. Neutral surfaces; colour only on the thin priority
   rail, the small reason badge, and the amount.
   ─────────────────────────────────────────────────────────────────────────────── *@

<PageTitle>@Branding.OfficeAcronym Admin — Follow-up Queue</PageTitle>

<header class="topbar">
    <div class="topbar-left">
        <div class="topbar-title">Follow-up Queue</div>
        <div class="topbar-breadcrumb">
            <a href="/menu" class="breadcrumb-link">@Branding.OfficeAcronym Admin</a>
            <span class="breadcrumb-sep">/</span>
            <span class="breadcrumb-active">Follow-up Queue</span>
        </div>
    </div>
    <div class="topbar-right">
        <div class="topbar-date">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            As of @AsOf.ToString("MMMM d, yyyy")
        </div>
        <div class="topbar-period">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
            Collection Period: <strong>@PeriodLabel</strong>
        </div>
        <AccountChip />
    </div>
</header>

<div class="content-area">

    <!-- Hero + queue summary -->
    <div class="fq-hero">
        <div class="fq-hero-left">
            <div class="fq-hero-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4" /><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11" /></svg>
            </div>
            <div>
                <div class="fq-hero-eyebrow">@Branding.OfficeAcronym Admin · Work queue</div>
                <div class="fq-hero-title">Follow-up Queue</div>
                <div class="fq-hero-sub">As of @AsOf.ToString("MMMM d, yyyy") · @PeriodLabel</div>
            </div>
        </div>
        <div class="fq-hero-stats">
            <div class="fq-stat">
                <div class="fq-stat-val fq-stat-critical">@SectionTotal(1)</div>
                <div class="fq-stat-key">Immediate</div>
            </div>
            <div class="fq-hero-divider"></div>
            <div class="fq-stat">
                <div class="fq-stat-val">@SectionTotal(2)</div>
                <div class="fq-stat-key">This period</div>
            </div>
            <div class="fq-hero-divider"></div>
            <div class="fq-stat">
                <div class="fq-stat-val">@SectionTotal(3)</div>
                <div class="fq-stat-key">Verify</div>
            </div>
            <div class="fq-hero-divider"></div>
            <div class="fq-stat">
                <div class="fq-stat-val">@SectionTotal(4)</div>
                <div class="fq-stat-key">Operational</div>
            </div>
        </div>
    </div>

    <!-- Filter choices + search -->
    <div class="fq-filterbar">
        <div class="fq-filters" role="group" aria-label="Filter by reason">
            @foreach (var f in Filters)
            {
                var count = CountFor(f.Key);
                <button type="button"
                        class="fq-chip @(_filter == f.Key ? "fq-chip-active" : "")"
                        disabled="@(count == 0 && f.Key != "all")"
                        @onclick="@(() => SelectFilter(f.Key))">
                    @f.Label
                    <span class="fq-chip-count">@count</span>
                </button>
            }
        </div>

        <div class="fq-toolrow">
            <div class="fq-search">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="7" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="search" placeholder="Search payor, stall, facility, or reason…" value="@_search" @oninput="OnSearchInput" aria-label="Search the queue" />
                @if (HasSearch)
                {
                    <button class="fq-search-clear" type="button" @onclick="ClearSearch" aria-label="Clear search">&times;</button>
                }
            </div>
            <div class="fq-filters" role="group" aria-label="Filter by facility">
                <button type="button" class="fq-chip @(_facility is null ? "fq-chip-active" : "")" @onclick="@(() => SelectFacility(null))">All Facilities</button>
                @foreach (var fc in FacilityCatalog.All)
                {
                    <button type="button" class="fq-chip @(_facility == fc ? "fq-chip-active" : "")" title="@fc" @onclick="@(() => SelectFacility(fc))">@FacilityCatalog.ShortNameOf(fc)</button>
                }
            </div>
            <a class="btn-outline fq-history-link" href="/reports/follow-up/history" title="Resolved & dismissed items from previous periods">
                <svg viewBox="0 0 24 24"><path d="M3 3v5h5" /><path d="M3.05 13A9 9 0 1 0 6 5.3L3 8" /><polyline points="12 7 12 12 15 14" /></svg>
                Past follow-up
            </a>
        </div>
    </div>

    @{
        var visibleSections = Sections
            .Select(s => new { Section = s, Items = ItemsFor(s.Id) })
            .Where(x => x.Items.Count > 0)
            .ToList();
    }

    @if (_loading)
    {
        <div class="fq-skeleton" aria-busy="true" aria-label="Loading follow-up queue">
            @for (var s = 0; s < 2; s++)
            {
                <section class="fq-section">
                    <div class="fq-sec-head fq-sec-normal">
                        <span class="fq-sec-rail"></span>
                        <Skeleton Width="26px" Height="26px" Radius="7px" />
                        <div class="fq-sec-info">
                            <Skeleton Width="210px" Height="13px" Radius="5px" />
                            <Skeleton Width="320px" Height="10px" Radius="5px" Class="fq-sk-mt" />
                        </div>
                    </div>
                    <div class="fq-table-wrap">
                        <div class="fq-sk-row fq-sk-head">
                            @for (var c = 0; c < 5; c++)
                            {
                                <Skeleton Height="9px" Radius="4px" />
                            }
                        </div>
                        @for (var r = 0; r < 4; r++)
                        {
                            <div class="fq-sk-row">
                                @for (var c = 0; c < 5; c++)
                                {
                                    <Skeleton Height="14px" Radius="6px" />
                                }
                            </div>
                        }
                    </div>
                </section>
            }
        </div>
    }
    else if (_data is null)
    {
        <div class="fq-state fq-state-error">
            Unable to load the follow-up queue.
            <button class="fq-retry" type="button" @onclick="Load">Try again</button>
        </div>
    }
    else if (visibleSections.Count == 0)
    {
        <div class="fq-empty">
            <div class="fq-empty-icon">
                <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
            </div>
            <div class="fq-empty-title">No follow-up items for the selected scope.</div>
            <div class="fq-empty-sub">All visible records are either paid, excused, or not yet due.</div>
        </div>
    }
    else
    {
        @foreach (var grp in visibleSections)
        {
            <section class="fq-section">
                <div class="fq-sec-head fq-sec-@grp.Section.Tone">
                    <span class="fq-sec-rail"></span>
                    <span class="fq-sec-count">@grp.Items.Count</span>
                    <div class="fq-sec-info">
                        <div class="fq-sec-title">@grp.Section.Title</div>
                        <div class="fq-sec-sub">@grp.Section.Sub</div>
                    </div>
                    @if (grp.Section.Id == SecImmediate && ImmediateExpiredContractCount > 0)
                    {
                        <button type="button" class="fq-hideall" title="Dismiss every expired-contract item (they remain on the Closed Accounts page)" @onclick="HideAllExpiredContracts">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" /><line x1="1" y1="1" x2="23" y2="23" /></svg>
                            Hide all Contract expired (@ImmediateExpiredContractCount)
                        </button>
                    }
                </div>

                <div class="fq-table-wrap">
                    @{ var cols = ColumnsFor(grp.Section.Id); }
                    <table class="fq-table">
                        <thead>
                            <tr>
                                @foreach (var col in cols)
                                {
                                    <th>@col.Header</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var it in grp.Items)
                            {
                                <tr class="fq-row fq-pri-@PriClass(it.Priority)">
                                    @foreach (var col in cols)
                                    {
                                        switch (col.Key)
                                        {
                                            case "reason":
                                                <td><span class="fq-reason fq-rb-@PriClass(it.Priority)">@it.Reason</span></td>
                                                break;
                                            case "payor":
                                                <td>
                                                    <div class="fq-person">@it.Person</div>
                                                    <div class="fq-sub">@it.Identifier · @it.Facility · @it.Model</div>
                                                </td>
                                                break;
                                            case "periodstatus":
                                                <td>
                                                    <div class="fq-period">@it.Period</div>
                                                    <div class="fq-sub">@it.Status</div>
                                                </td>
                                                break;
                                            case "period":
                                                <td><div class="fq-period">@it.Period</div></td>
                                                break;
                                            case "note":
                                                <td><span class="fq-note">@it.Status</span></td>
                                                break;
                                            case "amount":
                                                <td><span class="fq-amount @AmountClass(it)">@AmountLabel(it)</span></td>
                                                break;
                                            case "action":
                                                <td>
                                                    <div class="fq-action-cell">
                                                        @if (grp.Section.Id == SecImmediate)
                                                        {
                                                            <button type="button" class="fq-hidebtn" title="Dismiss from the live queue — reviewable under Past follow-up" @onclick="() => HideItem(it)">Hide</button>
                                                        }
                                                        @if (it.Action == "Add OR")
                                                        {
                                                            <button type="button" class="fq-action fq-action-btn" @onclick="() => OpenAddOr(it)">@it.Action<span class="fq-action-arrow">→</span></button>
                                                        }
                                                        else if (CanRecordMonthlyPayment(it))
                                                        {
                                                            <button type="button" class="fq-action fq-action-btn" @onclick="() => OpenMonthlyPayment(it)">Record payment<span class="fq-action-arrow">→</span></button>
                                                        }
                                                        else if (it.Action == "Pay Bill" && it.StallId.HasValue)
                                                        {
                                                            <button type="button" class="fq-action fq-action-btn" @onclick="() => OpenUtilityBill(it)">@it.Action<span class="fq-action-arrow">→</span></button>
                                                        }
                                                        else
                                                        {
                                                            <a class="fq-action" href="@it.Link">@it.Action<span class="fq-action-arrow">→</span></a>
                                                        }
                                                    </div>
                                                </td>
                                                break;
                                            default:
                                                <td></td>
                                                break;
                                        }
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        }
    }

    <div class="fq-foot-note">
        Priorities — <span class="fq-legend fq-rb-critical">Critical</span> overdue / untraceable money ·
        <span class="fq-legend fq-rb-high">High</span> act this week ·
        <span class="fq-legend fq-rb-normal">Normal</span> routine follow-up ·
        <span class="fq-legend fq-rb-review">Review</span> verify before action.
    </div>
</div>

@if (_orItem is not null)
{
    <div class="fq-modal-overlay" @onclick="CloseAddOr">
        <div class="fq-modal" @onclick:stopPropagation="true">
            <div class="fq-modal-head">
                <div>
                    <div class="fq-modal-title">Add OR — @_orItem.Person</div>
                    <div class="fq-modal-sub">@_orItem.Identifier · @_orItem.Facility · @_orItem.Period</div>
                </div>
                <button type="button" class="fq-modal-x" @onclick="CloseAddOr" aria-label="Close">&times;</button>
            </div>
            <div class="fq-modal-body">
                @if (_orLoading)
                {
                    <div class="fq-or-state">Loading records…</div>
                }
                else if (_orError is not null)
                {
                    <div class="fq-or-state fq-or-error">@_orError</div>
                }
                else if (_orRows.Count == 0)
                {
                    <div class="fq-or-state">All records for this entry already have an OR number.</div>
                }
                else
                {
                    var npmDaily = _orModel == OrModel.NpmDaily;
                    var unsaved = _orRows.Count(r => !r.Saved);
                    <div class="fq-or-note">
                        Enter the official receipt (OR) number for each record still missing one. Each OR must be unique.
                        @if (npmDaily)
                        {
                            <text> A single OR may cover several days of the same payor — one physical receipt, one OR.</text>
                        }
                        else
                        {
                            <text> For the slaughterhouse, one OR covers a whole visit (all animals on that date).</text>
                        }
                    </div>

                    @if (npmDaily && unsaved > 1)
                    {
                        <div class="fq-or-modes" role="tablist">
                            <button type="button" class="fq-or-mode @(!_orMulti ? "on" : "")" @onclick="() => SetOrMulti(false)" disabled="@_orMultiSaving">One OR per day</button>
                            <button type="button" class="fq-or-mode @(_orMulti ? "on" : "")" @onclick="() => SetOrMulti(true)" disabled="@_orMultiSaving">One OR · multiple days</button>
                        </div>
                    }

                    <div class="fq-or-list">
                        @foreach (var r in _orRows)
                        {
                            @if (_orMulti && npmDaily && !r.Saved)
                            {
                                <label class="fq-or-row fq-or-rowpick">
                                    <input type="checkbox" class="fq-or-pick" checked="@r.Selected"
                                           @onchange="e => r.Selected = (bool)(e.Value ?? false)" disabled="@_orMultiSaving" />
                                    <div class="fq-or-day">
                                        <div class="fq-or-date">@r.Label</div>
                                        <div class="fq-or-amt">₱@r.Amount.ToString("N0")</div>
                                    </div>
                                </label>
                            }
                            else
                            {
                                <div class="fq-or-row @(r.Saved ? "fq-or-rowdone" : "")">
                                    <div class="fq-or-day">
                                        <div class="fq-or-date">@r.Label</div>
                                        <div class="fq-or-amt">₱@r.Amount.ToString("N0")</div>
                                    </div>
                                    @if (r.Saved)
                                    {
                                        <div class="fq-or-done"><span class="fq-or-check">✓</span> OR @r.Input</div>
                                    }
                                    else if (r.Confirming)
                                    {
                                        <div class="fq-or-confirm">
                                            <span class="fq-or-confirm-q">Save OR <strong>@r.Input.Trim()</strong>?</span>
                                            <button type="button" class="fq-or-confirm-yes" @onclick="() => SaveOrDay(r)" disabled="@r.Saving">
                                                @(r.Saving ? "Saving…" : "Confirm")
                                            </button>
                                            <button type="button" class="fq-or-confirm-no" @onclick="() => CancelConfirm(r)" disabled="@r.Saving">Cancel</button>
                                        </div>
                                    }
                                    else
                                    {
                                        <input class="fq-or-input" placeholder="OR number" maxlength="50" @bind="r.Input" @bind:event="oninput" disabled="@r.Saving" />
                                        <button type="button" class="fq-or-save"
                                                @onclick="() => BeginSave(r)"
                                                disabled="@(r.Saving || string.IsNullOrWhiteSpace(r.Input))">
                                            Save
                                        </button>
                                    }
                                    @if (r.Error is not null)
                                    {
                                        <div class="fq-or-rowerr">@r.Error</div>
                                    }
                                </div>
                            }
                        }
                    </div>

                    @if (_orMulti && npmDaily)
                    {
                        var picked = _orRows.Count(r => !r.Saved && r.Selected);
                        <div class="fq-or-multibar">
                            <div class="fq-or-multiinfo">
                                <span class="fq-or-multicount">@picked day@(picked == 1 ? "" : "s") selected</span>
                                @if (picked > 0)
                                {
                                    <span class="fq-or-multitotal">₱@_orRows.Where(r => !r.Saved && r.Selected).Sum(r => r.Amount).ToString("N0")</span>
                                }
                            </div>
                            <div class="fq-or-multirow">
                                <input class="fq-or-input" placeholder="OR number" maxlength="50" @bind="_orMultiOr" @bind:event="oninput" disabled="@_orMultiSaving" />
                                <button type="button" class="fq-or-save"
                                        @onclick="ApplyOrToSelected"
                                        disabled="@(_orMultiSaving || string.IsNullOrWhiteSpace(_orMultiOr) || picked == 0)">
                                    @(_orMultiSaving ? "Saving…" : "Apply OR")
                                </button>
                            </div>
                            @if (_orMultiError is not null)
                            {
                                <div class="fq-or-rowerr">@_orMultiError</div>
                            }
                        </div>
                    }
                }
            </div>
            <div class="fq-modal-foot">
                <button type="button" class="fq-modal-done" @onclick="CloseAddOr">Done</button>
            </div>
        </div>
    </div>
}

@if (_utilityItem is not null)
{
    <UtilityBillModal Show="true"
                      StallId="@(_utilityItem.StallId ?? Guid.Empty)"
                      StallNo="@StallNoForUtility(_utilityItem)"
                      Occupant="@_utilityItem.Person"
                      Section="@UtilityKindFor(_utilityItem)"
                      Year="@AsOf.Year"
                      Month="@AsOf.Month"
                      OnClose="CloseUtilityBill"
                      OnSaved="OnUtilityBillSaved"
                      RequireUpdateConfirmation="true" />
}

@if (_monthlyPaymentItem is not null)
{
    <div class="fq-modal-overlay" @onclick="CloseMonthlyPayment">
        <div class="fq-modal fq-pay-modal" @onclick:stopPropagation="true">
            <div class="fq-modal-head">
                <div>
                    <div class="fq-modal-title">Record payment — @_monthlyPaymentItem.Person</div>
                    <div class="fq-modal-sub">@_monthlyPaymentItem.Identifier · @_monthlyPaymentItem.Facility · @_monthlyPaymentItem.Reason</div>
                </div>
                <button type="button" class="fq-modal-x" @onclick="CloseMonthlyPayment" aria-label="Close">&times;</button>
            </div>

            <div class="fq-modal-body">
                @if (_monthlyPaymentLoading)
                {
                    <div class="fq-or-state">Loading open billing months…</div>
                }
                else if (_monthlyPaymentError is not null && _monthlyPaymentRows.Count == 0)
                {
                    <div class="fq-or-state fq-or-error">@_monthlyPaymentError</div>
                }
                else if (_monthlyPaymentRows.Count == 0)
                {
                    <div class="fq-or-state">No open monthly payment record was found for this account.</div>
                }
                else
                {
                    var selected = SelectedMonthlyPaymentRow;
                    <div class="fq-pay-note">
                        Select the billing month being settled. Arrears and delinquent balances can cover more than one month, so this records one official payment update at a time.
                    </div>

                    <label class="fq-pay-field">
                        <span>Billing period</span>
                        <select class="fq-pay-select" value="@_monthlyPaymentPeriodKey" @onchange="OnMonthlyPaymentPeriodChanged" disabled="@_monthlyPaymentSaving">
                            @foreach (var row in _monthlyPaymentRows)
                            {
                                <option value="@row.Key">@row.Label — @Currency(row.BalanceDue) balance</option>
                            }
                        </select>
                    </label>

                    @if (selected is not null)
                    {
                        <div class="fq-pay-summary">
                            <div><span>Total bill</span><strong>@Currency(selected.TotalBill)</strong></div>
                            <div><span>Already recorded</span><strong>@Currency(selected.AmountPaid)</strong></div>
                            <div><span>Open balance</span><strong class="fq-pay-due">@Currency(selected.BalanceDue)</strong></div>
                        </div>

                        <div class="fq-pay-status-row" role="group" aria-label="Payment status">
                            <button type="button" class="fq-pay-status @(_monthlyPaymentStatus == PaymentStatus.Paid ? "on" : "")"
                                    @onclick="() => SetMonthlyPaymentStatus(PaymentStatus.Paid)"
                                    disabled="@_monthlyPaymentSaving">
                                Paid in full
                            </button>
                            <button type="button" class="fq-pay-status @(_monthlyPaymentStatus == PaymentStatus.Partial ? "on" : "")"
                                    @onclick="() => SetMonthlyPaymentStatus(PaymentStatus.Partial)"
                                    disabled="@_monthlyPaymentSaving">
                                Partial
                            </button>
                        </div>

                        @if (_monthlyPaymentStatus == PaymentStatus.Partial)
                        {
                            <label class="fq-pay-field">
                                <span>Total amount paid after this update</span>
                                <input class="fq-pay-input" type="number" step="0.01" min="0"
                                       value="@_monthlyPaymentAmount"
                                       @oninput="OnMonthlyPaymentAmountInput"
                                       disabled="@_monthlyPaymentSaving" />
                                <small>Current recorded amount: @Currency(selected.AmountPaid). Enter the new total paid for @selected.Label, not only the added cash.</small>
                            </label>
                        }

                        <label class="fq-pay-field">
                            <span>Official receipt number</span>
                            <input class="fq-pay-input" type="text" maxlength="30" placeholder="e.g. OR-2026-001"
                                   @bind="_monthlyPaymentOr"
                                   @bind:event="oninput"
                                   disabled="@_monthlyPaymentSaving" />
                        </label>

                        <label class="fq-pay-field">
                            <span>Remarks <em>optional</em></span>
                            <input class="fq-pay-input" type="text" maxlength="200" placeholder="e.g. Paid at @Branding.OfficeAcronym office"
                                   @bind="_monthlyPaymentRemarks"
                                   @bind:event="oninput"
                                   disabled="@_monthlyPaymentSaving" />
                        </label>

                        @if (_monthlyPaymentError is not null)
                        {
                            <div class="fq-pay-error">@_monthlyPaymentError</div>
                        }

                        @if (_monthlyPaymentConfirming)
                        {
                            <div class="fq-pay-confirm">
