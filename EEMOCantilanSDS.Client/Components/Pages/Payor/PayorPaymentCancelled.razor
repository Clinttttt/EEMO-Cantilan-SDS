@page "/payor/payment/cancelled"
@layout PayorLayout
@attribute [AllowAnonymous]

<PageTitle>@Branding.OfficeAcronym — Payment Cancelled</PageTitle>

<div class="pp-page-title">Payment cancelled</div>

<div class="pp-card pp-detail-card">
    <p style="margin:0;color:var(--text-subtle);">
        Your payment was not completed and nothing was charged. You can try again anytime from your balances.
    </p>
</div>

<a class="pp-pay-cta" href="/payor/balances">Back to balances</a>

<div class="pp-foot">@Branding.OfficeAcronym Revenue Collection · Municipality of @Branding.Municipality, @Branding.Province</div>
