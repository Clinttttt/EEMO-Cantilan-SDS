@page "/payor/activate"
@layout PayorLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using EEMOCantilanSDS.Application.Command.Auth.PayorAuth.Activate
@inject PayorAuthService PayorAuth

<PageTitle>EEMO — Activate Account</PageTitle>

<div class="pp-auth">
    <div class="pp-auth-card">
        <div class="pp-auth-title">Activate your account</div>
        <div class="pp-auth-sub">Use the one-time code on your bill and the contact number on file.</div>

        <label class="pp-field">
            <span class="pp-field-label">Full Name</span>
            <input class="pp-input" type="text" placeholder="Name on your account" @bind="FullName" />
        </label>

        <label class="pp-field">
            <span class="pp-field-label">Activation Code</span>
            <input class="pp-input pp-input-mono" type="text" placeholder="XXXX-XXXX" @bind="Code" />
        </label>

        <label class="pp-field">
            <span class="pp-field-label">Registered Mobile No.</span>
            <input class="pp-input" type="tel" inputmode="numeric" placeholder="09xx xxx xxxx" @bind="Contact" />
        </label>

        <div class="pp-divider-soft"></div>

        <label class="pp-field">
            <span class="pp-field-label">@PasswordLabel</span>
            <input class="pp-input" type="password" placeholder="@PasswordPlaceholder" @bind="Password" />
        </label>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="pp-auth-error">@Error</div>
        }

        <button class="pp-auth-btn" type="button" disabled="@Busy" @onclick="Activate">
            @(Busy ? "Activating…" : "Activate & Continue")
        </button>

        <div class="pp-auth-alt">
            Already activated?
            <a class="pp-link" href="/payor/login">Sign in</a>
        </div>
    </div>

    <div class="pp-auth-foot">
        Your activation code is printed on your latest statement of account.
    </div>
</div>

@code {
    private string FullName = string.Empty;
    private string Code = string.Empty;
    private string Contact = string.Empty;
    private string Password = string.Empty;
    private string? Error;
    private bool Busy;
    private bool MaybeReturning;

    // The "existing account" hint is driven ONLY by the server's response (below), never guessed from
    // the phone number — a first-time payor must see "Create Password", not "existing password".
    private string PasswordLabel => MaybeReturning ? "Password (existing account)" : "Create Password";
    private string PasswordPlaceholder => MaybeReturning ? "Your existing password" : "At least 8 characters";

    private async Task Activate()
    {
        Error = null;

        if (string.IsNullOrWhiteSpace(FullName) || string.IsNullOrWhiteSpace(Code)
            || string.IsNullOrWhiteSpace(Contact) || string.IsNullOrWhiteSpace(Password))
        {
            Error = "Please complete all fields.";
            return;
        }

        if (Password.Length < 8)
        {
            Error = "Password must be at least 8 characters.";
            return;
        }

        Busy = true;
        var (ok, serverError) = await PayorAuth.ActivateWithErrorAsync(new ActivatePayorAccountCommand(
            Code.Trim(), Contact.Trim(), FullName.Trim(), Password));
        Busy = false;

        if (!ok)
        {
            // Surface the exact server message (e.g. wrong password for existing account, expired code).
            Error = serverError ?? "Activation failed. Check your code and mobile number.";
            // If it's the "existing account" message, adjust the hint.
            if (serverError is not null && serverError.Contains("existing password", StringComparison.OrdinalIgnoreCase))
                MaybeReturning = true;
        }
    }
}
