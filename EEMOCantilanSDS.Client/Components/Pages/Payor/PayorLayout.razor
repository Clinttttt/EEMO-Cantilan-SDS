@using EEMOCantilanSDS.Client.Securities
@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Nav
@inject PayorAuthService PayorAuth

<div class="pp-shell @(ShowNav ? "" : "pp-shell-auth")">

    <header class="pp-appbar">
        <div class="pp-appbar-inner">
            <div class="pp-brand">
                <img class="pp-seal" src="@Branding.SealPath" alt="@Branding.Municipality seal" />
                <div class="pp-brand-text">
                    <span class="pp-eyebrow">@Branding.OfficeAcronym · Municipality of @Branding.Municipality</span>
                    <span class="pp-title">Payor Portal</span>
                </div>
            </div>
            @if (ShowNav)
            {
                <button class="pp-signout" type="button" title="Sign out" @onclick="SignOut">
                    <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                </button>
            }
        </div>
    </header>

    <main class="pp-main @(ShowNav ? "pp-main-nav" : "")">
        @Body
    </main>

    @if (ShowNav)
    {
        <EEMOCantilanSDS.Client.Components.Pages.Payor.PayorOrToaster />
    }

    @if (ShowNav)
    {
        <EEMOCantilanSDS.Client.Components.Shared.SessionGuard LoginPath="/payor/login" LogoutEndpoint="/api/payorauthproxy/logout" />
    }

    @if (ShowNav)
    {
        <nav class="pp-tabbar">
            <div class="pp-tabbar-inner">
                <NavLink class="pp-tab" href="/payor" Match="NavLinkMatch.All">
                    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                    <span>Home</span>
                </NavLink>
                <NavLink class="pp-tab" href="/payor/balances">
                    <svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2" /><line x1="2" y1="10" x2="22" y2="10" /></svg>
                    <span>Balances</span>
                </NavLink>
                <NavLink class="pp-tab" href="/payor/history">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><polyline points="12 7 12 12 15 14" /></svg>
                    <span>History</span>
                </NavLink>
                <NavLink class="pp-tab" href="/payor/profile">
                    <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                    <span>Profile</span>
                </NavLink>
            </div>
        </nav>
    }
</div>

@code {
    private bool ShowNav = true;

    protected override void OnInitialized()
    {
        Nav.LocationChanged += OnLocationChanged;
        UpdateNav();
    }

    // Load the signed-in LGU's branding (office acronym / municipality / seal) once per circuit so the
    // payor shell shows the correct tenant. Fails safe: on error the BrandingState fallbacks (Cantilan)
    // remain, so the default tenant is byte-for-byte unchanged.
    protected override async Task OnInitializedAsync()
    {
        await Branding.EnsureLoadedAsync();
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        UpdateNav();
        StateHasChanged();
    }

    // Auth pages (login / activate) render without the bottom nav + sign-out.
    private void UpdateNav()
    {
        var path = new Uri(Nav.Uri).AbsolutePath.ToLowerInvariant();
        ShowNav = !path.Contains("/payor/login") && !path.Contains("/payor/activate");
    }

    public void Dispose() => Nav.LocationChanged -= OnLocationChanged;

    private async Task SignOut() => await PayorAuth.LogoutAsync();
}
