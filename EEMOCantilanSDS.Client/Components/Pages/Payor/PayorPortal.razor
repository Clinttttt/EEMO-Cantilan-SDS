@page "/payor"
@layout PayorLayout
@attribute [Authorize(Roles = "Payor")]
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))
@using System.Security.Claims
@using EEMOCantilanSDS.Application.Dtos.Payors
@using Microsoft.AspNetCore.Components.Authorization
@inject IPayorApiClient PayorApi
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>EEMO — Payor Portal</PageTitle>

@if (Loading)
{
    <div class="pp-empty">Loading your account…</div>
}
else
{
    <div class="pp-greeting">
        <div class="pp-hello">Hi, <strong>@Name</strong></div>
        <div class="pp-hello-sub">Welcome to your collections portal</div>
    </div>

    <section class="pp-hero">
        <div class="pp-hero-label">Total Outstanding Balance</div>
        <div class="pp-hero-amount">@PayorFormat.Currency(TotalOutstanding)</div>
        <div class="pp-hero-meta">
            @UnpaidStalls account@(UnpaidStalls == 1 ? "" : "s") with a balance
        </div>
        <a class="pp-pay-cta" href="/payor/balances">
            <svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2" /><line x1="2" y1="10" x2="22" y2="10" /></svg>
            View &amp; Pay Balances
        </a>
        <div class="pp-hero-note">Official Receipt is issued by EEMO once your payment is validated.</div>
    </section>

    <div class="pp-section-label">Your Account@(Balances.Count == 1 ? "" : "s")</div>
    @if (Balances.Count == 0)
    {
        <div class="pp-empty">No linked stalls yet.</div>
    }
    else
    {
        @foreach (var acct in Balances)
        {
            <div class="pp-card pp-acct">
                <div class="pp-acct-icon">
                    <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
                </div>
                <div class="pp-acct-info">
                    <div class="pp-acct-facility">@PayorFormat.FacilityName(acct.Facility)</div>
                    <div class="pp-acct-sub">Stall @acct.StallNo · @acct.Occupant</div>
                </div>
                <div class="pp-acct-rate">
                    <span class="pp-acct-rate-val">@PayorFormat.Currency(acct.MonthlyRate)</span>
                    <span class="pp-acct-rate-key">/ month</span>
                </div>
            </div>
        }
    }

    <div class="pp-foot">
        EEMO Revenue Collection · Municipality of Cantilan, Surigao del Sur
    </div>
}

@code {
    private bool Loading = true;
    private string Name = "there";
    private IReadOnlyList<PayorStallBalanceDto> Balances = Array.Empty<PayorStallBalanceDto>();

    private decimal TotalOutstanding => Balances.Sum(b => b.OutstandingBalance);
    private int UnpaidStalls => Balances.Count(b => b.OutstandingBalance > 0);

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/payor/login", forceLoad: true);
            return;
        }

        Name = state.User.FindFirst(ClaimTypes.Name)?.Value ?? "there";

        var result = await PayorApi.GetBalancesAsync();
        if (result.IsSuccess && result.Value is not null)
            Balances = result.Value;

        Loading = false;
    }
}
