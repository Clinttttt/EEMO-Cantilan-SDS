@page "/payor"
@layout PayorLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using static EEMOCantilanSDS.Client.Components.Pages.Payor.PayorDemoData

<PageTitle>EEMO — Payor Portal</PageTitle>

<div class="pp-greeting">
    <div class="pp-hello">Hi, <strong>@Payor.Name</strong></div>
    <div class="pp-hello-sub">Welcome to your collections portal</div>
</div>

<section class="pp-hero">
    <div class="pp-hero-label">Total Outstanding Balance</div>
    <div class="pp-hero-amount">@FormatCurrency(TotalOutstanding)</div>
    <div class="pp-hero-meta">
        @Outstanding.Count unpaid period@(Outstanding.Count == 1 ? "" : "s") ·
        Earliest due <strong>@EarliestDue.ToString("MMM d, yyyy")</strong>
    </div>
    <a class="pp-pay-cta" href="/payor/balances">
        <svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2" /><line x1="2" y1="10" x2="22" y2="10" /></svg>
        Pay with GCash
    </a>
    <div class="pp-hero-note">Official Receipt is issued by EEMO once your payment is validated.</div>
</section>

<div class="pp-section-label">Your Account@(Accounts.Count == 1 ? "" : "s")</div>
@foreach (var acct in Accounts)
{
    <div class="pp-card pp-acct">
        <div class="pp-acct-icon">
            <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
        </div>
        <div class="pp-acct-info">
            <div class="pp-acct-facility">@acct.Facility</div>
            <div class="pp-acct-sub">Stall @acct.StallNo · @acct.Occupant</div>
        </div>
        <div class="pp-acct-rate">
            <span class="pp-acct-rate-val">@FormatCurrency(acct.MonthlyRate)</span>
            <span class="pp-acct-rate-key">/ month</span>
        </div>
    </div>
}

<div class="pp-section-head">
    <span class="pp-section-label pp-section-label-inline">Recent Activity</span>
    <a class="pp-link" href="/payor/history">View all</a>
</div>
<div class="pp-card pp-history">
    @foreach (var h in History.Take(3))
    {
        <div class="pp-hist-row">
            <div class="pp-hist-left">
                <div class="pp-hist-period">@h.Period</div>
                <div class="pp-hist-sub">
                    @h.Date.ToString("MMM d, yyyy")
                    @if (!string.IsNullOrWhiteSpace(h.OrNumber))
                    {
                        <span class="pp-hist-or">· OR @h.OrNumber</span>
                    }
                </div>
            </div>
            <div class="pp-hist-right">
                <span class="pp-hist-amount">@FormatCurrency(h.Amount)</span>
                <span class="pp-badge @StatusClass(h.Status)">@h.Status</span>
            </div>
        </div>
    }
</div>

<div class="pp-foot">
    EEMO Revenue Collection · Municipality of Cantilan, Surigao del Sur
</div>
