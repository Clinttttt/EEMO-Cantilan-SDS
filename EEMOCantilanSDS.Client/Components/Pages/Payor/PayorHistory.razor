@page "/payor/history"
@layout PayorLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using System.Security.Claims
@using EEMOCantilanSDS.Application.Dtos.Payments
@using EEMOCantilanSDS.Domain.Enums
@using Microsoft.AspNetCore.Components.Authorization
@inject IPayorApiClient PayorApi
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject EEMOCantilanSDS.Client.Securities.PayorRealtimeNotifier Realtime
@implements IDisposable

<PageTitle>EEMO — Payment History</PageTitle>

<div class="pp-page-title">Payment History</div>

@if (Loading)
{
    <div class="pp-empty">Loading history…</div>
}
else
{
    <div class="pp-card pp-history">
        @foreach (var h in Rows)
        {
            var paid = h.Item.Status == PaymentStatus.Paid;
            <div class="pp-hist-row @(paid ? "pp-hist-click" : "")" @onclick="() => OpenReceipt(h)">
                <div class="pp-hist-left">
                    <div class="pp-hist-period">@h.Item.Period</div>
                    <div class="pp-hist-sub">
                        @PayorFormat.FacilityName(h.Facility) · Stall @h.StallNo
                        @if (!string.IsNullOrWhiteSpace(h.Item.ORNumber))
                        {
                            <span class="pp-hist-or">· OR @h.Item.ORNumber</span>
                        }
                        else if (AwaitingOr(h.Item))
                        {
                            <span class="pp-hist-or">· awaiting OR</span>
                        }
                    </div>
                </div>
                <div class="pp-hist-right">
                    <span class="pp-hist-amount">@PayorFormat.Currency(RowAmount(h.Item))</span>
                    <span class="pp-badge @PayorFormat.StatusClass(h.Item.Status)">@PayorFormat.StatusText(h.Item.Status)</span>
                    @if (AwaitingOr(h.Item))
                    {
                        <span class="pp-badge badge-awaiting">OR pending</span>
                    }
                </div>
                @if (paid)
                {
                    <svg class="pp-hist-chev" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                }
            </div>
        }
        @if (Rows.Count == 0)
        {
            <div class="pp-empty-inline">No payments recorded yet.</div>
        }
    </div>

    <div class="pp-foot">
        Tap a paid item to view its receipt.
    </div>
}

@if (Selected is not null)
{
    <div class="pp-overlay" @onclick="CloseReceipt">
        <div class="pp-sheet pp-receipt-sheet" @onclick:stopPropagation="true">
            <div class="pp-sheet-handle"></div>
            <div class="pp-receipt">
                <div class="pp-rcpt-head">
                    <img class="pp-rcpt-seal" src="/images/LGU_CANTILAN_LOGO.jpg" alt="EEMO seal" />
                    <div class="pp-rcpt-gov">Republic of the Philippines</div>
                    <div class="pp-rcpt-org">Economic Enterprise &amp; Management Office</div>
                    <div class="pp-rcpt-muni">Municipality of Cantilan, Surigao del Sur</div>
                    <div class="pp-rcpt-doc">@PayorFormat.FacilityName(Selected.Facility)</div>
                    @if (AwaitingOr(Selected.Item))
                    {
                        <div class="pp-rcpt-tag provisional">Provisional · Awaiting Official Receipt</div>
                    }
                    else
                    {
                        <div class="pp-rcpt-tag official">Official Receipt</div>
                    }
                </div>

                <div class="pp-rcpt-divider"></div>

                <div class="pp-rcpt-meta">
                    <div class="pp-rcpt-row"><span>OR No.</span><strong>@(string.IsNullOrWhiteSpace(Selected.Item.ORNumber) ? "Pending validation" : Selected.Item.ORNumber)</strong></div>
                    <div class="pp-rcpt-row"><span>Date</span><strong>@(Selected.Item.PaidAt?.ToString("MMMM d, yyyy") ?? "—")</strong></div>
                    <div class="pp-rcpt-row"><span>Payor</span><strong>@Name</strong></div>
                    <div class="pp-rcpt-row"><span>Account</span><strong>Stall @Selected.StallNo</strong></div>
                    <div class="pp-rcpt-row"><span>Period</span><strong>@Selected.Item.Period</strong></div>
                </div>

                <div class="pp-rcpt-divider"></div>

                <div class="pp-rcpt-total">
                    <span>Amount Paid</span>
                    <span>@PayorFormat.Currency(Selected.Item.AmountPaid)</span>
                </div>

                <div class="pp-rcpt-divider dashed"></div>

                <div class="pp-rcpt-foot">
                    <div class="pp-rcpt-note">
                        @if (AwaitingOr(Selected.Item))
                        {
                            <text>Your payment has been received. The Official Receipt (OR) number will appear here once EEMO validates and encodes it. Keep this acknowledgment in the meantime.</text>
                        }
                        else
                        {
                            <text>This acknowledges receipt of the amount stated above. Keep for your records.</text>
                        }
                    </div>
                </div>
            </div>

            <div class="pp-receipt-close-row">
                <button class="pp-btn-pay" type="button" @onclick="CloseReceipt">Close</button>
            </div>
        </div>
    </div>
}

@code {
    private sealed record Row(FacilityCode Facility, string StallNo, PaymentHistoryDto Item);

    private bool Loading = true;
    private string Name = "—";
    private List<Row> Rows = new();
    private Row? Selected;

    private static decimal RowAmount(PaymentHistoryDto h) =>
        h.Status == PaymentStatus.Unpaid ? h.TotalBill : h.AmountPaid;

    // A paid record with no OR yet = online payment whose Official Receipt hasn't been encoded by staff.
    // The receipt shows as a provisional acknowledgment until EEMO encodes the OR.
    private static bool AwaitingOr(PaymentHistoryDto h) =>
        h.Status == PaymentStatus.Paid && string.IsNullOrWhiteSpace(h.ORNumber);

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/payor/login", forceLoad: true);
            return;
        }

        Name = state.User.FindFirst(ClaimTypes.Name)?.Value ?? "—";

        // Refresh live when staff encode an OR for this payor (provisional → official) — no manual reload.
        Realtime.OrIssued += OnOrIssued;

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        var rows = new List<Row>();
        var balances = await PayorApi.GetBalancesAsync();
        if (balances.IsSuccess && balances.Value is not null)
        {
            foreach (var stall in balances.Value)
            {
                var history = await PayorApi.GetHistoryAsync(stall.StallId);
                if (history.IsSuccess && history.Value is not null)
                    rows.AddRange(history.Value.Select(h => new Row(stall.Facility, stall.StallNo, h)));
            }
        }

        // Most recent first; records without a PaidAt (unpaid periods) sort last.
        Rows = rows.OrderByDescending(r => r.Item.PaidAt ?? DateTime.MinValue).ToList();
        Loading = false;
    }

    private void OnOrIssued()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadAsync();
            StateHasChanged();
        });
    }

    private void OpenReceipt(Row row)
    {
        if (row.Item.Status == PaymentStatus.Paid) Selected = row;
    }

    private void CloseReceipt() => Selected = null;

    public void Dispose() => Realtime.OrIssued -= OnOrIssued;
}
