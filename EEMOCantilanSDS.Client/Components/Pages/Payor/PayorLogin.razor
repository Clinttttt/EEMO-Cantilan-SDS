@page "/payor/login"
@layout PayorLayout
@attribute [AllowAnonymous]
@rendermode @(new Microsoft.AspNetCore.Components.Web.InteractiveServerRenderMode(prerender: false))
@inject PayorAuthService PayorAuth

<PageTitle>EEMO — Payor Sign in</PageTitle>

<div class="pp-auth">
    <div class="pp-auth-card">
        <div class="pp-auth-title">Sign in</div>
        <div class="pp-auth-sub">Access your balances and pay online.</div>

        <label class="pp-field">
            <span class="pp-field-label">Registered Mobile No.</span>
            <input class="pp-input" type="tel" inputmode="numeric" placeholder="09xx xxx xxxx" @bind="Contact" />
        </label>

        <label class="pp-field">
            <span class="pp-field-label">Password</span>
            <input class="pp-input" type="password" placeholder="••••••••" @bind="Password" />
        </label>

        @if (!string.IsNullOrEmpty(Error))
        {
            <div class="pp-auth-error">@Error</div>
        }

        <button class="pp-auth-btn" type="button" disabled="@Busy" @onclick="SignIn">
            @(Busy ? "Signing in…" : "Sign in")
        </button>

        <div class="pp-auth-alt">
            First time here?
            <a class="pp-link" href="/payor/activate">Activate your account</a>
        </div>
    </div>

    <div class="pp-auth-foot">
        EEMO Revenue Collection · Municipality of Cantilan, Surigao del Sur
    </div>
</div>

@code {
    private string Contact = string.Empty;
    private string Password = string.Empty;
    private string? Error;
    private bool Busy;

    private async Task SignIn()
    {
        Error = null;

        if (string.IsNullOrWhiteSpace(Contact) || string.IsNullOrWhiteSpace(Password))
        {
            Error = "Enter your mobile number and password.";
            return;
        }

        Busy = true;
        var ok = await PayorAuth.LoginAsync(Contact.Trim(), Password);
        Busy = false;

        // Login failures are intentionally generic (non-enumerating) — never reveal whether the
        // number exists; the server returns no message for 401/404 by design.
        if (!ok)
            Error = "Invalid mobile number or password.";
    }
}
