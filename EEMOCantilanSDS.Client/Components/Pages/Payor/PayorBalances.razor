@page "/payor/balances"
@layout PayorLayout
@attribute [AllowAnonymous]
@rendermode InteractiveServer
@using static EEMOCantilanSDS.Client.Components.Pages.Payor.PayorDemoData

<PageTitle>EEMO — Balances</PageTitle>

<div class="pp-page-title">Outstanding Balances</div>

<section class="pp-hero pp-hero-compact">
    <div class="pp-hero-label">Total Due</div>
    <div class="pp-hero-amount">@FormatCurrency(TotalOutstanding)</div>
    <div class="pp-hero-meta">Earliest due <strong>@EarliestDue.ToString("MMM d, yyyy")</strong></div>
    @if (Outstanding.Any())
    {
        <button class="pp-pay-cta" type="button" @onclick="() => OpenPay(null)">
            <svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2" /><line x1="2" y1="10" x2="22" y2="10" /></svg>
            Pay All with GCash
        </button>
    }
</section>

<div class="pp-section-label">Per Period</div>
@if (!Outstanding.Any())
{
    <div class="pp-empty">You're all paid up. Thank you!</div>
}
else
{
    @foreach (var item in Outstanding)
    {
        <div class="pp-card pp-bal">
            <div class="pp-bal-left">
                <div class="pp-bal-top">
                    <span class="pp-bal-period">@item.Period</span>
                    <span class="pp-badge @StatusClass(item.Status)">@item.Status</span>
                </div>
                <div class="pp-bal-sub">@item.Facility · Due @item.DueDate.ToString("MMM d, yyyy")</div>
            </div>
            <div class="pp-bal-right">
                <span class="pp-bal-amount">@FormatCurrency(item.Amount)</span>
                <button class="pp-bal-pay" type="button" @onclick="() => OpenPay(item)">Pay</button>
            </div>
        </div>
    }
}

<div class="pp-foot">Your balance updates automatically once GCash confirms the payment.</div>

@if (ShowPay)
{
    <div class="pp-overlay" @onclick="ClosePay">
        <div class="pp-sheet" @onclick:stopPropagation="true">
            <div class="pp-sheet-handle"></div>
            <div class="pp-sheet-title">Pay with GCash</div>
            <div class="pp-sheet-sub">You'll be securely redirected to GCash via PayMongo.</div>

            <div class="pp-sheet-summary">
                <div class="pp-sum-row"><span>Account</span><strong>@Accounts[0].Facility · Stall @Accounts[0].StallNo</strong></div>
                @if (PaySelection is not null)
                {
                    <div class="pp-sum-row"><span>Period</span><strong>@PaySelection.Period</strong></div>
                }
                else
                {
                    <div class="pp-sum-row"><span>Periods</span><strong>@Outstanding.Count unpaid</strong></div>
                }
                <div class="pp-sum-divider"></div>
                <div class="pp-sum-row pp-sum-total"><span>Amount due</span><strong>@FormatCurrency(PayAmount)</strong></div>
            </div>

            <div class="pp-sheet-note">
                Your Official Receipt (OR) will be issued by EEMO once the payment is validated.
            </div>

            @if (DemoNotice)
            {
                <div class="pp-demo-note">Demo preview — the GCash gateway isn't connected yet.</div>
            }

            <div class="pp-sheet-btns">
                <button class="pp-btn-ghost" type="button" @onclick="ClosePay">Cancel</button>
                <button class="pp-btn-pay" type="button" @onclick="() => DemoNotice = true">
                    <svg viewBox="0 0 24 24"><rect x="2" y="5" width="20" height="14" rx="2" /><line x1="2" y1="10" x2="22" y2="10" /></svg>
                    Proceed to GCash
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool ShowPay;
    private bool DemoNotice;
    private OutstandingItem? PaySelection;
    private decimal PayAmount => PaySelection?.Amount ?? TotalOutstanding;

    private void OpenPay(OutstandingItem? item)
    {
        PaySelection = item;
        DemoNotice = false;
        ShowPay = true;
    }

    private void ClosePay()
    {
        ShowPay = false;
        PaySelection = null;
        DemoNotice = false;
    }
}
