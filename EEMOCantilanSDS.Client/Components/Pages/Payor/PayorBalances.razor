@page "/payor/balances"
@layout PayorLayout
@attribute [Authorize(Roles = "Payor")]
@using EEMOCantilanSDS.Application.Command.OnlinePayments.Initiate
@using EEMOCantilanSDS.Application.Dtos.Payors
@using Microsoft.AspNetCore.Components.Authorization
@inject IPayorApiClient PayorApi
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>EEMO — Balances</PageTitle>

<div class="pp-page-title">Outstanding Balances</div>

@if (Loading)
{
    <div class="pp-empty">Loading balances…</div>
}
else
{
    <section class="pp-hero pp-hero-compact">
        <div class="pp-hero-label">Total Due</div>
        <div class="pp-hero-amount">@PayorFormat.Currency(TotalDue)</div>
        <div class="pp-hero-meta">@Items.Count unpaid period@(Items.Count == 1 ? "" : "s")</div>
    </section>

    <div class="pp-section-label">Per Period</div>
    @if (Items.Count == 0)
    {
        <div class="pp-empty">You're all paid up. Thank you!</div>
    }
    else
    {
        @foreach (var item in Items)
        {
            <div class="pp-card pp-bal">
                <div class="pp-bal-left">
                    <div class="pp-bal-top">
                        <span class="pp-bal-period">@item.Period</span>
                        <span class="pp-badge badge-unpaid">Unpaid</span>
                    </div>
                    <div class="pp-bal-sub">@PayorFormat.FacilityName(item.Facility) · Stall @item.StallNo</div>
                </div>
                <div class="pp-bal-right">
                    <span class="pp-bal-amount">@PayorFormat.Currency(item.BalanceDue)</span>
                    <button class="pp-bal-pay" type="button" disabled="@Busy" @onclick="() => Pay(item)">
                        @(PayingId == ItemKey(item) ? "…" : "Pay")
                    </button>
                </div>
            </div>
        }
    }

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="pp-demo-note">@Error</div>
    }

    <div class="pp-foot">
        You'll be redirected to PayMongo Checkout to pay via <strong>QR&nbsp;Ph</strong> — scan the QR with any
        supported bank or e-wallet app. On one phone, screenshot the QR and upload it from your app's QR scanner.
        Your balance updates automatically once payment is confirmed; the Official Receipt is issued by EEMO afterwards.
    </div>
}

@code {
    private bool Loading = true;
    private bool Busy;
    private string? PayingId;
    private string? Error;
    private IReadOnlyList<PayorPayableItemDto> Items = Array.Empty<PayorPayableItemDto>();

    private decimal TotalDue => Items.Sum(i => i.BalanceDue);

    private static string ItemKey(PayorPayableItemDto i) => $"{i.StallId}:{i.Year}:{i.Month}";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/payor/login", forceLoad: true);
            return;
        }

        await LoadAsync();
        Loading = false;
    }

    private async Task LoadAsync()
    {
        var result = await PayorApi.GetPayableItemsAsync();
        if (result.IsSuccess && result.Value is not null)
            Items = result.Value;
    }

    private async Task Pay(PayorPayableItemDto item)
    {
        Error = null;
        Busy = true;
        PayingId = ItemKey(item);

        var result = await PayorApi.InitiatePaymentAsync(new InitiateOnlinePaymentCommand(item.StallId, item.Year, item.Month));

        if (result.IsSuccess && result.Value is not null && !string.IsNullOrWhiteSpace(result.Value.CheckoutUrl))
        {
            // Hand off to the hosted PayMongo (QR Ph) checkout.
            Nav.NavigateTo(result.Value.CheckoutUrl, forceLoad: true);
            return;
        }

        Busy = false;
        PayingId = null;
        Error = result.Error ?? "Unable to start the payment. Please try again.";
    }
}
