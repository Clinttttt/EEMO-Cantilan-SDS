@page "/payor/balances"
@layout PayorLayout
@attribute [Authorize(Roles = "Payor")]
@using EEMOCantilanSDS.Application.Command.OnlinePayments.Initiate
@using EEMOCantilanSDS.Application.Dtos.Payors
@using Microsoft.AspNetCore.Components.Authorization
@inject IPayorApiClient PayorApi
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav

<PageTitle>@Branding.OfficeAcronym — Balances</PageTitle>

<div class="pp-page-title">Outstanding Balances</div>

@if (Loading)
{
    <div class="pp-empty">Loading balances…</div>
}
else
{
    <section class="pp-hero pp-hero-compact">
        <div class="pp-hero-label">Total Due</div>
        <div class="pp-hero-amount">@PayorFormat.Currency(TotalDue)</div>
        <div class="pp-hero-meta">@Items.Count unpaid period@(Items.Count == 1 ? "" : "s")</div>
    </section>

    <div class="pp-section-label">Per Period</div>
    @if (Items.Count == 0)
    {
        <div class="pp-empty">You're all paid up. Thank you!</div>
    }
    else
    {
        @foreach (var item in Items)
        {
            <div class="pp-card pp-bal">
                <div class="pp-bal-left">
                    <div class="pp-bal-top">
                        <span class="pp-bal-period">@item.Period</span>
                        <span class="pp-badge badge-unpaid">Unpaid</span>
                    </div>
                    <div class="pp-bal-sub">@PayorFormat.FacilityName(item.Facility) · Stall @item.StallNo@(KindLabel(item.Kind))</div>
                </div>
                <div class="pp-bal-right">
                    @if (item.Kind == PayorPayableKind.NpmFish)
                    {
                        <span class="pp-bal-amount">@PayorFormat.Currency(item.BaseFee ?? 0m)<small> + @PayorFormat.Currency(item.FishRatePerKilo ?? 0m)/kg</small></span>
                        <button class="pp-bal-pay" type="button" disabled="@Busy" @onclick="() => OpenFish(item)">Declare</button>
                    }
                    else
                    {
                        <span class="pp-bal-amount">@PayorFormat.Currency(item.BalanceDue)</span>
                        <button class="pp-bal-pay" type="button" disabled="@Busy" @onclick="() => Pay(item)">
                            @(PayingId == ItemKey(item) ? "…" : "Pay")
                        </button>
                    }
                </div>
            </div>
        }
    }

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="pp-demo-note">@Error</div>
    }

    @if (FishItem is not null)
    {
        <div class="pp-overlay" @onclick="CloseFish">
            <div class="pp-sheet" @onclick:stopPropagation="true">
                <div class="pp-sheet-handle"></div>
                <div class="pp-sheet-title">Fish daily fee</div>
                <div class="pp-sheet-sub">
                    Stall @FishItem.StallNo · declare the kilos you sold on an uncollected day and pay it online
                    (for when the collector wasn't around). The collector still weighs it in person when present.
                </div>

                <label class="pp-field">
                    <span class="pp-field-label">Day</span>
                    <select class="pp-input" @bind="FishDay">
                        <option value="">Select a day…</option>
                        @foreach (var d in FishItem.UncollectedDays ?? Array.Empty<DateOnly>())
                        {
                            <option value="@d.Day">@d.ToString("MMM d (ddd)")</option>
                        }
                    </select>
                </label>

                <label class="pp-field">
                    <span class="pp-field-label">Kilos sold that day</span>
                    <input class="pp-input" type="number" min="0" step="0.01" placeholder="e.g. 54"
                           @bind="FishKilos" @bind:event="oninput" />
                </label>

                <div class="pp-sheet-summary">
                    <div class="pp-sum-row"><span>Base daily fee</span><strong>@PayorFormat.Currency(FishItem.BaseFee ?? 0m)</strong></div>
                    <div class="pp-sum-row"><span>@((FishKilos ?? 0m).ToString("0.##")) kg × @PayorFormat.Currency(FishItem.FishRatePerKilo ?? 0m)</span><strong>@PayorFormat.Currency((FishKilos ?? 0m) * (FishItem.FishRatePerKilo ?? 0m))</strong></div>
                    <div class="pp-sum-divider"></div>
                    <div class="pp-sum-row pp-sum-total"><span>Total due</span><strong>@PayorFormat.Currency(FishAmount)</strong></div>
                </div>

                @if (!string.IsNullOrEmpty(FishError))
                {
                    <div class="pp-demo-note">@FishError</div>
                }

                <div class="pp-sheet-btns">
                    <button class="pp-btn-ghost" type="button" @onclick="CloseFish" disabled="@Busy">Cancel</button>
                    <button class="pp-btn-pay" type="button" disabled="@(Busy || FishDay is null || FishKilos is null)" @onclick="PayFish">
                        @(Busy ? "…" : "Pay")
                    </button>
                </div>
                <div class="pp-sheet-note">
                    You'll be sent to PayMongo Checkout (QR Ph). Your Official Receipt is issued by @Branding.OfficeAcronym after the
                    payment is confirmed. Declared kilos are recorded for that day pending @Branding.OfficeAcronym's receipt.
                </div>
            </div>
        </div>
    }

    <div class="pp-foot">
        You'll be redirected to PayMongo Checkout to pay via <strong>QR&nbsp;Ph</strong> — scan the QR with any
        supported bank or e-wallet app. On one phone, screenshot the QR and upload it from your app's QR scanner.
        Your balance updates automatically once payment is confirmed; the Official Receipt is issued by EEMO afterwards.
    </div>
}

@code {
    private bool Loading = true;
    private bool Busy;
    private string? PayingId;
    private string? Error;
    private IReadOnlyList<PayorPayableItemDto> Items = Array.Empty<PayorPayableItemDto>();

    private decimal TotalDue => Items.Sum(i => i.BalanceDue);

    private static string ItemKey(PayorPayableItemDto i) => $"{i.StallId}:{i.Year}:{i.Month}:{i.Kind}";

    // NPM has multiple payable items per month (daily fees / utilities / fish) — label them so the payor can tell them apart.
    private static string KindLabel(PayorPayableKind kind) => kind switch
    {
        PayorPayableKind.NpmDaily => " · Daily fees",
        PayorPayableKind.NpmUtility => " · Electricity & Water",
        PayorPayableKind.NpmFish => " · Fish daily fee",
        _ => ""
    };

    // ── Fish-day self-declare (NPM fish section): pick an uncollected day + declare kilos → base + kg × rate ──
    private PayorPayableItemDto? FishItem;
    private int? FishDay;
    private decimal? FishKilos;
    private string? FishError;

    private decimal FishAmount => (FishItem?.BaseFee ?? 0m) + (FishKilos ?? 0m) * (FishItem?.FishRatePerKilo ?? 0m);

    private void OpenFish(PayorPayableItemDto item)
    {
        FishItem = item;
        FishDay = null;
        FishKilos = null;
        FishError = null;
    }

    private void CloseFish()
    {
        FishItem = null;
        FishError = null;
    }

    private async Task PayFish()
    {
        if (FishItem is null || FishDay is null || FishKilos is null) return;
        FishError = null;
        Busy = true;

        var result = await PayorApi.InitiatePaymentAsync(new InitiateOnlinePaymentCommand(
            FishItem.StallId, FishItem.Year, FishItem.Month, PayorPayableKind.NpmFish, FishDay, FishKilos));

        if (result.IsSuccess && result.Value is not null && !string.IsNullOrWhiteSpace(result.Value.CheckoutUrl))
        {
            // Hand off to the hosted PayMongo (QR Ph) checkout.
            Nav.NavigateTo(result.Value.CheckoutUrl, forceLoad: true);
            return;
        }

        Busy = false;
        FishError = result.Error ?? "Unable to start the payment. Please try again.";
    }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/payor/login", forceLoad: true);
            return;
        }

        await LoadAsync();
        Loading = false;
    }

    private async Task LoadAsync()
    {
        var result = await PayorApi.GetPayableItemsAsync();
        if (result.IsSuccess && result.Value is not null)
            Items = result.Value;
    }

    private async Task Pay(PayorPayableItemDto item)
    {
        Error = null;
        Busy = true;
        PayingId = ItemKey(item);

        var result = await PayorApi.InitiatePaymentAsync(new InitiateOnlinePaymentCommand(item.StallId, item.Year, item.Month, item.Kind));

        if (result.IsSuccess && result.Value is not null && !string.IsNullOrWhiteSpace(result.Value.CheckoutUrl))
        {
            // Hand off to the hosted PayMongo (QR Ph) checkout.
            Nav.NavigateTo(result.Value.CheckoutUrl, forceLoad: true);
            return;
        }

        Busy = false;
        PayingId = null;
        Error = result.Error ?? "Unable to start the payment. Please try again.";
    }
}
