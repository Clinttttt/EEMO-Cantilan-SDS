@page "/payor/profile"
@layout PayorLayout
@attribute [Authorize(Roles = "Payor")]
@rendermode InteractiveServer
@using System.Security.Claims
@using EEMOCantilanSDS.Application.Dtos.Payors
@using Microsoft.AspNetCore.Components.Authorization
@inject IPayorApiClient PayorApi
@inject AuthenticationStateProvider AuthState
@inject PayorAuthService PayorAuth
@inject NavigationManager Nav

<PageTitle>EEMO — Profile</PageTitle>

<div class="pp-page-title">Profile</div>

<div class="pp-profile-head">
    <div class="pp-avatar">@Initials</div>
    <div class="pp-profile-name">@Name</div>
    <div class="pp-profile-role">Registered Payor</div>
</div>

<div class="pp-section-label">Contact Details</div>
<div class="pp-card pp-detail-card">
    <div class="pp-detail-row">
        <span class="pp-detail-key">Mobile</span>
        <span class="pp-detail-val">@Contact</span>
    </div>
</div>

<div class="pp-section-label">Linked Account@(Balances.Count == 1 ? "" : "s")</div>
@if (Balances.Count == 0)
{
    <div class="pp-empty">No linked stalls.</div>
}
else
{
    @foreach (var acct in Balances)
    {
        <div class="pp-card pp-acct">
            <div class="pp-acct-icon">
                <svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /><polyline points="9 22 9 12 15 12 15 22" /></svg>
            </div>
            <div class="pp-acct-info">
                <div class="pp-acct-facility">@PayorFormat.FacilityName(acct.Facility)</div>
                <div class="pp-acct-sub">Stall @acct.StallNo</div>
            </div>
        </div>
    }
}

<button class="pp-signout-btn" type="button" @onclick="SignOut">
    <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
    Sign out
</button>

<div class="pp-foot">EEMO Revenue Collection · Municipality of Cantilan</div>

@code {
    private string Name = "—";
    private string Contact = "—";
    private IReadOnlyList<PayorStallBalanceDto> Balances = Array.Empty<PayorStallBalanceDto>();

    private string Initials =>
        string.Concat((Name == "—" ? "" : Name)
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2).Select(p => char.ToUpper(p[0]))) is { Length: > 0 } s ? s : "P";

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true)
        {
            Nav.NavigateTo("/payor/login", forceLoad: true);
            return;
        }

        Name = state.User.FindFirst(ClaimTypes.Name)?.Value ?? "—";
        Contact = state.User.FindFirst("username")?.Value ?? "—";

        var result = await PayorApi.GetBalancesAsync();
        if (result.IsSuccess && result.Value is not null)
            Balances = result.Value;
    }

    private async Task SignOut() => await PayorAuth.LogoutAsync();
}
