@page "/login"
@attribute [AllowAnonymous]

@using EEMOCantilanSDS.Application.Command.Auth.AdminAuth.Login
@using EEMOCantilanSDS.Client.Securities
@using EEMOCantilanSDS.Application.Dtos.Tenancy
@using Microsoft.AspNetCore.WebUtilities
@inject AuthService AuthService
@inject ISetupApiClient SetupApi
@inject IMunicipalitiesApiClient MunicipalitiesApi
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>EEMO — Administrator Login</PageTitle>

<div class="setup-root">

    <!-- ═══════════════════════════════════════
         LEFT PANEL — Branding (identical to AccountSetup)
    ═══════════════════════════════════════ -->
    <div class="setup-left @(_isDefaultBrand ? "" : "setup-left--neutral")">
        <div class="setup-left-inner">
            <div class="setup-seal government-seals">
                <div class="government-logo-card">
                    <img src="@SealPath" alt="@MunicipalityName seal" />
                </div>
                <div class="government-logo-card stalltrack-logo">
                    <img src="/images/stalltrack-final-logo-transparent.png" alt="StallTrack Seal" />
                </div>
            </div>
            <div class="setup-brand">
                <div class="setup-brand-label">Republic of the Philippines</div>
                <div class="setup-brand-city">Municipality of @MunicipalityName</div>
                <div class="setup-brand-title">@OfficeAcronym</div>
                <div class="setup-brand-sub">@OfficeName</div>
            </div>
            <div class="login-secure-access">
                <div class="login-secure-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z" />
                        <rect x="9" y="10" width="6" height="5" rx="1" />
                        <path d="M10.5 10V8.5a1.5 1.5 0 013 0V10" />
                    </svg>
                </div>
                <div>
                    <div class="login-secure-title">Secure Access Portal</div>
                    <p>This system is for authorized @OfficeAcronym personnel only.</p>
                </div>
            </div>
            <div class="setup-left-footer">
                <div class="setup-system-name">Revenue Collection System</div>
                <div class="setup-version">Version 1.0</div>
            </div>
        </div>
    </div>

    <!-- ═══════════════════════════════════════
         RIGHT PANEL — Login Form
    ═══════════════════════════════════════ -->
    <div class="setup-right">
        <div class="setup-form-wrap">

            <section class="login-card" aria-labelledby="login-title">

            <!-- ── Step Indicator ──
                 Only visible when redirected from first-time setup
                 (/login?setup=true)
                 NEVER shown on normal login
            ── -->
            @if (IsFromSetup)
            {
                <div class="setup-step-row">
                    <div class="setup-step completed">
                        <span class="step-dot"></span>
                        <span class="step-label">Administrator Setup</span>
                    </div>
                    <div class="setup-step-line setup-step-line-done"></div>
                    <div class="setup-step active">
                        <span class="step-dot"></span>
                        <span class="step-label">Login</span>
                    </div>
                    <div class="setup-step-line"></div>
                    <div class="setup-step">
                        <span class="step-dot"></span>
                        <span class="step-label">Dashboard</span>
                    </div>
                </div>
            }

            <!-- ── Header ── -->
            <div class="setup-form-header">
                <div class="login-header-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7">
                        <circle cx="12" cy="8" r="3.5" />
                        <path d="M5.5 20c.5-3.5 2.8-5.5 6.5-5.5s6 2 6.5 5.5" />
                    </svg>
                </div>
                <div class="setup-form-title" id="login-title">
                    @(IsFromSetup ? "Sign In to Continue" : "Welcome Back")
                </div>
                <div class="setup-form-desc">
                    @(IsFromSetup
                        ? $"Your administrator account has been created. Sign in to access the {OfficeAcronym} Revenue Collection System."
                        : $"Sign in to access the {OfficeAcronym} Revenue Collection System")
                </div>
            </div>

            <!-- ── Login Form ── -->
            <div class="setup-form">

                <!-- Username -->
                <div class="form-group">
                    <label class="form-label">Username</label>
                    <div class="form-input-wrap @(GetFieldError("Username") != string.Empty ? "form-input-error" : "")">
                        <svg class="form-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                        <input @bind="Username"
                               @bind:event="oninput"
                               @bind:after="OnUsernameChanged"
                               @onkeydown="HandleKeyDown"
                               type="text"
                               class="form-input"
                               placeholder="Enter your username"
                               autocomplete="username"
                               disabled="@IsLocked" />
                    </div>
                    @if (GetFieldError("Username") != string.Empty)
                    {
                        <span class="form-error">@GetFieldError("Username")</span>
                    }
                </div>

                <!-- Password -->
                <div class="form-group">
                    <label class="form-label">Password</label>
                    <div class="form-input-wrap @(GetFieldError("Password") != string.Empty ? "form-input-error" : "")">
                        <svg class="form-input-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0110 0v4" />
                        </svg>
                        <input @key="@ShowPassword"
                               value="@Password"
                               @oninput="@((e) => Password = e.Value?.ToString() ?? string.Empty)"
                               @onkeydown="HandleKeyDown"
                               type="@(ShowPassword ? "text" : "password")"
                               class="form-input form-input-password"
                               placeholder="Enter your password"
                               autocomplete="current-password"
                               disabled="@IsLocked" />
                        <button type="button"
                                class="form-eye-btn"
                                @onclick="TogglePassword"
                                @onclick:stopPropagation="true"
                                tabindex="-1">
                            @if (ShowPassword)
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24" />
                                    <line x1="1" y1="1" x2="23" y2="23" />
                                </svg>
                            }
                            else
                            {
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                                    <circle cx="12" cy="12" r="3" />
                                </svg>
                            }
                        </button>
                    </div>
                    @if (GetFieldError("Password") != string.Empty)
                    {
                        <span class="form-error">@GetFieldError("Password")</span>
                    }
                </div>

                <!-- Remember me + forgot password -->
                <div class="login-options">
                    <label class="login-remember">
                        <input type="checkbox" @bind="RememberMe" disabled="@IsLocked" />
                        <span>Remember me</span>
                    </label>
                    <button type="button" class="login-forgot" @onclick="ToggleForgotHint">Forgot password?</button>
                </div>
                @if (ShowForgotHint)
                {
                    <div class="login-forgot-hint">
                        Password resets are handled by your system administrator. Please contact the EEMO Head to restore access.
                    </div>
                }

                <!-- Failed attempts warning (shows after 1st fail, before lockout) -->
                @if (FailedAttempts > 0 && FailedAttempts < 5 && !IsLocked)
                {
                    <div class="login-attempts-warn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                            <line x1="12" y1="9" x2="12" y2="13" />
                            <line x1="12" y1="17" x2="12.01" y2="17" />
                        </svg>
                        <span>
                            Incorrect credentials.
                            <strong>@(5 - FailedAttempts) attempt@(5 - FailedAttempts == 1 ? "" : "s")</strong>
                            remaining before account is temporarily locked.
                        </span>
                    </div>
                }

                <!-- Locked banner (replaces warning after 5 fails) -->
                @if (IsLocked)
                {
                    <div class="login-locked-banner">
                        <div class="login-locked-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0110 0v4" />
                            </svg>
                        </div>
                        <div>
                            <div class="login-locked-title">Account Temporarily Locked</div>
                            <div class="login-locked-sub">
                                Too many failed attempts. Please try again in <strong>@LockoutRemaining</strong>.
                            </div>
                        </div>
                    </div>
                }

                <!-- General error -->
                @if (!string.IsNullOrEmpty(ErrorMessage) && !IsLocked)
                {
                    <div class="setup-error">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
                            <circle cx="12" cy="12" r="10" />
                            <line x1="15" y1="9" x2="9" y2="15" />
                            <line x1="9" y1="9" x2="15" y2="15" />
                        </svg>
                        @ErrorMessage
                    </div>
                }

                <!-- Submit button -->
                <button class="setup-submit @(IsLoading ? "setup-submit-loading" : "") @(IsLocked ? "setup-submit-locked" : "")"
                        @onclick="HandleLogin"
                        disabled="@(IsLoading || IsLocked)">
                    @if (IsLoading)
                    {
                        <span class="setup-spinner"></span>
                        <span>Verifying credentials...</span>
                    }
                    else if (IsLocked)
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0110 0v4" />
                        </svg>
                        <span>Account Locked — @LockoutRemaining</span>
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                            <path d="M7 11V7a5 5 0 0110 0v4" />
                        </svg>
                        <span>Sign In to System</span>
                    }
                </button>

            </div><!-- end setup-form -->

            @if (!IsFromSetup)
            {
                <div class="login-divider"><span>or</span></div>
                <a class="login-network-link" href="https://www.stalltrack.site/select-municipality" aria-label="Access the CARCANMADCARLAN municipal network">
                    <span class="login-network-icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
                            <path d="M3 9.5 12 4l9 5.5" />
                            <path d="M4 9.5h16" />
                            <path d="M5.5 11v7M9.5 11v7M14.5 11v7M18.5 11v7" />
                            <path d="M3 20.5h18" />
                        </svg>
                    </span>
                    <span class="login-network-text">
                        <span class="login-network-title">Access CARCANMADCARLAN Municipal Network</span>
                        <span class="login-network-sub">Browse the five participating municipalities</span>
                    </span>
                    <span class="login-network-arrow" aria-hidden="true">&#8594;</span>
                </a>
            }

            </section>

            <!-- ── Footer ── -->
            <div class="setup-form-footer">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <rect x="5" y="11" width="14" height="10" rx="2" />
                    <path d="M8 11V8a4 4 0 018 0v3" />
                </svg>
                <span>Republic of the Philippines</span><span aria-hidden="true">•</span><span>Municipality of @MunicipalityName</span><span aria-hidden="true">•</span><span>@OfficeAcronym</span>
            </div>

        </div>
    </div>

</div>

@code {

    // ── Form state ────────────────────────────────────────────────────────────
    string Username = string.Empty;
    string Password = string.Empty;
    Dictionary<string, string> FieldErrors = new();
    bool ShowPassword = false;
    bool IsLoading = false;
    string ErrorMessage = string.Empty;
    int FailedAttempts = 0;
    bool IsLocked = false;
    string LockoutRemaining = "15 minutes";

    // ── Step indicator — only shown when redirected from /account-setup-admin ─
    // Redirect URL from AccountSetup should be: Navigation.NavigateTo("/login?setup=true")
    bool IsFromSetup = false;

    // ── Convenience controls (UI only; do not affect the auth flow) ───────────
    bool RememberMe = false;       // persists the username (never the password) in localStorage
    bool ShowForgotHint = false;
    const string RememberKey = "eemo_remember_username";

    // ── Per-LGU branding (pre-login) ──────────────────────────────────────────
    // Defaults are Cantilan's (the default LGU), so the panel is byte-for-byte unchanged until a
    // recognizable username resolves another LGU. Any failure keeps these defaults (never breaks login).
    const string DefaultSealPath = "/images/LGU_CANTILAN_LOGO.jpg";
    const string NeutralSealPath = "/images/stalltrack-seal.png";
    string SealPath = DefaultSealPath;
    string MunicipalityName = "Cantilan";
    string OfficeAcronym = "EEMO";
    string OfficeName = "Economic Enterprise and Management Office";
    // True for Cantilan (the default LGU) or before any LGU resolves — keeps Cantilan's building-photo
    // backdrop byte-for-byte. Set false for any other LGU so its panel uses a neutral backdrop instead of
    // Cantilan's building photo (which carries "Municipality of Cantilan" signage).
    bool _isDefaultBrand = true;

    // Carry the prerender-resolved branding into the interactive (hydration) pass. Without this, the
    // interactive circuit re-instantiates the component with the default (Cantilan) field values and paints
    // them for a frame before the async branding re-resolves — a visible flash of Cantilan branding on
    // another municipality's login. Persisting the resolved values makes the first interactive frame correct.
    // Carry the prerender-resolved branding into the interactive (hydration) pass to avoid a flash of the
    // default (Cantilan) branding. NOTE: the seal is deliberately NOT persisted — non-Cantilan seals are
    // large base64 data URIs, and putting one in persistent component state can exceed the SignalR message
    // size limit and drop the circuit ("connection closed with an error"). The seal is re-resolved by the
    // branding fetch below instead; only these small fields are persisted.
    [PersistentState] public string? PBrandName { get; set; }
    [PersistentState] public string? PBrandAcronym { get; set; }
    [PersistentState] public string? PBrandOffice { get; set; }
    [PersistentState] public bool? PBrandIsDefault { get; set; }
    string _brandedIdentifier = string.Empty;
    CancellationTokenSource? _brandingCts;

    // The LGU this login page is scoped to, from ?lgu={code} (the municipality selector links here).
    // When set, the panel is themed to that LGU and stays locked (typing a username won't re-theme it),
    // and the code is sent with the sign-in so the API enforces the account belongs to this LGU.
    string LguParam = string.Empty;
    bool _lguLocked = false;

    // Resolve the LGU from the typed username (Head usernames are "{tenant}.head", e.g. carrascal.head)
    // and theme the login panel from that LGU's onboarding branding. Debounced; falls back to defaults.
    async Task OnUsernameChanged()
    {
        // A scoped login (?lgu=) pins the branding to the selected LGU — don't let typing override it.
        if (_lguLocked) return;

        var id = DeriveIdentifier(Username);
        if (string.IsNullOrEmpty(id))
        {
            _brandedIdentifier = string.Empty;
            ResetBranding();
            return;
        }
        if (id == _brandedIdentifier) return;

        _brandingCts?.Cancel();
        var cts = _brandingCts = new CancellationTokenSource();
        try
        {
            await Task.Delay(450, cts.Token);
            var result = await MunicipalitiesApi.GetBrandingByIdentifierAsync(id);
            if (cts.IsCancellationRequested) return;
            if (result.IsSuccess && result.Value is not null)
            {
                _brandedIdentifier = id;
                ApplyBranding(result.Value);
                StateHasChanged();
            }
        }
        catch (OperationCanceledException) { }
        catch { /* keep current branding on any failure */ }
    }

    static string DeriveIdentifier(string? username)
    {
        var u = (username ?? string.Empty).Trim();
        if (u.Length == 0) return string.Empty;
        // The tenant slug is the part before the first separator (carrascal.head -> carrascal).
        return u.Split('.', '@', ' ')[0].Trim().ToLowerInvariant();
    }

    void ApplyBranding(MunicipalityBrandingDto b)
    {
        var isCantilan = string.Equals(b.Code, "CANTILAN", StringComparison.OrdinalIgnoreCase);
        _isDefaultBrand = isCantilan;
        SealPath = !string.IsNullOrWhiteSpace(b.SealPath) ? b.SealPath!
            : isCantilan ? DefaultSealPath : NeutralSealPath;
        MunicipalityName = string.IsNullOrWhiteSpace(b.Name) ? "Cantilan" : b.Name;
        OfficeAcronym = !string.IsNullOrWhiteSpace(b.OfficeAcronym) ? b.OfficeAcronym!
            : isCantilan ? "EEMO" : MunicipalityName;
        OfficeName = string.IsNullOrWhiteSpace(b.OfficeName) ? "Economic Enterprise and Management Office" : b.OfficeName;
    }

    // Snapshot the resolved branding so it survives the prerender → interactive handoff (no Cantilan flash).
    void PersistBrand()
    {
        PBrandName = MunicipalityName;
        PBrandAcronym = OfficeAcronym;
        PBrandOffice = OfficeName;
        PBrandIsDefault = _isDefaultBrand;
    }

    void ResetBranding()
    {
        _isDefaultBrand = true;
        SealPath = DefaultSealPath;
        MunicipalityName = "Cantilan";
        OfficeAcronym = "EEMO";
        OfficeName = "Economic Enterprise and Management Office";
    }

    protected override async Task OnInitializedAsync()
    {
        // If the prerender already resolved an LGU's branding, apply it up-front so the interactive pass
        // paints the correct municipality on the first frame instead of flashing the default (Cantilan)
        // seal/backdrop while it re-resolves.
        if (!string.IsNullOrEmpty(PBrandName))
        {
            _isDefaultBrand = PBrandIsDefault ?? true;
            // Seal isn't persisted (see note above): show the lightweight neutral seal for a non-default LGU
            // until the branding fetch below resolves the real one — never the Cantilan logo.
            if (PBrandIsDefault == false) SealPath = NeutralSealPath;
            MunicipalityName = PBrandName;
            if (PBrandAcronym is not null) OfficeAcronym = PBrandAcronym;
            if (PBrandOffice is not null) OfficeName = PBrandOffice;
        }

        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);
        var hasSetupParam = query.ContainsKey("setup") && query["setup"] == "true";

        // Scoped login from the municipality selector (?lgu={code}): theme the panel to that LGU and pin
        // it (locked), and remember the code so the sign-in enforces the account belongs to this LGU. Any
        // branding failure keeps the Cantilan defaults and never blocks login.
        if (query.TryGetValue("lgu", out var lguValues))
        {
            var lgu = lguValues.ToString().Trim();
            if (!string.IsNullOrEmpty(lgu))
            {
                LguParam = lgu;
                _lguLocked = true;
                try
                {
                    var branding = await MunicipalitiesApi.GetBrandingByIdentifierAsync(lgu);
                    if (branding.IsSuccess && branding.Value is not null)
                    {
                        _brandedIdentifier = lgu.ToLowerInvariant();
                        ApplyBranding(branding.Value);
                        PersistBrand();
                    }
                }
                catch { /* keep default branding on any failure */ }
            }
        }

        if (hasSetupParam)
        {
            var setupStatusResult = await SetupApi.GetSetupStatusAsync();

            if (setupStatusResult.IsSuccess && !setupStatusResult.Value!.IsSetupRequired)
            {
                Navigation.NavigateTo("/login", replace: true);
                return;
            }

            IsFromSetup = true;
            return;
        }

        // First-run guard: if no Head/administrator exists yet, the login page has nothing to
        // authenticate against — send the visitor to the initial account-setup page instead.
        // This mirrors AccountSetup's guard (which bounces back to /login once setup is complete),
        // so the two pages can never loop.
        var status = await SetupApi.GetSetupStatusAsync();
        if (status.IsSuccess && status.Value!.IsSetupRequired)
        {
            // Carry the LGU scope so the setup page themes to the same municipality.
            Navigation.NavigateTo("/account-setup-admin" + (string.IsNullOrEmpty(LguParam) ? "" : $"?lgu={LguParam}"), replace: true);
        }
    }

    // Prefill the remembered username (stored locally on a prior "Remember me" sign-in).
    // Runs only after the interactive render, where localStorage is available.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", RememberKey);
            if (!string.IsNullOrWhiteSpace(saved) && string.IsNullOrEmpty(Username))
            {
                Username = saved;
                RememberMe = true;
                StateHasChanged();
                await OnUsernameChanged();
            }
        }
        catch
        {
            // localStorage unavailable (e.g. during prerender) — ignore.
        }
    }

    void ToggleForgotHint() => ShowForgotHint = !ShowForgotHint;

    // ── Helpers ───────────────────────────────────────────────────────────────
    void TogglePassword(MouseEventArgs _)
    {
        ShowPassword = !ShowPassword;
        StateHasChanged();
    }

    async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !IsLoading && !IsLocked)
            await HandleLogin();
    }

    // ── Login logic ───────────────────────────────────────────────────────────
    async Task HandleLogin()
    {
        ErrorMessage = string.Empty;
        FieldErrors.Clear();

        IsLoading = true;
        StateHasChanged();

        // Persist the username (never the password) per the Remember me choice, before
        // authenticating — a successful sign-in navigates away immediately.
        try
        {
            if (RememberMe)
                await JS.InvokeVoidAsync("localStorage.setItem", RememberKey, Username);
            else
                await JS.InvokeVoidAsync("localStorage.removeItem", RememberKey);
        }
        catch { /* localStorage unavailable — non-fatal */ }

        try
        {
            var success = await AuthService.LoginAsync(Username, Password, LguParam);

            if (!success)
            {
                ErrorMessage = "Invalid username or password.";
            }
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    string GetFieldError(string fieldName) => FieldErrors.ContainsKey(fieldName) ? FieldErrors[fieldName] : string.Empty;
}
