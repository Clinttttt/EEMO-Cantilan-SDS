# Copy this file to .env, then replace every example value before starting Docker Compose.
POSTGRES_DB=EEMOCantilanSDS.DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=12345

# Use a long, random value. Never commit the resulting .env file.
JWT_KEY=EEMO-Cantilan-SDS-SuperSecretKey@2025!MunicipalityOfCantilan!Surigao
JWT_ISSUER=EEMOCantilanSDS
JWT_AUDIENCE=EEMOCantilanSDS.Client

# Local PayMongo test credentials only. Keep these blank if you are only testing
# login and general app behavior; they are required for checkout/webhook testing.
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=
