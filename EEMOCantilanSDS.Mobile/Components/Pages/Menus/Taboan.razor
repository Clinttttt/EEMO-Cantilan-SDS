@page "/taboan"
@using System.Globalization
@using global::EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Application.Dtos.TaboanMarket
@using global::EEMOCantilanSDS.Application.Requests.Mobile
@using global::EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Mobile.Models
@using EEMOCantilanSDS.Mobile.Services
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject IMobileApiClient MobileApi
@inject EEMOCantilanSDS.Mobile.Services.MobileSyncService Sync
@implements IDisposable

<div class="page-shell">
    <div class="header">
        <div class="header-eyebrow">Tabo-an Public Market</div>
        <div class="header-row">
            <button class="back-btn" type="button" @onclick="GoBack" aria-label="Back to menu">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
            </button>
            <div class="header-title-block">
                <div class="header-title">Tabo-an Market</div>
                <div class="header-sub">TPM - ₱100 per Vendor (Fridays)</div>
            </div>
        </div>
    </div>

    <div class="date-strip">
        <div class="date-strip-left">Collector: <span>@Session.CollectorName</span></div>
        <button class="collection-month-pill" type="button">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @MarketLabel
        </button>
    </div>

    <div class="content">
        @if (IsLoading)
        {
            <LoadingState Text="Loading market collections…" />
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <ErrorState Title="Couldn't load collections" Message="@ErrorMessage" OnRetry="LoadCollectionAsync" />
        }
        else if (Collection is not null)
        {
            @if (!Collection.IsMarketDay)
            {
                <div class="notice-card">
                    Tabo-an runs on <strong>Fridays</strong>. Showing the most recent market day
                    (@MarketLabel) — recording is available on the market day.
                </div>
            }

            <div class="summary-strip">
                <div class="summary-item">
                    <div class="summary-value">@FormatCurrency(Collection.CollectedAmount)</div>
                    <div class="summary-key">Collected</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.VendorCount</div>
                    <div class="summary-key">Vendors</div>
                </div>
            </div>

            @if (Collection.IsMarketDay)
            {
                <button class="record-cta" type="button" @onclick="OpenAddSheet">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    Add Vendor
                </button>
            }

            <div class="search-wrap">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search vendor or goods" @bind="SearchQuery" @bind:event="oninput" />
            </div>

            <div class="section-label">Vendor Attendance</div>

            @if (!FilteredAttendances.Any() && QueuedVendors.Count == 0)
            {
                <div class="state-card">
                    <div class="state-title">No vendors yet</div>
                    <div class="state-text">@(Collection.IsMarketDay ? "Add a vendor to start collecting for today." : "No vendors were recorded for this market day.")</div>
                </div>
            }
            else
            {
                @foreach (var q in QueuedVendors)
                {
                    <div class="tx-card tx-card-queued">
                        <div class="tx-left-bar tx-left-bar-queued"></div>
                        <div class="tx-body">
                            <div class="tx-row-main">
                                <div class="tx-col-info">
                                    <span class="tx-owner">@q.Vendor</span>
                                    <span class="tx-sub">
                                        <span class="tx-badge badge-queued">Queued · Offline</span>
                                        @if (!string.IsNullOrWhiteSpace(q.Goods))
                                        {
                                            <span class="tx-tag">@q.Goods</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(q.ORNumber))
                                        {
                                            <span class="tx-or">OR @q.ORNumber</span>
                                        }
                                    </span>
                                </div>
                                <div class="tx-col-right">
                                    <span class="tx-amount">@FormatCurrency(q.Fee)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                @foreach (var a in FilteredAttendances)
                {
                    <button class="tx-card" type="button" @onclick="() => OpenVendorAction(a)">
                        <div class="tx-left-bar @(a.IsPaid ? "bar-paid" : "")"></div>
                        <div class="tx-body">
                            <div class="tx-row-main">
                                <div class="tx-col-info">
                                    <span class="tx-owner">@a.VendorName</span>
                                    <span class="tx-sub">
                                        @if (!string.IsNullOrWhiteSpace(a.Goods))
                                        {
                                            <span class="tx-tag">@a.Goods</span>
                                        }
                                        @if (a.IsPaid && !string.IsNullOrWhiteSpace(a.ORNumber))
                                        {
                                            <span class="tx-or">OR @a.ORNumber</span>
                                        }
                                    </span>
                                </div>
                                <div class="tx-col-right">
                                    <span class="tx-tag @(a.IsPaid ? "tag-paid" : "tag-unpaid")">@(a.IsPaid ? "Paid" : "Unpaid")</span>
                                    <span class="tx-amount">@FormatCurrency(a.Fee)</span>
                                </div>
                            </div>
                        </div>
                    </button>
                }
            }
        }
    </div>

    <BottomNav ActiveTab="menu" />
</div>

@if (ShowAddSheet)
{
    <div class="sheet-overlay" @onclick="CloseSheets">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Add Vendor</div>
            <div class="sheet-sub">Register a vendor for @MarketLabel. The ₱100 fee is collected on entry.</div>

            <div class="or-number-wrap">
                <div class="form-label">Vendor name</div>
                @PickerField(VendorName, "Select or type vendor", "Select Vendor", KnownVendorNames, OnVendorPicked, SuggestionType.TpmVendor)

                <div class="form-label" style="margin-top:12px;">Goods</div>
                @PickerField(Goods, "Select or type goods", "Select Goods", KnownGoods, v => Goods = v, SuggestionType.TpmGoods)

                <div class="form-label" style="margin-top:12px;">Official receipt no. <span>optional</span></div>
                <input class="form-input mono-input" type="text" inputmode="numeric" maxlength="50" placeholder="000001" @bind="AddORNumber" @bind:event="oninput" />
            </div>

            @if (!string.IsNullOrWhiteSpace(SheetError))
            {
                <div class="form-error">@SheetError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseSheets" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmAddAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Add Vendor")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowPaySheet && SelectedAttendance is not null)
{
    <div class="sheet-overlay" @onclick="CloseSheets">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Update Receipt No.</div>
            <div class="sheet-sub">@SelectedAttendance.VendorName · ₱@Collection!.VendorFee.ToString("N0") · Paid</div>

            <div class="or-number-wrap">
                <div class="form-label">Official receipt no. <span>optional</span></div>
                <input class="form-input mono-input" type="text" inputmode="numeric" maxlength="50" placeholder="000001" @bind="ORNumber" @bind:event="oninput" />
            </div>

            @if (!string.IsNullOrWhiteSpace(SheetError))
            {
                <div class="form-error">@SheetError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseSheets" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmPayAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Save")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowVendorReceipt && SelectedAttendance is not null)
{
    <div class="sheet-overlay" @onclick="CloseSheets">
        <div class="sheet receipt-sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="receipt">
                <div class="receipt-head">
                    <img src="images/LGU_CANTILAN_LOGO.jpg" class="receipt-seal" alt="EEMO seal" />
                    <div class="receipt-gov">Republic of the Philippines</div>
                    <div class="receipt-org">Economic Enterprise &amp; Management Office</div>
                    <div class="receipt-muni">Municipality of Cantilan, Surigao del Sur</div>
                    <div class="receipt-doc">Tabo-an Public Market</div>
                </div>
                <div class="receipt-divider"></div>
                <div class="receipt-meta">
                    <div class="receipt-meta-row"><span>Market Date</span><strong>@SelectedAttendance.MarketDate.ToString("MMMM dd, yyyy")</strong></div>
                    <div class="receipt-meta-row"><span>Vendor</span><strong>@SelectedAttendance.VendorName</strong></div>
                    <div class="receipt-meta-row"><span>Goods</span><strong>@(string.IsNullOrWhiteSpace(SelectedAttendance.Goods) ? "—" : SelectedAttendance.Goods)</strong></div>
                    <div class="receipt-meta-row"><span>Status</span><strong>@(SelectedAttendance.IsPaid ? "Paid" : "Unpaid")</strong></div>
                    <div class="receipt-meta-row"><span>OR No.</span><strong>@(string.IsNullOrWhiteSpace(SelectedAttendance.ORNumber) ? "—" : SelectedAttendance.ORNumber)</strong></div>
                </div>
                <div class="receipt-divider"></div>
                <div class="receipt-total-row receipt-grand">
                    <span>Vendor Fee</span>
                    <span>&#8369;@SelectedAttendance.Fee.ToString("N2")</span>
                </div>
                <div class="receipt-divider dashed"></div>
                <div class="receipt-foot">
                    <div class="receipt-foot-row">
                        <span>Collected by</span>
                        <strong>@Session.CollectorName</strong>
                    </div>
                    <div class="receipt-note">This acknowledges receipt of the Tabo-an Public Market vendor fee. Keep for your records.</div>
                </div>
            </div>
            <div class="receipt-close-row">
                @if (Collection?.IsMarketDay == true)
                {
                    <button class="btn-receipt-edit" type="button" @onclick="OpenPayFromReceipt">Edit</button>
                }
                <button class="btn-receipt-close" type="button" @onclick="CloseSheets">Close</button>
            </div>
        </div>
    </div>
}

@if (ShowPicker)
{
    <div class="sheet-overlay picker-overlay" @onclick="ClosePicker">
        <div class="sheet picker-sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">@PickerTitle</div>

            <div class="search-wrap" style="margin-bottom:12px;">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search or type a new value" @bind="PickerSearch" @bind:event="oninput" />
            </div>

            <div class="picker-list">
                @if (!string.IsNullOrWhiteSpace(PickerSearch)
                     && !PickerOptions.Any(o => string.Equals(o, PickerSearch.Trim(), StringComparison.OrdinalIgnoreCase)))
                {
                    <button class="picker-item picker-item-new" type="button" @onclick="() => PickOption(PickerSearch.Trim())">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Use "<strong>@PickerSearch.Trim()</strong>"
                    </button>
                }

                @foreach (var opt in PickerFiltered)
                {
                    <div class="picker-item-row">
                        <button class="picker-item" type="button" @onclick="() => PickOption(opt)">@opt</button>
                        @if (PickerHideType is not null)
                        {
                            <button class="picker-item-remove" type="button" title="Remove from suggestions"
                                    @onclick="() => HidePickerOption(opt)">
                                <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                            </button>
                        }
                    </div>
                }

                @if (!PickerFiltered.Any() && string.IsNullOrWhiteSpace(PickerSearch))
                {
                    <div class="picker-empty">No options yet — type to add one.</div>
                }
            </div>

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="ClosePicker">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private MobileTpmCollectionDto? Collection;
    private bool IsLoading = true;
    private bool IsSaving;
    private string? ErrorMessage;
    private string? SheetError;
    private string SearchQuery = string.Empty;

    private bool ShowAddSheet;
    private bool ShowPaySheet;
    private bool ShowVendorReceipt;
    private TpmVendorAttendanceDto? SelectedAttendance;
    private string ORNumber = string.Empty;
    private string VendorName = string.Empty;
    private string Goods = string.Empty;
    private string AddORNumber = string.Empty;

    // Offline vendor captures (Kind = TpmVendor) for this market day, shown as "Queued · Offline" cards.
    private IReadOnlyList<QueuedVendor> QueuedVendors = Array.Empty<QueuedVendor>();
    private bool _disposed;
    private sealed record QueuedVendor(string Vendor, string? Goods, string? ORNumber, decimal Fee);

    private IReadOnlyList<string> KnownGoods => Collection?.KnownGoods ?? Array.Empty<string>();
    private IReadOnlyList<MobileTpmKnownVendorDto> KnownVendors => Collection?.KnownVendors ?? Array.Empty<MobileTpmKnownVendorDto>();
    private IReadOnlyList<string> KnownVendorNames => KnownVendors.Select(v => v.Name).ToList();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
        }
        catch (HttpRequestException)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        var hasAccess = Session.Menu?.Facilities.Any(f => f.Code == FacilityCode.TPM && f.IsAvailable) == true;
        if (!hasAccess)
        {
            Navigation.NavigateTo("/menu", forceLoad: false);
            return;
        }

        await LoadCollectionAsync();

        Sync.Changed += OnSyncChanged;
        await RefreshQueuedAsync();
    }

    private async Task LoadCollectionAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        StateHasChanged();

        try
        {
            var result = await MobileApi.GetTpmCollectionAsync();
            if (!result.IsSuccess || result.Value is null)
            {
                ErrorMessage = result.Error ?? "Unable to load market collections.";
                return;
            }

            Collection = result.Value;
        }
        catch
        {
            // The HTTP layer throws on a connection failure/timeout; keep the retry path safe and unstuck.
            ErrorMessage = "Unable to connect to the EEMO server. Please check the connection and try again.";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private IEnumerable<TpmVendorAttendanceDto> FilteredAttendances =>
        (Collection?.Attendances ?? Array.Empty<TpmVendorAttendanceDto>())
        .Where(a => string.IsNullOrWhiteSpace(SearchQuery)
            || a.VendorName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || a.Goods.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase))
        .OrderBy(a => a.IsPaid)
        .ThenBy(a => a.VendorName);

    private string MarketLabel =>
        (Collection?.MarketDate ?? DateOnly.FromDateTime(DateTime.Now)).ToString("MMM dd, yyyy", CultureInfo.InvariantCulture);

    private void GoBack() => Navigation.NavigateTo("/menu", forceLoad: false);

    private void OpenAddSheet()
    {
        VendorName = string.Empty;
        Goods = string.Empty;
        AddORNumber = string.Empty;
        SheetError = null;
        ShowAddSheet = true;
    }

    // Picking a returning vendor reuses them (matched by name on save) and prefills their usual goods
    // when goods hasn't been chosen yet — so the same vendor needs no retyping.
    private void OnVendorPicked(string name)
    {
        VendorName = name;
        if (string.IsNullOrWhiteSpace(Goods))
        {
            var match = KnownVendors.FirstOrDefault(v => string.Equals(v.Name, name, StringComparison.OrdinalIgnoreCase));
            if (match is not null && !string.IsNullOrWhiteSpace(match.Goods))
                Goods = match.Goods;
        }
    }

    // Clicking a card → receipt (view-only). Edit button inside receipt → pay sheet.
    private void OpenVendorAction(TpmVendorAttendanceDto attendance)
    {
        SelectedAttendance = attendance;
        SheetError = null;
        ShowVendorReceipt = true;
    }

    private void OpenPayFromReceipt()
    {
        ShowVendorReceipt = false;
        if (SelectedAttendance is null) return;
        ORNumber = SelectedAttendance.ORNumber ?? string.Empty;
        SheetError = null;
        ShowPaySheet = true;
    }

    private void OpenPaySheet(TpmVendorAttendanceDto attendance)
    {
        if (Collection?.IsMarketDay != true)
            return;

        SelectedAttendance = attendance;
        ORNumber = attendance.ORNumber ?? string.Empty;
        SheetError = null;
        ShowPaySheet = true;
    }

    private async Task ConfirmAddAsync()
    {
        if (string.IsNullOrWhiteSpace(VendorName))
        {
            SheetError = "Vendor name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(Goods))
        {
            SheetError = "Goods is required.";
            return;
        }

        IsSaving = true;
        SheetError = null;

        // Offline: queue the vendor entry (the ₱100 fee on entry); syncs when connectivity returns.
        if (!Sync.IsOnline)
        {
            await Sync.EnqueueAsync(new PendingOperation
            {
                Kind = OfflineOperationKind.TpmVendor,
                BusinessDate = DateOnly.FromDateTime(DateTime.Now),
                VendorName = VendorName.Trim(),
                Goods = Goods.Trim(),
                ORNumber = string.IsNullOrWhiteSpace(AddORNumber) ? null : AddORNumber.Trim(),
                FacilityLabel = "TPM",
                Title = VendorName.Trim(),
                Detail = Goods.Trim(),
                Amount = Collection?.VendorFee ?? 100m
            });

            await RefreshQueuedAsync();
            CloseSheets();
            IsSaving = false;
            return;
        }

        var result = await MobileApi.AddTpmVendorAsync(new AddMobileTpmVendorRequest(
            VendorName.Trim(),
            Goods.Trim(),
            string.IsNullOrWhiteSpace(AddORNumber) ? null : AddORNumber.Trim()));
        if (!result.IsSuccess)
        {
            SheetError = result.Error ?? "Unable to add the vendor.";
            IsSaving = false;
            return;
        }

        CloseSheets();
        try { await LoadCollectionAsync(); }
        finally { IsSaving = false; }
    }

    private async Task ConfirmPayAsync()
    {
        if (SelectedAttendance is null)
            return;

        IsSaving = true;
        SheetError = null;

        var request = new MarkMobileTpmVendorPaidRequest(
            SelectedAttendance.Id,
            true,
            string.IsNullOrWhiteSpace(ORNumber) ? null : ORNumber.Trim());

        var result = await MobileApi.MarkTpmVendorPaidAsync(request);
        if (!result.IsSuccess)
        {
            SheetError = result.Error ?? "Unable to update the payment.";
            IsSaving = false;
            return;
        }

        CloseSheets();
        try { await LoadCollectionAsync(); }
        finally { IsSaving = false; }
    }

    private void CloseSheets()
    {
        ShowAddSheet = false;
        ShowPaySheet = false;
        ShowVendorReceipt = false;
        SelectedAttendance = null;
        SheetError = null;
    }

    // ── Searchable picker (full-screen overlay) — same pattern as TRM ──
    private bool ShowPicker;
    private string PickerTitle = string.Empty;
    private string PickerSearch = string.Empty;
    private IReadOnlyList<string> PickerOptions = Array.Empty<string>();
    private Action<string>? PickerSet;
    private SuggestionType? PickerHideType;

    private IEnumerable<string> PickerFiltered =>
        PickerOptions.Where(o => string.IsNullOrWhiteSpace(PickerSearch)
            || o.Contains(PickerSearch, StringComparison.OrdinalIgnoreCase));

    // Read-only field that opens the picker; displays the current value or a placeholder.
    // hideType (when set) lets the collector remove a suggestion from the list via the X button.
    private RenderFragment PickerField(string value, string placeholder, string title,
        IReadOnlyList<string> options, Action<string> set, SuggestionType? hideType = null) => __builder =>
    {
        __builder.OpenElement(0, "button");
        __builder.AddAttribute(1, "type", "button");
        __builder.AddAttribute(2, "class", "picker-field");
        __builder.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, () => OpenPicker(title, options, set, hideType)));

        __builder.OpenElement(4, "span");
        __builder.AddAttribute(5, "class", string.IsNullOrWhiteSpace(value) ? "picker-field-placeholder" : "picker-field-value");
        __builder.AddContent(6, string.IsNullOrWhiteSpace(value) ? placeholder : value);
        __builder.CloseElement();

        __builder.OpenElement(7, "svg");
        __builder.AddAttribute(8, "class", "picker-field-chev");
        __builder.AddAttribute(9, "viewBox", "0 0 24 24");
        __builder.AddMarkupContent(10, "<polyline points=\"6 9 12 15 18 9\" />");
        __builder.CloseElement();

        __builder.CloseElement(); // button
    };

    private void OpenPicker(string title, IReadOnlyList<string> options, Action<string> set, SuggestionType? hideType)
    {
        PickerTitle = title;
        PickerOptions = options;
        PickerSet = set;
        PickerHideType = hideType;
        PickerSearch = string.Empty;
        ShowPicker = true;
    }

    private void PickOption(string value)
    {
        PickerSet?.Invoke(value);
        ShowPicker = false;
        PickerSet = null;
    }

    private void ClosePicker()
    {
        ShowPicker = false;
        PickerSet = null;
    }

    // Remove a value from the pick-list (persisted blocklist) so it is no longer suggested.
    private async Task HidePickerOption(string value)
    {
        if (PickerHideType is not { } type) return;
        var result = await MobileApi.HideSuggestionAsync(new HideMobileSuggestionRequest(type, value));
        if (result.IsSuccess)
        {
            PickerOptions = PickerOptions.Where(o => !string.Equals(o, value, StringComparison.OrdinalIgnoreCase)).ToList();
            await LoadCollectionAsync(); // refresh source list so it stays gone on reopen
        }
    }

    private static string FormatCurrency(decimal value) => $"₱{value:N0}";

    // Build the "Queued · Offline" vendor cards from this collector's pending TPM captures for the market day.
    private async Task RefreshQueuedAsync()
    {
        var marketDate = Collection?.MarketDate ?? DateOnly.FromDateTime(DateTime.Now);
        var pending = await Sync.GetAllAsync();
        QueuedVendors = pending
            .Where(o => o.Kind == OfflineOperationKind.TpmVendor
                     && o.BusinessDate == marketDate
                     && o.LocalStatus != PendingLocalStatus.Synced)
            .Select(o => new QueuedVendor(o.VendorName ?? "—", o.Goods, o.ORNumber, o.Amount))
            .ToList();
    }

    private async void OnSyncChanged()
    {
        if (_disposed) return;
        try
        {
            await InvokeAsync(async () =>
            {
                if (_disposed) return;
                await RefreshQueuedAsync();
                StateHasChanged();
            });
        }
        catch { /* navigated away */ }
    }

    public void Dispose()
    {
        _disposed = true;
        Sync.Changed -= OnSyncChanged;
    }
}
