@page "/market"
@using global::EEMOCantilanSDS.Domain.Enums
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session



<!-- ░░ PAGE SHELL ░░ -->
<div class="page-shell">

    <!-- Header -->
    <div class="header">
        <div class="header-eyebrow">Market Collections</div>
        <div class="header-row">
            <div class="back-btn" @onclick="GoBack">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
            </div>
            <div class="header-title-block">
                <div class="header-title">New Public Market</div>
                <div class="header-sub">NPM — Stall Rental &amp; Fees · @DateTime.Now.ToString("MMM dd, yyyy")</div>
            </div>
        </div>
    </div>

    <!-- Date Strip — shows collector + current collection month -->
    <div class="date-strip">
        <div class="date-strip-left">Collector: <span>@Session.CollectorName</span></div>
        <div class="collection-month-pill">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @CollectionMonth
        </div>
    </div>

    <!-- Scrollable Content -->
    <div class="content">

        <!-- Summary Strip -->
        <div class="summary-strip">
            <div class="summary-item">
                <div class="summary-value">₱@TotalCollected.ToString("N0")</div>
                <div class="summary-key">Collected</div>
            </div>
            <div class="summary-item">
                <div class="summary-value">₱@TotalPending.ToString("N0")</div>
                <div class="summary-key">Pending</div>
            </div>
            <div class="summary-item">
                <div class="summary-value">@Stalls.Count</div>
                <div class="summary-key">Total Stalls</div>
            </div>
        </div>

        <!-- Collection Month Banner -->
        <div class="month-banner">
            <div class="month-banner-left">
                <div class="month-banner-label">Collection Period</div>
                <div class="month-banner-month">@CollectionMonth</div>
            </div>
            <div class="month-banner-right">
                <div class="month-banner-stat">
                    <span class="month-banner-val">@Stalls.Count(s => s.IsPaid && !s.IsPartial)</span>
                    <span class="month-banner-key">of @Stalls.Count paid</span>
                </div>
                <div class="month-progress-wrap">
                    <div class="month-progress-fill"
                         style="width:@GetPaymentPercent()%"></div>
                </div>
            </div>
        </div>

        <!-- Search -->
        <div class="search-wrap">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
            <input type="text" placeholder="Search stall no. or name…"
                   @bind="SearchQuery" @bind:event="oninput" />
        </div>

        <!-- Filter Tabs -->
        <div class="filter-tabs">
            @foreach (var tab in FilterOptions)
            {
                <div class="filter-tab @(ActiveFilter == tab ? "active" : "")"
                     @onclick="() => ActiveFilter = tab">
                    @tab
                </div>
            }
        </div>

        <!-- Permanent Stalls -->
        <div class="section-label">
            Permanent Stalls
            <span class="section-count">@PermanentStalls.Count() stalls</span>
        </div>

        @foreach (var stall in PermanentStalls)
        {
            <div class="stall-row @GetRowClass(stall)"
                 @onclick="() => RequestToggle(stall)">
                <div class="stall-check @GetCheckClass(stall)">
                    @if (stall.IsPaid && !stall.IsPartial)
                    {
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                    }
                    else if (stall.IsPartial)
                    {
                        <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    }
                    else if (stall.IsConfirmed)
                    {
                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                    }
                </div>
                <div class="stall-num">
                    <span class="stall-num-label">Stall</span>
                    <span class="stall-num-val">@stall.StallNo</span>
                </div>
                <div class="stall-info">
                    <div class="stall-name">@stall.PayorName</div>
                    <div class="stall-meta">
                        <span class="stall-type-badge badge-permanent">Permanent</span>
                        <span class="stall-section">@stall.Section</span>
                    </div>
                </div>
                <div class="stall-amount-col">
                    <div class="stall-amount">₱@stall.Amount.ToString("N0")</div>
                    <span class="stall-status-pill @GetPillClass(stall)">@GetStatusLabel(stall)</span>
                </div>
            </div>
        }

        <!-- Temporary Stalls -->
        <div class="group-spacer"></div>
        <div class="section-label">
            Temporary Stalls
            <span class="section-count">@TemporaryStalls.Count() stalls</span>
        </div>

        @foreach (var stall in TemporaryStalls)
        {
            <div class="stall-row @GetRowClass(stall)"
                 @onclick="() => RequestToggle(stall)">
                <div class="stall-check @GetCheckClass(stall)">
                    @if (stall.IsPaid && !stall.IsPartial)
                    {
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                    }
                    else if (stall.IsPartial)
                    {
                        <svg viewBox="0 0 24 24"><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    }
                    else if (stall.IsConfirmed)
                    {
                        <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                    }
                </div>
                <div class="stall-num">
                    <span class="stall-num-label">Stall</span>
                    <span class="stall-num-val">@stall.StallNo</span>
                </div>
                <div class="stall-info">
                    <div class="stall-name">@stall.PayorName</div>
                    <div class="stall-meta">
                        <span class="stall-type-badge badge-temporary">Temporary</span>
                        <span class="stall-section">@stall.Section</span>
                    </div>
                </div>
                <div class="stall-amount-col">
                    <div class="stall-amount">₱@stall.Amount.ToString("N0")</div>
                    <span class="stall-status-pill @GetPillClass(stall)">@GetStatusLabel(stall)</span>
                </div>
            </div>
        }

        <!-- Add Temporary Vendor -->
        <div class="add-temp-row" @onclick="OpenAddVendor">
            <div class="add-temp-icon">
                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
            </div>
            <div class="add-temp-text">Add temporary vendor / payor…</div>
        </div>

    </div>
    <!-- end .content -->
    <!-- Bottom Nav -->
    <BottomNav ActiveTab="menu" />

</div>
<!-- end .page-shell -->
<!-- ════════════════════════════════════════════
     STATUS PICKER SHEET
     Collector picks: Paid / Partial / Unpaid
════════════════════════════════════════════ -->
@if (ShowConfirmSheet && PendingToggle is not null)
{
    <div class="sheet-overlay" @onclick="CloseConfirm">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>

            <div class="sheet-title">Update Payment Status</div>
            <div class="sheet-sub">Select the current payment status for this stall.</div>

            <!-- Stall Preview -->
            <div class="sheet-preview">
                <div class="preview-num">@PendingToggle.StallNo</div>
                <div class="preview-info">
                    <div class="preview-name">@PendingToggle.PayorName</div>
                    <div class="preview-detail">
                        @PendingToggle.Section &nbsp;·&nbsp; ₱@PendingToggle.Amount.ToString("N0")
                    </div>
                </div>
            </div>

            <!-- Status Options -->
            <div class="status-option @(SelectedStatus == "Paid" ? "status-option-active paid" : "")"
                 @onclick='() => SelectedStatus = "Paid"'>
                <div class="status-option-icon paid-icon-sm">
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Paid</div>
                    <div class="status-option-sub">Full amount collected — ₱@PendingToggle.Amount.ToString("N0")</div>
                </div>
                @if (SelectedStatus == "Paid")
                {
                    <div class="status-option-check">✓</div>
                }
            </div>

            <div class="status-option @(SelectedStatus == "Partial" ? "status-option-active partial" : "")"
                 @onclick='() => SelectedStatus = "Partial"'>
                <div class="status-option-icon partial-icon-sm">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Partial</div>
                    <div class="status-option-sub">Partially collected — not yet full amount</div>
                </div>
                @if (SelectedStatus == "Partial")
                {
                    <div class="status-option-check">✓</div>
                }
            </div>

            <!-- Partial amount input — only visible when Partial is selected -->
            @if (SelectedStatus == "Partial")
            {
                <div class="partial-amount-wrap">
                    <div class="partial-amount-label">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                        Amount Collected
                    </div>
                    <div class="partial-input-row">
                        <span class="partial-peso-sign">₱</span>
                        <input class="partial-amount-input"
                               type="number"
                               min="1"
                               max="@PendingToggle?.Amount"
                               placeholder="0"
                               @bind="PartialAmount"
                               @bind:event="oninput" />
                        <span class="partial-of-total">of ₱@PendingToggle?.Amount.ToString("N0")</span>
                    </div>
                    @if (PartialAmount > 0 && PendingToggle is not null)
                    {
                        <div class="partial-remaining">
                            Remaining balance: ₱@((PendingToggle.Amount - PartialAmount).ToString("N0"))
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(PartialError))
                    {
                        <div class="form-error" style="margin-top:8px;">@PartialError</div>
                    }
                </div>
            }

            <div class="status-option @(SelectedStatus == "Unpaid" ? "status-option-active unpaid" : "")"
                 @onclick='() => SelectedStatus = "Unpaid"'>
                <div class="status-option-icon unpaid-icon-sm">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Unpaid</div>
                    <div class="status-option-sub">No payment collected yet</div>
                </div>
                @if (SelectedStatus == "Unpaid")
                {
                    <div class="status-option-check">✓</div>
                }
            </div>

            <div class="sheet-btn-row">
                <div class="btn-cancel" @onclick="CloseConfirm">Cancel</div>
                <div class="btn-confirm" @onclick="ConfirmStatus">Confirm</div>
            </div>
        </div>
    </div>
}


<!-- ════════════════════════════════════════════
     ADD VENDOR BOTTOM SHEET
════════════════════════════════════════════ -->
@if (ShowAddVendorSheet)
{
    <div class="sheet-overlay" @onclick="CloseAddVendor">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>

            <div class="sheet-title">Add Temporary Vendor</div>
            <div class="sheet-sub">Fill in the vendor details below.</div>

            <div class="form-field">
                <div class="form-label">Payor / Vendor Name</div>
                <input class="form-input" type="text"
                       placeholder="e.g. Juan dela Cruz"
                       @bind="NewVendorName"
                       @bind:event="oninput" />
            </div>

            <div class="form-row">
                <div class="form-field">
                    <div class="form-label">Stall No.</div>
                    <input class="form-input" type="text"
                           placeholder="e.g. T4"
                           @bind="NewVendorStallNo"
                           @bind:event="oninput" />
                </div>
                <div class="form-field">
                    <div class="form-label">Section / Area</div>
                    <input class="form-input" type="text"
                           placeholder="e.g. Open Area"
                           @bind="NewVendorSection"
                           @bind:event="oninput" />
                </div>
            </div>

            <div class="form-field">
                <div class="form-label">Amount (₱)</div>
                <input class="form-input" type="number"
                       placeholder="e.g. 50"
                       @bind="NewVendorAmount"
                       @bind:event="oninput" />
            </div>

            @if (!string.IsNullOrEmpty(AddVendorError))
            {
                <div class="form-error">@AddVendorError</div>
            }

            <div class="sheet-btn-row">
                <div class="btn-cancel" @onclick="CloseAddVendor">Cancel</div>
                <div class="btn-confirm" @onclick="ConfirmAddVendor">Add Vendor</div>
            </div>
        </div>
    </div>
}


@code {
    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
        }
        catch (HttpRequestException)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        var hasNpmAccess = Session.Menu?.AssignedFacilities.Any(f => f.Code == FacilityCode.NPM && f.IsAvailable) == true;

        if (!hasNpmAccess)
        {
            Navigation.NavigateTo("/menu", forceLoad: false);
        }
    }

    // ── Navigation ────────────────────────────────────────────────────────────
    void GoBack() => Navigation.NavigateTo("/menu", forceLoad: false);

    // ── Collection Month ──────────────────────────────────────────────────────
    // Auto-set to current month — when admin sets it via web system,
    // replace this with a value from your service/session:
    //   e.g. CollectionMonth = await CollectionService.GetCurrentMonthAsync();
    string CollectionMonth => DateTime.Now.ToString("MMMM yyyy");

    // Progress: how many stalls paid this month
    int GetPaymentPercent()
    {
        if (Stalls.Count == 0) return 0;
        int paid = Stalls.Count(s => s.IsPaid && !s.IsPartial);
        return (int)((double)paid / Stalls.Count * 100);
    }

    // ── Search & Filter ───────────────────────────────────────────────────────
    string SearchQuery = string.Empty;
    string ActiveFilter = "All";

    readonly List<string> FilterOptions = new()
        { "All", "Permanent", "Temporary", "Paid", "Unpaid" };

    // ─────────────────────────────────────────────────────────────────────────
    // STALL MODEL
    // ─────────────────────────────────────────────────────────────────────────
    class StallEntry
    {
        public string StallNo { get; set; } = string.Empty;
        public string PayorName { get; set; } = string.Empty;
        public string Section { get; set; } = string.Empty;
        public decimal Amount { get; set; }
        public bool IsPaid { get; set; }
        public bool IsPartial { get; set; }
        public bool IsTemporary { get; set; }
        public bool IsConfirmed { get; set; }
        // Amount actually collected when status is Partial
        public decimal PartialAmountPaid { get; set; }
    }

    // ─────────────────────────────────────────────────────────────────────────
    // MASTER STALL LIST
    // Replace with DB call later: Stalls = await MarketService.GetStallsAsync()
    // ─────────────────────────────────────────────────────────────────────────
    List<StallEntry> Stalls = new()
    {
        new() { StallNo="01", PayorName="Dela Cruz, Maria S.",   Section="Sec. A · Dry Goods",  Amount=150, IsPaid=false,  IsTemporary=false },
        new() { StallNo="02", PayorName="Santos, Rodrigo T.",    Section="Sec. A · Dry Goods",  Amount=150, IsPaid=false,  IsTemporary=false },
        new() { StallNo="03", PayorName="Bautista, Nena L.",     Section="Sec. A · Dry Goods",  Amount=150, IsPaid=false, IsTemporary=false },
        new() { StallNo="05", PayorName="Reyes, Luzviminda A.",  Section="Sec. B · Vegetables", Amount=150, IsPaid=false,  IsTemporary=false },
        new() { StallNo="06", PayorName="Garcia, Flordeliza B.", Section="Sec. B · Vegetables", Amount=150, IsPaid=false, IsTemporary=false },
        new() { StallNo="09", PayorName="Mangubat, Jose P.",     Section="Sec. C · Fish/Meat",  Amount=200, IsPaid=false, IsTemporary=false },
        new() { StallNo="11", PayorName="Cañada, Elvira M.",     Section="Sec. C · Fish/Meat",  Amount=200, IsPaid=false, IsTemporary=false, IsPartial=false },
        new() { StallNo="14", PayorName="Villanueva, Ricardo",   Section="Sec. D · General",    Amount=150, IsPaid=false,  IsTemporary=false },
        new() { StallNo="T1", PayorName="Buenaventura, Carlo",   Section="Open Area",           Amount=50,  IsPaid=false,  IsTemporary=true  },
        new() { StallNo="T2", PayorName="Peralta, Nimfa R.",     Section="Open Area",           Amount=50,  IsPaid=false, IsTemporary=true  },
        new() { StallNo="T3", PayorName="Tiu, Marcelino",        Section="Open Area",           Amount=50,  IsPaid=false, IsTemporary=true  },
    };

    // ── Filtered Views ────────────────────────────────────────────────────────
    IEnumerable<StallEntry> FilteredStalls => Stalls.Where(s =>
    {
        bool matchSearch = string.IsNullOrWhiteSpace(SearchQuery)
            || s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || s.PayorName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);

        bool matchFilter = ActiveFilter switch
        {
            "Permanent" => !s.IsTemporary,
            "Temporary" => s.IsTemporary,
            "Paid" => s.IsPaid && !s.IsPartial,
            "Unpaid" => !s.IsPaid || s.IsPartial,
            _ => true
        };

        return matchSearch && matchFilter;
    });

    IEnumerable<StallEntry> PermanentStalls => FilteredStalls.Where(s => !s.IsTemporary);
    IEnumerable<StallEntry> TemporaryStalls => FilteredStalls.Where(s => s.IsTemporary);

    // ── Totals ────────────────────────────────────────────────────────────────
    decimal TotalCollected => Stalls.Where(s => s.IsPaid && !s.IsPartial).Sum(s => s.Amount);
    decimal TotalPending => Stalls.Where(s => !s.IsPaid || s.IsPartial).Sum(s => s.Amount);

    // ── Confirm Sheet ─────────────────────────────────────────────────────────
    // ── Status Picker Sheet ───────────────────────────────────────────────────
    bool ShowConfirmSheet = false;
    StallEntry? PendingToggle = null;
    string SelectedStatus = string.Empty;
    decimal PartialAmount = 0;
    string PartialError = string.Empty;

    void RequestToggle(StallEntry stall)
    {
        PendingToggle = stall;
        PartialAmount = stall.IsPartial ? stall.PartialAmountPaid : 0;
        PartialError = string.Empty;
        SelectedStatus = stall.IsPartial ? "Partial"
                       : stall.IsPaid ? "Paid"
                       : "Unpaid";
        ShowConfirmSheet = true;
    }

    void ConfirmStatus()
    {
        if (PendingToggle is null) return;

        // Validate partial amount
        if (SelectedStatus == "Partial")
        {
            if (PartialAmount <= 0)
            {
                PartialError = "Please enter the amount collected.";
                return;
            }
            if (PartialAmount >= PendingToggle.Amount)
            {
                PartialError = $"Amount must be less than ₱{PendingToggle.Amount:N0}. Use Paid for full amount.";
                return;
            }
        }

        PendingToggle.IsPaid = SelectedStatus == "Paid";
        PendingToggle.IsPartial = SelectedStatus == "Partial";
        PendingToggle.IsConfirmed = true;
        PendingToggle.PartialAmountPaid = SelectedStatus == "Partial" ? PartialAmount : 0;

        CloseConfirm();
    }

    void CloseConfirm()
    {
        ShowConfirmSheet = false;
        PendingToggle = null;
        SelectedStatus = string.Empty;
        PartialAmount = 0;
        PartialError = string.Empty;
    }

    // ── Add Vendor Sheet ──────────────────────────────────────────────────────
    bool ShowAddVendorSheet = false;
    string NewVendorName = string.Empty;
    string NewVendorStallNo = string.Empty;
    string NewVendorSection = "Open Area";
    decimal NewVendorAmount = 50;
    string AddVendorError = string.Empty;

    void OpenAddVendor()
    {
        int next = Stalls.Count(s => s.IsTemporary) + 1;
        NewVendorStallNo = $"T{next}";
        NewVendorName = string.Empty;
        NewVendorSection = "Open Area";
        NewVendorAmount = 50;
        AddVendorError = string.Empty;
        ShowAddVendorSheet = true;
    }

    void ConfirmAddVendor()
    {
        if (string.IsNullOrWhiteSpace(NewVendorName))
        {
            AddVendorError = "Payor / vendor name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(NewVendorStallNo))
        {
            AddVendorError = "Stall number is required.";
            return;
        }
        if (NewVendorAmount <= 0)
        {
            AddVendorError = "Amount must be greater than ₱0.";
            return;
        }

        Stalls.Add(new StallEntry
        {
            StallNo = NewVendorStallNo.Trim().ToUpper(),
            PayorName = NewVendorName.Trim(),
            Section = string.IsNullOrWhiteSpace(NewVendorSection) ? "Open Area" : NewVendorSection.Trim(),
            Amount = NewVendorAmount,
            IsPaid = false,
            IsTemporary = true
        });

        CloseAddVendor();
    }

    void CloseAddVendor()
    {
        ShowAddVendorSheet = false;
        AddVendorError = string.Empty;
    }

    // ── Row & checkbox class helpers ──────────────────────────────────────────
    // stall-row left border color
    string GetRowClass(StallEntry s) =>
        s.IsPaid && !s.IsPartial ? "paid" :
        s.IsPartial ? "partial" :
        s.IsConfirmed ? "confirmed-unpaid" :
                                    "";

    // checkbox fill + icon color
    string GetCheckClass(StallEntry s) =>
        s.IsPaid && !s.IsPartial ? "checked checked-paid" :
        s.IsPartial ? "checked checked-partial" :
        s.IsConfirmed ? "checked checked-unpaid" :
                                    "";

    // ── Pill helpers ──────────────────────────────────────────────────────────
    string GetPillClass(StallEntry s) =>
        s.IsPartial ? "stall-status-pill pill-partial" :
        s.IsPaid ? "stall-status-pill pill-paid" :
                      "stall-status-pill pill-unpaid";

    string GetStatusLabel(StallEntry s) =>
        s.IsPartial ? $"₱{s.PartialAmountPaid:N0} paid" :
        s.IsPaid ? "Paid" : "Unpaid";
}
