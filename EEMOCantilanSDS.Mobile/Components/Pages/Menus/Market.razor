@page "/market"
@using System.Globalization
@using global::EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Application.Requests.Mobile
@using global::EEMOCantilanSDS.Domain.Enums
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject IMobileApiClient MobileApi

<div class="page-shell">
    <div class="header">
        <div class="header-eyebrow">Market Collections</div>
        <div class="header-row">
            <button class="back-btn" type="button" @onclick="GoBack" aria-label="Back to menu">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
            </button>
            <div class="header-title-block">
                <div class="header-title">New Public Market</div>
                <div class="header-sub">NPM - Stall Rental &amp; Fees</div>
            </div>
        </div>
    </div>

    <div class="date-strip">
        <div class="date-strip-left">Collector: <span>@Session.CollectorName</span></div>
        <button class="collection-month-pill" type="button">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @MonthLabel
        </button>
    </div>

    <div class="content">
        @if (IsLoading)
        {
            <div class="state-card">
                <div class="state-title">Loading NPM collections</div>
                <div class="state-text">Please wait while the assigned stalls are loaded.</div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="state-card error">
                <div class="state-title">Unable to load collections</div>
                <div class="state-text">@ErrorMessage</div>
                <button class="primary-action" type="button" @onclick="LoadCollectionAsync">Try Again</button>
            </div>
        }
        else if (Collection is not null)
        {
            <div class="summary-strip">
                <div class="summary-item">
                    <div class="summary-value">@FormatCurrency(Collection.CollectedTodayAmount)</div>
                    <div class="summary-key">Today</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.CollectedTodayCount</div>
                    <div class="summary-key">Collected</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.PendingTodayCount</div>
                    <div class="summary-key">Pending</div>
                </div>
            </div>

            <div class="month-banner">
                <div class="month-banner-left">
                    <div class="month-banner-label">Collection Period</div>
                    <div class="month-banner-month">@MonthLabel</div>
                    <div class="month-banner-date">@Collection.CollectionDate.ToString("MMM dd, yyyy", CultureInfo.InvariantCulture)</div>
                </div>
                <div class="month-banner-right">
                    <div class="month-banner-stat">
                        <span class="month-banner-val">@Collection.CollectedTodayCount</span>
                        <span class="month-banner-key">of @Collection.TotalStalls collected</span>
                    </div>
                    <div class="month-progress-wrap">
                        <div class="month-progress-fill" style="width:@TodayCollectionPercent%"></div>
                    </div>
                </div>
            </div>

            <div class="search-wrap">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search stall no. or name" @bind="SearchQuery" @bind:event="oninput" />
            </div>

            <div class="seg-filter">
                @foreach (var tab in FilterOptions)
                {
                    <button class="seg-filter-btn @(ActiveFilter == tab ? "active" : "")" type="button" @onclick="() => ActiveFilter = tab">
                        @tab
                    </button>
                }
            </div>

            @if (!FilteredStalls.Any())
            {
                <div class="state-card">
                    <div class="state-title">No matching stalls</div>
                    <div class="state-text">Try another search or filter.</div>
                </div>
            }
            else
            {
                @foreach (var sectionGroup in FilteredStalls.GroupBy(s => s.Section))
                {
                    <div class="section-label">@GetSectionHeading(sectionGroup.Key)</div>

                    @foreach (var stall in sectionGroup)
                    {
                        <button class="tx-card" type="button" @onclick="() => OpenStall(stall)">
                            <div class="tx-left-bar @GetBarClass(stall)"></div>
                            <div class="tx-body">
                                <div class="tx-row-main">
                                    <div class="tx-col-info">
                                        <span class="tx-owner">@stall.PayorName</span>
                                        <span class="tx-sub">
                                            <span class="tx-tag">No. @stall.StallNo</span>
                                            @if (!string.IsNullOrWhiteSpace(stall.ORNumberToday))
                                            {
                                                <span class="tx-or">OR @stall.ORNumberToday</span>
                                            }
                                            else if (!string.IsNullOrWhiteSpace(stall.ContractName) && stall.ContractName != stall.PayorName)
                                            {
                                                <span class="tx-or">@stall.ContractName</span>
                                            }
                                        </span>
                                    </div>
                                    <div class="tx-col-right">
                                        <span class="tx-badge @GetBadgeClass(stall)">@GetStatusLabel(stall)</span>
                                        <span class="tx-amount">@FormatCurrency(stall.DailyRate)</span>
                                    </div>
                                </div>
                            </div>
                        </button>
                    }
                }
            }
        }
    </div>

    <BottomNav ActiveTab="menu" />
</div>

@if (ShowCollectionSheet && SelectedStall is not null)
{
    <div class="sheet-overlay" @onclick="CloseCollectionSheet">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Record Daily Collection</div>
            <div class="sheet-sub">Update today's collection status for this stall.</div>

            <div class="sheet-preview">
                <div class="preview-num">@SelectedStall.StallNo</div>
                <div class="preview-info">
                    <div class="preview-name">@SelectedStall.PayorName</div>
                    <div class="preview-detail">@GetSectionShortName(SelectedStall.Section) - @FormatCurrency(SelectedStall.DailyRate)</div>
                </div>
            </div>

            <button class="status-option @(SelectedIsPaid ? "status-option-active paid" : "")" type="button" @onclick="() => SelectedIsPaid = true">
                <div class="status-option-icon paid-icon-sm">
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Collected</div>
                    <div class="status-option-sub">Daily stall fee collected - @FormatCurrency(SelectedStall.DailyRate)</div>
                </div>
                @if (SelectedIsPaid)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            @if (SelectedIsPaid && SelectedStall.Section == MarketSection.FishSection)
            {
                <div class="fish-kilo-wrap">
                    <div class="form-label">Fish kilos collected</div>
                    <div class="fish-input-row">
                        <input class="form-input" type="number" min="0" step="0.01" placeholder="0" @bind="FishKilos" @bind:event="oninput" />
                        <span>kg</span>
                    </div>
                </div>
            }

            @if (SelectedIsPaid)
            {
                <div class="or-number-wrap">
                    <div class="form-label">Official receipt no. <span>optional</span></div>
                    <input class="form-input mono-input"
                           type="text"
                           inputmode="numeric"
                           maxlength="30"
                           placeholder="000001"
                           @bind="ORNumber"
                           @bind:event="oninput" />
                    <div class="form-hint">Use the pre-numbered OR from the issued receipt.</div>
                </div>
            }

            <button class="status-option @(!SelectedIsPaid ? "status-option-active unpaid" : "")" type="button" @onclick="() => SelectedIsPaid = false">
                <div class="status-option-icon unpaid-icon-sm">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Not Collected</div>
                    <div class="status-option-sub">Mark this stall as unpaid for the day.</div>
                </div>
                @if (!SelectedIsPaid)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            @if (!string.IsNullOrWhiteSpace(SheetError))
            {
                <div class="form-error">@SheetError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseCollectionSheet" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmCollectionAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Confirm")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowReceipt && SelectedStall is not null && Collection is not null)
{
    <div class="sheet-overlay" @onclick="CloseReceipt">
        <div class="sheet receipt-sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="receipt">
                <div class="receipt-head">
                    <img src="images/LGU_CANTILAN_LOGO.jpg" class="receipt-seal" alt="EEMO seal" />
                    <div class="receipt-gov">Republic of the Philippines</div>
                    <div class="receipt-org">Economic Enterprise &amp; Management Office</div>
                    <div class="receipt-muni">Municipality of Cantilan, Surigao del Sur</div>
                    <div class="receipt-doc">New Public Market</div>
                </div>
                <div class="receipt-divider"></div>
                <div class="receipt-meta">
                    <div class="receipt-meta-row"><span>Date</span><strong>@Collection.CollectionDate.ToString("MMMM dd, yyyy", CultureInfo.InvariantCulture)</strong></div>
                    <div class="receipt-meta-row"><span>Stall No.</span><strong>@SelectedStall.StallNo</strong></div>
                    <div class="receipt-meta-row"><span>Payor</span><strong>@SelectedStall.PayorName</strong></div>
                    <div class="receipt-meta-row"><span>Section</span><strong>@GetSectionShortName(SelectedStall.Section)</strong></div>
                    @if (SelectedStall.Section == MarketSection.FishSection && SelectedStall.FishKilosToday is { } kg)
                    {
                        <div class="receipt-meta-row"><span>Fish kilos</span><strong>@kg.ToString("0.##") kg</strong></div>
                    }
                    <div class="receipt-meta-row"><span>OR No.</span><strong>@(string.IsNullOrWhiteSpace(SelectedStall.ORNumberToday) ? "—" : SelectedStall.ORNumberToday)</strong></div>
                </div>
                <div class="receipt-divider"></div>
                <div class="receipt-total-row receipt-grand">
                    <span>Daily Fee</span>
                    <span>&#8369;@SelectedStall.DailyRate.ToString("N2")</span>
                </div>
                <div class="receipt-divider dashed"></div>
                <div class="receipt-foot">
                    <div class="receipt-foot-row">
                        <span>Collected by</span>
                        <strong>@Session.CollectorName</strong>
                    </div>
                    <div class="receipt-note">This acknowledges receipt of the daily stall fee stated above. Keep for your records.</div>
                </div>
            </div>
            <div class="receipt-close-row">
                <button class="btn-receipt-edit" type="button" @onclick="OpenEditFromReceipt">Edit</button>
                <button class="btn-receipt-close" type="button" @onclick="CloseReceipt">Close</button>
            </div>
        </div>
    </div>
}

@code {
    private MobileNpmCollectionDto? Collection;
    private bool IsLoading = true;
    private bool IsSaving;
    private string? ErrorMessage;
    private string? SheetError;
    private string SearchQuery = string.Empty;
    private string ActiveFilter = "All";
    private int SelectedYear;
    private int SelectedMonth;
    private bool ShowCollectionSheet;
    private bool ShowReceipt;
    private MobileNpmStallCollectionDto? SelectedStall;
    private bool SelectedIsPaid;
    private decimal? FishKilos;
    private string ORNumber = string.Empty;

    private readonly string[] FilterOptions = ["All", "Vegetables", "Meat", "Fish"];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
        }
        catch (HttpRequestException)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        var hasNpmAccess = Session.Menu?.Facilities.Any(f => f.Code == FacilityCode.NPM && f.IsAvailable) == true;
        if (!hasNpmAccess)
        {
            Navigation.NavigateTo("/menu", forceLoad: false);
            return;
        }

        var today = Session.Menu?.Today ?? DateOnly.FromDateTime(DateTime.Now);
        SelectedYear = today.Year;
        SelectedMonth = today.Month;

        await LoadCollectionAsync();
    }

    private async Task LoadCollectionAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        var result = await MobileApi.GetNpmCollectionAsync(SelectedYear, SelectedMonth);
        if (!result.IsSuccess || result.Value is null)
        {
            ErrorMessage = result.Error ?? "Unable to load assigned NPM stalls.";
            IsLoading = false;
            return;
        }

        Collection = result.Value;
        if (Collection.CollectionDate.Year != SelectedYear || Collection.CollectionDate.Month != SelectedMonth)
        {
            SelectedYear = Collection.CollectionDate.Year;
            SelectedMonth = Collection.CollectionDate.Month;
            var currentMonthResult = await MobileApi.GetNpmCollectionAsync(SelectedYear, SelectedMonth);
            if (currentMonthResult.IsSuccess && currentMonthResult.Value is not null)
                Collection = currentMonthResult.Value;
        }

        IsLoading = false;
    }

    private IEnumerable<MobileNpmStallCollectionDto> FilteredStalls =>
        (Collection?.Stalls ?? Array.Empty<MobileNpmStallCollectionDto>())
        .Where(s =>
        {
            var matchesSearch = string.IsNullOrWhiteSpace(SearchQuery)
                || s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
                || s.PayorName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);

            var matchesFilter = ActiveFilter switch
            {
                "Vegetables" => s.Section == MarketSection.VegetableArea,
                "Meat" => s.Section == MarketSection.MeatSection,
                "Fish" => s.Section == MarketSection.FishSection,
                _ => true
            };

            return matchesSearch && matchesFilter;
        })
        .OrderBy(s => s.Section)
        .ThenBy(s => s.StallNo);

    private string MonthLabel =>
        new DateTime(SelectedYear, SelectedMonth, 1).ToString("MMMM yyyy", CultureInfo.InvariantCulture);

    private int TodayCollectionPercent =>
        Collection is null || Collection.TotalStalls == 0
            ? 0
            : Math.Clamp((int)Math.Round((decimal)Collection.CollectedTodayCount / Collection.TotalStalls * 100m), 0, 100);

    private void GoBack() => Navigation.NavigateTo("/menu", forceLoad: false);

    // Collected stalls open a receipt (view) with an Edit option; pending/uncollected open the
    // record sheet directly so the collector can log the collection.
    private void OpenStall(MobileNpmStallCollectionDto stall)
    {
        SelectedStall = stall;
        if (stall.IsCollectedToday)
        {
            SheetError = null;
            ShowReceipt = true;
        }
        else
        {
            OpenCollectionSheet(stall);
        }
    }

    private void OpenEditFromReceipt()
    {
        ShowReceipt = false;
        if (SelectedStall is not null) OpenCollectionSheet(SelectedStall);
    }

    private void CloseReceipt()
    {
        ShowReceipt = false;
        SelectedStall = null;
    }

    private void OpenCollectionSheet(MobileNpmStallCollectionDto stall)
    {
        SelectedStall = stall;
        SelectedIsPaid = stall.IsCollectedToday;
        FishKilos = stall.FishKilosToday;
        ORNumber = stall.ORNumberToday ?? string.Empty;
        SheetError = null;
        ShowCollectionSheet = true;
    }

    private async Task ConfirmCollectionAsync()
    {
        if (SelectedStall is null || Collection is null)
            return;

        IsSaving = true;
        SheetError = null;

        var request = new RecordMobileNpmCollectionRequest(
            SelectedStall.StallId,
            SelectedIsPaid,
            SelectedIsPaid ? ORNumber : null,
            SelectedIsPaid && SelectedStall.Section == MarketSection.FishSection ? FishKilos : null);

        var result = await MobileApi.RecordNpmCollectionAsync(request);
        if (!result.IsSuccess)
        {
            SheetError = result.Error ?? "Unable to save the collection status.";
            IsSaving = false;
            return;
        }

        CloseCollectionSheet();
        try
        {
            await LoadCollectionAsync();
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void CloseCollectionSheet()
    {
        ShowCollectionSheet = false;
        SelectedStall = null;
        SelectedIsPaid = false;
        FishKilos = null;
        ORNumber = string.Empty;
        SheetError = null;
    }

    private static string FormatCurrency(decimal value) => $"₱{value:N0}";

    private static string GetSectionHeading(MarketSection? section) => section switch
    {
        MarketSection.VegetableArea => "Vegetables",
        MarketSection.FishSection => "Fish",
        MarketSection.MeatSection => "Meat",
        _ => "Unassigned"
    };

    private static string GetSectionShortName(MarketSection? section) => section switch
    {
        MarketSection.VegetableArea => "Vegetables",
        MarketSection.FishSection => "Fish",
        MarketSection.MeatSection => "Meat",
        _ => "Unassigned"
    };

    private static string GetBarClass(MobileNpmStallCollectionDto stall) =>
        stall.IsCollectedToday ? "bar-paid" :
        stall.IsMarkedToday ? "bar-unpaid" :
        string.Empty;

    private static string GetBadgeClass(MobileNpmStallCollectionDto stall) =>
        stall.IsCollectedToday ? "collected" :
        stall.IsMarkedToday ? "notcollected" :
        "pending";

    private static string GetStatusLabel(MobileNpmStallCollectionDto stall) =>
        stall.IsCollectedToday ? "Collected" :
        stall.IsMarkedToday ? "Not collected" :
        "Pending";
}
