@page "/market"
@using System.Globalization
@using global::EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Application.Requests.Mobile
@using global::EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Mobile.Models
@using EEMOCantilanSDS.Mobile.Services
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject IMobileApiClient MobileApi
@inject EEMOCantilanSDS.Mobile.Services.MobileSyncService Sync
@inject IJSRuntime JS

<div class="page-shell">
    <div class="header">
        <div class="header-eyebrow">Market Collections</div>
        <div class="header-row">
            <button class="back-btn" type="button" @onclick="GoBack" aria-label="Back to menu">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
            </button>
            <div class="header-title-block">
                <div class="header-title">New Public Market</div>
                <div class="header-sub">NPM - Stall Rental &amp; Fees</div>
            </div>
        </div>
    </div>

    <div class="date-strip">
        <div class="date-strip-left">Collector: <span>@Session.CollectorName</span></div>
        <button class="collection-month-pill" type="button">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @MonthLabel
        </button>
    </div>

    <div class="content">
        @if (IsLoading)
        {
            <LoadingState Text="Loading NPM collections…" />
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <ErrorState Title="Couldn't load collections" Message="@ErrorMessage" OnRetry="LoadCollectionAsync" />
        }
        else if (Collection is not null)
        {
            <div class="summary-strip">
                <div class="summary-item">
                    <div class="summary-value">@FormatCurrency(Collection.CollectedTodayAmount)</div>
                    <div class="summary-key">Today</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.CollectedTodayCount</div>
                    <div class="summary-key">Collected</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.PendingTodayCount</div>
                    <div class="summary-key">Pending</div>
                </div>
            </div>

            <div class="month-banner">
                <div class="month-banner-left">
                    <div class="month-banner-label">Collection Period</div>
                    <div class="month-banner-month">@MonthLabel</div>
                    <div class="month-banner-date">@Collection.CollectionDate.ToString("MMM dd, yyyy", CultureInfo.InvariantCulture)</div>
                </div>
                <div class="month-banner-right">
                    <div class="month-banner-stat">
                        <span class="month-banner-val">@Collection.CollectedTodayCount</span>
                        <span class="month-banner-key">of @Collection.TotalStalls collected</span>
                    </div>
                    <div class="month-progress-wrap">
                        <div class="month-progress-fill" style="width:@TodayCollectionPercent%"></div>
                    </div>
                </div>
            </div>

            <div class="search-wrap">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search stall no. or name" @bind="SearchQuery" @bind:event="oninput" />
            </div>

            <div class="seg-filter">
                @foreach (var tab in FilterOptions)
                {
                    <button class="seg-filter-btn @(ActiveFilter == tab ? "active" : "")" type="button" @onclick="() => ActiveFilter = tab">
                        @tab
                    </button>
                }
            </div>

            @if (!FilteredStalls.Any())
            {
                <div class="state-card">
                    <div class="state-title">No matching stalls</div>
                    <div class="state-text">Try another search or filter.</div>
                </div>
            }
            else
            {
                @foreach (var sectionGroup in FilteredStalls.GroupBy(s => s.Section))
                {
                    <div class="section-label">@GetSectionHeading(sectionGroup.Key)</div>

                    @foreach (var stall in sectionGroup)
                    {
                        <button class="tx-card" type="button" @onclick="() => OpenStall(stall)">
                            <div class="tx-body">
                                <div class="tx-avatar">@Initials(stall.PayorName)</div>
                                <div class="tx-col-info">
                                    <span class="tx-owner">@stall.PayorName</span>
                                    <span class="tx-sub">
                                        <span class="tx-tag">No. @stall.StallNo</span>
                                        @if (!string.IsNullOrWhiteSpace(stall.ORNumberToday))
                                        {
                                            <span class="tx-or">OR @stall.ORNumberToday</span>
                                        }
                                        else if (!string.IsNullOrWhiteSpace(stall.ContractName) && stall.ContractName != stall.PayorName)
                                        {
                                            <span class="tx-or">@stall.ContractName</span>
                                        }
                                    </span>
                                </div>
                                <div class="tx-col-right">
                                    @if (IsQueuedOffline(stall))
                                    {
                                        <span class="tx-badge queued"><span class="tx-dot"></span>Queued</span>
                                    }
                                    else
                                    {
                                        <span class="tx-badge @GetBadgeClass(stall)"><span class="tx-dot"></span>@GetStatusLabel(stall)</span>
                                    }
                                    <span class="tx-amount">@FormatCurrency(stall.DailyRate)</span>
                                </div>
                            </div>
                        </button>
                    }
                }
            }
        }
    </div>

    <BottomNav ActiveTab="menu" />
</div>

@if (ShowCollectionSheet && SelectedStall is not null)
{
    <div class="sheet-overlay" @onclick="CloseCollectionSheet">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Record Daily Collection</div>
            <div class="sheet-sub">Update today's collection status for this stall.</div>

            <div class="sheet-preview">
                <div class="preview-num">@SelectedStall.StallNo</div>
                <div class="preview-info">
                    <div class="preview-name">@SelectedStall.PayorName</div>
                    <div class="preview-detail">@GetSectionShortName(SelectedStall.Section) - @FormatCurrency(SelectedStall.DailyRate)</div>
                </div>
            </div>

            <button class="status-option @(SelectedIsPaid ? "status-option-active paid" : "")" type="button" @onclick="() => SetStatus(true, false)">
                <div class="status-option-icon paid-icon-sm">
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Collected</div>
                    <div class="status-option-sub">Daily stall fee collected - @FormatCurrency(SelectedStall.DailyRate)</div>
                </div>
                @if (SelectedIsPaid)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            @if (SelectedIsPaid && SelectedStall.Section == MarketSection.FishSection)
            {
                <div class="fish-kilo-wrap">
                    <div class="form-label">Fish kilos collected</div>
                    <div class="fish-input-row">
                        <input class="form-input" type="number" min="0" step="0.01" placeholder="0" @bind="FishKilos" @bind:event="oninput" />
                        <span>kg</span>
                    </div>
                </div>
            }

            @if (SelectedIsPaid)
            {
                <div class="or-number-wrap">
                    <div class="form-label">Official receipt no. <span>optional</span></div>
                    <input class="form-input mono-input"
                           type="text"
                           inputmode="numeric"
                           maxlength="30"
                           placeholder="000001"
                           @bind="ORNumber"
                           @bind:event="oninput" />
                    <div class="form-hint">Use the pre-numbered OR from the issued receipt.</div>
                </div>
            }

            <button class="status-option @(!SelectedIsPaid && !SelectedIsAbsent && !SelectedIsMisc ? "status-option-active unpaid" : "")" type="button" @onclick="() => SetStatus(false, false)">
                <div class="status-option-icon unpaid-icon-sm">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Not Collected</div>
                    <div class="status-option-sub">Mark this stall as unpaid for the day.</div>
                </div>
                @if (!SelectedIsPaid && !SelectedIsAbsent && !SelectedIsMisc)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            <button class="status-option @(SelectedIsAbsent ? "status-option-active absent" : "")" type="button" @onclick="() => SetStatus(false, true)">
                <div class="status-option-icon absent-icon-sm">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="8" y1="12" x2="16" y2="12" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Absent</div>
                    <div class="status-option-sub">Vendor not operating today — nothing owed for this day.</div>
                </div>
                @if (SelectedIsAbsent)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            <button id="misc-option" class="status-option @(SelectedIsMisc ? "status-option-active misc" : "")" type="button" @onclick="SetMisc">
                <div class="status-option-icon misc-icon-sm">
                    <svg viewBox="0 0 24 24"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Miscellaneous</div>
                    <div class="status-option-sub">
                        Electricity &amp; water bill@(SelectedBill is not null ? $" · {FormatPeso(SelectedBill.BalanceDue)} due" : "")
                    </div>
                </div>
                @if (SelectedIsMisc)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            @if (SelectedIsMisc)
            {
                @if (SelectedBill is null)
                {
                    <div class="misc-empty">No electricity or water bill recorded for this stall in @MonthLabel. Utility bills are entered at the office.</div>
                }
                else
                {
                    <div class="misc-pay">
                        <div class="misc-util-head">
                            <span class="misc-util-name">Electricity</span>
                            <span class="misc-util-amt">
                                @FormatPeso(SelectedBill.ElecBalanceDue)
                                @if (SelectedBill.ElecBalanceDue < SelectedBill.ElecCharge)
                                {
                                    <span class="misc-util-of">of @FormatPeso(SelectedBill.ElecCharge)</span>
                                }
                            </span>
                        </div>
                        <div class="util-pay-row">
                            <button class="util-pay-chip @(MiscElecPay == PaymentStatus.Unpaid ? "on" : "")" type="button" @onclick="() => MiscElecPay = PaymentStatus.Unpaid">Unpaid</button>
                            <button class="util-pay-chip @(MiscElecPay == PaymentStatus.Paid ? "on" : "")" type="button" @onclick="() => MiscElecPay = PaymentStatus.Paid">Paid</button>
                            <button class="util-pay-chip @(MiscElecPay == PaymentStatus.Partial ? "on" : "")" type="button" @onclick="() => MiscElecPay = PaymentStatus.Partial">Partial</button>
                        </div>
                        @if (MiscElecPay == PaymentStatus.Partial)
                        {
                            <input class="form-input" type="number" min="0" step="0.01" placeholder="Electricity partial amount" @bind="MiscElecPartial" @bind:event="oninput" />
                        }
                        @if (MiscElecPay != PaymentStatus.Unpaid)
                        {
                            <input class="form-input mono-input misc-or-input" type="text" inputmode="numeric" maxlength="50" placeholder="Electricity OR no." @bind="MiscElecOr" @bind:event="oninput" />
                        }

                        <div class="misc-util-head misc-util-head-gap">
                            <span class="misc-util-name">Water</span>
                            <span class="misc-util-amt">
                                @FormatPeso(SelectedBill.WaterBalanceDue)
                                @if (SelectedBill.WaterBalanceDue < SelectedBill.WaterCharge)
                                {
                                    <span class="misc-util-of">of @FormatPeso(SelectedBill.WaterCharge)</span>
                                }
                            </span>
                        </div>
                        <div class="util-pay-row">
                            <button class="util-pay-chip @(MiscWaterPay == PaymentStatus.Unpaid ? "on" : "")" type="button" @onclick="() => MiscWaterPay = PaymentStatus.Unpaid">Unpaid</button>
                            <button class="util-pay-chip @(MiscWaterPay == PaymentStatus.Paid ? "on" : "")" type="button" @onclick="() => MiscWaterPay = PaymentStatus.Paid">Paid</button>
                            <button class="util-pay-chip @(MiscWaterPay == PaymentStatus.Partial ? "on" : "")" type="button" @onclick="() => MiscWaterPay = PaymentStatus.Partial">Partial</button>
                        </div>
                        @if (MiscWaterPay == PaymentStatus.Partial)
                        {
                            <input class="form-input" type="number" min="0" step="0.01" placeholder="Water partial amount" @bind="MiscWaterPartial" @bind:event="oninput" />
                        }
                        @if (MiscWaterPay != PaymentStatus.Unpaid)
                        {
                            <input class="form-input mono-input misc-or-input" type="text" inputmode="numeric" maxlength="50" placeholder="Water OR no." @bind="MiscWaterOr" @bind:event="oninput" />
                        }

                        <div class="misc-collect"><span>Collecting</span><strong>@FormatPeso(MiscCollectAmount)</strong></div>
                    </div>
                }
            }

            @if (!string.IsNullOrWhiteSpace(SheetError))
            {
                <div class="form-error">@SheetError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseCollectionSheet" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmCollectionAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Confirm")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowReceipt && SelectedStall is not null && Collection is not null)
{
    <div class="sheet-overlay" @onclick="CloseReceipt">
        <div class="sheet receipt-sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="receipt">
                <div class="receipt-head">
                    <img src="images/LGU_CANTILAN_LOGO.jpg" class="receipt-seal" alt="EEMO seal" />
                    <div class="receipt-gov">Republic of the Philippines</div>
                    <div class="receipt-org">Economic Enterprise &amp; Management Office</div>
                    <div class="receipt-muni">Municipality of Cantilan, Surigao del Sur</div>
                    <div class="receipt-doc">New Public Market</div>
                </div>
                <div class="receipt-divider"></div>
                <div class="receipt-meta">
                    <div class="receipt-meta-row"><span>Date</span><strong>@Collection.CollectionDate.ToString("MMMM dd, yyyy", CultureInfo.InvariantCulture)</strong></div>
                    <div class="receipt-meta-row"><span>Stall No.</span><strong>@SelectedStall.StallNo</strong></div>
                    <div class="receipt-meta-row"><span>Payor</span><strong>@SelectedStall.PayorName</strong></div>
                    <div class="receipt-meta-row"><span>Section</span><strong>@GetSectionShortName(SelectedStall.Section)</strong></div>
                    @if (SelectedStall.Section == MarketSection.FishSection && SelectedStall.FishKilosToday is { } kg)
                    {
                        <div class="receipt-meta-row"><span>Fish kilos</span><strong>@kg.ToString("0.##") kg</strong></div>
                    }
                    <div class="receipt-meta-row"><span>OR No.</span><strong>@(string.IsNullOrWhiteSpace(SelectedStall.ORNumberToday) ? "—" : SelectedStall.ORNumberToday)</strong></div>
                </div>
                <div class="receipt-divider"></div>
                <div class="receipt-total-row receipt-grand">
                    <span>Daily Fee</span>
                    <span>&#8369;@SelectedStall.DailyRate.ToString("N2")</span>
                </div>
                <div class="receipt-divider dashed"></div>
                <div class="receipt-foot">
                    <div class="receipt-foot-row">
                        <span>Collected by</span>
                        <strong>@Session.CollectorName</strong>
                    </div>
                    <div class="receipt-note">This acknowledges receipt of the daily stall fee stated above. Keep for your records.</div>
                </div>
            </div>
            <div class="receipt-close-row">
                <button class="btn-receipt-edit" type="button" @onclick="OpenEditFromReceipt">Edit</button>
                <button class="btn-receipt-misc" type="button" @onclick="OpenMiscFromReceipt">Misc</button>
                <button class="btn-receipt-close" type="button" @onclick="CloseReceipt">Close</button>
            </div>
        </div>
    </div>
}

@code {
    private MobileNpmCollectionDto? Collection;
    // Stall ids with a locally-queued (not-yet-synced) offline collection for the shown day.
    private HashSet<Guid> QueuedOfflineStalls = new();
    private bool IsLoading = true;
    private bool IsSaving;
    private string? ErrorMessage;
    private string? SheetError;
    private string SearchQuery = string.Empty;
    private string ActiveFilter = "All";
    private int SelectedYear;
    private int SelectedMonth;
    private bool ShowCollectionSheet;
    private bool ShowReceipt;
    private MobileNpmStallCollectionDto? SelectedStall;
    private bool SelectedIsPaid;
    private bool SelectedIsAbsent;
    private decimal? FishKilos;
    private string ORNumber = string.Empty;

    // Miscellaneous (electricity & water bill) collection, settled from the same daily sheet.
    private bool SelectedIsMisc;
    private MobileUtilityBillDto? SelectedBill;
    private PaymentStatus MiscElecPay = PaymentStatus.Unpaid;
    private PaymentStatus MiscWaterPay = PaymentStatus.Unpaid;
    private decimal MiscElecPartial;
    private decimal MiscWaterPartial;
    private string MiscElecOr = string.Empty;
    private string MiscWaterOr = string.Empty;
    private bool _scrollToMisc;
    // The month's utility bills keyed by stall number, so the sheet can settle a stall's bill inline.
    private Dictionary<string, MobileUtilityBillDto> UtilityByStallNo = new(StringComparer.OrdinalIgnoreCase);

    private decimal MiscCollectAmount
    {
        get
        {
            if (SelectedBill is null) return 0m;
            var elec = MiscElecPay == PaymentStatus.Paid ? SelectedBill.ElecBalanceDue
                     : MiscElecPay == PaymentStatus.Partial ? MiscElecPartial : 0m;
            var water = MiscWaterPay == PaymentStatus.Paid ? SelectedBill.WaterBalanceDue
                      : MiscWaterPay == PaymentStatus.Partial ? MiscWaterPartial : 0m;
            return elec + water;
        }
    }

    private readonly string[] FilterOptions = ["All", "Vegetables", "Meat", "Fish"];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
        }
        catch (HttpRequestException)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        var hasNpmAccess = Session.Menu?.Facilities.Any(f => f.Code == FacilityCode.NPM && f.IsAvailable) == true;
        if (!hasNpmAccess)
        {
            Navigation.NavigateTo("/menu", forceLoad: false);
            return;
        }

        var today = Session.Menu?.Today ?? DateOnly.FromDateTime(DateTime.Now);
        SelectedYear = today.Year;
        SelectedMonth = today.Month;

        await LoadCollectionAsync();
    }

    private async Task LoadCollectionAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        StateHasChanged();

        try
        {
            var result = await MobileApi.GetNpmCollectionAsync(SelectedYear, SelectedMonth);
            if (!result.IsSuccess || result.Value is null)
            {
                ErrorMessage = result.Error ?? "Unable to load assigned NPM stalls.";
                return;
            }

            Collection = result.Value;
            if (Collection.CollectionDate.Year != SelectedYear || Collection.CollectionDate.Month != SelectedMonth)
            {
                SelectedYear = Collection.CollectionDate.Year;
                SelectedMonth = Collection.CollectionDate.Month;
                var currentMonthResult = await MobileApi.GetNpmCollectionAsync(SelectedYear, SelectedMonth);
                if (currentMonthResult.IsSuccess && currentMonthResult.Value is not null)
                    Collection = currentMonthResult.Value;
            }

            await RefreshQueuedOfflineAsync();
            await LoadUtilityBillsAsync();
        }
        catch
        {
            // The HTTP layer throws on a connection failure/timeout; keep the retry path safe and unstuck.
            ErrorMessage = "Unable to connect to the EEMO server. Please check the connection and try again.";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    // Stalls collected offline for the shown day → show "Queued · Offline" instead of "Pending".
    private async Task RefreshQueuedOfflineAsync()
    {
        if (Collection is null)
        {
            QueuedOfflineStalls = new();
            return;
        }

        var pending = await Sync.GetAllAsync();
        QueuedOfflineStalls = pending
            .Where(o => o.Kind == OfflineOperationKind.NpmDaily
                     && o.StallId is not null
                     && string.Equals(o.FacilityLabel, "NPM", StringComparison.OrdinalIgnoreCase)
                     && o.BusinessDate == Collection.CollectionDate
                     && o.LocalStatus is PendingLocalStatus.Pending or PendingLocalStatus.Failed)
            .Select(o => o.StallId!.Value)
            .ToHashSet();
    }

    private bool IsQueuedOffline(MobileNpmStallCollectionDto stall) => QueuedOfflineStalls.Contains(stall.StallId);

    // Loads the month's electricity/water bills so a stall's bill can be settled inline from the sheet.
    private async Task LoadUtilityBillsAsync()
    {
        try
        {
            var util = await MobileApi.GetNpmUtilityAsync(SelectedYear, SelectedMonth);
            UtilityByStallNo = util.IsSuccess && util.Value is not null
                ? util.Value.Bills
                    .GroupBy(b => b.StallNo, StringComparer.OrdinalIgnoreCase)
                    .ToDictionary(g => g.Key, g => g.First(), StringComparer.OrdinalIgnoreCase)
                : new(StringComparer.OrdinalIgnoreCase);
        }
        catch
        {
            UtilityByStallNo = new(StringComparer.OrdinalIgnoreCase); // non-fatal; daily collection still works
        }
    }

    private IEnumerable<MobileNpmStallCollectionDto> FilteredStalls =>
        (Collection?.Stalls ?? Array.Empty<MobileNpmStallCollectionDto>())
        .Where(s =>
        {
            var matchesSearch = string.IsNullOrWhiteSpace(SearchQuery)
                || s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
                || s.PayorName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);

            var matchesFilter = ActiveFilter switch
            {
                "Vegetables" => s.Section == MarketSection.VegetableArea,
                "Meat" => s.Section == MarketSection.MeatSection,
                "Fish" => s.Section == MarketSection.FishSection,
                _ => true
            };

            return matchesSearch && matchesFilter;
        })
        .OrderBy(s => s.Section)
        .ThenBy(s => s.StallNo);

    private string MonthLabel =>
        new DateTime(SelectedYear, SelectedMonth, 1).ToString("MMMM yyyy", CultureInfo.InvariantCulture);

    private int TodayCollectionPercent =>
        Collection is null || Collection.TotalStalls == 0
            ? 0
            : Math.Clamp((int)Math.Round((decimal)Collection.CollectedTodayCount / Collection.TotalStalls * 100m), 0, 100);

    private void GoBack() => Navigation.NavigateTo("/menu", forceLoad: false);

    // Collected stalls open a receipt (view) with an Edit option; pending/uncollected open the
    // record sheet directly so the collector can log the collection.
    private void OpenStall(MobileNpmStallCollectionDto stall)
    {
        SelectedStall = stall;
        if (stall.IsCollectedToday)
        {
            SheetError = null;
            ShowReceipt = true;
        }
        else
        {
            OpenCollectionSheet(stall);
        }
    }

    private void OpenEditFromReceipt()
    {
        ShowReceipt = false;
        if (SelectedStall is not null) OpenCollectionSheet(SelectedStall);
    }

    // From a collected stall's receipt: jump straight into the Miscellaneous (electricity & water)
    // collection so the collector can settle utilities the daily fee flow didn't cover.
    private void OpenMiscFromReceipt()
    {
        ShowReceipt = false;
        if (SelectedStall is not null)
        {
            OpenCollectionSheet(SelectedStall);
            SetMisc();
        }
    }

    private void CloseReceipt()
    {
        ShowReceipt = false;
        SelectedStall = null;
    }

    private void OpenCollectionSheet(MobileNpmStallCollectionDto stall)
    {
        SelectedStall = stall;
        SelectedIsPaid = stall.IsCollectedToday;
        SelectedIsAbsent = stall.IsAbsentToday;
        FishKilos = stall.FishKilosToday;
        ORNumber = stall.ORNumberToday ?? string.Empty;
        SelectedIsMisc = false;
        SelectedBill = UtilityByStallNo.TryGetValue(stall.StallNo, out var bill) ? bill : null;
        MiscElecPay = MiscWaterPay = PaymentStatus.Unpaid;
        MiscElecPartial = MiscWaterPartial = 0m;
        MiscElecOr = MiscWaterOr = string.Empty;
        SheetError = null;
        ShowCollectionSheet = true;
    }

    // Tri-state selection in the record sheet: Collected (paid), Not Collected (neither), Absent (excused).
    private void SetStatus(bool paid, bool absent)
    {
        SelectedIsPaid = paid;
        SelectedIsAbsent = absent;
        SelectedIsMisc = false;
    }

    // Selects the Miscellaneous (electricity & water bill) option and seeds each utility to Paid
    // when it still has a balance, mirroring the office/web collection defaults.
    private void SetMisc()
    {
        SelectedIsPaid = false;
        SelectedIsAbsent = false;
        SelectedIsMisc = true;
        if (SelectedBill is not null)
        {
            MiscElecPay = SelectedBill.ElecBalanceDue > 0m ? PaymentStatus.Paid : PaymentStatus.Unpaid;
            MiscWaterPay = SelectedBill.WaterBalanceDue > 0m ? PaymentStatus.Paid : PaymentStatus.Unpaid;
        }
        MiscElecPartial = MiscWaterPartial = 0m;
        MiscElecOr = MiscWaterOr = string.Empty;
        SheetError = null;
        _scrollToMisc = true;
    }

    private async Task ConfirmCollectionAsync()
    {
        if (SelectedStall is null || Collection is null)
            return;

        if (SelectedIsMisc)
        {
            await ConfirmMiscAsync();
            return;
        }

        IsSaving = true;
        SheetError = null;

        // Offline: queue the collection locally and let it sync when connectivity returns. Collected
        // and Absent (₱0 excused) can be captured offline; only a no-money "Not collected" needs the
        // server (it's a plain state change with nothing to replay).
        if (!Sync.IsOnline)
        {
            if (!SelectedIsPaid && !SelectedIsAbsent)
            {
                SheetError = "You're offline. Marking a stall 'Not collected' needs a connection.";
                IsSaving = false;
                return;
            }

            await Sync.EnqueueAsync(new PendingOperation
            {
                Kind = OfflineOperationKind.NpmDaily,
                BusinessDate = DateOnly.FromDateTime(DateTime.Now),
                StallId = SelectedStall.StallId,
                IsPaid = SelectedIsPaid,
                IsAbsent = SelectedIsAbsent,
                FishKilos = SelectedIsPaid && SelectedStall.Section == MarketSection.FishSection ? FishKilos : null,
                ORNumber = SelectedIsPaid && !string.IsNullOrWhiteSpace(ORNumber) ? ORNumber.Trim() : null,
                FacilityLabel = "NPM",
                Title = SelectedStall.PayorName,
                Detail = SelectedIsAbsent ? $"No. {SelectedStall.StallNo} · Absent" : $"No. {SelectedStall.StallNo}",
                Amount = SelectedIsAbsent ? 0m : SelectedStall.DailyRate
            });

            QueuedOfflineStalls.Add(SelectedStall.StallId); // reflect immediately on the card
            CloseCollectionSheet();
            IsSaving = false;
            return;
        }

        var request = new RecordMobileNpmCollectionRequest(
            SelectedStall.StallId,
            SelectedIsPaid,
            SelectedIsPaid ? ORNumber : null,
            SelectedIsPaid && SelectedStall.Section == MarketSection.FishSection ? FishKilos : null,
            SelectedIsAbsent);

        var result = await MobileApi.RecordNpmCollectionAsync(request);
        if (!result.IsSuccess)
        {
            SheetError = result.Error ?? "Unable to save the collection status.";
            IsSaving = false;
            return;
        }

        CloseCollectionSheet();
        try
        {
            await LoadCollectionAsync();
        }
        finally
        {
            IsSaving = false;
        }
    }

    // Records the stall's electricity/water bill from the sheet — online via the API, offline queued
    // (replays idempotently on the bill via ClientOperationId), mirroring the daily-collection flow.
    private async Task ConfirmMiscAsync()
    {
        if (SelectedStall is null || SelectedBill is null)
        {
            SheetError = "No electricity or water bill for this stall this month.";
            return;
        }
        if (MiscElecPay == PaymentStatus.Unpaid && MiscWaterPay == PaymentStatus.Unpaid)
        {
            SheetError = "Choose Paid or Partial for electricity and/or water.";
            return;
        }
        if (MiscElecPay == PaymentStatus.Partial && MiscElecPartial <= 0m) { SheetError = "Enter an electricity partial amount."; return; }
        if (MiscWaterPay == PaymentStatus.Partial && MiscWaterPartial <= 0m) { SheetError = "Enter a water partial amount."; return; }
        if (MiscElecPay != PaymentStatus.Unpaid && string.IsNullOrWhiteSpace(MiscElecOr)) { SheetError = "Electricity OR number is required."; return; }
        if (MiscWaterPay != PaymentStatus.Unpaid && string.IsNullOrWhiteSpace(MiscWaterOr)) { SheetError = "Water OR number is required."; return; }

        IsSaving = true;
        SheetError = null;
        var elecPartial = MiscElecPay == PaymentStatus.Partial ? (decimal?)MiscElecPartial : null;
        var waterPartial = MiscWaterPay == PaymentStatus.Partial ? (decimal?)MiscWaterPartial : null;
        var elecOr = MiscElecPay != PaymentStatus.Unpaid ? MiscElecOr.Trim() : null;
        var waterOr = MiscWaterPay != PaymentStatus.Unpaid ? MiscWaterOr.Trim() : null;
        var orLabel = elecOr ?? waterOr;

        if (!Sync.IsOnline)
        {
            await Sync.EnqueueAsync(new PendingOperation
            {
                Kind = OfflineOperationKind.NpmUtility,
                BusinessDate = new DateOnly(SelectedYear, SelectedMonth, 1),
                UtilityBillId = SelectedBill.BillId,
                ElecStatus = MiscElecPay,
                ElecPartialAmount = elecPartial,
                WaterStatus = MiscWaterPay,
                WaterPartialAmount = waterPartial,
                ElecORNumber = elecOr,
                WaterORNumber = waterOr,
                FacilityLabel = "NPM",
                Title = SelectedStall.PayorName,
                Detail = $"No. {SelectedStall.StallNo} · utilities · OR {orLabel}",
                Amount = MiscCollectAmount
            });
            CloseCollectionSheet();
            IsSaving = false;
            return;
        }

        var result = await MobileApi.RecordNpmUtilityPaymentAsync(new RecordMobileUtilityPaymentRequest(
            SelectedBill.BillId, MiscElecPay, elecPartial, MiscWaterPay, waterPartial, elecOr, waterOr, null));
        if (!result.IsSuccess)
        {
            SheetError = result.Error ?? "Unable to record the utility payment.";
            IsSaving = false;
            return;
        }

        CloseCollectionSheet();
        try
        {
            await LoadCollectionAsync();
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void CloseCollectionSheet()
    {
        ShowCollectionSheet = false;
        SelectedStall = null;
        SelectedIsPaid = false;
        SelectedIsAbsent = false;
        FishKilos = null;
        ORNumber = string.Empty;
        SelectedIsMisc = false;
        SelectedBill = null;
        MiscElecPay = MiscWaterPay = PaymentStatus.Unpaid;
        MiscElecPartial = MiscWaterPartial = 0m;
        MiscElecOr = MiscWaterOr = string.Empty;
        SheetError = null;
    }

    private static string FormatCurrency(decimal value) => $"₱{value:N0}";

    // Formal 2-decimal peso for official bill amounts (electricity/water/collecting).
    private static string FormatPeso(decimal value) => $"₱{value:N2}";

    // Brings the Miscellaneous panel into view when it opens, so the sheet stays clean/structured.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_scrollToMisc)
        {
            _scrollToMisc = false;
            try { await JS.InvokeVoidAsync("scrollElementIntoView", "misc-option"); }
            catch { /* webview not ready / sheet closed — non-fatal */ }
        }
    }

    private static string GetSectionHeading(MarketSection? section) => section switch
    {
        MarketSection.VegetableArea => "Vegetables",
        MarketSection.FishSection => "Fish",
        MarketSection.MeatSection => "Meat",
        _ => "Unassigned"
    };

    private static string GetSectionShortName(MarketSection? section) => section switch
    {
        MarketSection.VegetableArea => "Vegetables",
        MarketSection.FishSection => "Fish",
        MarketSection.MeatSection => "Meat",
        _ => "Unassigned"
    };

    private static string GetBarClass(MobileNpmStallCollectionDto stall) =>
        stall.IsCollectedToday ? "bar-paid" :
        stall.IsAbsentToday ? "bar-absent" :
        stall.IsMarkedToday ? "bar-unpaid" :
        string.Empty;

    private static string GetBadgeClass(MobileNpmStallCollectionDto stall) =>
        stall.IsCollectedToday ? "collected" :
        stall.IsAbsentToday ? "absent" :
        stall.IsMarkedToday ? "notcollected" :
        "pending";

    private static string GetStatusLabel(MobileNpmStallCollectionDto stall) =>
        stall.IsCollectedToday ? "Collected" :
        stall.IsAbsentToday ? "Absent" :
        stall.IsMarkedToday ? "Not collected" :
        "Pending";

    // Initials for the card avatar (1–2 letters from the payor's name).
    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "•";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
            return parts[0].Substring(0, 1).ToUpperInvariant();
        return (parts[0].Substring(0, 1) + parts[^1].Substring(0, 1)).ToUpperInvariant();
    }
}
