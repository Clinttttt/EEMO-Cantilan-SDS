@page "/reports"
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Domain.Enums
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject EEMOCantilanSDS.Application.Common.Interface.ApiClients.IMobileApiClient Api

<div class="page-shell">

    <AppHeader CollectorName="@Session.CollectorName" />

    <div class="content">

        <div class="period-selector">
            <div class="period-arrow" @onclick="PrevPeriod">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
            </div>
            <div class="period-label-block">
                <div class="period-title">@PeriodTitle</div>
                <div class="period-sub">@PeriodSubtitle</div>
            </div>
            <div class="period-arrow @(CanGoNext ? "" : "disabled")" @onclick="NextPeriod">
                <svg viewBox="0 0 24 24"><polyline points="9 6 15 12 9 18" /></svg>
            </div>
        </div>

        <div class="report-type-tabs">
            @foreach (var tab in ReportTypes)
            {
                <div class="report-type-tab @(ActiveReportType == tab ? "active" : "")"
                     @onclick="() => SetReportType(tab)">
                    @tab
                </div>
            }
        </div>

        @if (IsLoading)
        {
            <LoadingState Text="Loading your reports…" />
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <ErrorState Title="Couldn't load reports" Message="@ErrorMessage" OnRetry="LoadReportAsync" />
        }
        else
        {
            <div class="total-banner">
                <div class="total-banner-left">
                    <div class="total-banner-label">Total Collection</div>
                    <div class="total-banner-amount">&#8369;@GrandTotal.ToString("N0")</div>
                </div>
                <div class="total-banner-right">
                    <div class="total-banner-stat">
                        <span class="stat-val">@TotalTransactions</span>
                        <span class="stat-key">Transactions</span>
                    </div>
                    <div class="total-banner-stat">
                        <span class="stat-val">@PayeeCount</span>
                        <span class="stat-key">Payees</span>
                    </div>
                </div>
            </div>

            @if (ActiveReportType == PrimaryReportTab)
            {
                <div class="section-label">
                    @(WeeklyReportMode ? "Breakdown by Market Day" : DailyReportMode ? "Breakdown by Day" : "Breakdown by Month")
                    <span class="section-total">&#8369;@GrandTotal.ToString("N0")</span>
                </div>

                @if (DailyReportMode)
                {
                    @if (!DailySummaries.Any())
                    {
                        @EmptyState("No collections recorded for this period.")
                    }
                    else
                    {
                        @foreach (var day in DailySummaries)
                        {
                            <div class="day-row">
                                <div class="day-date-block">
                                    <span class="day-date-num">@day.PeriodDate.Day</span>
                                    <span class="day-date-mon">@day.PeriodDate.ToDateTime(TimeOnly.MinValue).ToString("MMM")</span>
                                </div>
                                <div class="day-info">
                                    <div class="day-label">@GetDayLabel(day.PeriodDate)</div>
                                    <div class="day-meta">@day.TransactionCount entries from @day.PayeeCount payees</div>
                                </div>
                                <div class="day-amount-col">
                                    <div class="day-amount">&#8369;@day.CollectedAmount.ToString("N0")</div>
                                    <div class="day-count">@GetPeriodStatusText(day)</div>
                                </div>
                            </div>
                        }
                    }
                }
                else
                {
                    @if (!MonthlySummaries.Any())
                    {
                        @EmptyState("No collections recorded for this period.")
                    }
                    else
                    {
                        @foreach (var month in MonthlySummaries)
                        {
                            <div class="day-row">
                                <div class="day-date-block">
                                    <span class="day-date-num">@month.PeriodDate.ToDateTime(TimeOnly.MinValue).ToString("MMM")</span>
                                    <span class="day-date-mon">@month.PeriodDate.Year</span>
                                </div>
                                <div class="day-info">
                                    <div class="day-label">@month.PeriodDate.ToDateTime(TimeOnly.MinValue).ToString("MMMM yyyy")</div>
                                    <div class="day-meta">@month.TransactionCount entries from @month.PayeeCount payees</div>
                                </div>
                                <div class="day-amount-col">
                                    <div class="day-amount">&#8369;@month.CollectedAmount.ToString("N0")</div>
                                    <div class="day-count">@GetPeriodStatusText(month)</div>
                                </div>
                            </div>
                        }
                    }
                }
            }

            @if (ActiveReportType == "Per Payee")
            {
                <div class="section-label">
                    Per Payee Collections
                    <span class="section-total">@FilteredPayees.Count() payees</span>
                </div>

                <div class="search-wrap">
                    <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                    <input type="text"
                           placeholder="Search payor name, stall no., OR..."
                           @bind="PayeeSearch"
                           @bind:event="oninput" />
                    @if (!string.IsNullOrEmpty(PayeeSearch))
                    {
                        <div style="cursor:pointer;padding:0 4px;color:var(--text-muted);font-size:16px;"
                             @onclick="() => PayeeSearch = string.Empty">
                            x
                        </div>
                    }
                </div>

                @if (!FilteredPayees.Any())
                {
                    @EmptyState("No payee collections recorded for this period.")
                }
                else
                {
                    @foreach (var p in FilteredPayees)
                    {
                        <div class="payee-row">
                            <div class="payee-status-dot @GetPayeeStatusClass(p)"></div>
                            <div class="payee-info">
                                <div class="payee-name">@p.PayorName</div>
                                <div class="payee-meta">
                                    <span class="facility-code">@p.FacilityCode</span>
                                    @if (!string.IsNullOrWhiteSpace(p.StallNo))
                                    {
                                        <span class="payee-months">Stall @p.StallNo</span>
                                    }
                                    <span class="payee-months">@p.TransactionCount entries</span>
                                </div>
                                @if (p.LastCollectedAt.HasValue)
                                {
                                    <div class="payee-last-paid">
                                        <span class="last-paid-ok">Last collection: @p.LastCollectedAt.Value.ToString("MMM d, yyyy")</span>
                                    </div>
                                }
                            </div>
                            <div class="payee-amount-col">
                                <div class="payee-total paid-total">&#8369;@p.AmountPaid.ToString("N0")</div>
                                <div class="payee-balance-sub">
                                    @if (p.Balance > 0)
                                    {
                                        <span>Balance &#8369;@p.Balance.ToString("N0")</span>
                                    }
                                    else
                                    {
                                        <span>@p.PartialCount partial</span>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
            }

            @if (ActiveReportType == "Summary")
            {
                <div class="section-label">Collection Summary</div>

                <div class="facility-row report-card-tap" role="button" tabindex="0" @onclick="@(() => OpenDetail("collected"))" @onkeydown="@(e => OnCardKey(e, "collected"))">
                    <div class="facility-icon">
                        <svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z" /><path d="M2 17l10 5 10-5M2 12l10 5 10-5" /></svg>
                    </div>
                    <div class="facility-info">
                        <div class="facility-name">Total Collected</div>
                        <div class="facility-meta"><span class="facility-count">@ScopeLabel · @PeriodTitle</span></div>
                    </div>
                    <div class="facility-amount-col">
                        <div class="facility-amount">&#8369;@GrandTotal.ToString("N0")</div>
                    </div>
                </div>

                <div class="facility-row report-card-tap" role="button" tabindex="0" @onclick="@(() => OpenDetail("outstanding"))" @onkeydown="@(e => OnCardKey(e, "outstanding"))">
                    <div class="facility-icon">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="1" x2="12" y2="23" /><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6" /></svg>
                    </div>
                    <div class="facility-info">
                        <div class="facility-name">Outstanding Balance</div>
                        <div class="facility-meta"><span class="facility-count">Remaining collectible from current payors</span></div>
                    </div>
                    <div class="facility-amount-col">
                        <div class="facility-amount">&#8369;@Outstanding.ToString("N0")</div>
                    </div>
                </div>

                <div class="facility-row">
                    <div class="facility-icon">
                        <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                    </div>
                    <div class="facility-info">
                        <div class="facility-name">Recorded Transactions</div>
                        <div class="facility-meta"><span class="facility-count">Paid and partial collection events</span></div>
                    </div>
                    <div class="facility-amount-col">
                        <div class="facility-amount">@TotalTransactions</div>
                    </div>
                </div>

                <div class="facility-row">
                    <div class="facility-icon">
                        <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                    </div>
                    <div class="facility-info">
                        <div class="facility-name">Payees Served</div>
                        <div class="facility-meta"><span class="facility-count">Unique payors in this period</span></div>
                    </div>
                    <div class="facility-amount-col">
                        <div class="facility-amount">@PayeeCount</div>
                    </div>
                </div>

                <div class="facility-row report-card-tap" role="button" tabindex="0" @onclick="@(() => OpenDetail("paid"))" @onkeydown="@(e => OnCardKey(e, "paid"))">
                    <div class="facility-icon">
                        <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                    </div>
                    <div class="facility-info">
                        <div class="facility-name">Paid Payors</div>
                        <div class="facility-meta"><span class="facility-count">Fully settled for this period</span></div>
                    </div>
                    <div class="facility-amount-col">
                        <div class="facility-amount">@PaidPayorCount</div>
                    </div>
                </div>

                <div class="facility-row report-card-tap" role="button" tabindex="0" @onclick="@(() => OpenDetail("partial"))" @onkeydown="@(e => OnCardKey(e, "partial"))">
                    <div class="facility-icon">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                    </div>
                    <div class="facility-info">
                        <div class="facility-name">Partial Payors</div>
                        <div class="facility-meta"><span class="facility-count">Payors with remaining balance</span></div>
                    </div>
                    <div class="facility-amount-col">
                        <div class="facility-amount">@PartialCount</div>
                    </div>
                </div>

                <div class="facility-row report-card-tap" role="button" tabindex="0" @onclick="@(() => OpenDetail("unpaid"))" @onkeydown="@(e => OnCardKey(e, "unpaid"))">
                    <div class="facility-icon">
                        <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                    </div>
                    <div class="facility-info">
                        <div class="facility-name">Unpaid Payors</div>
                        <div class="facility-meta"><span class="facility-count">Current valid payors not yet collected</span></div>
                    </div>
                    <div class="facility-amount-col">
                        <div class="facility-amount">@UnpaidPayorCount</div>
                    </div>
                </div>

                <div class="facility-row report-card-tap" role="button" tabindex="0" @onclick="@(() => OpenDetail("absent-excused"))" @onkeydown="@(e => OnCardKey(e, "absent-excused"))">
                    <div class="facility-icon">
                        <svg viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" /><circle cx="9" cy="7" r="4" /><line x1="23" y1="11" x2="17" y2="11" /></svg>
                    </div>
                    <div class="facility-info">
                        <div class="facility-name">Absent / Excused</div>
                        <div class="facility-meta"><span class="facility-count">Excused records — not counted as unpaid</span></div>
                    </div>
                    <div class="facility-amount-col">
                        <div class="facility-amount">@AbsentExcusedCount</div>
                    </div>
                </div>

                @if (Utility is not null)
                {
                    <div class="facility-row report-card-tap" role="button" tabindex="0" @onclick="@(() => OpenDetail("misc"))" @onkeydown="@(e => OnCardKey(e, "misc"))">
                        <div class="facility-icon">
                            <svg viewBox="0 0 24 24"><polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" /></svg>
                        </div>
                        <div class="facility-info">
                            <div class="facility-name">Miscellaneous</div>
                            <div class="facility-meta"><span class="facility-count">Electricity &amp; water · @PeriodTitle</span></div>
                            <div class="facility-substats">
                                <span class="substat paid">@Utility.PaidCount paid</span>
                                <span class="substat partial">@Utility.PartialCount partial</span>
                                <span class="substat unpaid">@Utility.UnpaidCount unpaid</span>
                            </div>
                        </div>
                        <div class="facility-amount-col">
                            <div class="facility-amount">&#8369;@Utility.TotalCollected.ToString("N0")</div>
                            @if (Utility.TotalOutstanding > 0)
                            {
                                <div class="facility-count" style="text-align:right;">&#8369;@Utility.TotalOutstanding.ToString("N0") due</div>
                            }
                        </div>
                    </div>
                }

                <div class="group-spacer"></div>
                <div class="section-label">Assigned Scope</div>

                @foreach (var f in ReportFacilities)
                {
                    <div class="facility-row">
                        <div class="facility-icon">
                            @((MarkupString)GetFacilityIcon(f.FacilityCode))
                        </div>
                        <div class="facility-info">
                            <div class="facility-name">@f.FacilityName</div>
                            <div class="facility-meta">
                                <span class="facility-code">@f.FacilityCode</span>
                                <span class="facility-count">@f.TransactionCount txns · @f.PayeeCount payees</span>
                            </div>
                            <div class="facility-substats">
                                <span class="substat paid">@f.PaidCount paid</span>
                                <span class="substat partial">@f.PartialCount partial</span>
                                <span class="substat unpaid">@f.UnpaidCount unpaid</span>
                                @if (f.AbsentExcusedCount > 0)
                                {
                                    <span class="substat excused">@f.AbsentExcusedCount excused</span>
                                }
                            </div>
                        </div>
                        <div class="facility-amount-col">
                            <div class="facility-amount">&#8369;@f.CollectedAmount.ToString("N0")</div>
                            <div class="facility-progress">
                                <div class="facility-progress-fill" style="width:@GetProgressPercent(f.CollectedAmount)%"></div>
                            </div>
                        </div>
                    </div>
                }
            }
        }

    </div>

    @if (SelectedDetailCard is not null && ReportData is not null)
    {
        <div class="detail-sheet-backdrop" @onclick="CloseDetail"></div>
        <div class="detail-sheet">
            <div class="detail-sheet-head">
                <div>
                    <div class="detail-sheet-title">@DetailTitle</div>
                    <div class="detail-sheet-sub">@ScopeLabel · @PeriodTitle</div>
                </div>
                <button class="detail-sheet-close" @onclick="CloseDetail" aria-label="Close">&times;</button>
            </div>
            <div class="detail-sheet-body">
                @switch (SelectedDetailCard)
                {
                    case "collected":
                        @if (Transactions.Count == 0)
                        {
                            @DetailEmpty("No collections recorded for this period.")
                        }
                        else
                        {
                            @foreach (var t in Transactions)
                            {
                                <div class="detail-row">
                                    <div class="detail-row-main">
                                        <div class="detail-row-name">@t.PayorName</div>
                                        <div class="detail-row-sub">@FacilityStall(t.FacilityCode, t.StallNo) · @t.CollectionDate.ToString("MMM d")@(string.IsNullOrWhiteSpace(t.ORNumber) ? "" : " · OR " + t.ORNumber)</div>
                                    </div>
                                    <div class="detail-row-amt">
                                        <div class="detail-amt-val">&#8369;@t.Amount.ToString("N0")</div>
                                        @if (t.IsPartial)
                                        {
                                            <span class="detail-tag partial">Partial</span>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        break;

                    case "outstanding":
                        @if (!OutstandingPayees.Any())
                        {
                            @DetailEmpty("No outstanding balances — everything is collected.")
                        }
                        else
                        {
                            @foreach (var p in OutstandingPayees)
                            {
                                <div class="detail-row">
                                    <div class="detail-row-main">
                                        <div class="detail-row-name">@p.PayorName</div>
                                        <div class="detail-row-sub">@FacilityStall(p.FacilityCode, p.StallNo) · Paid &#8369;@p.AmountPaid.ToString("N0") of &#8369;@p.AssessedAmount.ToString("N0")</div>
                                    </div>
                                    <div class="detail-row-amt">
                                        <div class="detail-amt-val due">&#8369;@p.Balance.ToString("N0")</div>
                                        <span class="detail-tag @GetPayeeStatusClass(p)">@p.Status</span>
                                    </div>
                                </div>
                            }
                        }
                        break;

                    case "paid":
                        @if (!PaidPayees.Any())
                        {
                            @DetailEmpty("No fully-paid payors for this period.")
                        }
                        else
                        {
                            @foreach (var p in PaidPayees)
                            {
                                <div class="detail-row">
                                    <div class="detail-row-main">
                                        <div class="detail-row-name">@p.PayorName</div>
                                        <div class="detail-row-sub">@FacilityStall(p.FacilityCode, p.StallNo)@(string.IsNullOrWhiteSpace(p.ORNumber) ? "" : " · OR " + p.ORNumber)@(p.LastCollectedAt.HasValue ? " · " + p.LastCollectedAt.Value.ToString("MMM d") : "")</div>
                                    </div>
                                    <div class="detail-row-amt">
                                        <div class="detail-amt-val paid">&#8369;@p.AmountPaid.ToString("N0")</div>
                                    </div>
                                </div>
                            }
                        }
                        break;

                    case "partial":
                        @if (!PartialPayees.Any())
                        {
                            @DetailEmpty("No partial payors for this period.")
                        }
                        else
                        {
                            @foreach (var p in PartialPayees)
                            {
                                <div class="detail-row">
                                    <div class="detail-row-main">
                                        <div class="detail-row-name">@p.PayorName</div>
                                        <div class="detail-row-sub">@FacilityStall(p.FacilityCode, p.StallNo)@(string.IsNullOrWhiteSpace(p.ORNumber) ? "" : " · OR " + p.ORNumber)@(p.LastCollectedAt.HasValue ? " · " + p.LastCollectedAt.Value.ToString("MMM d") : "")</div>
                                    </div>
                                    <div class="detail-row-amt">
                                        <div class="detail-amt-val">&#8369;@p.AmountPaid.ToString("N0")</div>
                                        <div class="detail-amt-bal">Balance &#8369;@p.Balance.ToString("N0")</div>
                                    </div>
                                </div>
                            }
                        }
                        break;

                    case "unpaid":
                        @if (!UnpaidPayees.Any())
                        {
                            @DetailEmpty("No unpaid current payors for this period.")
                        }
                        else
                        {
                            @foreach (var p in UnpaidPayees)
                            {
                                <div class="detail-row">
                                    <div class="detail-row-main">
                                        <div class="detail-row-name">@p.PayorName</div>
                                        <div class="detail-row-sub">@FacilityStall(p.FacilityCode, p.StallNo)</div>
                                    </div>
                                    <div class="detail-row-amt">
                                        <div class="detail-amt-val due">&#8369;@p.Balance.ToString("N0")</div>
                                        <div class="detail-amt-bal">amount due</div>
                                    </div>
                                </div>
                            }
                        }
                        break;

                    case "misc":
                        @if (Utility is null || Utility.Payees.Count == 0)
                        {
                            @DetailEmpty("No electricity or water bills for this period.")
                        }
                        else
                        {
                            @foreach (var u in Utility.Payees)
                            {
                                <div class="detail-row">
                                    <div class="detail-row-main">
                                        <div class="detail-row-name">@u.PayorName</div>
                                        <div class="detail-row-sub">@(string.IsNullOrWhiteSpace(u.StallNo) ? "NPM" : "Stall " + u.StallNo) · E · @u.ElecStatus · W · @u.WaterStatus</div>
                                    </div>
                                    <div class="detail-row-amt">
                                        <div class="detail-amt-val @(u.Balance > 0 ? "" : "paid")">&#8369;@u.AmountPaid.ToString("N0")</div>
                                        @if (u.Balance > 0)
                                        {
                                            <div class="detail-amt-bal">Balance &#8369;@u.Balance.ToString("N0")</div>
                                        }
                                        else
                                        {
                                            <span class="detail-tag">@u.OverallStatus</span>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        break;

                    case "absent-excused":
                        @if (AbsentExcusedRows.Count == 0)
                        {
                            @DetailEmpty("No absent or excused records for this period.")
                        }
                        else
                        {
                            @foreach (var a in AbsentExcusedRows)
                            {
                                <div class="detail-row">
                                    <div class="detail-row-main">
                                        <div class="detail-row-name">@a.PayorName</div>
                                        <div class="detail-row-sub">@FacilityStall(a.FacilityCode, a.StallNo) · @a.Date.ToString("MMM d, yyyy")@(string.IsNullOrWhiteSpace(a.Reason) ? "" : " · " + a.Reason)</div>
                                    </div>
                                    <div class="detail-row-amt">
                                        <span class="detail-tag excused">@a.Source</span>
                                    </div>
                                </div>
                            }
                        }
                        break;
                }
            </div>
        </div>
    }

    <BottomNav ActiveTab="reports" />

</div>

@code {
    static readonly HashSet<FacilityCode> DailyFacilities = new()
    {
        FacilityCode.NPM, FacilityCode.SLH, FacilityCode.TRM, FacilityCode.TPM
    };

    bool IsLoading = true;
    string ErrorMessage = string.Empty;
    string ActiveReportType = string.Empty;
    string PayeeSearch = string.Empty;
    int PeriodOffset = 0;
    MobileCollectorReportDto? ReportData;

    IReadOnlyList<MobileFacilityMenuItemDto> AssignedFacilityItems =>
        Session.Menu?.Facilities.Where(f => f.IsAssigned).OrderBy(f => f.Code).ToList()
        ?? new List<MobileFacilityMenuItemDto>();

    IReadOnlyList<FacilityCode> AssignedFacilities => AssignedFacilityItems.Select(f => f.Code).ToList();

    bool DailyReportMode =>
        ReportData?.DailyReportMode
        ?? (AssignedFacilities.Count > 0 && AssignedFacilities.All(code => DailyFacilities.Contains(code)));

    string PrimaryReportTab => WeeklyReportMode ? "By Market Day" : DailyReportMode ? "By Day" : "By Month";

    // Tabo-an (TPM) trades only on Fridays — its breakdown reads as market days, not generic days.
    bool WeeklyReportMode =>
        AssignedFacilities.Count > 0 && AssignedFacilities.All(code => code == FacilityCode.TPM);

    IReadOnlyList<string> ReportTypes => new[] { PrimaryReportTab, "Per Payee", "Summary" };

    DateTime PeriodDate => DateTime.Now.AddMonths(PeriodOffset);
    bool CanGoNext => PeriodOffset < 0;

    string PeriodTitle => PeriodOffset == 0
        ? "This Month"
        : PeriodDate.ToString("MMMM yyyy");

    string PeriodSubtitle =>
        $"{new DateTime(PeriodDate.Year, PeriodDate.Month, 1):MMM d} - " +
        $"{new DateTime(PeriodDate.Year, PeriodDate.Month, DateTime.DaysInMonth(PeriodDate.Year, PeriodDate.Month)):MMM d, yyyy}";

    string ScopeLabel => AssignedFacilityItems.Count switch
    {
        0 => "No assigned facility",
        1 => AssignedFacilityItems[0].Name,
        _ => $"{AssignedFacilityItems.Count} assigned facilities"
    };

    FacilityCode? RequestFacility =>
        AssignedFacilities.Count == 1 ? AssignedFacilities[0] : null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
            if (Session.Menu is null)
            {
                Navigation.NavigateTo("/login", forceLoad: false);
                return;
            }

            ActiveReportType = PrimaryReportTab;
            await LoadReportAsync();
        }
        catch (HttpRequestException)
        {
            ErrorMessage = "Unable to connect to the EEMO server. Please check the connection and try again.";
            IsLoading = false;
        }
    }

    async Task LoadReportAsync()
    {
        IsLoading = true;
        ErrorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var result = await Api.GetReportAsync(RequestFacility, PeriodDate.Year, PeriodDate.Month);

            if (result.IsSuccess && result.Value is not null)
                ReportData = result.Value;
            else
                ErrorMessage = result.Error ?? "Unable to load your report.";

            if (!ReportTypes.Contains(ActiveReportType))
                ActiveReportType = PrimaryReportTab;
        }
        catch
        {
            // The HTTP layer throws on a connection failure/timeout; keep period nav + retry safe and unstuck.
            ErrorMessage = "Unable to connect to the EEMO server. Please check the connection and try again.";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    async Task PrevPeriod()
    {
        PeriodOffset--;
        await LoadReportAsync();
    }

    async Task NextPeriod()
    {
        if (!CanGoNext) return;
        PeriodOffset++;
        await LoadReportAsync();
    }

    void SetReportType(string tab)
    {
        ActiveReportType = tab;
        PayeeSearch = string.Empty;
    }

    IEnumerable<MobileReportPeriodSummaryDto> DailySummaries =>
        ReportData?.Periods.OrderByDescending(x => x.PeriodDate)
        ?? Enumerable.Empty<MobileReportPeriodSummaryDto>();

    IEnumerable<MobileReportPeriodSummaryDto> MonthlySummaries =>
        ReportData?.Periods.OrderByDescending(x => x.PeriodDate)
        ?? Enumerable.Empty<MobileReportPeriodSummaryDto>();

    IEnumerable<MobileReportPayeeSummaryDto> PayeeSummaries =>
        ReportData?.Payees
            .OrderByDescending(p => p.Balance)
            .ThenByDescending(p => p.AmountPaid)
            .ThenBy(p => p.PayorName)
        ?? Enumerable.Empty<MobileReportPayeeSummaryDto>();

    IEnumerable<MobileReportPayeeSummaryDto> FilteredPayees => PayeeSummaries.Where(p =>
        string.IsNullOrWhiteSpace(PayeeSearch)
        || p.PayorName.Contains(PayeeSearch, StringComparison.OrdinalIgnoreCase)
        || (p.StallNo ?? "").Contains(PayeeSearch, StringComparison.OrdinalIgnoreCase)
        || p.FacilityCode.ToString().Contains(PayeeSearch, StringComparison.OrdinalIgnoreCase));

    IReadOnlyList<MobileReportFacilitySummaryDto> ReportFacilities =>
        ReportData?.Facilities ?? Array.Empty<MobileReportFacilitySummaryDto>();

    // ── Clickable summary-card detail sheets ──
    string? SelectedDetailCard;
    void OpenDetail(string card) => SelectedDetailCard = card;
    void CloseDetail() => SelectedDetailCard = null;

    // Honour the cards' role="button" / tabindex="0": activate on Enter or Space.
    void OnCardKey(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e, string card)
    {
        if (e.Key is "Enter" or " " or "Spacebar")
            OpenDetail(card);
    }

    string DetailTitle => SelectedDetailCard switch
    {
        "collected" => "Total Collected",
        "outstanding" => "Outstanding Balance",
        "paid" => "Paid Payors",
        "partial" => "Partial Payors",
        "unpaid" => "Unpaid Payors",
        "absent-excused" => "Absent / Excused",
        "misc" => "Miscellaneous · Electricity & Water",
        _ => "Details"
    };

    IReadOnlyList<MobileReportTransactionDto> Transactions =>
        ReportData?.Transactions ?? Array.Empty<MobileReportTransactionDto>();
    IReadOnlyList<MobileReportAbsentExcusedDto> AbsentExcusedRows =>
        ReportData?.AbsentExcused ?? Array.Empty<MobileReportAbsentExcusedDto>();
    MobileReportUtilitySummaryDto? Utility => ReportData?.Utility;
    IEnumerable<MobileReportPayeeSummaryDto> OutstandingPayees => PayeeSummaries.Where(p => p.Balance > 0m);
    IEnumerable<MobileReportPayeeSummaryDto> PaidPayees => PayeeSummaries.Where(p => p.Status == PaymentStatus.Paid);
    IEnumerable<MobileReportPayeeSummaryDto> PartialPayees => PayeeSummaries.Where(p => p.Status == PaymentStatus.Partial);
    IEnumerable<MobileReportPayeeSummaryDto> UnpaidPayees => PayeeSummaries.Where(p => p.Status == PaymentStatus.Unpaid);

    static string FacilityStall(FacilityCode code, string? stallNo) =>
        string.IsNullOrWhiteSpace(stallNo) ? code.ToString() : $"{code} · Stall {stallNo}";

    RenderFragment DetailEmpty(string message) =>@<div class="detail-empty">@message</div>;

    decimal GrandTotal => ReportData?.Totals.CollectedAmount ?? 0m;
    int TotalTransactions => ReportData?.Totals.TransactionCount ?? 0;
    int PayeeCount => ReportData?.Totals.PayeeCount ?? 0;
    int PartialCount => ReportData?.Totals.PartialCount ?? 0;
    decimal Outstanding => ReportData?.Totals.OutstandingAmount ?? 0m;
    int PaidPayorCount => ReportData?.Totals.PaidCount ?? 0;
    int UnpaidPayorCount => ReportData?.Totals.UnpaidCount ?? 0;
    int AbsentExcusedCount => ReportData?.Totals.AbsentExcusedCount ?? 0;

    int GetProgressPercent(decimal amount)
    {
        var max = ReportFacilities.Select(f => f.CollectedAmount).DefaultIfEmpty(0m).Max();
        return max <= 0m ? 0 : Math.Max(6, (int)Math.Round(amount / max * 100m));
    }

    static string GetDayLabel(DateOnly date)
    {
        var today = DateOnly.FromDateTime(DateTime.Today);
        if (date == today) return "Today";
        if (date == today.AddDays(-1)) return "Yesterday";
        return date.ToDateTime(TimeOnly.MinValue).ToString("dddd");
    }

    static string GetPeriodStatusText(MobileReportPeriodSummaryDto period)
    {
        if (period.OpenItemCount > 0)
            return $"{period.OpenItemCount} unpaid";

        if (period.PartialCount > 0)
            return $"{period.PartialCount} partial";

        return "complete";
    }

    static string GetPayeeStatusClass(MobileReportPayeeSummaryDto payee) => payee.Status switch
    {
        PaymentStatus.Unpaid => "status-delinquent",
        PaymentStatus.Partial => "status-partial",
        _ => "status-consistent"
    };

    static string GetFacilityIcon(FacilityCode code) => code switch
    {
        FacilityCode.NPM => """<svg viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>""",
        FacilityCode.TCC or FacilityCode.BBQ or FacilityCode.ICE => """<svg viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>""",
        FacilityCode.NCC => """<svg viewBox="0 0 24 24"><path d="M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18"/></svg>""",
        FacilityCode.TRM => """<svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>""",
        FacilityCode.SLH => """<svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>""",
        FacilityCode.TPM => """<svg viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>""",
        _ => """<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>"""
    };

    RenderFragment EmptyState(string message) => @<div class="empty-state">
        <div class="empty-icon">
            <svg viewBox="0 0 24 24"><line x1="18" y1="20" x2="18" y2="10" /><line x1="12" y1="20" x2="12" y2="4" /><line x1="6" y1="20" x2="6" y2="14" /></svg>
        </div>
        <div class="empty-title">No Data</div>
        <div class="empty-sub">@message</div>
    </div>;

}
