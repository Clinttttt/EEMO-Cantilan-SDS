@page "/profile"
@using EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Application.Dtos.Mobile
@using EEMOCantilanSDS.Application.Requests.Mobile
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject EEMOCantilanSDS.Application.Common.Interface.ApiClients.IMobileApiClient Api

<!-- ░░ PAGE SHELL ░░ -->
<div class="page-shell">

    <!-- Header — home variant (no back button, main tab) -->
    <AppHeader CollectorName="@CollectorName" />

    <!-- Scrollable Content -->
    <div class="content">

        @if (IsLoading)
        {
            <LoadingState Text="Loading your profile…" />
        }
        else
        {

        <!-- Profile Card -->
        <div class="profile-card">
            <div class="profile-avatar" @onclick="OpenEdit">
                @if (!string.IsNullOrEmpty(AvatarSrc))
                {
                    <img class="profile-avatar-img" src="@AvatarSrc" alt="@CollectorName" />
                }
                else
                {
                    <span class="profile-avatar-initials">@Initials</span>
                }
                <!-- camera overlay hint -->
                <div class="profile-avatar-overlay">
                    <svg viewBox="0 0 24 24"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
                </div>
            </div>
            <div class="profile-info">
                <div class="profile-name">@CollectorName</div>
                <div class="profile-role">Revenue Collector</div>
                <div class="profile-org">EEMO · Cantilan, Surigao del Sur</div>
            </div>
            <div class="profile-edit-btn" @onclick="OpenEdit">
                <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            </div>
        </div>

        <!-- Stats Strip -->
        <div class="summary-strip">
            <div class="summary-item">
                <div class="summary-value">@TotalCollected</div>
                <div class="summary-key">Collected</div>
            </div>
            <div class="summary-item">
                <div class="summary-value">@TotalDays</div>
                <div class="summary-key">Days Active</div>
            </div>
            <div class="summary-item">
                <div class="summary-value">@FacilityList.Count</div>
                <div class="summary-key">Facilities</div>
            </div>
        </div>

        <!-- Account Info -->
        <div class="section-label">Account Information</div>

        <div class="profile-group">
            <div class="profile-row">
                <div class="profile-row-icon">
                    <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                </div>
                <div class="profile-row-info">
                    <div class="profile-row-label">Full Name</div>
                    <div class="profile-row-val">@CollectorName</div>
                </div>
            </div>

            <div class="profile-row">
                <div class="profile-row-icon">
                    <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
                </div>
                <div class="profile-row-info">
                    <div class="profile-row-label">Employee ID</div>
                    <div class="profile-row-val">@EmployeeId</div>
                </div>
            </div>

            <div class="profile-row">
                <div class="profile-row-icon">
                    <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 14.92v2z"/></svg>
                </div>
                <div class="profile-row-info">
                    <div class="profile-row-label">Contact</div>
                    <div class="profile-row-val">@ContactNumber</div>
                </div>
            </div>

            <div class="profile-row" style="border-bottom:none;">
                <div class="profile-row-icon">
                    <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                </div>
                <div class="profile-row-info">
                    <div class="profile-row-label">Email</div>
                    <div class="profile-row-val">@Email</div>
                </div>
            </div>
        </div>

        <!-- Assigned Facilities -->
        <div class="group-spacer"></div>
        <div class="section-label">
            Assigned Facilities
            <span class="section-count">@FacilityList.Count facilities</span>
        </div>

        <div class="profile-group">
            @foreach (var (fac, index) in FacilityList.Select((f, i) => (f, i)))
            {
                <div class="profile-row @(index == FacilityList.Count - 1 ? "no-border" : "")">
                    <div class="profile-row-icon">
                        @((MarkupString)fac.IconSvg)
                    </div>
                    <div class="profile-row-info">
                        <div class="profile-row-label">@fac.Code</div>
                        <div class="profile-row-val">@fac.Name</div>
                    </div>
                    <div class="facility-active-dot"></div>
                </div>
            }
        </div>

        <!-- App Settings -->
        <div class="group-spacer"></div>
        <div class="section-label">App Settings</div>

        <div class="profile-group">
            <div class="profile-row" @onclick="ToggleNotifications">
                <div class="profile-row-icon">
                    <svg viewBox="0 0 24 24"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 01-3.46 0"/></svg>
                </div>
                <div class="profile-row-info">
                    <div class="profile-row-label">Notifications</div>
                    <div class="profile-row-val">@(NotificationsEnabled ? "Enabled" : "Disabled")</div>
                </div>
                <div class="toggle-switch @(NotificationsEnabled ? "on" : "")">
                    <div class="toggle-thumb"></div>
                </div>
            </div>

            <div class="profile-row" style="border-bottom:none;">
                <div class="profile-row-icon">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93l-1.41 1.41M19.07 19.07l-1.41-1.41M4.93 19.07l1.41-1.41M4.93 4.93l1.41 1.41M21 12h-2M5 12H3M12 21v-2M12 5V3"/></svg>
                </div>
                <div class="profile-row-info">
                    <div class="profile-row-label">App Version</div>
                    <div class="profile-row-val">EEMO Collectors v1.0</div>
                </div>
            </div>
        </div>

        <!-- Sign Out -->
        <div class="group-spacer"></div>

        <div class="signout-wrap">
            <div class="signout-btn" @onclick="SignOut">
                <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Sign Out
            </div>
        </div>

        <div class="profile-footer">
            Republic of the Philippines · @Session.BrandingMunicipalityLine<br />
            @Session.BrandingOffice
        </div>

        }
    </div>
    <!-- end .content -->

    <BottomNav ActiveTab="profile" />

</div>
<!-- end .page-shell -->


<!-- ════════════════════════════════════════════
     EDIT PROFILE BOTTOM SHEET
════════════════════════════════════════════ -->
@if (ShowEditSheet)
{
    <div class="sheet-overlay" @onclick="CloseEdit">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Edit Profile</div>
            <div class="sheet-sub">Update your account information.</div>

            <!-- Avatar Picker -->
            <div class="edit-avatar-wrap">
                <div class="edit-avatar">
                    @if (!string.IsNullOrEmpty(EditAvatarSrc))
                    {
                        <img class="profile-avatar-img" src="@EditAvatarSrc" alt="Preview" />
                    }
                    else
                    {
                        <span class="profile-avatar-initials" style="font-size:18px;">@Initials</span>
                    }
                </div>
                <div class="edit-avatar-actions">
                    <div class="edit-avatar-label">Profile Photo</div>
                    <div class="edit-avatar-btns">
                        <!-- hidden real file input -->
                        <InputFile id="avatarInput"
                                   OnChange="OnAvatarSelected"
                                   accept="image/*"
                                   style="display:none;" />
                        <label for="avatarInput" class="edit-avatar-choose">
                            <svg viewBox="0 0 24 24"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
                            Choose Photo
                        </label>
                        @if (!string.IsNullOrEmpty(EditAvatarSrc))
                        {
                            <div class="edit-avatar-remove" @onclick="RemoveAvatar">Remove</div>
                        }
                    </div>
                    <div class="edit-avatar-hint">JPG, PNG · Max 5MB</div>
                </div>
            </div>

            <div class="form-field">
                <div class="form-label">Full Name</div>
                <input class="form-input" type="text"
                       placeholder="e.g. Juan dela Cruz"
                       @bind="EditName" @bind:event="oninput" />
            </div>

            <div class="form-field">
                <div class="form-label">Employee ID</div>
                <input class="form-input" type="text" value="@EmployeeId" readonly disabled />
            </div>

            <div class="form-row">
                <div class="form-field">
                    <div class="form-label">Contact No.</div>
                    <input class="form-input" type="tel"
                           placeholder="+63 9xx xxx xxxx"
                           @bind="EditContact" @bind:event="oninput" />
                </div>
                <div class="form-field">
                    <div class="form-label">Email</div>
                    <input class="form-input" type="email"
                           placeholder="email@example.com"
                           @bind="EditEmail" @bind:event="oninput" />
                </div>
            </div>

            @if (!string.IsNullOrEmpty(EditError))
            {
                <div class="form-error">@EditError</div>
            }

            <div class="sheet-btn-row">
                <div class="btn-cancel" @onclick="CloseEdit">Cancel</div>
                <div class="btn-confirm" @onclick="SaveEdit">@(IsSavingEdit ? "Saving..." : "Save Changes")</div>
            </div>
        </div>
    </div>
}


@code {

    // ── Navigation ────────────────────────────────────────────────────────────
    void GoTo(string path) => Navigation.NavigateTo(path, forceLoad: false);

    // ── Collector Info (loaded from session menu + profile API) ──
    string CollectorName  = "Collector";
    string EmployeeId     = string.Empty;
    string ContactNumber  = string.Empty;
    string Email          = string.Empty;
    string AvatarSrc      = string.Empty;   // initials unless a (local) photo is chosen

    // Derived initials for avatar
    string Initials => string.Concat(
        (string.IsNullOrWhiteSpace(CollectorName) ? "C" : CollectorName)
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(w => w[0].ToString().ToUpper()));

    // ── Stats (loaded) ──
    decimal TotalCollectedAmount;
    string  TotalCollected => $"₱{TotalCollectedAmount:N0}";
    int     TotalDays;

    // ── Settings (persisted locally per collector, offline-safe) ──
    bool NotificationsEnabled = true;
    async Task ToggleNotifications()
    {
        NotificationsEnabled = !NotificationsEnabled;
        await Session.SetNotificationsEnabledAsync(NotificationsEnabled);
    }

    // Gate the page on the initial profile load so it shows a spinner instead of half-empty fields.
    bool IsLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
            if (Session.Menu is null)
            {
                Navigation.NavigateTo("/login", forceLoad: false);
                return;
            }

            // Name, Employee ID and assigned facilities come straight from the session menu.
            CollectorName = Session.Menu.CollectorName;
            EmployeeId    = Session.Menu.EmployeeId;
            BuildFacilityList();

            // Device-local + offline-safe: restore the saved photo and notifications preference before the
            // (network) profile load, so they show instantly and survive re-render / navigation / offline.
            NotificationsEnabled = Session.GetNotificationsEnabled();
            AvatarSrc            = await Session.GetProfilePhotoAsync() ?? string.Empty;

            await LoadProfileAsync();
        }
        catch (HttpRequestException)
        {
            // Offline — keep whatever the session already provided; still show the page.
            IsLoading = false;
        }
    }

    async Task LoadProfileAsync()
    {
        try
        {
            var result = await Api.GetProfileAsync();
            if (result.IsSuccess && result.Value is { } p)
            {
                if (!string.IsNullOrWhiteSpace(p.FullName)) CollectorName = p.FullName;
                if (!string.IsNullOrWhiteSpace(p.EmployeeId)) EmployeeId = p.EmployeeId;
                ContactNumber        = p.ContactNumber;
                Email                = p.Email;
                TotalCollectedAmount = p.TotalCollected;
                TotalDays            = p.DaysActive;
            }
        }
        catch
        {
            // Offline/failed — keep the session-provided info; the page stays usable.
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    void BuildFacilityList()
    {
        FacilityList = (Session.Menu?.Facilities ?? new List<MobileFacilityMenuItemDto>())
            .Where(f => f.IsAssigned)
            .OrderBy(f => f.Code)
            .Select(f => new FacilityItem
            {
                Code = f.Code.ToString(),
                Name = f.Name,
                IconSvg = GetFacilityIcon(f.Code)
            })
            .ToList();
    }

    static string GetFacilityIcon(FacilityCode code) => code switch
    {
        FacilityCode.NPM => """<svg viewBox="0 0 24 24" class="profile-svg"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>""",
        FacilityCode.TCC or FacilityCode.BBQ or FacilityCode.ICE => """<svg viewBox="0 0 24 24" class="profile-svg"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>""",
        FacilityCode.NCC => """<svg viewBox="0 0 24 24" class="profile-svg"><path d="M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18"/></svg>""",
        FacilityCode.TRM => """<svg viewBox="0 0 24 24" class="profile-svg"><rect x="1" y="3" width="15" height="13" rx="1"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>""",
        FacilityCode.SLH => """<svg viewBox="0 0 24 24" class="profile-svg"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>""",
        FacilityCode.TPM => """<svg viewBox="0 0 24 24" class="profile-svg"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5M2 12l10 5 10-5"/></svg>""",
        _ => """<svg viewBox="0 0 24 24" class="profile-svg"><circle cx="12" cy="12" r="10"/></svg>"""
    };

    // ── Assigned Facilities Model ─────────────────────────────────────────────
    class FacilityItem
    {
        public string Code    { get; set; } = string.Empty;
        public string Name    { get; set; } = string.Empty;
        public string IconSvg { get; set; } = string.Empty;
    }

    List<FacilityItem> FacilityList = new();

    // ── Sign Out ──────────────────────────────────────────────────────────────
    async Task SignOut()
    {
        // Revoke the refresh token server-side and clear the local session/tokens
        // so the next collector signs in fresh.
        await Session.LogoutAsync();
        Navigation.NavigateTo("/login", forceLoad: true);
    }

    // ── Edit Profile Sheet ────────────────────────────────────────────────────
    bool   ShowEditSheet  = false;
    bool   IsSavingEdit   = false;
    string EditName       = string.Empty;
    string EditContact    = string.Empty;
    string EditEmail      = string.Empty;
    string EditAvatarSrc  = string.Empty;   // base64 preview or path
    string EditError      = string.Empty;

    void OpenEdit()
    {
        EditName       = CollectorName;
        EditContact    = ContactNumber;
        EditEmail      = Email;
        EditAvatarSrc  = AvatarSrc;      // carry current photo into edit
        EditError      = string.Empty;
        ShowEditSheet  = true;
    }

    async Task OnAvatarSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null) return;

        // Max 5MB guard
        if (file.Size > 5 * 1024 * 1024)
        {
            EditError = "Image must be smaller than 5MB.";
            return;
        }

        // Read file → base64 data URL for instant preview
        using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
        using var ms     = new System.IO.MemoryStream();
        await stream.CopyToAsync(ms);
        var bytes     = ms.ToArray();
        var base64    = Convert.ToBase64String(bytes);
        var mimeType  = file.ContentType;
        EditAvatarSrc = $"data:{mimeType};base64,{base64}";
        EditError     = string.Empty;
    }

    void RemoveAvatar()
    {
        EditAvatarSrc = string.Empty;
    }

    async Task SaveEdit()
    {
        if (string.IsNullOrWhiteSpace(EditName))
        {
            EditError = "Full name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(EditEmail))
        {
            EditError = "Email is required.";
            return;
        }

        IsSavingEdit = true;
        EditError = string.Empty;

        // Persist the photo locally FIRST. It's a device-only feature (no backend), so it must be saved
        // even when the profile API is unreachable, and must survive re-render, navigation and offline use.
        try
        {
            if (string.IsNullOrEmpty(EditAvatarSrc))
                await Session.RemoveProfilePhotoAsync();
            else
                await Session.SaveProfilePhotoAsync(EditAvatarSrc);

            AvatarSrc = EditAvatarSrc;   // reflect on the page immediately
        }
        catch { /* non-critical: the preview below still applies */ }

        try
        {
            var result = await Api.UpdateProfileAsync(new UpdateMobileProfileRequest(
                EditName.Trim(), EditContact.Trim(), EditEmail.Trim()));

            if (!result.IsSuccess)
            {
                // The photo is already saved locally above; only name/contact/email failed to sync.
                EditError = result.Error ?? "Unable to save changes. Please try again.";
                return;
            }

            // Apply locally so the page reflects the change immediately.
            CollectorName = EditName.Trim();
            ContactNumber = EditContact.Trim();
            Email         = EditEmail.Trim();
            CloseEdit();

            // Best-effort: refresh the session menu so the name updates across the app.
            try { await Session.LoadMenuAsync(); } catch { /* non-critical */ }
        }
        catch (Exception)
        {
            EditError = "Unable to save changes. Please check your connection and try again.";
        }
        finally
        {
            IsSavingEdit = false;
        }
    }

    void CloseEdit()
    {
        ShowEditSheet = false;
        EditError     = string.Empty;
    }
}

<style>
    /* ─────────────────────────────────────────────
       PROFILE PAGE — Profile.razor only
       All classes prefixed with profile- or unique
       so they don't clash with eemo.css globals
    ───────────────────────────────────────────── */

    /* ── Profile Card (avatar + name) ── */
    .profile-card {
        background: var(--bg-card);
        border-radius: 16px;
        border: 1px solid var(--border);
        padding: 20px 18px;
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 14px;
        position: relative;
    }

    /* circular avatar with initials */
    .profile-avatar {
        width: 58px;
        height: 58px;
        border-radius: 50%;
        background: linear-gradient(145deg, var(--navy-accent), var(--navy-primary));
        border: 2px solid var(--gold-primary);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

    /* actual photo fills the circle */
    .profile-avatar-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
    }

    /* camera icon overlay on hover/tap */
    .profile-avatar-overlay {
        position: absolute;
        inset: 0;
        border-radius: 50%;
        background: rgba(13,33,55,0.45);
        display: flex;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.18s;
    }

        .profile-avatar:active .profile-avatar-overlay { opacity: 1; }

        .profile-avatar-overlay svg {
            width: 18px; height: 18px;
            stroke: #e8cc76;
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .profile-avatar-initials {
        font-family: 'EB Garamond', serif;
        font-size: 20px;
        font-weight: 600;
        color: var(--gold-light);
        letter-spacing: 1px;
    }

    .profile-info { flex: 1; min-width: 0; }

    .profile-name {
        font-family: 'EB Garamond', serif;
        font-size: 18px;
        font-weight: 600;
        color: var(--navy-primary);
        line-height: 1.2;
    }

    .profile-role {
        font-size: 10.5px;
        color: var(--text-muted);
        margin-top: 2px;
        font-weight: 500;
    }

    .profile-org {
        font-size: 9.5px;
        color: var(--text-subtle);
        margin-top: 1px;
    }

    /* pencil edit icon top-right */
    .profile-edit-btn {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: var(--bg-icon);
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        flex-shrink: 0;
        align-self: flex-start;
    }

        .profile-edit-btn svg {
            width: 14px; height: 14px;
            stroke: var(--text-muted);
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    /* ── Info / Settings Group Card ── */
    .profile-group {
        background: var(--bg-card);
        border-radius: 12px;
        border: 1px solid var(--border);
        overflow: hidden;
        margin-bottom: 4px;
    }

    /* each row inside a group */
    .profile-row {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 13px 16px;
        border-bottom: 1px solid var(--bg-icon);
        cursor: pointer;
        transition: background 0.15s;
    }

        .profile-row:active { background: var(--bg-page); }
        .profile-row.no-border { border-bottom: none; }

    /* icon box on the left of each row */
    .profile-row-icon {
        width: 34px;
        height: 34px;
        border-radius: 9px;
        background: var(--bg-icon);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

        .profile-row-icon svg,
        .profile-row-icon .profile-svg {
            width: 16px; height: 16px;
            stroke: var(--navy-primary);
            fill: none;
            stroke-width: 1.7;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    .profile-row-info { flex: 1; min-width: 0; }

    .profile-row-label {
        font-size: 9px;
        font-weight: 600;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: var(--text-muted);
        margin-bottom: 2px;
