@page "/terminal"
@using System.Globalization
@using global::EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Application.Dtos.TransportTerminal
@using global::EEMOCantilanSDS.Application.Requests.Mobile
@using global::EEMOCantilanSDS.Domain.Enums
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject IMobileApiClient MobileApi

<div class="page-shell">
    <div class="header">
        <div class="header-eyebrow">Transport Terminal</div>
        <div class="header-row">
            <button class="back-btn" type="button" @onclick="GoBack" aria-label="Back to menu">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
            </button>
            <div class="header-title-block">
                <div class="header-title">Transport Terminal</div>
                <div class="header-sub">TRM - ₱30 per Trip</div>
            </div>
        </div>
    </div>

    <div class="date-strip">
        <div class="date-strip-left">Collector: <span>@Session.CollectorName</span></div>
        <button class="collection-month-pill" type="button">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @DayLabel
        </button>
    </div>

    <div class="content">
        @if (IsLoading)
        {
            <div class="state-card">
                <div class="state-title">Loading terminal collections</div>
                <div class="state-text">Please wait while today's trips are loaded.</div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="state-card error">
                <div class="state-title">Unable to load collections</div>
                <div class="state-text">@ErrorMessage</div>
                <button class="primary-action" type="button" @onclick="LoadCollectionAsync">Try Again</button>
            </div>
        }
        else if (Collection is not null)
        {
            <div class="summary-strip">
                <div class="summary-item">
                    <div class="summary-value">@FormatCurrency(Collection.CollectedToday)</div>
                    <div class="summary-key">Today</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.TripsToday</div>
                    <div class="summary-key">Trips</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.TransporterCount</div>
                    <div class="summary-key">Transporters</div>
                </div>
            </div>

            <div class="search-wrap">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search transporter or plate" @bind="SearchQuery" @bind:event="oninput" />
            </div>

            <div class="section-label">Tap to record a trip</div>

            <div class="trip-choice-row">
                <button class="trip-choice-btn primary" type="button" @onclick="OpenQuickTripSheet">
                    <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13" rx="1" /><path d="M16 8h4l3 3v5h-7V8z" /><circle cx="5.5" cy="18.5" r="2.5" /><circle cx="18.5" cy="18.5" r="2.5" /></svg>
                    <span class="trip-choice-title">Record a Trip</span>
                    <span class="trip-choice-sub">Quick, no registration needed</span>
                </button>
                <button class="trip-choice-btn" type="button" @onclick="OpenNewTransporterSheet">
                    <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                    <span class="trip-choice-title">Register Transporter</span>
                    <span class="trip-choice-sub">Add to permanent roster</span>
                </button>
            </div>

            @if (!FilteredTransporters.Any())
            {
                <div class="state-card">
                    <div class="state-title">No transporters</div>
                    <div class="state-text">No registered transporters match your search.</div>
                </div>
            }
            else
            {
                @foreach (var t in FilteredTransporters)
                {
                    <button class="tx-card" type="button" @onclick="() => OpenSheet(t)">
                        <div class="tx-left-bar"></div>
                        <div class="tx-body">
                            <div class="tx-row-main">
                                <div class="tx-col-info">
                                    <span class="tx-owner">@t.Name</span>
                                    <span class="tx-sub">
                                        @if (!string.IsNullOrWhiteSpace(t.PlateNumber))
                                        {
                                            <span class="tx-tag">@t.PlateNumber</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(t.DefaultRoute))
                                        {
                                            <span class="tx-or">@t.DefaultRoute</span>
                                        }
                                    </span>
                                </div>
                                <div class="tx-col-right">
                                    @if (t.TripsToday > 0)
                                    {
                                        <span class="tx-tag trip-count">@t.TripsToday trip@(t.TripsToday == 1 ? "" : "s")</span>
                                    }
                                    <span class="tx-add-trip">+ Trip</span>
                                </div>
                            </div>
                        </div>
                    </button>
                }
            }

            <div class="section-label">Today's Trips</div>

            @if (!Collection.TodayTrips.Any())
            {
                <div class="state-card">
                    <div class="state-title">No trips yet</div>
                    <div class="state-text">Recorded trips for @DayLabel will appear here.</div>
                </div>
            }
            else
            {
                @foreach (var trip in Collection.TodayTrips)
                {
                    <div class="tx-card">
                        <div class="tx-left-bar"></div>
                        <div class="tx-body">
                            <div class="tx-row-main">
                                <div class="tx-col-info">
                                    <span class="tx-owner">#@trip.TripNumber · @trip.DriverName</span>
                                    <span class="tx-sub">
                                        @if (!string.IsNullOrWhiteSpace(trip.PlateNumber))
                                        {
                                            <span class="tx-tag">@trip.PlateNumber</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(trip.Route))
                                        {
                                            <span class="tx-or">@trip.Route</span>
                                        }
                                        @if (!string.IsNullOrWhiteSpace(trip.ORNumber))
                                        {
                                            <span class="tx-or">OR @trip.ORNumber</span>
                                        }
                                    </span>
                                </div>
                                <div class="tx-col-right">
                                    <span class="tx-trip-amount">@FormatCurrency(trip.Fee)</span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
        }
    </div>

    <BottomNav ActiveTab="menu" />
</div>

@* Suggestion lists rendered inline via custom SuggestInput — see @code *@

@if (ShowQuickTripSheet)
{
    <div class="sheet-overlay" @onclick="CloseQuickTripSheet">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Record a Trip</div>
            <div class="sheet-sub">Enter the driver details and record directly — no roster entry is created.</div>

            <div class="or-number-wrap">
                <div class="form-label">Driver name</div>
                <input class="form-input" type="text" maxlength="100" placeholder="Driver name" @bind="QuickDriverName" @bind:event="oninput" />

                <div class="form-label" style="margin-top:12px;">Organization <span>optional</span></div>
                @SuggestInput(QuickOrg, v => QuickOrg = v, KnownOrganizations, "Non-associated")

                <div class="form-label" style="margin-top:12px;">Plate number</div>
                <input class="form-input" type="text" maxlength="20" placeholder="ABC 1234" @bind="QuickPlate" @bind:event="oninput" />

                <div class="form-label" style="margin-top:12px;">Route</div>
                @SuggestInput(QuickRoute, v => QuickRoute = v, KnownRoutes, "e.g. Cantilan – Tandag")

                <div class="form-label" style="margin-top:12px;">Official receipt no.</div>
                <input class="form-input mono-input" type="text" inputmode="numeric" maxlength="50" placeholder="000001" @bind="QuickORNumber" @bind:event="oninput" />
            </div>

            <div class="fee-preview">
                <span>Trip fee</span>
                <strong>@FormatCurrency(Collection?.TripFee ?? 30m)</strong>
            </div>

            @if (!string.IsNullOrWhiteSpace(QuickTripError))
            {
                <div class="form-error">@QuickTripError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseQuickTripSheet" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmQuickTripAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Confirm Trip")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowNewTransporterSheet)
{
    <div class="sheet-overlay" @onclick="CloseNewTransporterSheet">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Register Transporter</div>
            <div class="sheet-sub">Add a new transporter to today's terminal roster.</div>

            <div class="or-number-wrap">
                <div class="form-label">Name</div>
                <input class="form-input" type="text" maxlength="100" placeholder="Driver / operator name" @bind="NewName" @bind:event="oninput" />

                <div class="form-label" style="margin-top:12px;">Organization / Cooperative <span>optional</span></div>
                @SuggestInput(NewOrg, v => NewOrg = v, KnownOrganizations, "Non-associated")

                <div class="form-label" style="margin-top:12px;">Default route</div>
                @SuggestInput(NewRoute, v => NewRoute = v, KnownRoutes, "e.g. Cantilan–Tandag")

                <div class="form-label" style="margin-top:12px;">Plate number</div>
                <input class="form-input" type="text" maxlength="20" placeholder="ABC 1234" @bind="NewPlate" @bind:event="oninput" />
            </div>

            @if (!string.IsNullOrWhiteSpace(NewTransporterError))
            {
                <div class="form-error">@NewTransporterError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseNewTransporterSheet" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmNewTransporterAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Register")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowSheet && SelectedTransporter is not null)
{
    <div class="sheet-overlay" @onclick="CloseSheet">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Record Trip</div>
            <div class="sheet-sub">@SelectedTransporter.Name@(!string.IsNullOrWhiteSpace(SelectedTransporter.Organization) ? $" · {SelectedTransporter.Organization}" : "") · ₱@Collection!.TripFee.ToString("N0") per trip</div>

            <div class="or-number-wrap">
                <div class="form-label">Driver name</div>
                <input class="form-input" type="text" maxlength="100" placeholder="Driver name" @bind="DriverName" @bind:event="oninput" />

                <div class="form-label" style="margin-top:12px;">Plate number</div>
                <input class="form-input" type="text" maxlength="20" placeholder="ABC 1234" @bind="PlateNumber" @bind:event="oninput" />

                <div class="form-label" style="margin-top:12px;">Route</div>
                @SuggestInput(Route, v => Route = v, KnownRoutes, "Route / destination")

                <div class="form-label" style="margin-top:12px;">Official receipt no.</div>
                <input class="form-input mono-input" type="text" inputmode="numeric" maxlength="50" placeholder="000001" @bind="ORNumber" @bind:event="oninput" />
            </div>

            <div class="fee-preview">
                <span>Trip fee</span>
                <strong>@FormatCurrency(Collection!.TripFee)</strong>
            </div>

            @if (!string.IsNullOrWhiteSpace(SheetError))
            {
                <div class="form-error">@SheetError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseSheet" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Confirm Trip")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private MobileTrmCollectionDto? Collection;
    private bool IsLoading = true;
    private bool IsSaving;
    private string? ErrorMessage;
    private string? SheetError;
    private string SearchQuery = string.Empty;
    private bool ShowSheet;

    private TrmTransporterListDto? SelectedTransporter;
    private string DriverName = string.Empty;
    private string PlateNumber = string.Empty;
    private string Route = string.Empty;
    private string ORNumber = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
        }
        catch (HttpRequestException)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        var hasAccess = Session.Menu?.Facilities.Any(f => f.Code == FacilityCode.TRM && f.IsAvailable) == true;
        if (!hasAccess)
        {
            Navigation.NavigateTo("/menu", forceLoad: false);
            return;
        }

        await LoadCollectionAsync();
    }

    private async Task LoadCollectionAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        var result = await MobileApi.GetTrmCollectionAsync();
        if (!result.IsSuccess || result.Value is null)
        {
            ErrorMessage = result.Error ?? "Unable to load terminal collections.";
            IsLoading = false;
            return;
        }

        Collection = result.Value;
        IsLoading = false;
    }

    private IEnumerable<TrmTransporterListDto> FilteredTransporters =>
        (Collection?.Transporters ?? Array.Empty<TrmTransporterListDto>())
        .Where(t => string.IsNullOrWhiteSpace(SearchQuery)
            || t.Name.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || t.PlateNumber.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
            || t.Organization.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

    private string DayLabel =>
        (Collection?.Date ?? DateOnly.FromDateTime(DateTime.Now)).ToString("MMM dd, yyyy", CultureInfo.InvariantCulture);

    private void GoBack() => Navigation.NavigateTo("/menu", forceLoad: false);

    private IReadOnlyList<string> KnownRoutes => Collection?.KnownRoutes ?? Array.Empty<string>();
    private IReadOnlyList<string> KnownOrganizations => Collection?.KnownOrganizations ?? Array.Empty<string>();

    // ── Searchable suggestion input ──────────────────────────────
    // Tracks which field has the picker open and its search query.
    private string? _openPickerId;
    private string _pickSearch = string.Empty;

    /// <summary>
    /// Inline searchable pick-list — renders a text input + a filtered suggestion panel.
    /// The panel appears when the input is focused and closes when a suggestion is tapped
    /// or the user continues typing a custom value.
    /// </summary>
    private RenderFragment SuggestInput(string value, Action<string> set,
        IReadOnlyList<string> options, string placeholder)
    {
        var id = $"si-{placeholder.GetHashCode():x}";
        var isOpen = _openPickerId == id;
        var search = isOpen ? _pickSearch : value;
        var filtered = options
            .Where(o => string.IsNullOrWhiteSpace(search) || o.Contains(search, StringComparison.OrdinalIgnoreCase))
            .Take(8).ToList();

        return __builder =>
        {
            __builder.OpenElement(0, "div");
            __builder.AddAttribute(1, "class", "suggest-wrap");

            __builder.OpenElement(2, "input");
            __builder.AddAttribute(3, "class", "form-input");
            __builder.AddAttribute(4, "type", "text");
            __builder.AddAttribute(5, "maxlength", "100");
            __builder.AddAttribute(6, "placeholder", placeholder);
            __builder.AddAttribute(7, "value", value);
            __builder.AddAttribute(8, "autocomplete", "off");
            __builder.AddAttribute(9, "oninput", EventCallback.Factory.Create<Microsoft.AspNetCore.Components.ChangeEventArgs>(this, e =>
            {
                var v = e.Value?.ToString() ?? string.Empty;
                set(v);
                _openPickerId = id;
                _pickSearch = v;
                StateHasChanged();
            }));
            __builder.AddAttribute(10, "onfocus", EventCallback.Factory.Create(this, () =>
            {
                _openPickerId = id;
                _pickSearch = value;
                StateHasChanged();
            }));
            __builder.CloseElement(); // input

            if (isOpen && options.Count > 0)
            {
                __builder.OpenElement(20, "div");
                __builder.AddAttribute(21, "class", "suggest-panel");

                if (filtered.Count == 0)
                {
                    __builder.OpenElement(22, "div");
                    __builder.AddAttribute(23, "class", "suggest-empty");
                    __builder.AddContent(24, "No matches");
                    __builder.CloseElement();
                }
                else
                {
                    var idx = 25;
                    foreach (var opt in filtered)
                    {
                        var captured = opt;
                        __builder.OpenElement(idx++, "button");
                        __builder.AddAttribute(idx++, "type", "button");
                        __builder.AddAttribute(idx++, "class", $"suggest-item{(opt == value ? " suggest-active" : "")}");
                        __builder.AddAttribute(idx++, "onclick", EventCallback.Factory.Create(this, () =>
                        {
                            set(captured);
                            _openPickerId = null;
                            _pickSearch = string.Empty;
                            StateHasChanged();
                        }));
                        __builder.AddContent(idx++, opt);
                        __builder.CloseElement();
                    }
                }

                __builder.CloseElement(); // suggest-panel
            }

            __builder.CloseElement(); // suggest-wrap
        };
    }

    // ── New transporter registration ──
    private bool ShowNewTransporterSheet;
    private string NewName = string.Empty;
    private string NewOrg = string.Empty;
    private string NewRoute = string.Empty;
    private string NewPlate = string.Empty;
    private string? NewTransporterError;

    // ── Quick trip (register-then-record in one action) ──
    private bool ShowQuickTripSheet;
    private string QuickDriverName = string.Empty;
    private string QuickOrg = "Non-associated";
    private string QuickPlate = string.Empty;
    private string QuickRoute = string.Empty;
    private string QuickORNumber = string.Empty;
    private string? QuickTripError;

    private void OpenQuickTripSheet()
    {
        QuickDriverName = string.Empty; QuickPlate = string.Empty;
        QuickRoute = string.Empty; QuickORNumber = string.Empty; QuickOrg = "Non-associated"; QuickTripError = null;
        ShowQuickTripSheet = true;
    }

    private void CloseQuickTripSheet()
    {
        ShowQuickTripSheet = false;
        QuickTripError = null;
    }

    private async Task ConfirmQuickTripAsync()
    {
        if (string.IsNullOrWhiteSpace(QuickDriverName)) { QuickTripError = "Driver name is required."; return; }
        if (string.IsNullOrWhiteSpace(QuickPlate)) { QuickTripError = "Plate number is required."; return; }
        if (string.IsNullOrWhiteSpace(QuickRoute)) { QuickTripError = "Route is required."; return; }
        if (string.IsNullOrWhiteSpace(QuickORNumber)) { QuickTripError = "OR number is required."; return; }

        IsSaving = true;
        QuickTripError = null;

        // Ad-hoc trip — no transporter registration (TransporterId stays null). The trip itself
        // carries the driver, plate and route, so nothing is added to the permanent roster.
        var result = await MobileApi.RecordTripAsync(new RecordMobileTripRequest(
            TransporterId: null,
            QuickDriverName.Trim(),
            QuickPlate.Trim(),
            QuickRoute.Trim(),
            QuickORNumber.Trim(),
            Organization: string.IsNullOrWhiteSpace(QuickOrg) ? "Non-associated" : QuickOrg.Trim()));

        if (!result.IsSuccess)
        {
            QuickTripError = result.Error ?? "Unable to save the trip.";
            IsSaving = false;
            return;
        }

        CloseQuickTripSheet();
        try { await LoadCollectionAsync(); }
        finally { IsSaving = false; }
    }

    private void OpenNewTransporterSheet()
    {
        NewName = string.Empty; NewOrg = "Non-associated"; NewRoute = string.Empty; NewPlate = string.Empty;
        NewTransporterError = null;
        ShowNewTransporterSheet = true;
    }

    private void CloseNewTransporterSheet()
    {
        ShowNewTransporterSheet = false;
        NewTransporterError = null;
    }

    private async Task ConfirmNewTransporterAsync()
    {
        if (string.IsNullOrWhiteSpace(NewName)) { NewTransporterError = "Name is required."; return; }
        if (string.IsNullOrWhiteSpace(NewRoute)) { NewTransporterError = "Default route is required."; return; }
        if (string.IsNullOrWhiteSpace(NewPlate)) { NewTransporterError = "Plate number is required."; return; }

        IsSaving = true;
        NewTransporterError = null;

        var result = await MobileApi.AddTransporterAsync(NewName.Trim(), NewOrg.Trim(), NewRoute.Trim(), NewPlate.Trim());
        if (!result.IsSuccess)
        {
            NewTransporterError = result.Error ?? "Unable to register the transporter.";
            IsSaving = false;
            return;
        }

        // Reload so the new transporter appears, then auto-open its trip sheet.
        CloseNewTransporterSheet();
        try
        {
            await LoadCollectionAsync();
            // Pre-select the newly-registered transporter so the collector can record immediately.
            var newT = Collection?.Transporters.FirstOrDefault(t =>
                string.Equals(t.PlateNumber, NewPlate.Trim(), StringComparison.OrdinalIgnoreCase));
            if (newT is not null) OpenSheet(newT);
        }
        finally { IsSaving = false; }
    }

    private void OpenSheet(TrmTransporterListDto transporter)
    {
        SelectedTransporter = transporter;
        DriverName = transporter.Name;
        PlateNumber = transporter.PlateNumber;
        Route = transporter.DefaultRoute;
        ORNumber = string.Empty;
        SheetError = null;
        ShowSheet = true;
    }

    private async Task ConfirmAsync()
    {
        if (SelectedTransporter is null)
            return;

        if (string.IsNullOrWhiteSpace(DriverName))
        {
            SheetError = "Driver name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(PlateNumber))
        {
            SheetError = "Plate number is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(Route))
        {
            SheetError = "Route is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(ORNumber))
        {
            SheetError = "OR number is required.";
            return;
        }

        IsSaving = true;
        SheetError = null;

        var request = new RecordMobileTripRequest(
            SelectedTransporter.Id,
            DriverName.Trim(),
            PlateNumber.Trim(),
            Route.Trim(),
            ORNumber.Trim());

        var result = await MobileApi.RecordTripAsync(request);
        if (!result.IsSuccess)
        {
            SheetError = result.Error ?? "Unable to save the trip.";
            IsSaving = false;
            return;
        }

        CloseSheet();
        try
        {
            await LoadCollectionAsync();
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void CloseSheet()
    {
        ShowSheet = false;
        SelectedTransporter = null;
        SheetError = null;
    }

    private static string FormatCurrency(decimal value) => $"₱{value:N0}";
}
