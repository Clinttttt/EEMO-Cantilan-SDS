@page "/records"
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Mobile.Models
@using EEMOCantilanSDS.Mobile.Services
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject EEMOCantilanSDS.Application.Common.Interface.ApiClients.IMobileApiClient Api
@inject EEMOCantilanSDS.Mobile.Services.MobileSyncService Sync
@implements IDisposable

<!-- ░░ PAGE SHELL ░░ -->
<div class="page-shell">

    <AppHeader CollectorName="@Session.CollectorName" />

    <!-- Scrollable Content -->
    <div class="content">

        <!-- Summary Strip -->
        <div class="summary-strip">
            <div class="summary-item">
                <div class="summary-value">₱@TotalCollected.ToString("N0")</div>
                <div class="summary-key">Collected</div>
            </div>
            <div class="summary-item">
                <div class="summary-value">@PaidCount</div>
                <div class="summary-key">Paid</div>
            </div>
            <div class="summary-item">
                <div class="summary-value">@PartialCount</div>
                <div class="summary-key">Partial</div>
            </div>
            @if (ExcusedCount > 0)
            {
                <div class="summary-item">
                    <div class="summary-value">@ExcusedCount</div>
                    <div class="summary-key">Excused</div>
                </div>
            }
        </div>

        <!-- Search + Pending -->
        <div class="search-row">
            <div class="search-wrap">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text"
                       placeholder="Search name, OR no., stall…"
                       @bind="SearchQuery"
                       @bind:event="oninput" />
            </div>
            <button class="pending-btn @(Sync.PendingCount > 0 ? "has-pending" : "")"
                    type="button"
                    @onclick="OpenPendingSheetAsync"
                    aria-label="Pending offline collections">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="9" /><polyline points="12 7 12 12 15.5 14" /></svg>
                @if (Sync.PendingCount > 0)
                {
                    <span class="pending-badge">@Sync.PendingCount</span>
                }
            </button>
        </div>

        <!-- Combined period + facility chips in one scrollable row -->
        <div class="filter-tabs">
            @foreach (var p in PeriodChips)
            {
                <div class="filter-tab @(ActivePeriodKey == p.Key ? "active" : "")"
                     @onclick="() => SetPeriodAsync(p.Key)">@p.Label</div>
            }
            @if (AssignedFacilities.Count > 1)
            {
                <div class="filter-tab-sep"></div>
                <div class="filter-tab @(ActiveFacility is null ? "active" : "")"
                     @onclick="() => SetFacilityAsync(null)">All</div>
                @foreach (var fcode in AssignedFacilities)
                {
                    <div class="filter-tab @(ActiveFacility == fcode ? "active" : "")"
                         @onclick="() => SetFacilityAsync(fcode)">@(fcode)</div>
                }
            }
        </div>

        @if (IsLoading)
        {
            <LoadingState Text="Loading collection records…" />
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <ErrorState Title="Couldn't load records" Message="@ErrorMessage" OnRetry="LoadRecordsAsync" />
        }
        else if (!FilteredRecords.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                </div>
                <div class="empty-title">No Records Found</div>
                <div class="empty-sub">@EmptyMessage</div>
            </div>
        }
        else
        {
            @foreach (var group in GroupedRows)
            {
                @* On a single-day selection the date header is redundant — skip it. *@
                @if (!SingleDayMode)
                {
                    <div class="section-label">
                        @group.Key
                        <span class="section-count">@group.Value.Count entries</span>
                    </div>
                }

                @foreach (var row in group.Value)
                {
                    var rec = row.Primary;
                    <div class="record-card @RowCardClass(row)" @onclick="() => OpenDetail(row)">
                        <div class="record-info">
                            <div class="record-name">@rec.PayorName</div>
                            <div class="record-meta">
                                @if (AssignedFacilities.Count > 1)
                                {
                                    <span class="record-facility">@rec.FacilityCode</span>
                                }
                                @if (rec.Section is not null)
                                {
                                    <span class="record-section">@SectionLabel(rec.Section.Value)</span>
                                }
                                @if (rec.IsAdminRecorded)
                                {
                                    <span class="record-admin-tag">Office</span>
                                }
                                @if (row.IsMerged)
                                {
                                    <span class="record-section">@MergedLabel(row)</span>
                                }
                                else if (rec.SlaughterLines is { Count: > 1 })
                                {
                                    <span class="record-section">@rec.SlaughterLines.Count animal types</span>
                                }
                                <span class="record-time">@rec.CollectedAt.ToString("hh:mm tt")@(rec.IsAbsent ? " · marked absent" : " · OR #" + rec.ORNumber)</span>
                            </div>
                        </div>
                        <div class="record-amount-col">
                            <div class="record-amount">@(rec.IsAbsent ? "—" : "₱" + row.TotalAmount.ToString("N0"))</div>
                            <span class="record-status-pill @RowPillClass(row)">@RowStatusLabel(row)</span>
                        </div>
                    </div>
                }

                <div class="group-spacer"></div>
            }
        }

    </div>
    <BottomNav ActiveTab="records" />

</div>

@if (ShowDetailSheet && SelectedRecord is not null)
{
    <div class="sheet-overlay" @onclick="CloseDetail">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">@SelectedRecord.PayorName</div>
            <div class="sheet-sub">Collection Record Detail</div>

            @if (!SelectedRecord.IsAbsent)
            {
                <div class="detail-row"><span class="detail-key">OR Number</span><span class="detail-val">#@SelectedRecord.ORNumber</span></div>
            }
            <div class="detail-row"><span class="detail-key">Facility</span><span class="detail-val">@SelectedRecord.FacilityName</span></div>
            @if (!string.IsNullOrWhiteSpace(SelectedRecord.StallNo))
            {
                <div class="detail-row"><span class="detail-key">Stall / Unit</span><span class="detail-val">@SelectedRecord.StallNo</span></div>
            }
            @if (SelectedRecord.Section is not null)
            {
                <div class="detail-row"><span class="detail-key">Section</span><span class="detail-val">@SectionLabel(SelectedRecord.Section.Value)</span></div>
            }
            @if (SelectedRecord.FishKilos is > 0)
            {
                <div class="detail-row"><span class="detail-key">Fish Weight</span><span class="detail-val">@SelectedRecord.FishKilos.Value.ToString("0.##") kg</span></div>
            }
            <div class="detail-row"><span class="detail-key">Nature</span><span class="detail-val">@SelectedRecord.Nature</span></div>
            @if (SelectedRecord.SlaughterLines is { Count: > 0 })
            {
                var totalHeads = SelectedRecord.SlaughterLines.Sum(l => l.Heads);
                <div class="detail-row"><span class="detail-key">Animals</span><span class="detail-val">@totalHeads head@(totalHeads == 1 ? "" : "s") · @SelectedRecord.SlaughterLines.Count type@(SelectedRecord.SlaughterLines.Count == 1 ? "" : "s")</span></div>
                @foreach (var line in SelectedRecord.SlaughterLines)
                {
                    <div class="detail-row"><span class="detail-key">· @line.AnimalType × @line.Heads</span><span class="detail-val">₱@line.Amount.ToString("N0")</span></div>
                }
            }
            <div class="detail-row"><span class="detail-key">Recorded by</span><span class="detail-val">@(SelectedRecord.IsAdminRecorded ? "Office / Admin" : Session.CollectorName)</span></div>
            <div class="detail-row"><span class="detail-key">Date &amp; Time</span><span class="detail-val">@SelectedRecord.CollectedAt.ToString("MMM d, yyyy · hh:mm tt")</span></div>
            <div class="detail-row"><span class="detail-key">Status</span><span class="detail-val"><span class="record-status-pill @PillClass(SelectedRecord)">@StatusLabel(SelectedRecord)</span></span></div>
            @if (SelectedRow is { IsMerged: true })
            {
                <div class="detail-row"><span class="detail-key">Payments in this receipt</span><span class="detail-val">@SelectedRow.Count</span></div>
                @foreach (var it in SelectedRow.Items)
                {
                    <div class="detail-row"><span class="detail-key">· @it.Nature</span><span class="detail-val">₱@it.Amount.ToString("N0")</span></div>
                }
                <div class="detail-row"><span class="detail-key">Total Amount</span><span class="detail-val amount-val">₱@SelectedRow.TotalAmount.ToString("N0")</span></div>
                @if (SelectedRow.AnyPartial)
                {
                    <div class="detail-row"><span class="detail-key">Collected</span><span class="detail-val" style="color:var(--paid-green);font-weight:600;">₱@SelectedRow.TotalPaid.ToString("N0")</span></div>
                    <div class="detail-row"><span class="detail-key">Balance Due</span><span class="detail-val" style="color:var(--error-red);font-weight:600;">₱@((SelectedRow.TotalAmount - SelectedRow.TotalPaid).ToString("N0"))</span></div>
                }
            }
            else
            {
                <div class="detail-row"><span class="detail-key">Amount</span><span class="detail-val amount-val">₱@SelectedRecord.Amount.ToString("N0")</span></div>
                @if (SelectedRecord.IsPartial)
                {
                    <div class="detail-row"><span class="detail-key">Collected</span><span class="detail-val" style="color:var(--paid-green);font-weight:600;">₱@SelectedRecord.AmountPaid.ToString("N0")</span></div>
                    <div class="detail-row"><span class="detail-key">Balance Due</span><span class="detail-val" style="color:var(--error-red);font-weight:600;">₱@((SelectedRecord.Amount - SelectedRecord.AmountPaid).ToString("N0"))</span></div>
                }
            }

            @if (SelectedRecord.Utility is { } u)
            {
                <div class="detail-util-head">Electricity &amp; Water</div>
                <div class="detail-row">
                    <span class="detail-key">Electricity · @u.ElecStatus@(string.IsNullOrWhiteSpace(u.ElecORNumber) ? "" : " · OR #" + u.ElecORNumber)</span>
                    <span class="detail-val">₱@u.ElecAmountPaid.ToString("N2") / ₱@u.ElecCharge.ToString("N2")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-key">Water · @u.WaterStatus@(string.IsNullOrWhiteSpace(u.WaterORNumber) ? "" : " · OR #" + u.WaterORNumber)</span>
                    <span class="detail-val">₱@u.WaterAmountPaid.ToString("N2") / ₱@u.WaterCharge.ToString("N2")</span>
                </div>
                <div class="detail-row">
                    <span class="detail-key">Utilities Balance</span>
                    <span class="detail-val amount-val">₱@u.Balance.ToString("N2")</span>
                </div>
            }

            <div class="sheet-btn-row">
                <div class="btn-close" @onclick="CloseDetail">Close</div>
            </div>
        </div>
    </div>
}

@if (ShowPendingSheet)
{
    <div class="sheet-overlay" @onclick="ClosePendingSheet">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Pending Sync</div>
            <div class="sheet-sub">
                @if (PendingOps.Count == 0)
                {
                    <text>No offline collections are waiting to sync.</text>
                }
                else
                {
                    <text>@PendingOps.Count collection@(PendingOps.Count == 1 ? "" : "s") queued on this device.</text>
                }
            </div>

            <div class="pending-conn @(Sync.IsOnline ? "online" : "offline")">
                <span class="conn-dot"></span>
                @(Sync.IsOnline ? "Online" : "Offline — items sync automatically when you reconnect")
            </div>

            @if (PendingOps.Count > 0)
            {
                <div class="pending-list">
                    @foreach (var op in PendingOps)
                    {
                        var orphaned = op.OwnerKey is null;
                        <div class="pending-item @(orphaned ? "rejected" : PendingItemClass(op))" @key="op.ClientOperationId">
                            <div class="pending-item-main">
                                <div class="pending-item-title">@op.Title</div>
                                <div class="pending-item-detail">
                                    @op.FacilityLabel@(string.IsNullOrWhiteSpace(op.Detail) ? "" : " · " + op.Detail)@(string.IsNullOrWhiteSpace(op.ORNumber) ? "" : " · OR " + op.ORNumber)
                                </div>
                                @if (orphaned)
                                {
                                    <div class="pending-item-msg">Unassigned — captured in a previous session. Discard if it isn't yours.</div>
                                }
                                else if (op.LocalStatus == PendingLocalStatus.Rejected && !string.IsNullOrWhiteSpace(op.ResultMessage))
                                {
                                    <div class="pending-item-msg">@op.ResultMessage</div>
                                }
                            </div>
                            <div class="pending-item-right">
                                <div class="pending-item-amount">₱@op.Amount.ToString("N0")</div>
                                <span class="pending-status @(orphaned ? "rejected" : PendingItemClass(op))">@(orphaned ? "Unassigned" : PendingStatusLabel(op))</span>
                                @if (orphaned || op.LocalStatus == PendingLocalStatus.Rejected)
                                {
                                    <button class="pending-discard" type="button" @onclick="() => DiscardPendingAsync(op.ClientOperationId)">Discard</button>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            <div class="sheet-btn-row">
                <div class="btn-close" @onclick="ClosePendingSheet">Close</div>
                @if (HasRetryable)
                {
                    <button class="btn-sync-now" type="button" @onclick="SyncPendingNowAsync" disabled="@(Sync.IsSyncing || !Sync.IsOnline)">
                        @(Sync.IsSyncing ? "Syncing…" : "Sync now")
                    </button>
                }
            </div>
        </div>
    </div>
}

@code {
    // ── Daily-context facilities (per-transaction / per-day). The rest are monthly rentals. ──
    static readonly HashSet<FacilityCode> DailyFacilities = new()
    {
        FacilityCode.NPM, FacilityCode.SLH, FacilityCode.TRM, FacilityCode.TPM
    };

    // Tabo-an Public Market trades only on Fridays (₱100/vendor/market day), so its Records show
    // market-day (Friday) chips instead of consecutive-day chips.
    static readonly HashSet<FacilityCode> WeeklyFacilities = new() { FacilityCode.TPM };

    bool IsLoading = true;
    string ErrorMessage = string.Empty;
    string SearchQuery = string.Empty;

    FacilityCode? ActiveFacility = null;       // null = All
    string ActivePeriodKey = "0";              // key within the active mode
    IReadOnlyList<MobileCollectorRecordDto> Records = Array.Empty<MobileCollectorRecordDto>();

    // Instant re-open while online: keep the last records per (collector · facility · date-range) in memory,
    // so returning to Records shows them immediately and then refreshes quietly in the background instead of
    // a loading state every time. Keyed by CollectorId so two collectors on one device never mix.
    private static readonly Dictionary<string, IReadOnlyList<MobileCollectorRecordDto>> _recordsCache = new();
    private string RecordsCacheKey
    {
        get
        {
            var (from, to) = CurrentRange();
            return $"{Session.Menu?.CollectorId:N}|{ActiveFacility?.ToString() ?? "all"}|{from:yyyy-MM-dd}|{to:yyyy-MM-dd}";
        }
    }

    IReadOnlyList<FacilityCode> AssignedFacilities =>
        Session.Menu?.Facilities.Where(f => f.IsAssigned).Select(f => f.Code).OrderBy(c => c).ToList()
        ?? new List<FacilityCode>();

    // Tabo-an (TPM) is a weekly Friday market — its chips are market days (Fridays), and it takes
    // precedence over daily mode (TPM is also listed under DailyFacilities for the mixed-facility case).
    bool WeeklyMode => ActiveFacility is { } wf
        ? WeeklyFacilities.Contains(wf)
        : AssignedFacilities.Count > 0 && AssignedFacilities.All(c => WeeklyFacilities.Contains(c));

    // Daily mode when a per-day facility is selected, or when "All" is shown but every assigned
    // facility is daily-type (e.g. a collector assigned only to NPM). Monthly facilities use months.
    bool DailyMode => !WeeklyMode && (ActiveFacility is { } f
        ? DailyFacilities.Contains(f)
        : AssignedFacilities.Count > 0 && AssignedFacilities.All(c => DailyFacilities.Contains(c)));

    record Chip(string Key, string Label);

    // Recent market days (Fridays), most recent first — for the weekly (TPM) chips.
    static IReadOnlyList<DateTime> RecentMarketDays()
    {
        var today = DateTime.Now.Date;
        var delta = ((int)today.DayOfWeek - (int)DayOfWeek.Friday + 7) % 7;
        var lastFriday = today.AddDays(-delta);
        return Enumerable.Range(0, 6).Select(i => lastFriday.AddDays(-7 * i)).ToList();
    }

    IReadOnlyList<Chip> PeriodChips => WeeklyMode
        ? RecentMarketDays().Select(fri =>
            {
                var label = fri == DateTime.Now.Date ? "Today" : fri.ToString("MMM d");
                return new Chip(fri.ToString("yyyy-MM-dd"), label);
            }).ToList()
        : DailyMode
            ? Enumerable.Range(0, 7).Select(i =>
                {
                    var d = DateTime.Now.Date.AddDays(-i);
                    var label = i == 0 ? "Today" : i == 1 ? "Yesterday" : d.ToString("M/d");
                    return new Chip(i.ToString(), label);
                }).ToList()
            : Enumerable.Range(0, 12).Select(i =>
                {
                    var d = DateTime.Now.AddMonths(-i);
                    var label = i == 0
                        ? $"This Month ({d:MMM})"
                        : d.Year == DateTime.Now.Year ? d.ToString("MMM") : d.ToString("MMM yyyy");
                    return new Chip(i.ToString(), label);
                }).ToList();

    string ActivePeriodLabel => PeriodChips.FirstOrDefault(c => c.Key == ActivePeriodKey)?.Label ?? "this period";

    // Single-day selections (daily chips Today/Yesterday/6/16, or a weekly market-day Friday):
    // hide the date group header.
    bool SingleDayMode => WeeklyMode || (DailyMode && int.TryParse(ActivePeriodKey, out _));

    string EmptyMessage =>
        "No collections you recorded for " + ActivePeriodLabel
        + (ActiveFacility is null ? "" : " at " + ActiveFacility) + ".";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
            if (Session.Menu is null)
            {
                Navigation.NavigateTo("/login", forceLoad: false);
                return;
            }
            // Assigned facilities are now known, so the period mode (daily/weekly/monthly) is resolved —
            // seed the active period with the first valid chip key for that mode.
            ActivePeriodKey = PeriodChips.FirstOrDefault()?.Key ?? "0";
            await LoadOrRefreshRecordsAsync();

            // Offline queue: show the pending badge and best-effort flush anything captured offline.
            Sync.Changed += OnSyncChanged;
            await Sync.InitializeAsync();
            _ = InitialFlushAsync();
        }
        catch (HttpRequestException)
        {
            ErrorMessage = "Unable to connect to the EEMO server. Please check the connection and try again.";
            IsLoading = false;
        }
    }

    // Best-effort sync on entry; refresh the server list only if something was actually accepted.
    private async Task InitialFlushAsync()
    {
        var summary = await Sync.SyncNowAsync();
        if (summary.Synced > 0)
            await InvokeAsync(RefreshRecordsAsync);
    }

    // Show cached records instantly (no spinner) then refresh in the background; a cold range with no cache
    // shows the full loading state. Keeps online navigation snappy and consistent.
    async Task LoadOrRefreshRecordsAsync()
    {
        if (_recordsCache.TryGetValue(RecordsCacheKey, out var cached))
        {
            Records = cached;
            IsLoading = false;
            ErrorMessage = string.Empty;
            StateHasChanged();
            await RefreshRecordsAsync();
        }
        else
        {
            await LoadRecordsAsync();
        }
    }

    // Quiet background refresh — updates the data + cache without flashing the loading state. A transient
    // failure keeps the cached view.
    async Task RefreshRecordsAsync()
    {
        try
        {
            var (from, to) = CurrentRange();
            var result = await Api.GetRecordsAsync(ActiveFacility, from, to);
            if (result.IsSuccess && result.Value is not null)
            {
                Records = result.Value;
                _recordsCache[RecordsCacheKey] = result.Value;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch
        {
            // Keep the cached records on a transient/offline refresh failure.
        }
    }

    (DateOnly From, DateOnly To) CurrentRange()
    {
        var today = DateOnly.FromDateTime(DateTime.Now);
        if (WeeklyMode)
        {
            // Each weekly chip is a single market day (Friday); key = "yyyy-MM-dd".
            if (DateOnly.TryParseExact(ActivePeriodKey, "yyyy-MM-dd",
                    System.Globalization.CultureInfo.InvariantCulture,
                    System.Globalization.DateTimeStyles.None, out var fri))
                return (fri, fri);
            var mostRecent = DateOnly.FromDateTime(RecentMarketDays().First());
            return (mostRecent, mostRecent);
        }
        if (DailyMode)
        {
            // Each daily chip is a single day in the past week (key = days-back offset).
            var offset = int.TryParse(ActivePeriodKey, out var o) ? o : 0;
            var day = today.AddDays(-offset);
            return (day, day);
        }

        var monthsBack = int.TryParse(ActivePeriodKey, out var m) ? m : 0;
        var anchor = new DateOnly(today.Year, today.Month, 1).AddMonths(-monthsBack);
        var monthEnd = anchor.AddMonths(1).AddDays(-1);
        // Don't reach into the future for the current month.
        var to = monthEnd > today ? today : monthEnd;
        return (anchor, to);
    }

    async Task LoadRecordsAsync()
    {
        IsLoading = true;
        ErrorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var (from, to) = CurrentRange();
            var result = await Api.GetRecordsAsync(ActiveFacility, from, to);

            if (result.IsSuccess && result.Value is not null)
            {
                Records = result.Value;
                _recordsCache[RecordsCacheKey] = result.Value;
            }
            else
                ErrorMessage = result.Error ?? "Unable to load your collection records.";
        }
        catch
        {
            // The HTTP layer throws on a connection failure/timeout (it doesn't return a Result). Catch it
            // here so the retry path (which calls this directly) can never throw or get stuck loading.
            ErrorMessage = "Unable to connect to the EEMO server. Please check the connection and try again.";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    async Task SetFacilityAsync(FacilityCode? code)
    {
        ActiveFacility = code;
        // Switching facilities can change the period mode (daily/weekly/monthly) — reset to the
        // first chip of the new mode so the active key is always valid.
        ActivePeriodKey = PeriodChips.FirstOrDefault()?.Key ?? "0";
        await LoadOrRefreshRecordsAsync();
    }

    async Task SetPeriodAsync(string key)
    {
        ActivePeriodKey = key;
        await LoadOrRefreshRecordsAsync();
    }

    // ── Client-side search over the loaded (already facility/period-filtered) records ──
    IEnumerable<MobileCollectorRecordDto> FilteredRecords => Records.Where(r =>
        string.IsNullOrWhiteSpace(SearchQuery)
        || r.PayorName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
        || r.ORNumber.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
        || (r.StallNo ?? "").Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

    // Transaction rows: collapse records that belong to the SAME receipt (same OR number, payor, facility)
    // into ONE row. A multi-month monthly payment writes one record per month sharing a single OR, so it
    // renders as one row with the combined total; daily facilities issue a distinct OR per collection and
    // never collapse. Presentation only — the underlying records + settlement are untouched.
    Dictionary<string, IReadOnlyList<RecordRow>> GroupedRows =>
        FilteredRecords
            .OrderByDescending(r => r.CollectedAt)
            .GroupBy(r => DateLabel(r.CollectedAt))
            .ToDictionary(g => g.Key, g => BuildRows(g));

    static IReadOnlyList<RecordRow> BuildRows(IEnumerable<MobileCollectorRecordDto> recs)
    {
        var rows = new List<RecordRow>();
        var byReceipt = new Dictionary<string, RecordRow>();
        foreach (var r in recs)
        {
            // Only merge genuine multi-period receipts: a real OR number and not an absent mark.
            if (!r.IsAbsent && !string.IsNullOrWhiteSpace(r.ORNumber))
            {
                var key = r.FacilityCode + "|" + r.PayorName + "|" + r.ORNumber;
                if (byReceipt.TryGetValue(key, out var existing))
                {
                    existing.Items.Add(r);
                    continue;
                }
                var row = new RecordRow(r);
                byReceipt[key] = row;
                rows.Add(row);
            }
            else
            {
                rows.Add(new RecordRow(r));
            }
        }
        return rows;
    }

    sealed class RecordRow
    {
        public RecordRow(MobileCollectorRecordDto first) => Items = new List<MobileCollectorRecordDto> { first };
        public List<MobileCollectorRecordDto> Items { get; }
        public MobileCollectorRecordDto Primary => Items[0];
        public int Count => Items.Count;
        public bool IsMerged => Items.Count > 1;
        public decimal TotalAmount => Items.Sum(i => i.Amount);
        public decimal TotalPaid => Items.Sum(i => i.AmountPaid);
        public bool AnyPartial => Items.Any(i => i.IsPartial) || TotalPaid < TotalAmount;
    }

    static string DateLabel(DateTime dt)
    {
        if (dt.Date == DateTime.Today) return "Today";
        if (dt.Date == DateTime.Today.AddDays(-1)) return "Yesterday";
        return dt.ToString("MMMM d, yyyy");
    }

    IEnumerable<RecordRow> AllRows => GroupedRows.SelectMany(g => g.Value);

    decimal TotalCollected => FilteredRecords.Sum(r => r.AmountPaid);
    int PaidCount => AllRows.Count(row => !row.Primary.IsAbsent && !row.AnyPartial);
    int PartialCount => AllRows.Count(row => !row.Primary.IsAbsent && row.AnyPartial);
    int ExcusedCount => AllRows.Count(row => row.Primary.IsAbsent);

    bool ShowDetailSheet = false;
    RecordRow? SelectedRow;
    MobileCollectorRecordDto? SelectedRecord;
    void OpenDetail(RecordRow row) { SelectedRow = row; SelectedRecord = row.Primary; ShowDetailSheet = true; }
    void CloseDetail() { ShowDetailSheet = false; SelectedRow = null; SelectedRecord = null; }

    // ── Merged-row display helpers (mirror the single-record helpers, over the whole receipt) ──
    static string RowCardClass(RecordRow row) =>
        row.Primary.IsAbsent ? "absent" : row.AnyPartial ? "unpaid" : "paid";

    static string RowPillClass(RecordRow row) =>
        row.Primary.IsAbsent ? "record-status-pill pill-absent"
        : row.AnyPartial ? "record-status-pill pill-partial"
        : "record-status-pill pill-paid";

    static string RowStatusLabel(RecordRow row) =>
        row.Primary.IsAbsent ? "Excused"
        : row.AnyPartial ? $"₱{row.TotalPaid:N0} paid"
        : "Paid";

    // Tag on a collapsed row: monthly rentals collapse months; other facilities show a generic entry count.
    string MergedLabel(RecordRow row) =>
        (DailyFacilities.Contains(row.Primary.FacilityCode) || WeeklyFacilities.Contains(row.Primary.FacilityCode))
            ? $"{row.Count} entries"
            : $"{row.Count} months";

    // ── Offline pending queue (button right of the search bar) ──────────────
    bool ShowPendingSheet = false;
    IReadOnlyList<PendingOperation> PendingOps = Array.Empty<PendingOperation>();

    bool HasRetryable => PendingOps.Any(o => o.OwnerKey is not null && o.LocalStatus is PendingLocalStatus.Pending or PendingLocalStatus.Failed);

    async Task OpenPendingSheetAsync()
    {
        PendingOps = await Sync.GetAllAsync();
        ShowPendingSheet = true;
    }

    void ClosePendingSheet() => ShowPendingSheet = false;

    async Task SyncPendingNowAsync()
    {
        var summary = await Sync.SyncNowAsync();
        PendingOps = await Sync.GetAllAsync();
        if (summary.Synced > 0)
            await RefreshRecordsAsync();
    }

    async Task DiscardPendingAsync(Guid clientOperationId)
    {
        await Sync.DiscardAsync(clientOperationId);
        PendingOps = await Sync.GetAllAsync();
    }

    static string PendingStatusLabel(PendingOperation op) => op.LocalStatus switch
    {
        PendingLocalStatus.Pending => "Pending",
        PendingLocalStatus.Failed => "Retry",
        PendingLocalStatus.Rejected => "Rejected",
        PendingLocalStatus.Synced => "Synced",
        _ => string.Empty
    };

    static string PendingItemClass(PendingOperation op) => op.LocalStatus switch
    {
        PendingLocalStatus.Rejected => "rejected",
        PendingLocalStatus.Failed => "failed",
        _ => "pending"
    };

    // Sync events fire off the UI thread — marshal before touching component state.
    private bool _disposed;

    // Tracks the queue size across Changed events so we can tell when an item actually left the queue
    // (synced/removed) and therefore the server record list needs re-fetching.
    private int _lastPendingCount = -1;

    private async void OnSyncChanged()
    {
        if (_disposed)
            return;
        try
        {
            var previous = _lastPendingCount;
            var current = Sync.PendingCount;
            _lastPendingCount = current;
            // Something left the queue (an offline capture just synced) → the server now has it recorded,
            // so re-fetch the list so the paid row renders without a manual refresh.
            var queueDrained = previous >= 0 && current < previous;

            await InvokeAsync(async () =>
            {
                if (_disposed)
                    return;
                if (ShowPendingSheet)
                    PendingOps = await Sync.GetAllAsync();

                if (queueDrained)
                    await RefreshRecordsAsync();
                else
                    StateHasChanged();
            });
        }
        catch
        {
            // Component is tearing down (navigated away) — ignore.
        }
    }

    public void Dispose()
    {
        _disposed = true;
        Sync.Changed -= OnSyncChanged;
    }

    static string CardClass(MobileCollectorRecordDto r) =>
        r.IsAbsent ? "absent" : r.IsPartial ? "unpaid" : "paid";

    static string IconClass(MobileCollectorRecordDto r) =>
        r.IsAbsent ? "absent-icon" : r.IsPartial ? "" : "paid-icon";

    static string PillClass(MobileCollectorRecordDto r) =>
        r.IsAbsent ? "record-status-pill pill-absent"
        : r.IsPartial ? "record-status-pill pill-partial"
        : "record-status-pill pill-paid";

    static string StatusLabel(MobileCollectorRecordDto r) =>
        r.IsAbsent ? "Excused"
        : r.IsPartial ? $"₱{r.AmountPaid:N0} paid"
        : "Paid";

    static string SectionLabel(MarketSection s) => s switch
    {
        MarketSection.VegetableArea => "Vegetable",
        MarketSection.FishSection => "Fish",
        MarketSection.MeatSection => "Meat",
        _ => s.ToString()
    };
}
