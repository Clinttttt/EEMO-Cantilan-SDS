@page "/records"
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Domain.Enums
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject EEMOCantilanSDS.Application.Common.Interface.ApiClients.IMobileApiClient Api

<!-- ░░ PAGE SHELL ░░ -->
<div class="page-shell">

    <AppHeader CollectorName="@Session.CollectorName" />

    <!-- Scrollable Content -->
    <div class="content">

        <!-- Summary Strip -->
        <div class="summary-strip">
            <div class="summary-item">
                <div class="summary-value">₱@TotalCollected.ToString("N0")</div>
                <div class="summary-key">Collected</div>
            </div>
            <div class="summary-item">
                <div class="summary-value">@PaidCount</div>
                <div class="summary-key">Paid</div>
            </div>
            <div class="summary-item">
                <div class="summary-value">@PartialCount</div>
                <div class="summary-key">Partial</div>
            </div>
        </div>

        <!-- Search -->
        <div class="search-wrap">
            <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
            <input type="text"
                   placeholder="Search name, OR no., stall…"
                   @bind="SearchQuery"
                   @bind:event="oninput" />
        </div>

        <!-- Combined period + facility chips in one scrollable row -->
        <div class="filter-tabs">
            @foreach (var p in PeriodChips)
            {
                <div class="filter-tab @(ActivePeriodKey == p.Key ? "active" : "")"
                     @onclick="() => SetPeriodAsync(p.Key)">@p.Label</div>
            }
            @if (AssignedFacilities.Count > 1)
            {
                <div class="filter-tab-sep"></div>
                <div class="filter-tab @(ActiveFacility is null ? "active" : "")"
                     @onclick="() => SetFacilityAsync(null)">All</div>
                @foreach (var fcode in AssignedFacilities)
                {
                    <div class="filter-tab @(ActiveFacility == fcode ? "active" : "")"
                         @onclick="() => SetFacilityAsync(fcode)">@(fcode)</div>
                }
            }
        </div>

        @if (IsLoading)
        {
            <div class="menu-state-card">Loading your collection records…</div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="menu-state-card error">
                @ErrorMessage
                <div style="margin-top:10px;"><span class="filter-tab active" @onclick="LoadRecordsAsync">Try again</span></div>
            </div>
        }
        else if (!FilteredRecords.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">
                    <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                </div>
                <div class="empty-title">No Records Found</div>
                <div class="empty-sub">@EmptyMessage</div>
            </div>
        }
        else
        {
            @foreach (var group in GroupedRecords)
            {
                @* On a single-day selection the date header is redundant — skip it. *@
                @if (!SingleDayMode)
                {
                    <div class="section-label">
                        @group.Key
                        <span class="section-count">@group.Value.Count() entries</span>
                    </div>
                }

                @foreach (var rec in group.Value)
                {
                    <div class="record-card @(rec.IsPartial ? "unpaid" : "paid")" @onclick="() => OpenDetail(rec)">
                        <div class="record-icon @(rec.IsPartial ? "" : "paid-icon")">
                            <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" /><polyline points="14 2 14 8 20 8" /></svg>
                        </div>
                        <div class="record-info">
                            <div class="record-name">@rec.PayorName</div>
                            <div class="record-meta">
                                @if (AssignedFacilities.Count > 1)
                                {
                                    <span class="record-facility">@rec.FacilityCode</span>
                                }
                                @if (rec.Section is not null)
                                {
                                    <span class="record-section">@SectionLabel(rec.Section.Value)</span>
                                }
                                <span class="record-time">@rec.CollectedAt.ToString("hh:mm tt") · OR #@rec.ORNumber</span>
                            </div>
                        </div>
                        <div class="record-amount-col">
                            <div class="record-amount">₱@rec.Amount.ToString("N0")</div>
                            <span class="record-status-pill @PillClass(rec)">@StatusLabel(rec)</span>
                        </div>
                    </div>
                }

                <div class="group-spacer"></div>
            }
        }

    </div>
    <BottomNav ActiveTab="records" />

</div>

@if (ShowDetailSheet && SelectedRecord is not null)
{
    <div class="sheet-overlay" @onclick="CloseDetail">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">@SelectedRecord.PayorName</div>
            <div class="sheet-sub">Collection Record Detail</div>

            <div class="detail-row"><span class="detail-key">OR Number</span><span class="detail-val">#@SelectedRecord.ORNumber</span></div>
            <div class="detail-row"><span class="detail-key">Facility</span><span class="detail-val">@SelectedRecord.FacilityName</span></div>
            @if (!string.IsNullOrWhiteSpace(SelectedRecord.StallNo))
            {
                <div class="detail-row"><span class="detail-key">Stall / Unit</span><span class="detail-val">@SelectedRecord.StallNo</span></div>
            }
            @if (SelectedRecord.Section is not null)
            {
                <div class="detail-row"><span class="detail-key">Section</span><span class="detail-val">@SectionLabel(SelectedRecord.Section.Value)</span></div>
            }
            @if (SelectedRecord.FishKilos is > 0)
            {
                <div class="detail-row"><span class="detail-key">Fish Weight</span><span class="detail-val">@SelectedRecord.FishKilos.Value.ToString("0.##") kg</span></div>
            }
            <div class="detail-row"><span class="detail-key">Nature</span><span class="detail-val">@SelectedRecord.Nature</span></div>
            <div class="detail-row"><span class="detail-key">Date &amp; Time</span><span class="detail-val">@SelectedRecord.CollectedAt.ToString("MMM d, yyyy · hh:mm tt")</span></div>
            <div class="detail-row"><span class="detail-key">Status</span><span class="detail-val"><span class="record-status-pill @PillClass(SelectedRecord)">@StatusLabel(SelectedRecord)</span></span></div>
            <div class="detail-row"><span class="detail-key">Amount</span><span class="detail-val amount-val">₱@SelectedRecord.Amount.ToString("N0")</span></div>
            @if (SelectedRecord.IsPartial)
            {
                <div class="detail-row"><span class="detail-key">Collected</span><span class="detail-val" style="color:var(--paid-green);font-weight:600;">₱@SelectedRecord.AmountPaid.ToString("N0")</span></div>
                <div class="detail-row"><span class="detail-key">Balance Due</span><span class="detail-val" style="color:var(--error-red);font-weight:600;">₱@((SelectedRecord.Amount - SelectedRecord.AmountPaid).ToString("N0"))</span></div>
            }

            <div class="sheet-btn-row">
                <div class="btn-close" @onclick="CloseDetail">Close</div>
            </div>
        </div>
    </div>
}

@code {
    // ── Daily-context facilities (per-transaction / per-day). The rest are monthly rentals. ──
    static readonly HashSet<FacilityCode> DailyFacilities = new()
    {
        FacilityCode.NPM, FacilityCode.SLH, FacilityCode.TRM, FacilityCode.TPM
    };

    bool IsLoading = true;
    string ErrorMessage = string.Empty;
    string SearchQuery = string.Empty;

    FacilityCode? ActiveFacility = null;       // null = All
    string ActivePeriodKey = "0";              // key within the active mode
    IReadOnlyList<MobileCollectorRecordDto> Records = Array.Empty<MobileCollectorRecordDto>();

    IReadOnlyList<FacilityCode> AssignedFacilities =>
        Session.Menu?.Facilities.Where(f => f.IsAssigned).Select(f => f.Code).OrderBy(c => c).ToList()
        ?? new List<FacilityCode>();

    // Daily mode when a per-day facility is selected, or when "All" is shown but every assigned
    // facility is daily-type (e.g. a collector assigned only to NPM). Monthly facilities use months.
    bool DailyMode => ActiveFacility is { } f
        ? DailyFacilities.Contains(f)
        : AssignedFacilities.Count > 0 && AssignedFacilities.All(c => DailyFacilities.Contains(c));

    record Chip(string Key, string Label);

    IReadOnlyList<Chip> PeriodChips => DailyMode
        ? Enumerable.Range(0, 7).Select(i =>
            {
                var d = DateTime.Now.Date.AddDays(-i);
                var label = i == 0 ? "Today" : i == 1 ? "Yesterday" : d.ToString("M/d");
                return new Chip(i.ToString(), label);
            }).ToList()
        : new List<Chip>
            {
                new("0", $"This Month ({DateTime.Now:MMM})"),
                new("1", $"Last Month ({DateTime.Now.AddMonths(-1):MMM})"),
                new("2", $"{DateTime.Now.AddMonths(-2):MMM}")
            };

    string ActivePeriodLabel => PeriodChips.FirstOrDefault(c => c.Key == ActivePeriodKey)?.Label ?? "this period";

    // Single-day selections (daily chips Today/Yesterday/6/16): hide the date group header.
    bool SingleDayMode => DailyMode && int.TryParse(ActivePeriodKey, out _);

    string EmptyMessage =>
        "No collections you recorded for " + ActivePeriodLabel
        + (ActiveFacility is null ? "" : " at " + ActiveFacility) + ".";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
            if (Session.Menu is null)
            {
                Navigation.NavigateTo("/login", forceLoad: false);
                return;
            }
            await LoadRecordsAsync();
        }
        catch (HttpRequestException)
        {
            ErrorMessage = "Unable to connect to the EEMO server. Please check the connection and try again.";
            IsLoading = false;
        }
    }

    (DateOnly From, DateOnly To) CurrentRange()
    {
        var today = DateOnly.FromDateTime(DateTime.Now);
        if (DailyMode)
        {
            // Each daily chip is a single day in the past week (key = days-back offset).
            var offset = int.TryParse(ActivePeriodKey, out var o) ? o : 0;
            var day = today.AddDays(-offset);
            return (day, day);
        }

        var monthsBack = int.TryParse(ActivePeriodKey, out var m) ? m : 0;
        var anchor = new DateOnly(today.Year, today.Month, 1).AddMonths(-monthsBack);
        var monthEnd = anchor.AddMonths(1).AddDays(-1);
        // Don't reach into the future for the current month.
        var to = monthEnd > today ? today : monthEnd;
        return (anchor, to);
    }

    async Task LoadRecordsAsync()
    {
        IsLoading = true;
        ErrorMessage = string.Empty;
        StateHasChanged();

        var (from, to) = CurrentRange();
        var result = await Api.GetRecordsAsync(ActiveFacility, from, to);

        if (result.IsSuccess && result.Value is not null)
            Records = result.Value;
        else
            ErrorMessage = result.Error ?? "Unable to load your collection records.";

        IsLoading = false;
        StateHasChanged();
    }

    async Task SetFacilityAsync(FacilityCode? code)
    {
        var wasDaily = DailyMode;
        ActiveFacility = code;
        // Switching between daily/monthly modes invalidates the period key — reset to the first chip.
        if (wasDaily != DailyMode) ActivePeriodKey = "0";
        await LoadRecordsAsync();
    }

    async Task SetPeriodAsync(string key)
    {
        ActivePeriodKey = key;
        await LoadRecordsAsync();
    }

    // ── Client-side search over the loaded (already facility/period-filtered) records ──
    IEnumerable<MobileCollectorRecordDto> FilteredRecords => Records.Where(r =>
        string.IsNullOrWhiteSpace(SearchQuery)
        || r.PayorName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
        || r.ORNumber.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
        || (r.StallNo ?? "").Contains(SearchQuery, StringComparison.OrdinalIgnoreCase));

    Dictionary<string, IEnumerable<MobileCollectorRecordDto>> GroupedRecords =>
        FilteredRecords
            .OrderByDescending(r => r.CollectedAt)
            .GroupBy(r => DateLabel(r.CollectedAt))
            .ToDictionary(g => g.Key, g => g.AsEnumerable());

    static string DateLabel(DateTime dt)
    {
        if (dt.Date == DateTime.Today) return "Today";
        if (dt.Date == DateTime.Today.AddDays(-1)) return "Yesterday";
        return dt.ToString("MMMM d, yyyy");
    }

    decimal TotalCollected => FilteredRecords.Sum(r => r.AmountPaid);
    int PaidCount => FilteredRecords.Count(r => !r.IsPartial);
    int PartialCount => FilteredRecords.Count(r => r.IsPartial);

    bool ShowDetailSheet = false;
    MobileCollectorRecordDto? SelectedRecord;
    void OpenDetail(MobileCollectorRecordDto rec) { SelectedRecord = rec; ShowDetailSheet = true; }
    void CloseDetail() { ShowDetailSheet = false; SelectedRecord = null; }

    static string PillClass(MobileCollectorRecordDto r) =>
        r.IsPartial ? "record-status-pill pill-partial" : "record-status-pill pill-paid";

    static string StatusLabel(MobileCollectorRecordDto r) =>
        r.IsPartial ? $"₱{r.AmountPaid:N0} paid" : "Paid";

    static string SectionLabel(MarketSection s) => s switch
    {
        MarketSection.VegetableArea => "Vegetable",
        MarketSection.FishSection => "Fish",
        MarketSection.MeatSection => "Meat",
        _ => s.ToString()
    };
}
