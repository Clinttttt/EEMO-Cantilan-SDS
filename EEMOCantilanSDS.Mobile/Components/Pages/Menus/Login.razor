@page "/login"
@using EEMOCantilanSDS.Application.Dtos.Tenancy
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject EEMOCantilanSDS.Application.Common.Interface.ApiClients.IMunicipalitiesApiClient MunicipalitiesApi

<style>
    /* ─────────────────────────────────────────────
           LOGIN PAGE — Login.razor only
           Full-screen navy layout, no bottom nav,
           no header component — standalone entry point
        ───────────────────────────────────────────── */


    /* ── Login Shell ── */
    .login-shell {
        display: flex;
        flex-direction: column;
        height: 100dvh;
        overflow: hidden;
        background: #0d2137;
        will-change: transform;
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
    }

    /* ── Top Section — Logo + Org Name ── */
    .login-top {
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: calc(env(safe-area-inset-top, 20px) + 38px) 32px 34px;
        position: relative;
        background-color: #0b1b30;
        background-image:
            linear-gradient(180deg, rgba(11,27,48,0.30) 0%, rgba(11,27,48,0.55) 70%, rgba(11,27,48,0.78) 100%),
            url('images/stalltrack-raw-background.webp');
        background-size: cover;
        background-position: center top;
    }

        /* concentric gold rings behind the seal */
        .login-top::before,
        .login-top::after {
            content: '';
            position: absolute;
            top: calc(env(safe-area-inset-top, 20px) + 10px);
            left: 50%;
            transform: translateX(-50%);
            border-radius: 50%;
            border: 1px solid rgba(200,168,75,0.10);
            pointer-events: none;
        }
        .login-top::before { width: 250px; height: 250px; }
        .login-top::after  { width: 320px; height: 320px; border-color: rgba(200,168,75,0.05); }

    .login-seal {
        width: 150px;
        height: 150px;
        margin-bottom: 16px;
        flex-shrink: 0;
        position: relative;
        z-index: 1;
        filter: drop-shadow(0 0 24px rgba(200,168,75,0.28)) drop-shadow(0 6px 20px rgba(0,0,0,0.45));
    }

        .login-seal img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .login-gov {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 3px;
        color: #c8a84b;
        text-transform: uppercase;
        margin-bottom: 6px;
        text-align: center;
        position: relative;
        z-index: 1;
    }

    .login-org {
        font-family: 'EB Garamond', serif;
        font-size: 30px;
        font-weight: 600;
        color: #ffffff;
        text-align: center;
        line-height: 1.1;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
        position: relative;
        z-index: 1;
    }

    .login-tagline {
        font-family: 'DM Sans', sans-serif;
        font-size: 12.5px;
        font-weight: 600;
        color: #e8cc76;
        text-align: center;
        letter-spacing: 0.2px;
        position: relative;
        z-index: 1;
    }

    .login-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #c8a84b;
        margin: 12px auto 10px;
        box-shadow: 0 0 6px rgba(232,204,118,0.6);
        position: relative;
        z-index: 1;
    }

    .login-access {
        font-family: 'DM Sans', sans-serif;
        font-size: 11px;
        color: rgba(255,255,255,0.55);
        text-align: center;
        letter-spacing: 0.4px;
        position: relative;
        z-index: 1;
    }

    /* ── Bottom Card — Login Form ── */
    .login-card {
        flex: 1;
        min-height: 0;
        background: #f0f4f8;
        border-radius: 28px 28px 0 0;
        padding: 15px 24px calc(env(safe-area-inset-bottom, 16px) + 24px);
        overflow-y: auto;
        scrollbar-width: none;
        position: relative;
    }

        .login-card::-webkit-scrollbar {
            display: none;
        }

        /* gold top accent on card */
        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 10%;
            right: 10%;
            height: 2px;
            background: linear-gradient(90deg, transparent, #c8a84b, #e8cc76, #c8a84b, transparent);
            border-radius: 1px;
        }

    .login-card-title {
        font-family: 'EB Garamond', serif;
        font-size: 22px;
        font-weight: 600;
        color: #0d2137;
        margin-bottom: 3px;
    }

    .login-card-sub {
        font-size: 11px;
        color: #8faabf;
        margin-bottom: 24px;
        letter-spacing: 0.2px;
    }

    /* ── Form Fields ── */
    .login-field {
        margin-bottom: 14px;
    }

    .login-label {
        font-size: 9.5px;
        font-weight: 600;
        letter-spacing: 1.5px;
        color: #8faabf;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    /* input wrapper — icon + field */
    .login-input-wrap {
        background: #ffffff;
        border-radius: 11px;
        border: 1.5px solid #dde4ea;
        display: flex;
        align-items: center;
        padding: 0 14px;
        gap: 10px;
        height: 48px;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

        .login-input-wrap:focus-within {
            border-color: #c8a84b;
            box-shadow: 0 0 0 3px rgba(200,168,75,0.12);
        }

        .login-input-wrap svg {
            width: 16px;
            height: 16px;
            stroke: #b0c4d4;
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
            flex-shrink: 0;
            transition: stroke 0.15s;
        }

        .login-input-wrap:focus-within svg {
            stroke: #c8a84b;
        }

        .login-input-wrap input {
            flex: 1;
            border: none;
            outline: none;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            color: #0d2137;
            background: transparent;
            height: 100%;
        }

            .login-input-wrap input::placeholder {
                color: #b0c4d4;
            }

        .login-input-wrap select {
            flex: 1;
            border: none;
            outline: none;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            color: #0d2137;
            background: transparent;
            height: 100%;
            appearance: none;
            -webkit-appearance: none;
            cursor: pointer;
        }

    /* eye toggle for password */
    .pw-toggle {
        cursor: pointer;
        flex-shrink: 0;
        display: flex;
        align-items: center;
    }

        .pw-toggle svg {
            width: 16px;
            height: 16px;
            stroke: #b0c4d4;
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    /* ── Error Banner ── */
    .login-error {
        background: #fdf0f0;
        border: 1px solid #f5c6c6;
        border-radius: 10px;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
        font-size: 12px;
        color: #8b3a3a;
        font-weight: 500;
    }

        .login-error svg {
            width: 15px;
            height: 15px;
            stroke: #8b3a3a;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            flex-shrink: 0;
        }

    /* ── Login Button ── */
    .login-btn {
        width: 100%;
        padding: 15px;
        border-radius: 12px;
        background: #0d2137;
        border: none;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        font-weight: 600;
        color: #e8cc76;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: opacity 0.15s, transform 0.15s;
        margin-top: 6px;
        position: relative;
        overflow: hidden;
        letter-spacing: 0.3px;
        box-sizing: border-box;
    }

        /* gold shimmer line at top of btn */
        .login-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(200,168,75,0.4), transparent);
        }

        .login-btn:active {
            opacity: 0.84;
            transform: scale(0.985);
        }

        /* loading state — dim + block clicks (spinner shown inline).
           NOTE: the class is `is-loading`, NOT `loading` — a bare `loading` collides with the global
           DaisyUI/Tailwind `.loading` utility in site.min.css, whose mask-image spinner scales to 100%
           of the full-width button and renders a giant navy arc. Keep this name distinct. */
        .login-btn.is-loading {
            opacity: 0.85;
            pointer-events: none;
            letter-spacing: 1.5px;
        }

    /* inline spinner shown while signing in — reuses the global eemo-spin keyframe (css/eemo.css) */
    .login-btn .btn-spinner {
        width: 15px;
        height: 15px;
        border-radius: 50%;
        border: 2px solid rgba(232,204,118,0.35);
        border-top-color: #e8cc76;
        animation: eemo-spin 0.7s linear infinite;
        flex-shrink: 0;
    }

    /* ── Notice Banner ── */
    .login-notice {
        background: rgba(13,33,55,0.05);
        border-radius: 10px;
        border: 1px solid #dde4ea;
        padding: 12px 14px;
        display: flex;
        align-items: flex-start;
        gap: 9px;
        margin-top: 18px;
    }

        .login-notice svg {
            width: 14px;
            height: 14px;
            stroke: #8faabf;
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
            flex-shrink: 0;
            margin-top: 1px;
        }

    .login-notice-text {
        font-size: 10.5px;
        color: #8faabf;
        line-height: 1.55;
    }

        .login-notice-text strong {
            color: #6a8aa0;
            font-weight: 600;
        }

    /* ── Footer ── */
    .login-footer {
        text-align: center;
        font-size: 8.5px;
        color: #b0c4d4;
        letter-spacing: 0.3px;
        line-height: 1.6;
        margin-top: 20px;
    }
</style>


<div class="login-shell">

    <!-- Top: STALLTRACK platform brand -->
    <div class="login-top">
        <div class="login-seal">
            <img src="images/stalltrack-seal.png" alt="StallTrack Seal" />
        </div>
        <div class="login-gov">Republic of the Philippines</div>
        <div class="login-org">StallTrack</div>
        <div class="login-tagline">Unified LGU Market Management Platform</div>
        <div class="login-dot"></div>
        <div class="login-access">Collector Mobile Access</div>
    </div>

    <!-- Bottom: Login Form Card -->
    <div class="login-card">

        <div class="login-card-title">Collector Sign In</div>
        <div class="login-card-sub">Enter your credentials to access the system.</div>

        <!-- Error Banner -->
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="login-error">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                @ErrorMessage
            </div>
        }

        <!-- Municipality picker — only shown when more than one LGU is live (single-tenant stays clean) -->
        @if (_showMunicipalityPicker)
        {
            <div class="login-field">
                <div class="login-label">Municipality</div>
                <div class="login-input-wrap">
                    <svg viewBox="0 0 24 24"><path d="M3 9.5 12 4l9 5.5" /><path d="M4 9.5h16" /><path d="M5.5 11v7M9.5 11v7M14.5 11v7M18.5 11v7" /><path d="M3 20.5h18" /></svg>
                    <select @bind="SelectedMunicipalityCode">
                        <option value="">Select your municipality…</option>
                        @foreach (var m in _municipalities)
                        {
                            <option value="@m.Code">@m.Name</option>
                        }
                    </select>
                </div>
            </div>
        }

        <!-- Username -->
        <div class="login-field">
            <div class="login-label">Username / Employee ID</div>
            <div class="login-input-wrap">
                <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                <input type="text"
                       placeholder="e.g. EEMO-2024-001"
                       @bind="Username"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown" />
            </div>
        </div>

        <!-- Password -->
        <div class="login-field">
            <div class="login-label">Password</div>
            <div class="login-input-wrap">
                <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0110 0v4" /></svg>
                <input type="@(ShowPassword ? "text" : "password")"
                       placeholder="Enter your password"
                       @bind="Password"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown" />
                <div class="pw-toggle" @onclick="() => ShowPassword = !ShowPassword">
                    @if (ShowPassword)
                    {
                        <!-- eye-off icon -->
                        <svg viewBox="0 0 24 24"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24" /><line x1="1" y1="1" x2="23" y2="23" /></svg>
                    }
                    else
                    {
                        <!-- eye icon -->
                        <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                    }
                </div>
            </div>
        </div>

        <!-- Login Button -->
        <button type="button" class="login-btn @(IsLoading ? "is-loading" : "")" disabled="@IsLoading" @onclick="HandleLogin">
            @if (IsLoading)
            {
                <span class="btn-spinner"></span>
                <span>Signing in…</span>
            }
            else
            {
                <span>Sign In</span>
            }
        </button>

        <!-- Notice -->
        <div class="login-notice">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
            <div class="login-notice-text">
                <strong>No registration available here.</strong> Accounts are created exclusively by the administrator through the web portal. Contact your office administrator if you need access.
            </div>
        </div>

        <!-- Footer -->
        <div class="login-footer">
            StallTrack · For authorized personnel only
        </div>

    </div>
    <!-- end .login-card -->

</div>
<!-- end .login-shell -->
@code {

    string Username = string.Empty;
    string Password = string.Empty;
    bool ShowPassword = false;
    bool IsLoading = false;
    string ErrorMessage = string.Empty;

    // Municipality picker: only prompt when more than one LGU is live. Single-tenant (Cantilan) shows no
    // picker and sends no code — the backend login lookup stays global, exactly as before.
    List<MunicipalityDto> _municipalities = new();
    string? SelectedMunicipalityCode;
    bool _showMunicipalityPicker = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (await Session.RestoreSessionAsync())
            {
                Navigation.NavigateTo("/menu", forceLoad: false);
                return;
            }
        }
        catch (HttpRequestException)
        {
            // Stay on the login page when the server is unreachable.
        }

        // Load the live municipalities (best-effort). Only show the picker when 2+ are active.
        try
        {
            var muni = await MunicipalitiesApi.GetMunicipalitiesAsync();
            if (muni.IsSuccess && muni.Value is not null)
            {
                _municipalities = muni.Value.Where(m => m.IsActive).OrderBy(m => m.Name).ToList();
                _showMunicipalityPicker = _municipalities.Count > 1;

                // Even when there is only one active LGU, send its code so collector lookup is tenant-
                // scoped. A null code triggers the legacy global lookup and becomes ambiguous as soon as
                // two municipalities contain the same username or employee ID.
                if (_municipalities.Count == 1)
                {
                    SelectedMunicipalityCode = _municipalities[0].Code;
                }
            }
        }
        catch
        {
            // Offline / unreachable — no picker; login stays global (works for the single-tenant case).
        }
    }

    async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await HandleLogin();
        }
    }

    async Task HandleLogin()
    {
        if (IsLoading)
        {
            return;
        }

        ErrorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(Username))
        {
            ErrorMessage = "Please enter your username or employee ID.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Please enter your password.";
            return;
        }

        if (_showMunicipalityPicker && string.IsNullOrWhiteSpace(SelectedMunicipalityCode))
        {
            ErrorMessage = "Please select your municipality.";
            return;
        }

        IsLoading = true;

        try
        {
            var error = await Session.LoginAsync(Username, Password, SelectedMunicipalityCode);

            if (string.IsNullOrWhiteSpace(error))
            {
                Navigation.NavigateTo("/menu", forceLoad: false);
                return;
            }

            ErrorMessage = error;
        }
        catch (HttpRequestException ex)
        {
#if DEBUG
            ErrorMessage = $"Unable to connect to the EEMO server. {ex.Message}";
#else
            ErrorMessage = "Unable to connect to the EEMO server. Please check the connection and try again.";
#endif
        }
        catch (TaskCanceledException)
        {
            ErrorMessage = "The EEMO server did not respond in time. Please try again.";
        }
        finally
        {
            IsLoading = false;
        }
    }
}
