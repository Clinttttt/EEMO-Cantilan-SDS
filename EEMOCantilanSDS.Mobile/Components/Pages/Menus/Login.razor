@page "/login"
@using EEMOCantilanSDS.Application.Dtos.Tenancy
@using EEMOCantilanSDS.Application.Dtos.Mobile
@using EEMOCantilanSDS.Mobile.Services
@implements IDisposable
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject EEMOCantilanSDS.Application.Common.Interface.ApiClients.IMunicipalitiesApiClient MunicipalitiesApi

<style>
    /* ─────────────────────────────────────────────
           LOGIN PAGE — Login.razor only
           Full-screen navy layout, no bottom nav,
           no header component — standalone entry point
        ───────────────────────────────────────────── */


    /* ── Login Shell ── */
    .login-shell {
        display: flex;
        flex-direction: column;
        height: 100dvh;
        overflow: hidden;
        background: #0d2137;
        will-change: transform;
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
    }

    /* ── Top Section — Logo + Org Name ── */
    .login-top {
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: calc(env(safe-area-inset-top, 20px) + 38px) 32px 34px;
        position: relative;
        background-color: #0b1b30;
        background-image:
            linear-gradient(180deg, rgba(11,27,48,0.30) 0%, rgba(11,27,48,0.55) 70%, rgba(11,27,48,0.78) 100%),
            url('images/stalltrack-raw-background.webp');
        background-size: cover;
        background-position: center top;
    }

        /* concentric gold rings behind the seal */
        .login-top::before,
        .login-top::after {
            content: '';
            position: absolute;
            top: calc(env(safe-area-inset-top, 20px) + 10px);
            left: 50%;
            transform: translateX(-50%);
            border-radius: 50%;
            border: 1px solid rgba(200,168,75,0.10);
            pointer-events: none;
        }
        .login-top::before { width: 250px; height: 250px; }
        .login-top::after  { width: 320px; height: 320px; border-color: rgba(200,168,75,0.05); }

    .login-seal {
        width: 150px;
        height: 150px;
        margin-bottom: 16px;
        flex-shrink: 0;
        position: relative;
        z-index: 1;
        filter: drop-shadow(0 0 24px rgba(200,168,75,0.28)) drop-shadow(0 6px 20px rgba(0,0,0,0.45));
    }

        .login-seal img {
            width: 100%;
            height: 100%;
            object-fit: contain;
        }

    .login-gov {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 3px;
        color: #c8a84b;
        text-transform: uppercase;
        margin-bottom: 6px;
        text-align: center;
        position: relative;
        z-index: 1;
    }

    .login-org {
        font-family: 'EB Garamond', serif;
        font-size: 30px;
        font-weight: 600;
        color: #ffffff;
        text-align: center;
        line-height: 1.1;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
        position: relative;
        z-index: 1;
    }

    .login-tagline {
        font-family: 'DM Sans', sans-serif;
        font-size: 12.5px;
        font-weight: 600;
        color: #e8cc76;
        text-align: center;
        letter-spacing: 0.2px;
        position: relative;
        z-index: 1;
    }

    .login-dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #c8a84b;
        margin: 12px auto 10px;
        box-shadow: 0 0 6px rgba(232,204,118,0.6);
        position: relative;
        z-index: 1;
    }

    .login-access {
        font-family: 'DM Sans', sans-serif;
        font-size: 11px;
        color: rgba(255,255,255,0.55);
        text-align: center;
        letter-spacing: 0.4px;
        position: relative;
        z-index: 1;
    }

    /* ── Bottom Card — Login Form ── */
    .login-card {
        flex: 1;
        min-height: 0;
        background: #f0f4f8;
        border-radius: 28px 28px 0 0;
        padding: 15px 24px calc(env(safe-area-inset-bottom, 16px) + 24px);
        overflow-y: auto;
        scrollbar-width: none;
        position: relative;
    }

        .login-card::-webkit-scrollbar {
            display: none;
        }

        /* gold top accent on card */
        .login-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 10%;
            right: 10%;
            height: 2px;
            background: linear-gradient(90deg, transparent, #c8a84b, #e8cc76, #c8a84b, transparent);
            border-radius: 1px;
        }

    .login-card-title {
        font-family: 'EB Garamond', serif;
        font-size: 22px;
        font-weight: 600;
        color: #0d2137;
        margin-bottom: 3px;
    }

    .login-card-sub {
        font-size: 11px;
        color: #8faabf;
        margin-bottom: 24px;
        letter-spacing: 0.2px;
    }

    /* ── Form Fields ── */
    .login-field {
        margin-bottom: 14px;
    }

    .login-label {
        font-size: 9.5px;
        font-weight: 600;
        letter-spacing: 1.5px;
        color: #8faabf;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    /* input wrapper — icon + field */
    .login-input-wrap {
        background: #ffffff;
        border-radius: 11px;
        border: 1.5px solid #dde4ea;
        display: flex;
        align-items: center;
        padding: 0 14px;
        gap: 10px;
        height: 48px;
        transition: border-color 0.15s, box-shadow 0.15s;
    }

        .login-input-wrap:focus-within {
            border-color: #c8a84b;
            box-shadow: 0 0 0 3px rgba(200,168,75,0.12);
        }

        .login-input-wrap svg {
            width: 16px;
            height: 16px;
            stroke: #b0c4d4;
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
            flex-shrink: 0;
            transition: stroke 0.15s;
        }

        .login-input-wrap:focus-within svg {
            stroke: #c8a84b;
        }

        .login-input-wrap input {
            flex: 1;
            border: none;
            outline: none;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            color: #0d2137;
            background: transparent;
            height: 100%;
        }

            .login-input-wrap input::placeholder {
                color: #b0c4d4;
            }

        .login-input-wrap select {
            flex: 1;
            border: none;
            outline: none;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            color: #0d2137;
            background: transparent;
            height: 100%;
            appearance: none;
            -webkit-appearance: none;
            cursor: pointer;
        }

    /* eye toggle for password */
    .pw-toggle {
        cursor: pointer;
        flex-shrink: 0;
        display: flex;
        align-items: center;
    }

        .pw-toggle svg {
            width: 16px;
            height: 16px;
            stroke: #b0c4d4;
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
        }

    /* ── Error Banner ── */
    .login-error {
        background: #fdf0f0;
        border: 1px solid #f5c6c6;
        border-radius: 10px;
        padding: 10px 14px;
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 16px;
        font-size: 12px;
        color: #8b3a3a;
        font-weight: 500;
    }

        .login-error svg {
            width: 15px;
            height: 15px;
            stroke: #8b3a3a;
            fill: none;
            stroke-width: 2;
            stroke-linecap: round;
            stroke-linejoin: round;
            flex-shrink: 0;
        }

    /* ── Login Button ── */
    .login-btn {
        width: 100%;
        padding: 15px;
        border-radius: 12px;
        background: #0d2137;
        border: none;
        font-family: 'DM Sans', sans-serif;
        font-size: 14px;
        font-weight: 600;
        color: #e8cc76;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        transition: opacity 0.15s, transform 0.15s;
        margin-top: 6px;
        position: relative;
        overflow: hidden;
        letter-spacing: 0.3px;
        box-sizing: border-box;
    }

        /* gold shimmer line at top of btn */
        .login-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(200,168,75,0.4), transparent);
        }

        .login-btn:active {
            opacity: 0.84;
            transform: scale(0.985);
        }

        /* loading state — dim + block clicks (spinner shown inline).
           NOTE: the class is `is-loading`, NOT `loading` — a bare `loading` collides with the global
           DaisyUI/Tailwind `.loading` utility in site.min.css, whose mask-image spinner scales to 100%
           of the full-width button and renders a giant navy arc. Keep this name distinct. */
        .login-btn.is-loading {
            opacity: 0.85;
            pointer-events: none;
            letter-spacing: 1.5px;
        }

    /* inline spinner shown while signing in — reuses the global eemo-spin keyframe (css/eemo.css) */
    .login-btn .btn-spinner {
        width: 15px;
        height: 15px;
        border-radius: 50%;
        border: 2px solid rgba(232,204,118,0.35);
        border-top-color: #e8cc76;
        animation: eemo-spin 0.7s linear infinite;
        flex-shrink: 0;
    }

    /* ── Notice Banner ── */
    .login-notice {
        background: rgba(13,33,55,0.05);
        border-radius: 10px;
        border: 1px solid #dde4ea;
        padding: 12px 14px;
        display: flex;
        align-items: flex-start;
        gap: 9px;
        margin-top: 18px;
    }

        .login-notice svg {
            width: 14px;
            height: 14px;
            stroke: #8faabf;
            fill: none;
            stroke-width: 1.8;
            stroke-linecap: round;
            stroke-linejoin: round;
            flex-shrink: 0;
            margin-top: 1px;
        }

    .login-notice-text {
        font-size: 10.5px;
        color: #8faabf;
        line-height: 1.55;
    }

        .login-notice-text strong {
            color: #6a8aa0;
            font-weight: 600;
        }

    /* ── Footer ── */
    .login-footer {
        text-align: center;
        font-size: 8.5px;
        color: #b0c4d4;
        letter-spacing: 0.3px;
        line-height: 1.6;
        margin-top: 20px;
    }
    /* ── First-launch "Confirm your municipality" (bind) overlay ── */
    .bind-overlay {
        position: fixed;
        inset: 0;
        background: rgba(13,33,55,0.74);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        z-index: 200;
    }

    .bind-modal {
        background: #ffffff;
        border-radius: 20px;
        padding: 28px 24px 22px;
        width: 100%;
        max-width: 360px;
        text-align: center;
        box-shadow: 0 24px 60px rgba(0,0,0,0.4);
        border-top: 3px solid #c8a84b;
    }

    .bind-seal {
        width: 84px;
        height: 84px;
        margin: 2px auto 16px;
        border-radius: 50%;
        background: #f0f4f8;
        border: 2px solid #e8cc76;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
    }

        .bind-seal img { width: 100%; height: 100%; object-fit: contain; }
        .bind-seal svg { width: 36px; height: 36px; stroke: #0d2137; fill: none; }

    .bind-eyebrow {
        font-size: 10.5px;
        font-weight: 600;
        letter-spacing: 1.6px;
        text-transform: uppercase;
        color: #8faabf;
        margin-bottom: 4px;
    }

    .bind-name {
        font-family: 'EB Garamond', serif;
        font-size: 26px;
        font-weight: 700;
        color: #0d2137;
        line-height: 1.15;
    }

    .bind-office {
        font-size: 13px;
        font-weight: 600;
        color: #33475b;
        margin-top: 6px;
    }

    .bind-prov {
        font-size: 12px;
        color: #8faabf;
        margin-top: 2px;
    }

    .bind-note {
        font-size: 12.5px;
        color: #6a8aa0;
        line-height: 1.55;
        margin: 16px 4px 20px;
    }

    .bind-confirm {
        width: 100%;
        padding: 15px;
        border: none;
        border-radius: 13px;
        background: #0d2137;
        color: #e8cc76;
        font-family: 'DM Sans', sans-serif;
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 0.3px;
        cursor: pointer;
        box-shadow: 0 8px 22px rgba(13,33,55,0.22);
        transition: transform 0.12s, opacity 0.12s;
    }

        .bind-confirm:active { transform: scale(0.99); opacity: 0.92; }

    .bind-dismiss {
        width: 100%;
        margin-top: 10px;
        padding: 11px;
        border: none;
        background: transparent;
        color: #6a8aa0;
        font-family: 'DM Sans', sans-serif;
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
    }

        .bind-dismiss:active { opacity: 0.7; }

    .bind-hint {
        font-size: 11px;
        color: #8faabf;
        margin-top: 12px;
        line-height: 1.45;
    }
</style>


<div class="login-shell">

    @* Branded first-launch confirmation: shown when an invite token resolved to an LGU. The collector
       confirms their municipality before anything else — the professional, intentional bind moment. *@
    @if (_pendingBindInfo is not null)
    {
        <div class="bind-overlay">
            <div class="bind-modal">
                <div class="bind-seal">
                    @if (!string.IsNullOrWhiteSpace(_pendingBindInfo.SealPath))
                    {
                        <img src="@_pendingBindInfo.SealPath" alt="@_pendingBindInfo.Name seal" />
                    }
                    else
                    {
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18" /><path d="M5 21V7l8-4v18" /><path d="M19 21V11l-6-4" /><path d="M9 9v.01M9 12v.01M9 15v.01M9 18v.01" /></svg>
                    }
                </div>
                <div class="bind-eyebrow">Set up StallTrack for</div>
                <div class="bind-name">@_pendingBindInfo.Name</div>
                @if (!string.IsNullOrWhiteSpace(_pendingBindInfo.OfficeName))
                {
                    <div class="bind-office">@_pendingBindInfo.OfficeName</div>
                }
                @if (!string.IsNullOrWhiteSpace(_pendingBindInfo.Province))
                {
                    <div class="bind-prov">@_pendingBindInfo.Province</div>
                }
                <div class="bind-note">
                    This device will be set up to collect for this municipality. Confirm to continue to sign in.
                </div>
                <button type="button" class="bind-confirm" @onclick="ConfirmMunicipality">Confirm &amp; Continue</button>
                <button type="button" class="bind-dismiss" @onclick="DismissBind">Not now</button>
                <div class="bind-hint">Not your municipality? Ask your office for the correct invite link.</div>
            </div>
        </div>
    }

    <!-- Top: STALLTRACK platform brand -->
    <div class="login-top">
        <div class="login-seal">
            <img src="images/stalltrack-seal.png" alt="StallTrack Seal" />
        </div>
        <div class="login-gov">Republic of the Philippines</div>
        <div class="login-org">StallTrack</div>
        <div class="login-tagline">Unified LGU Market Management Platform</div>
        <div class="login-dot"></div>
        <div class="login-access">Collector Mobile Access</div>
    </div>

    <!-- Bottom: Login Form Card -->
    <div class="login-card">

        <div class="login-card-title">Collector Sign In</div>
        <div class="login-card-sub">Enter your credentials to access the system.</div>

        <!-- Error Banner -->
        @if (!string.IsNullOrEmpty(ErrorMessage))
        {
            <div class="login-error">
                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
                @ErrorMessage
            </div>
        }

        <!-- Municipality is determined by the app's bind link (or the default tenant) — no picker. -->

        <!-- Username -->
        <div class="login-field">
            <div class="login-label">Username</div>
            <div class="login-input-wrap">
                <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" /><circle cx="12" cy="7" r="4" /></svg>
                <input type="text"
                       placeholder="Your username"
                       @bind="Username"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown" />
            </div>
        </div>

        <!-- Password -->
        <div class="login-field">
            <div class="login-label">Password</div>
            <div class="login-input-wrap">
                <svg viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0110 0v4" /></svg>
                <input type="@(ShowPassword ? "text" : "password")"
                       placeholder="Enter your password"
                       @bind="Password"
                       @bind:event="oninput"
                       @onkeydown="HandleKeyDown" />
                <div class="pw-toggle" @onclick="() => ShowPassword = !ShowPassword">
                    @if (ShowPassword)
                    {
                        <!-- eye-off icon -->
                        <svg viewBox="0 0 24 24"><path d="M17.94 17.94A10.07 10.07 0 0112 20c-7 0-11-8-11-8a18.45 18.45 0 015.06-5.94M9.9 4.24A9.12 9.12 0 0112 4c7 0 11 8 11 8a18.5 18.5 0 01-2.16 3.19m-6.72-1.07a3 3 0 11-4.24-4.24" /><line x1="1" y1="1" x2="23" y2="23" /></svg>
                    }
                    else
                    {
                        <!-- eye icon -->
                        <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" /><circle cx="12" cy="12" r="3" /></svg>
                    }
                </div>
            </div>
        </div>

        <!-- Login Button -->
        <button type="button" class="login-btn @(IsLoading ? "is-loading" : "")" disabled="@IsLoading" @onclick="HandleLogin">
            @if (IsLoading)
            {
                <span class="btn-spinner"></span>
                <span>Signing in…</span>
            }
            else
            {
                <span>Sign In</span>
            }
        </button>

        <!-- Notice -->
        <div class="login-notice">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" y1="8" x2="12" y2="12" /><line x1="12" y1="16" x2="12.01" y2="16" /></svg>
            <div class="login-notice-text">
                <strong>No registration available here.</strong> Accounts are created exclusively by the administrator through the web portal. Contact your office administrator if you need access.
            </div>
        </div>

        <!-- Footer -->
        <div class="login-footer">
            StallTrack · For authorized personnel only
        </div>

    </div>
    <!-- end .login-card -->

</div>
<!-- end .login-shell -->
@code {

    string Username = string.Empty;
    string Password = string.Empty;
    bool ShowPassword = false;
    bool IsLoading = false;
    string ErrorMessage = string.Empty;

    // Municipality is resolved automatically — from the app's bind link, or (unbound) the single live LGU
    // or the default tenant. No picker: accounts are provisioned + bound per-LGU from the web portal.
    string? SelectedMunicipalityCode;

    // A pending invite token resolved to this LGU's branding — drives the "confirm your municipality" setup
    // screen. Non-null = show the confirmation; binding is only persisted when the collector taps Confirm.
    MobileBindInfoDto? _pendingBindInfo;
    bool _bindResolveStarted;

    protected override async Task OnInitializedAsync()
    {
        MobileBindBridge.PendingTokenChanged += OnBindTokenChanged;

        try
        {
            if (await Session.RestoreSessionAsync())
            {
                Navigation.NavigateTo("/menu", forceLoad: false);
                return;
            }
        }
        catch (HttpRequestException)
        {
            // Stay on the login page when the server is unreachable.
        }

        ApplyBinding();

        // Bound app → the bound code is sent silently on login. Unbound → scope to the single/default LGU
        // (Cantilan) so the golden path is preserved; a pending invite token (below) shows a confirmation.
        if (!Session.IsBound)
        {
            await LoadMunicipalitiesAsync();
        }
    }

    // Bind resolution runs AFTER first render — the window must be focused (Android blocks clipboard reads
    // otherwise), and the deep-link token is read here too. If a pending invite token resolves to an LGU, we
    // show a BRANDED confirmation (instead of binding silently). Runs once, only while unbound.
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || Session.IsBound || _bindResolveStarted)
            return;
        _bindResolveStarted = true;

        await Task.Delay(250); // let the window settle into focus before touching the clipboard
        var info = await Session.ResolvePendingBindInfoAsync();
        if (info is not null)
        {
            _pendingBindInfo = info;
            await InvokeAsync(StateHasChanged);
        }
    }

    // A bind link opened while this page is already foregrounded (Android OnNewIntent) arrives here.
    private void OnBindTokenChanged() => _ = InvokeAsync(async () =>
    {
        if (Session.IsBound)
            return;
        var info = await Session.ResolvePendingBindInfoAsync();
        if (info is not null)
        {
            _pendingBindInfo = info;
            StateHasChanged();
        }
    });

    // The collector confirmed the municipality on the branded setup screen → persist the binding and pin
    // the login scope to it. One-time per install; every later launch skips this and goes straight to login.
    private void ConfirmMunicipality()
    {
        if (_pendingBindInfo is null)
            return;
        Session.ConfirmBind(_pendingBindInfo);
        ApplyBinding();
        _pendingBindInfo = null;
    }

    // Dismiss the setup screen without binding (e.g. a wrong invite link was opened) — returns to sign-in.
    // Nothing is persisted, so re-opening the correct invite link shows the confirmation again.
    private void DismissBind() => _pendingBindInfo = null;

    // Reflect the current LGU binding into the login form: pin the code (no picker to hide).
    private void ApplyBinding()
    {
        var bound = Session.BoundMunicipalityCode;
        if (!string.IsNullOrWhiteSpace(bound))
        {
            SelectedMunicipalityCode = bound;
        }
    }

    private async Task LoadMunicipalitiesAsync()
    {
        // App is unbound (no bind link opened) — there is no picker. Scope login to the single live LGU, or
        // to the default tenant (Cantilan) when several are live, so the golden Cantilan path is preserved.
        // A genuinely unknown multi-tenant case falls back to the global lookup (null code).
        try
        {
            var muni = await MunicipalitiesApi.GetMunicipalitiesAsync();
            if (muni.IsSuccess && muni.Value is not null)
            {
                var active = muni.Value.Where(m => m.IsActive).OrderBy(m => m.Name).ToList();
                if (active.Count == 1)
                {
                    SelectedMunicipalityCode = active[0].Code;
                }
                else if (active.Count > 1)
                {
                    SelectedMunicipalityCode = active.FirstOrDefault(m => m.IsDefault)?.Code;
                }
            }
        }
        catch
        {
            // Offline / unreachable — login stays global (works for the single-tenant case).
        }
    }

    public void Dispose() => MobileBindBridge.PendingTokenChanged -= OnBindTokenChanged;

    async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await HandleLogin();
        }
    }

    async Task HandleLogin()
    {
        if (IsLoading)
        {
            return;
        }

        ErrorMessage = string.Empty;

        if (string.IsNullOrWhiteSpace(Username))
        {
            ErrorMessage = "Please enter your username.";
            return;
        }

        if (string.IsNullOrWhiteSpace(Password))
        {
            ErrorMessage = "Please enter your password.";
            return;
        }

        IsLoading = true;

        try
        {
            var error = await Session.LoginAsync(Username, Password, SelectedMunicipalityCode);

            if (string.IsNullOrWhiteSpace(error))
            {
                Navigation.NavigateTo("/menu", forceLoad: false);
                return;
            }

            ErrorMessage = error;
        }
        catch (HttpRequestException ex)
        {
#if DEBUG
            ErrorMessage = $"Unable to connect to the EEMO server. {ex.Message}";
#else
            ErrorMessage = "Unable to connect to the EEMO server. Please check the connection and try again.";
#endif
        }
        catch (TaskCanceledException)
        {
            ErrorMessage = "The EEMO server did not respond in time. Please try again.";
        }
        finally
        {
            IsLoading = false;
        }
    }
}
