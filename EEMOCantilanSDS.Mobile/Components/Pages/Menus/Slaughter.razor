@page "/slaughter"
@using System.Globalization
@using global::EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Application.Dtos.Slaughterhouse
@using global::EEMOCantilanSDS.Application.Requests.Mobile
@using global::EEMOCantilanSDS.Domain.Enums
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject IMobileApiClient MobileApi

<div class="page-shell">
    <div class="header">
        <div class="header-eyebrow">Slaughterhouse</div>
        <div class="header-row">
            <button class="back-btn" type="button" @onclick="GoBack" aria-label="Back to menu">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
            </button>
            <div class="header-title-block">
                <div class="header-title">Slaughterhouse</div>
                <div class="header-sub">SLH - Per-Head Slaughter Fees</div>
            </div>
        </div>
    </div>

    <div class="date-strip">
        <div class="date-strip-left">Collector: <span>@Session.CollectorName</span></div>
        <button class="collection-month-pill" type="button">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @DayLabel
        </button>
    </div>

    <div class="content">
        @if (IsLoading)
        {
            <div class="state-card">
                <div class="state-title">Loading slaughter collections</div>
                <div class="state-text">Please wait while today's transactions are loaded.</div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="state-card error">
                <div class="state-title">Unable to load collections</div>
                <div class="state-text">@ErrorMessage</div>
                <button class="primary-action" type="button" @onclick="LoadCollectionAsync">Try Again</button>
            </div>
        }
        else if (Collection is not null)
        {
            <div class="summary-strip">
                <div class="summary-item">
                    <div class="summary-value">@FormatCurrency(Collection.TotalCollected)</div>
                    <div class="summary-key">Today</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.TotalHeads</div>
                    <div class="summary-key">Heads</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.TransactionCount</div>
                    <div class="summary-key">Receipts</div>
                </div>
            </div>

            <button class="record-cta" type="button" @onclick="OpenSheet">
                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                Record Slaughter
            </button>

            <div class="section-label">Today's Transactions</div>

            @if (!Collection.Transactions.Any())
            {
                <div class="state-card">
                    <div class="state-title">No transactions yet</div>
                    <div class="state-text">Recorded slaughter fees for @DayLabel will appear here.</div>
                </div>
            }
            else
            {
                @foreach (var tx in Collection.Transactions)
                {
                    <div class="stall-row paid">
                        <div class="stall-info">
                            <div class="stall-main-row">
                                <div class="stall-name">@tx.OwnerName</div>
                                <span class="stall-status-pill pill-paid">@AnimalLabel(tx)</span>
                            </div>
                            <div class="stall-meta">
                                <span>@tx.NumberOfHeads head@(tx.NumberOfHeads == 1 ? "" : "s")</span>
                                <span>@FormatCurrency(tx.RatePerHead)/head</span>
                                @if (!string.IsNullOrWhiteSpace(tx.ORNumber))
                                {
                                    <span>OR @tx.ORNumber</span>
                                }
                            </div>
                        </div>
                        <div class="stall-amount-col">
                            <div class="stall-amount">@FormatCurrency(tx.TotalAmount)</div>
                        </div>
                    </div>
                }
            }
        }
    </div>

    <BottomNav ActiveTab="menu" />
</div>

@if (ShowSheet)
{
    <div class="sheet-overlay" @onclick="CloseSheet">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Record Slaughter</div>
            <div class="sheet-sub">Log a per-head slaughter transaction for @DayLabel.</div>

            <div class="form-label">Animal type</div>
            <div class="animal-grid">
                @foreach (var opt in AnimalOptions)
                {
                    <button class="animal-chip @(SelectedAnimal == opt.Type ? "active" : "")" type="button" @onclick="() => SelectAnimal(opt.Type)">
                        <span class="animal-chip-name">@opt.Label</span>
                        <span class="animal-chip-rate">@(opt.Type == AnimalType.Other ? "custom" : FormatCurrency(opt.Rate))</span>
                    </button>
                }
            </div>

            @if (SelectedAnimal == AnimalType.Other)
            {
                <div class="or-number-wrap">
                    <div class="form-label">Animal name</div>
                    <input class="form-input" type="text" maxlength="100" placeholder="e.g. Goat" @bind="CustomAnimalType" @bind:event="oninput" />
                    <div class="form-label" style="margin-top:12px;">Rate per head</div>
                    <div class="fish-input-row">
                        <span>₱</span>
                        <input class="form-input" type="number" min="0" step="0.01" placeholder="0" @bind="CustomRate" @bind:event="oninput" />
                    </div>
                </div>
            }

            <div class="or-number-wrap">
                <div class="form-label">Owner name</div>
                <input class="form-input" type="text" maxlength="100" placeholder="Owner of the animal" @bind="OwnerName" @bind:event="oninput" />

                <div class="form-label" style="margin-top:12px;">Number of heads</div>
                <input class="form-input" type="number" min="1" step="1" placeholder="1" @bind="NumberOfHeads" @bind:event="oninput" />

                <div class="form-label" style="margin-top:12px;">Official receipt no.</div>
                <input class="form-input mono-input" type="text" inputmode="numeric" maxlength="50" placeholder="000001" @bind="ORNumber" @bind:event="oninput" />
            </div>

            <div class="fee-preview">
                <span>Total fee</span>
                <strong>@FormatCurrency(PreviewTotal)</strong>
            </div>

            @if (!string.IsNullOrWhiteSpace(SheetError))
            {
                <div class="form-error">@SheetError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseSheet" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Confirm")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private MobileSlaughterCollectionDto? Collection;
    private bool IsLoading = true;
    private bool IsSaving;
    private string? ErrorMessage;
    private string? SheetError;
    private DateOnly SelectedDate;
    private bool ShowSheet;

    private AnimalType SelectedAnimal = AnimalType.Hog;
    private string OwnerName = string.Empty;
    private int NumberOfHeads = 1;
    private string ORNumber = string.Empty;
    private string CustomAnimalType = string.Empty;
    private decimal? CustomRate;

    private record AnimalOption(AnimalType Type, string Label, decimal Rate);

    private AnimalOption[] AnimalOptions =>
    [
        new(AnimalType.Hog, "Hog", Collection?.HogRatePerHead ?? 250m),
        new(AnimalType.Carabao, "Carabao", Collection?.LargeAnimalRatePerHead ?? 365m),
        new(AnimalType.Cow, "Cow", Collection?.LargeAnimalRatePerHead ?? 365m),
        new(AnimalType.Other, "Other", 0m)
    ];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
        }
        catch (HttpRequestException)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        var hasAccess = Session.Menu?.Facilities.Any(f => f.Code == FacilityCode.SLH && f.IsAvailable) == true;
        if (!hasAccess)
        {
            Navigation.NavigateTo("/menu", forceLoad: false);
            return;
        }

        SelectedDate = Session.Menu?.Today ?? DateOnly.FromDateTime(DateTime.Now);
        await LoadCollectionAsync();
    }

    private async Task LoadCollectionAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        var result = await MobileApi.GetSlaughterCollectionAsync(SelectedDate.Year, SelectedDate.Month, SelectedDate.Day);
        if (!result.IsSuccess || result.Value is null)
        {
            ErrorMessage = result.Error ?? "Unable to load slaughter transactions.";
            IsLoading = false;
            return;
        }

        Collection = result.Value;
        IsLoading = false;
    }

    private string DayLabel => SelectedDate.ToString("MMM dd, yyyy", CultureInfo.InvariantCulture);

    private decimal SelectedRate => SelectedAnimal switch
    {
        AnimalType.Hog => Collection?.HogRatePerHead ?? 250m,
        AnimalType.Carabao or AnimalType.Cow => Collection?.LargeAnimalRatePerHead ?? 365m,
        AnimalType.Other => CustomRate ?? 0m,
        _ => 0m
    };

    private decimal PreviewTotal => SelectedRate * Math.Max(0, NumberOfHeads);

    private void GoBack() => Navigation.NavigateTo("/menu", forceLoad: false);

    private void OpenSheet()
    {
        SelectedAnimal = AnimalType.Hog;
        OwnerName = string.Empty;
        NumberOfHeads = 1;
        ORNumber = string.Empty;
        CustomAnimalType = string.Empty;
        CustomRate = null;
        SheetError = null;
        ShowSheet = true;
    }

    private void SelectAnimal(AnimalType type)
    {
        SelectedAnimal = type;
        SheetError = null;
    }

    private async Task ConfirmAsync()
    {
        if (string.IsNullOrWhiteSpace(OwnerName))
        {
            SheetError = "Owner name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(ORNumber))
        {
            SheetError = "OR number is required.";
            return;
        }
        if (NumberOfHeads < 1)
        {
            SheetError = "Number of heads must be at least 1.";
            return;
        }
        if (SelectedAnimal == AnimalType.Other && (string.IsNullOrWhiteSpace(CustomAnimalType) || CustomRate is null or <= 0))
        {
            SheetError = "Enter the custom animal name and a rate greater than 0.";
            return;
        }

        IsSaving = true;
        SheetError = null;

        var request = new RecordMobileSlaughterRequest(
            OwnerName.Trim(),
            ORNumber.Trim(),
            SelectedAnimal,
            NumberOfHeads,
            SelectedAnimal == AnimalType.Other ? CustomAnimalType.Trim() : null,
            SelectedAnimal == AnimalType.Other ? CustomRate : null);

        var result = await MobileApi.RecordSlaughterAsync(request);
        if (!result.IsSuccess)
        {
            SheetError = result.Error ?? "Unable to save the slaughter transaction.";
            IsSaving = false;
            return;
        }

        CloseSheet();
        try
        {
            await LoadCollectionAsync();
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void CloseSheet()
    {
        ShowSheet = false;
        SheetError = null;
    }

    private static string FormatCurrency(decimal value) => $"₱{value:N0}";

    private static string AnimalLabel(SlaughterTransactionDto tx) =>
        tx.AnimalType == AnimalType.Other && !string.IsNullOrWhiteSpace(tx.CustomAnimalType)
            ? tx.CustomAnimalType!
            : tx.AnimalType.ToString();
}
