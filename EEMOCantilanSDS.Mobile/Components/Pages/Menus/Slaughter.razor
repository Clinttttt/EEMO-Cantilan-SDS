@page "/slaughter"
@using System.Globalization
@using global::EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Application.Dtos.Slaughterhouse
@using global::EEMOCantilanSDS.Application.Requests.Mobile
@using global::EEMOCantilanSDS.Domain.Enums
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject IMobileApiClient MobileApi

<div class="page-shell">
    <div class="header">
        <div class="header-eyebrow">Slaughterhouse</div>
        <div class="header-row">
            <button class="back-btn" type="button" @onclick="GoBack" aria-label="Back to menu">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
            </button>
            <div class="header-title-block">
                <div class="header-title">Slaughterhouse</div>
                <div class="header-sub">SLH - Per-Head Slaughter Fees</div>
            </div>
        </div>
    </div>

    <div class="date-strip">
        <div class="date-strip-left">Collector: <span>@Session.CollectorName</span></div>
        <button class="collection-month-pill" type="button">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @DayLabel
        </button>
    </div>

    <div class="content slh-content">
        @if (IsLoading)
        {
            <div class="state-card">
                <div class="state-title">Loading slaughter collections</div>
                <div class="state-text">Please wait while today's transactions are loaded.</div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="state-card error">
                <div class="state-title">Unable to load collections</div>
                <div class="state-text">@ErrorMessage</div>
                <button class="primary-action" type="button" @onclick="LoadCollectionAsync">Try Again</button>
            </div>
        }
        else if (Collection is not null)
        {
            <div class="summary-strip">
                <div class="summary-item">
                    <div class="summary-value">@FormatCurrency(Collection.TotalCollected)</div>
                    <div class="summary-key">Today</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.TotalHeads</div>
                    <div class="summary-key">Heads</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.TransactionCount</div>
                    <div class="summary-key">Receipts</div>
                </div>
            </div>

            <button class="record-cta" type="button" @onclick="OpenSheet">
                <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                Record Slaughter
            </button>

            <div class="section-label">Today's Transactions</div>

            @if (!Collection.Transactions.Any())
            {
                <div class="state-card">
                    <div class="state-title">No transactions yet</div>
                    <div class="state-text">Recorded slaughter fees for @DayLabel will appear here.</div>
                </div>
            }
            else
            {
                @foreach (var r in GroupedReceipts)
                {
                    <button class="tx-card" type="button" @onclick="() => OpenReceipt(r)">
                        <div class="tx-left-bar"></div>
                        <div class="tx-body">
                            <div class="tx-row-main">
                                <div class="tx-col-info">
                                    <span class="tx-owner">@r.Owner</span>
                                    <span class="tx-sub">
                                        <span class="tx-tag">@LineLabel(r.Lines.First())</span>
                                        @if (r.Lines.Count > 1)
                                        {
                                            <span class="tx-tag">+@(r.Lines.Count - 1) more</span>
                                        }
                                        <span class="tx-or">@r.TotalHeads head@(r.TotalHeads == 1 ? "" : "s")</span>
                                        @if (!string.IsNullOrWhiteSpace(r.ORNumber))
                                        {
                                            <span class="tx-or">OR @r.ORNumber</span>
                                        }
                                    </span>
                                </div>
                                <div class="tx-col-right">
                                    <span class="tx-amount">@FormatCurrency(r.Total)</span>
                                </div>
                            </div>
                        </div>
                    </button>
                }
            }
        }
    </div>

    <BottomNav ActiveTab="menu" />
</div>

@if (ShowSheet)
{
    <div class="sheet-overlay" @onclick="CloseSheet">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Record Slaughter</div>
            <div class="sheet-sub">Log a per-head slaughter transaction for @DayLabel.</div>

            <div class="or-number-wrap">
                <div class="form-label">Owner name</div>
                @PickerField(OwnerName, "Select or type an owner", "Select Owner", KnownOwners, v => OwnerName = v, SuggestionType.SlhOwner)

                <div class="form-label" style="margin-top:12px;">Official receipt no.</div>
                <input class="form-input mono-input" type="text" inputmode="numeric" maxlength="50" placeholder="000001" @bind="ORNumber" @bind:event="oninput" />
            </div>

            <div class="form-label">Animal types · select one or more</div>
            <div class="animal-grid">
                @foreach (var opt in FixedAnimals)
                {
                    <button class="animal-chip @(opt.Heads() > 0 ? "active" : "")" type="button" @onclick="opt.Toggle">
                        <span class="animal-chip-name">@opt.Label</span>
                        <span class="animal-chip-rate">@FormatCurrency(opt.Rate)</span>
                    </button>
                }
                <button class="animal-chip @(UseCustomAnimal ? "active" : "")" type="button" @onclick="ToggleCustom">
                    <span class="animal-chip-name">Other</span>
                    <span class="animal-chip-rate">custom</span>
                </button>
            </div>

            @if (FixedAnimals.Any(a => a.Heads() > 0))
            {
                <div class="line-input-group">
                    @foreach (var opt in FixedAnimals.Where(a => a.Heads() > 0))
                    {
                        <div class="line-input">
                            <span class="line-input-label">@opt.Label</span>
                            <div class="line-input-right">
                                <span class="line-input-rate">@FormatCurrency(opt.Rate)/head</span>
                                <input class="form-input heads-input" type="number" min="1" step="1" value="@opt.Heads()"
                                       @onchange="e => opt.SetHeads(e.Value?.ToString())" />
                            </div>
                        </div>
                    }
                </div>
            }

            @if (UseCustomAnimal)
            {
                <div class="or-number-wrap">
                    <div class="form-label">Animal name</div>
                    <input class="form-input" type="text" maxlength="100" placeholder="e.g. Goat" @bind="CustomAnimalType" @bind:event="oninput" />
                    <div class="form-label" style="margin-top:12px;">Rate per head</div>
                    <div class="fish-input-row">
                        <span>₱</span>
                        <input class="form-input" type="number" min="0" step="0.01" placeholder="0" @bind="CustomRate" @bind:event="oninput" />
                    </div>
                    <div class="form-label" style="margin-top:12px;">Number of heads</div>
                    <input class="form-input" type="number" min="1" step="1" @bind="CustomHeads" @bind:event="oninput" />
                </div>
            }

            <div class="fee-preview">
                <span>Total fee · @TotalHeads head@(TotalHeads == 1 ? "" : "s")</span>
                <strong>@FormatCurrency(PreviewTotal)</strong>
            </div>

            @if (!string.IsNullOrWhiteSpace(SheetError))
            {
                <div class="form-error">@SheetError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseSheet" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Confirm")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowReceipt && SelectedReceipt is not null)
{
    <div class="sheet-overlay" @onclick="CloseReceipt">
        <div class="sheet receipt-sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>

            <div class="receipt">
                <!-- Letterhead -->
                <div class="receipt-head">
                    <img src="images/LGU_CANTILAN_LOGO.jpg" class="receipt-seal" alt="EEMO seal" />
                    <div class="receipt-gov">Republic of the Philippines</div>
                    <div class="receipt-org">Economic Enterprise &amp; Management Office</div>
                    <div class="receipt-muni">Municipality of Cantilan, Surigao del Sur</div>
                    <div class="receipt-doc">Slaughterhouse</div>
                </div>

                <div class="receipt-divider"></div>

                <!-- Meta -->
                <div class="receipt-meta">
                    <div class="receipt-meta-row">
                        <span>OR No.</span>
                        <strong>@(string.IsNullOrWhiteSpace(SelectedReceipt.ORNumber) ? "—" : SelectedReceipt.ORNumber)</strong>
                    </div>
                    <div class="receipt-meta-row">
                        <span>Date</span>
                        <strong>@SelectedReceipt.Date.ToString("MMMM dd, yyyy", CultureInfo.InvariantCulture)</strong>
                    </div>
                    <div class="receipt-meta-row">
                        <span>Owner / Client</span>
                        <strong>@SelectedReceipt.Owner</strong>
                    </div>
                </div>

                <div class="receipt-divider"></div>

                <!-- Line items -->
                <div class="receipt-items">
                    <div class="receipt-item receipt-item-head">
                        <span class="ri-name">Animal</span>
                        <span class="ri-qty">Heads</span>
                        <span class="ri-rate">Rate</span>
                        <span class="ri-amt">Amount</span>
                    </div>
                    @foreach (var line in SelectedReceipt.Lines)
                    {
                        <div class="receipt-item">
                            <span class="ri-name">@LineLabel(line)</span>
                            <span class="ri-qty">@line.NumberOfHeads</span>
                            <span class="ri-rate">@FormatCurrency(line.RatePerHead)</span>
                            <span class="ri-amt">@FormatCurrency(line.TotalAmount)</span>
                        </div>
                    }
                </div>

                <div class="receipt-divider"></div>

                <!-- Totals -->
                <div class="receipt-total-row">
                    <span>Total heads</span>
                    <span>@SelectedReceipt.TotalHeads</span>
                </div>
                <div class="receipt-total-row receipt-grand">
                    <span>Total amount</span>
                    <span>@FormatCurrency(SelectedReceipt.Total)</span>
                </div>

                <div class="receipt-divider dashed"></div>

                <!-- Footer -->
                <div class="receipt-foot">
                    <div class="receipt-foot-row">
                        <span>Collected by</span>
                        <strong>@Session.CollectorName</strong>
                    </div>
                    <div class="receipt-note">
                        This acknowledges receipt of the per-head slaughter fees stated above.
                        Keep for your records.
                    </div>
                </div>
            </div>

            <div class="receipt-close-row">
                <button class="btn-receipt-edit" type="button" @onclick="OpenEditFromReceipt">Edit</button>
                <button class="btn-receipt-close" type="button" @onclick="CloseReceipt">Close</button>
            </div>
        </div>
    </div>
}

@if (ShowEdit && EditReceipt is not null)
{
    <div class="sheet-overlay" @onclick="CloseEdit">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Edit Transaction</div>
            <div class="sheet-sub">@EditReceipt.Owner · OR @(EditReceipt.ORNumber ?? "—")</div>

            <div class="form-label">Animal types</div>
            <div class="animal-grid">
                @foreach (var opt in EditFixedAnimals)
                {
                    <button class="animal-chip @(opt.Heads() > 0 ? "active" : "")" type="button" @onclick="opt.Toggle">
                        <span class="animal-chip-name">@opt.Label</span>
                        <span class="animal-chip-rate">@FormatCurrency(opt.Rate)</span>
                    </button>
                }
                <button class="animal-chip @(EditUseCustom ? "active" : "")" type="button" @onclick="ToggleEditCustom">
                    <span class="animal-chip-name">Other</span>
                    <span class="animal-chip-rate">custom</span>
                </button>
            </div>

            @if (EditFixedAnimals.Any(a => a.Heads() > 0))
            {
                <div class="line-input-group">
                    @foreach (var opt in EditFixedAnimals.Where(a => a.Heads() > 0))
                    {
                        <div class="line-input">
                            <span class="line-input-label">@opt.Label</span>
                            <div class="line-input-right">
                                <span class="line-input-rate">@FormatCurrency(opt.Rate)/head</span>
                                <input class="form-input heads-input" type="number" min="1" step="1" value="@opt.Heads()"
                                       @onchange="e => opt.SetHeads(e.Value?.ToString())" />
                            </div>
                        </div>
                    }
                </div>
            }

            @if (EditUseCustom)
            {
                <div class="or-number-wrap">
                    <div class="form-label">Animal name</div>
                    <input class="form-input" type="text" maxlength="100" @bind="EditCustomType" @bind:event="oninput" />
                    <div class="form-label" style="margin-top:12px;">Rate per head</div>
                    <div class="fish-input-row">
                        <span>₱</span>
                        <input class="form-input" type="number" min="0" step="0.01" @bind="EditCustomRate" @bind:event="oninput" />
                    </div>
                    <div class="form-label" style="margin-top:12px;">Number of heads</div>
                    <input class="form-input" type="number" min="1" step="1" @bind="EditCustomHeads" @bind:event="oninput" />
                </div>
            }

            @if (!string.IsNullOrWhiteSpace(EditError))
            {
                <div class="form-error">@EditError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseEdit" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmEditAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Save Changes")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowPicker)
{
    <div class="sheet-overlay picker-overlay" @onclick="ClosePicker">
        <div class="sheet picker-sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">@PickerTitle</div>

            <div class="search-wrap" style="margin-bottom:12px;">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search or type a new value" @bind="PickerSearch" @bind:event="oninput" />
            </div>

            <div class="picker-list">
                @if (!string.IsNullOrWhiteSpace(PickerSearch)
                     && !PickerOptions.Any(o => string.Equals(o, PickerSearch.Trim(), StringComparison.OrdinalIgnoreCase)))
                {
                    <button class="picker-item picker-item-new" type="button" @onclick="() => PickOption(PickerSearch.Trim())">
                        <svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19" /><line x1="5" y1="12" x2="19" y2="12" /></svg>
                        Use "<strong>@PickerSearch.Trim()</strong>"
                    </button>
                }

                @foreach (var opt in PickerFiltered)
                {
                    <div class="picker-item-row">
                        <button class="picker-item" type="button" @onclick="() => PickOption(opt)">@opt</button>
                        @if (PickerHideType is not null)
                        {
                            <button class="picker-item-remove" type="button" title="Remove from suggestions"
                                    @onclick="() => HidePickerOption(opt)">
                                <svg viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" /></svg>
                            </button>
                        }
                    </div>
                }

                @if (!PickerFiltered.Any() && string.IsNullOrWhiteSpace(PickerSearch))
                {
                    <div class="picker-empty">No options yet — type to add one.</div>
                }
            </div>

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="ClosePicker">Cancel</button>
            </div>
        </div>
    </div>
}

@code {
    private MobileSlaughterCollectionDto? Collection;
    private bool IsLoading = true;
    private bool IsSaving;
    private string? ErrorMessage;
    private string? SheetError;
    private DateOnly SelectedDate;
    private bool ShowSheet;

    // Receipt view (grouped transaction)
    private bool ShowReceipt;
    private SlaughterReceipt? SelectedReceipt;

    // Edit state
    private bool ShowEdit;
    private SlaughterReceipt? EditReceipt;
    private int EditHogHeads;
    private int EditCarabaoHeads;
    private int EditCowHeads;
    private bool EditUseCustom;
    private string EditCustomType = string.Empty;
    private int EditCustomHeads = 1;
    private decimal? EditCustomRate;
    private string? EditError;

    // One transaction = one owner + one OR + one or more animal lines (mirrors the web admin).
    private string OwnerName = string.Empty;
    private string ORNumber = string.Empty;
    private int HogHeads;
    private int CarabaoHeads;
    private int CowHeads;
    private bool UseCustomAnimal;
    private string CustomAnimalType = string.Empty;
    private int CustomHeads = 1;
    private decimal? CustomRate;

    private decimal HogRate => Collection?.HogRatePerHead ?? 250m;
    private decimal LargeRate => Collection?.LargeAnimalRatePerHead ?? 365m;

    private IReadOnlyList<string> KnownOwners => Collection?.KnownOwners ?? Array.Empty<string>();

    // ── Searchable picker (full-screen overlay) — same pattern as TRM ──
    private bool ShowPicker;
    private string PickerTitle = string.Empty;
    private string PickerSearch = string.Empty;
    private IReadOnlyList<string> PickerOptions = Array.Empty<string>();
    private Action<string>? PickerSet;
    private SuggestionType? PickerHideType;

    private IEnumerable<string> PickerFiltered =>
        PickerOptions.Where(o => string.IsNullOrWhiteSpace(PickerSearch)
            || o.Contains(PickerSearch, StringComparison.OrdinalIgnoreCase));

    private RenderFragment PickerField(string value, string placeholder, string title,
        IReadOnlyList<string> options, Action<string> set, SuggestionType? hideType = null) => __builder =>
    {
        __builder.OpenElement(0, "button");
        __builder.AddAttribute(1, "type", "button");
        __builder.AddAttribute(2, "class", "picker-field");
        __builder.AddAttribute(3, "onclick", EventCallback.Factory.Create(this, () => OpenPicker(title, options, set, hideType)));

        __builder.OpenElement(4, "span");
        __builder.AddAttribute(5, "class", string.IsNullOrWhiteSpace(value) ? "picker-field-placeholder" : "picker-field-value");
        __builder.AddContent(6, string.IsNullOrWhiteSpace(value) ? placeholder : value);
        __builder.CloseElement();

        __builder.OpenElement(7, "svg");
        __builder.AddAttribute(8, "class", "picker-field-chev");
        __builder.AddAttribute(9, "viewBox", "0 0 24 24");
        __builder.AddMarkupContent(10, "<polyline points=\"6 9 12 15 18 9\" />");
        __builder.CloseElement();

        __builder.CloseElement(); // button
    };

    private void OpenPicker(string title, IReadOnlyList<string> options, Action<string> set, SuggestionType? hideType)
    {
        PickerTitle = title;
        PickerOptions = options;
        PickerSet = set;
        PickerHideType = hideType;
        PickerSearch = string.Empty;
        ShowPicker = true;
    }

    private void PickOption(string value)
    {
        PickerSet?.Invoke(value);
        ShowPicker = false;
        PickerSet = null;
    }

    private void ClosePicker()
    {
        ShowPicker = false;
        PickerSet = null;
    }

    private async Task HidePickerOption(string value)
    {
        if (PickerHideType is not { } type) return;
        var result = await MobileApi.HideSuggestionAsync(new HideMobileSuggestionRequest(type, value));
        if (result.IsSuccess)
        {
            PickerOptions = PickerOptions.Where(o => !string.Equals(o, value, StringComparison.OrdinalIgnoreCase)).ToList();
            await LoadCollectionAsync();
        }
    }

    // Lightweight adapter so the markup can iterate the fixed animals uniformly.
    private sealed record FixedAnimal(string Label, AnimalType Type, decimal Rate, Func<int> Heads, Action Toggle, Action<string?> SetHeads);

    private FixedAnimal[] FixedAnimals => new[]
    {
        new FixedAnimal("Hog", AnimalType.Hog, HogRate, () => HogHeads,
            () => { HogHeads = HogHeads > 0 ? 0 : 1; SheetError = null; },
            v => HogHeads = ParseHeads(v)),
        new FixedAnimal("Carabao", AnimalType.Carabao, LargeRate, () => CarabaoHeads,
            () => { CarabaoHeads = CarabaoHeads > 0 ? 0 : 1; SheetError = null; },
            v => CarabaoHeads = ParseHeads(v)),
        new FixedAnimal("Cow", AnimalType.Cow, LargeRate, () => CowHeads,
            () => { CowHeads = CowHeads > 0 ? 0 : 1; SheetError = null; },
            v => CowHeads = ParseHeads(v)),
    };

    private static int ParseHeads(string? raw) =>
        int.TryParse(raw, out var n) && n > 0 ? n : 1;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
        }
        catch (HttpRequestException)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        var hasAccess = Session.Menu?.Facilities.Any(f => f.Code == FacilityCode.SLH && f.IsAvailable) == true;
        if (!hasAccess)
        {
            Navigation.NavigateTo("/menu", forceLoad: false);
            return;
        }

        SelectedDate = Session.Menu?.Today ?? DateOnly.FromDateTime(DateTime.Now);
        await LoadCollectionAsync();
    }

    private async Task LoadCollectionAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        var result = await MobileApi.GetSlaughterCollectionAsync(SelectedDate.Year, SelectedDate.Month, SelectedDate.Day);
        if (!result.IsSuccess || result.Value is null)
        {
            ErrorMessage = result.Error ?? "Unable to load slaughter transactions.";
            IsLoading = false;
            return;
        }

        Collection = result.Value;
        IsLoading = false;
    }

    private string DayLabel => SelectedDate.ToString("MMM dd, yyyy", CultureInfo.InvariantCulture);

    // One card/receipt per owner + OR (groups the multi-animal lines recorded together).
    private sealed record SlaughterReceipt(
        string Owner, string? ORNumber, DateOnly Date, IReadOnlyList<SlaughterTransactionDto> Lines)
    {
        public int TotalHeads => Lines.Sum(l => l.NumberOfHeads);
        public decimal Total => Lines.Sum(l => l.TotalAmount);
    }

    private IEnumerable<SlaughterReceipt> GroupedReceipts =>
        (Collection?.Transactions ?? Array.Empty<SlaughterTransactionDto>())
        .GroupBy(t => new { t.OwnerName, OR = t.ORNumber ?? string.Empty })
        .Select(g => new SlaughterReceipt(g.Key.OwnerName, g.First().ORNumber, g.First().TransactionDate, g.ToList()));

    private void OpenReceipt(SlaughterReceipt receipt)
    {
        SelectedReceipt = receipt;
        ShowReceipt = true;
    }

    private void CloseReceipt()
    {
        ShowReceipt = false;
        SelectedReceipt = null;
    }

    private decimal EditHogRate => Collection?.HogRatePerHead ?? 250m;
    private decimal EditLargeRate => Collection?.LargeAnimalRatePerHead ?? 365m;

    private FixedAnimal[] EditFixedAnimals => new[]
    {
        new FixedAnimal("Hog", AnimalType.Hog, EditHogRate, () => EditHogHeads,
            () => { EditHogHeads = EditHogHeads > 0 ? 0 : 1; EditError = null; },
            v => EditHogHeads = ParseHeads(v)),
        new FixedAnimal("Carabao", AnimalType.Carabao, EditLargeRate, () => EditCarabaoHeads,
            () => { EditCarabaoHeads = EditCarabaoHeads > 0 ? 0 : 1; EditError = null; },
            v => EditCarabaoHeads = ParseHeads(v)),
        new FixedAnimal("Cow", AnimalType.Cow, EditLargeRate, () => EditCowHeads,
            () => { EditCowHeads = EditCowHeads > 0 ? 0 : 1; EditError = null; },
            v => EditCowHeads = ParseHeads(v)),
    };

    private void OpenEditFromReceipt()
    {
        if (SelectedReceipt is null) return;
        EditReceipt = SelectedReceipt;
        // Seed edit state from current receipt lines.
        EditHogHeads = EditReceipt.Lines.FirstOrDefault(l => l.AnimalType == AnimalType.Hog)?.NumberOfHeads ?? 0;
        EditCarabaoHeads = EditReceipt.Lines.FirstOrDefault(l => l.AnimalType == AnimalType.Carabao)?.NumberOfHeads ?? 0;
        EditCowHeads = EditReceipt.Lines.FirstOrDefault(l => l.AnimalType == AnimalType.Cow)?.NumberOfHeads ?? 0;
        var customLine = EditReceipt.Lines.FirstOrDefault(l => l.AnimalType == AnimalType.Other);
        EditUseCustom = customLine is not null;
        EditCustomType = customLine?.CustomAnimalType ?? string.Empty;
        EditCustomHeads = customLine?.NumberOfHeads ?? 1;
        EditCustomRate = customLine?.RatePerHead;
        EditError = null;
        ShowReceipt = false;
        ShowEdit = true;
    }

    private void ToggleEditCustom()
    {
        EditUseCustom = !EditUseCustom;
        if (!EditUseCustom) { EditCustomType = string.Empty; EditCustomHeads = 1; EditCustomRate = null; }
        EditError = null;
    }

    private void CloseEdit()
    {
        ShowEdit = false;
        EditReceipt = null;
        EditError = null;
    }

    private async Task ConfirmEditAsync()
    {
        if (EditReceipt is null) return;

        var animals = new List<MobileAnimalEntry>();
        if (EditHogHeads > 0) animals.Add(new MobileAnimalEntry(AnimalType.Hog, EditHogHeads));
        if (EditCarabaoHeads > 0) animals.Add(new MobileAnimalEntry(AnimalType.Carabao, EditCarabaoHeads));
        if (EditCowHeads > 0) animals.Add(new MobileAnimalEntry(AnimalType.Cow, EditCowHeads));
        if (EditUseCustom)
        {
            if (string.IsNullOrWhiteSpace(EditCustomType) || EditCustomRate is null or <= 0 || EditCustomHeads < 1)
            {
                EditError = "Enter the custom animal name, a rate greater than 0, and at least 1 head.";
                return;
            }
            animals.Add(new MobileAnimalEntry(AnimalType.Other, EditCustomHeads, EditCustomType.Trim(), EditCustomRate));
        }
        if (animals.Count == 0) { EditError = "Select at least one animal type."; return; }

        IsSaving = true;
        EditError = null;

        var request = new UpdateMobileSlaughterRequest(
            EditReceipt.Owner,
            EditReceipt.Date,
            EditReceipt.ORNumber ?? string.Empty,
            animals);

        var result = await MobileApi.UpdateSlaughterAsync(request);
        if (!result.IsSuccess)
        {
            EditError = result.Error ?? "Unable to save the changes.";
            IsSaving = false;
            return;
        }

        CloseEdit();
        try { await LoadCollectionAsync(); }
        finally { IsSaving = false; }
    }

    private static string LineLabel(SlaughterTransactionDto tx) =>
        tx.AnimalType == AnimalType.Other && !string.IsNullOrWhiteSpace(tx.CustomAnimalType)
            ? tx.CustomAnimalType!
            : tx.AnimalType.ToString();

    private int TotalHeads =>
        HogHeads + CarabaoHeads + CowHeads + (UseCustomAnimal ? Math.Max(0, CustomHeads) : 0);

    private decimal PreviewTotal =>
        (HogHeads * HogRate) + (CarabaoHeads * LargeRate) + (CowHeads * LargeRate)
        + (UseCustomAnimal ? Math.Max(0, CustomHeads) * (CustomRate ?? 0m) : 0m);

    private void GoBack() => Navigation.NavigateTo("/menu", forceLoad: false);

    private void OpenSheet()
    {
        OwnerName = string.Empty;
        ORNumber = string.Empty;
        HogHeads = 0;
        CarabaoHeads = 0;
        CowHeads = 0;
        UseCustomAnimal = false;
        CustomAnimalType = string.Empty;
        CustomHeads = 1;
        CustomRate = null;
        SheetError = null;
        ShowSheet = true;
    }

    private void ToggleCustom()
    {
        UseCustomAnimal = !UseCustomAnimal;
        if (UseCustomAnimal)
        {
            CustomHeads = 1;
        }
        else
        {
            CustomAnimalType = string.Empty;
            CustomHeads = 1;
            CustomRate = null;
        }
        SheetError = null;
    }

    private async Task ConfirmAsync()
    {
        if (string.IsNullOrWhiteSpace(OwnerName))
        {
            SheetError = "Owner name is required.";
            return;
        }
        if (string.IsNullOrWhiteSpace(ORNumber))
        {
            SheetError = "OR number is required.";
            return;
        }

        // Build the animal lines for this single owner + OR.
        var lines = new List<RecordMobileSlaughterRequest>();
        var owner = OwnerName.Trim();
        var or = ORNumber.Trim();

        if (HogHeads > 0)
            lines.Add(new RecordMobileSlaughterRequest(owner, or, AnimalType.Hog, HogHeads));
        if (CarabaoHeads > 0)
            lines.Add(new RecordMobileSlaughterRequest(owner, or, AnimalType.Carabao, CarabaoHeads));
        if (CowHeads > 0)
            lines.Add(new RecordMobileSlaughterRequest(owner, or, AnimalType.Cow, CowHeads));
        if (UseCustomAnimal)
        {
            if (string.IsNullOrWhiteSpace(CustomAnimalType) || CustomRate is null or <= 0 || CustomHeads < 1)
            {
                SheetError = "For 'Other', enter the animal name, a rate greater than 0, and at least 1 head.";
                return;
            }
            lines.Add(new RecordMobileSlaughterRequest(owner, or, AnimalType.Other, CustomHeads, CustomAnimalType.Trim(), CustomRate));
        }

        if (lines.Count == 0)
        {
            SheetError = "Select at least one animal type.";
            return;
        }

        IsSaving = true;
        SheetError = null;

        // Record each line under the same owner + OR (mirrors the web admin's per-animal rows).
        // Submitted sequentially; stop on the first failure and surface the error.
        foreach (var line in lines)
        {
            var result = await MobileApi.RecordSlaughterAsync(line);
            if (!result.IsSuccess)
            {
                SheetError = result.Error ?? $"Unable to save the {line.AnimalType} line.";
                IsSaving = false;
                await LoadCollectionAsync(); // reflect any lines that did save
                return;
            }
        }

        CloseSheet();
        try
        {
            await LoadCollectionAsync();
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void CloseSheet()
    {
        ShowSheet = false;
        SheetError = null;
    }

    private static string FormatCurrency(decimal value) => $"₱{value:N0}";
}
