@page "/collect/{Facility}"
@using System.Globalization
@using Microsoft.JSInterop
@using global::EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using global::EEMOCantilanSDS.Application.Command.Payors.GenerateStallActivationCode
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Application.Dtos.Payors
@using global::EEMOCantilanSDS.Application.Requests.Mobile
@using global::EEMOCantilanSDS.Application.Common.Payments
@using global::EEMOCantilanSDS.Domain.Enums
@using EEMOCantilanSDS.Mobile.Models
@using EEMOCantilanSDS.Mobile.Services
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject EEMOCantilanSDS.Mobile.Services.MobilePaymentHubService PaymentHub
@inject IMobileApiClient MobileApi
@inject EEMOCantilanSDS.Mobile.Services.MobileSyncService Sync
@inject IJSRuntime JS
@implements IDisposable

<div class="page-shell">
    <div class="header">
        <div class="header-eyebrow">Monthly Collections</div>
        <div class="header-row">
            <button class="back-btn" type="button" @onclick="GoBack" aria-label="Back to menu">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
            </button>
            <div class="header-title-block">
                <div class="header-title">@(Collection?.FacilityName ?? FacilityTitle)</div>
                <div class="header-sub">@FacilityCodeUpper - Monthly Stall Rental</div>
            </div>
        </div>
    </div>

    <div class="date-strip">
        <div class="date-strip-left">Collector: <span>@Session.CollectorName</span></div>
        <button class="collection-month-pill" type="button">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @MonthLabel
        </button>
    </div>

    <div class="content">
        @if (IsLoading)
        {
            <LoadingState Text="Loading collections…" />
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <ErrorState Title="Couldn't load collections" Message="@ErrorMessage" OnRetry="LoadCollectionAsync" />
        }
        else if (Collection is not null)
        {
            <div class="summary-strip">
                <div class="summary-item">
                    <div class="summary-value">@FormatCurrency(Collection.CollectedAmount)</div>
                    <div class="summary-key">Collected</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.PaidCount</div>
                    <div class="summary-key">Paid</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@(Collection.PartialCount + Collection.UnpaidCount)</div>
                    <div class="summary-key">Pending</div>
                </div>
            </div>

            <div class="month-banner">
                <div class="month-banner-left">
                    <div class="month-banner-label">Collection Period</div>
                    <div class="month-banner-month">@MonthLabel</div>
                    <div class="month-banner-date">Outstanding: @FormatCurrency(Collection.OutstandingAmount)</div>
                </div>
                <div class="month-banner-right">
                    <div class="month-banner-stat">
                        <span class="month-banner-val">@Collection.PaidCount</span>
                        <span class="month-banner-key">of @Collection.TotalStalls paid</span>
                    </div>
                    <div class="month-progress-wrap">
                        <div class="month-progress-fill" style="width:@PaidPercent%"></div>
                    </div>
                </div>
            </div>

            <div class="search-wrap">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search stall no. or name" @bind="SearchQuery" @bind:event="oninput" />
            </div>

            <div class="seg-filter">
                @foreach (var tab in FilterOptions)
                {
                    <button class="seg-filter-btn @(ActiveFilter == tab ? "active" : "")" type="button" @onclick="() => ActiveFilter = tab">
                        @tab
                    </button>
                }
            </div>

            @if (!FilteredStalls.Any())
            {
                <div class="state-card">
                    <div class="state-title">No matching stalls</div>
                    <div class="state-text">Try another search or filter.</div>
                </div>
            }
            else
            {
                <div class="section-label">@Collection.TotalStalls Occupied Stalls</div>
                @foreach (var stall in FilteredStalls)
                {
                    <button class="tx-card" type="button" @onclick="() => OnCardTap(stall)">
                        <div class="tx-avatar">@Initials(stall.PayorName)</div>
                        <div class="tx-body">
                            <div class="tx-top">
                                <span class="tx-owner">@stall.PayorName</span>
                                <span class="tx-amount">@FormatCurrency(stall.MonthlyRate)</span>
                            </div>

                            <div class="tx-meta">
                                <span>Stall No. @stall.StallNo</span>
                                @if (!string.IsNullOrWhiteSpace(stall.AreaLabel))
                                {
                                    <span class="tx-meta-sep">·</span><span>@stall.AreaLabel</span>
                                }
                                @if (stall.Status != PaymentStatus.Unpaid && !string.IsNullOrWhiteSpace(stall.ORNumber))
                                {
                                    <span class="tx-meta-sep">·</span><span>OR @stall.ORNumber</span>
                                }
                                @if (stall.Status == PaymentStatus.Partial)
                                {
                                    <span class="tx-meta-sep">·</span><span>Balance @FormatCurrency(stall.Balance)</span>
                                }
                            </div>

                            <div class="tx-statusrow">
                                <div class="tx-statuschips">
                                    @if (IsQueuedOffline(stall))
                                    {
                                        <span class="tx-badge badge-queued">
                                            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                                            Queued
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="tx-badge @GetBadgeClass(stall)">
                                            @if (stall.Status == PaymentStatus.Paid)
                                            {
                                                <svg viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                                            }
                                            else if (stall.Status == PaymentStatus.Partial)
                                            {
                                                <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
                                            }
                                            else
                                            {
                                                <svg viewBox="0 0 24 24"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" /><line x1="12" y1="9" x2="12" y2="13" /><line x1="12" y1="17" x2="12.01" y2="17" /></svg>
                                            }
                                            @stall.Status
                                        </span>
                                    }
                                    @if (stall.PaidOnline)
                                    {
                                        <span class="tx-online">
                                            <svg viewBox="0 0 24 24"><path d="M5 12.55a11 11 0 0 1 14 0" /><path d="M8.5 16.1a6 6 0 0 1 7 0" /><line x1="12" y1="20" x2="12" y2="20" /></svg>
                                            Online
                                        </span>
                                    }
                                    @if (stall.AwaitingOr)
                                    {
                                        <span class="tx-pending">OR pending</span>
                                    }
                                </div>

                                <span class="tx-action @(IsCollectAction(stall) ? "tx-action-collect" : "tx-action-view")" role="button" tabindex="0"
                                      @onclick="() => OnCardTap(stall)" @onclick:stopPropagation="true">
                                    @if (IsCollectAction(stall))
                                    {
                                        <svg viewBox="0 0 24 24"><path d="M21 12V7H5a2 2 0 0 1 0-4h14v4" /><path d="M3 5v14a2 2 0 0 0 2 2h16v-5" /><path d="M18 12a2 2 0 0 0 0 4h4v-4z" /></svg>
                                    }
                                    else
                                    {
                                        <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" /><polyline points="14 2 14 8 20 8" /><line x1="16" y1="13" x2="8" y2="13" /><line x1="16" y1="17" x2="8" y2="17" /></svg>
                                    }
                                    <span>@ActionLabel(stall)</span>
                                </span>
                            </div>
                        </div>
                    </button>
                }
            }
        }
    </div>

    <BottomNav ActiveTab="menu" />
</div>

@if (ShowSheet && SelectedStall is not null)
{
    <div class="sheet-overlay" @onclick="CloseSheet">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Record Monthly Payment</div>
            <div class="sheet-sub">Update this stall's payment status for @MonthLabel.</div>

            <div class="sheet-preview">
                <div class="preview-num">@SelectedStall.StallNo</div>
                <div class="preview-info">
                    <div class="preview-name">@SelectedStall.PayorName</div>
                    <div class="preview-detail">Monthly rental - @FormatCurrency(SelectedStall.MonthlyRate)</div>
                </div>
            </div>

            <button class="status-option @(SelectedStatus == PaymentStatus.Paid ? "status-option-active paid" : "")" type="button" @onclick="() => SelectStatus(PaymentStatus.Paid)">
                <div class="status-option-icon paid-icon-sm">
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Paid in Full</div>
                    <div class="status-option-sub">Full monthly rental collected - @FormatCurrency(SelectedStall.MonthlyRate)</div>
                </div>
                @if (SelectedStatus == PaymentStatus.Paid)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            <button class="status-option @(SelectedStatus == PaymentStatus.Partial ? "status-option-active partial" : "")" type="button" @onclick="() => SelectStatus(PaymentStatus.Partial)">
                <div class="status-option-icon partial-icon-sm">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Partial Payment</div>
                    <div class="status-option-sub">Collected less than the full monthly rental.</div>
                </div>
                @if (SelectedStatus == PaymentStatus.Partial)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            @if (SelectedStatus == PaymentStatus.Partial)
            {
                <div class="or-number-wrap">
                    <div class="form-label">Amount collected</div>
                    <div class="fish-input-row">
                        <span>₱</span>
                        <input class="form-input" type="number" min="0" step="0.01" placeholder="0" @bind="PartialAmount" @bind:event="oninput" />
                    </div>
                    <div class="form-hint">Must be greater than 0 and less than @FormatCurrency(SelectedStall.MonthlyRate).</div>
                </div>
            }

            @if (SelectedStatus != PaymentStatus.Unpaid)
            {
                <div class="or-number-wrap">
                    <div class="form-label">Official receipt no. <span>optional</span></div>
                    <input class="form-input mono-input"
                           type="text"
                           inputmode="numeric"
                           maxlength="30"
                           placeholder="000001"
                           @bind="ORNumber"
                           @bind:event="oninput" />
                    <div class="form-hint">Use the pre-numbered OR from the issued receipt.</div>
                </div>
            }

            <button class="status-option @(SelectedStatus == PaymentStatus.Unpaid ? "status-option-active unpaid" : "")" type="button" @onclick="() => SelectStatus(PaymentStatus.Unpaid)">
                <div class="status-option-icon unpaid-icon-sm">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Unpaid</div>
                    <div class="status-option-sub">Mark this stall as unpaid for the month.</div>
                </div>
                @if (SelectedStatus == PaymentStatus.Unpaid)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            @if (!string.IsNullOrWhiteSpace(SheetError))
            {
                <div class="form-error">@SheetError</div>
            }

            @if (Sync.IsOnline)
            {
                <button class="sheet-activation-link" type="button" @onclick="OpenActivationFromSheet">
                    <svg viewBox="0 0 24 24"><circle cx="7.5" cy="15.5" r="5.5" /><path d="m21 2-9.6 9.6" /><path d="m15.5 7.5 3 3L22 7l-3-3" /></svg>
                    Issue payor activation code
                </button>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseSheet" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Confirm")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowReceipt && SelectedStall is not null && Collection is not null)
{
    <div class="sheet-overlay" @onclick="CloseReceipt">
        <div class="sheet receipt-sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="receipt">
                <div class="receipt-head">
                    <img src="images/LGU_CANTILAN_LOGO.jpg" class="receipt-seal" alt="EEMO seal" />
                    <div class="receipt-gov">Republic of the Philippines</div>
                    <div class="receipt-org">Economic Enterprise &amp; Management Office</div>
                    <div class="receipt-muni">Municipality of Cantilan, Surigao del Sur</div>
                    <div class="receipt-doc">@(Collection.FacilityName)</div>
                </div>
                <div class="receipt-divider"></div>
                <div class="receipt-meta">
                    <div class="receipt-meta-row"><span>Period</span><strong>@MonthLabel</strong></div>
                    <div class="receipt-meta-row"><span>Stall No.</span><strong>@SelectedStall.StallNo</strong></div>
                    <div class="receipt-meta-row"><span>Payor</span><strong>@SelectedStall.PayorName</strong></div>
                    @if (!string.IsNullOrWhiteSpace(SelectedStall.AreaLabel))
                    {
                        <div class="receipt-meta-row"><span>Area</span><strong>@SelectedStall.AreaLabel</strong></div>
                    }
                    <div class="receipt-meta-row"><span>Status</span><strong>@SelectedStall.Status</strong></div>
                    @if (SelectedStall.Status == PaymentStatus.Partial)
                    {
                        <div class="receipt-meta-row"><span>Amount Paid</span><strong>@FormatCurrency(SelectedStall.AmountPaid)</strong></div>
                        <div class="receipt-meta-row"><span>Balance</span><strong>@FormatCurrency(SelectedStall.Balance)</strong></div>
                    }
                    <div class="receipt-meta-row"><span>OR No.</span><strong>@(string.IsNullOrWhiteSpace(SelectedStall.ORNumber) ? "—" : SelectedStall.ORNumber)</strong></div>
                </div>
                <div class="receipt-divider"></div>
                <div class="receipt-total-row receipt-grand">
                    <span>Monthly Rental</span>
                    <span>&#8369;@SelectedStall.MonthlyRate.ToString("N2")</span>
                </div>
                <div class="receipt-divider dashed"></div>
                <div class="receipt-foot">
                    <div class="receipt-foot-row">
                        <span>Collected by</span>
                        <strong>@Session.CollectorName</strong>
                    </div>
                    <div class="receipt-note">This acknowledges receipt of the monthly stall rental stated above. Keep for your records.</div>
                </div>
            </div>
            @if (SelectedStall.Status == PaymentStatus.Partial && SelectedStall.Balance > 0)
            {
                <button class="btn-receipt-collect" type="button" @onclick="OpenCollectBalance">
                    Collect Balance · @FormatCurrency(SelectedStall.Balance)
                </button>
            }
            @if (Sync.IsOnline)
            {
                <button class="sheet-activation-link" type="button" @onclick="OpenActivationFromSheet">
                    <svg viewBox="0 0 24 24"><circle cx="7.5" cy="15.5" r="5.5" /><path d="m21 2-9.6 9.6" /><path d="m15.5 7.5 3 3L22 7l-3-3" /></svg>
                    Issue payor activation code
                </button>
            }
            <div class="receipt-close-row">
                <button class="btn-receipt-edit" type="button" @onclick="OpenEditFromReceipt">Edit</button>
                <button class="btn-receipt-close" type="button" @onclick="CloseReceipt">Close</button>
            </div>
        </div>
    </div>
}

@if (ShowCollectBalance && SelectedStall is not null)
{
    <div class="sheet-overlay" @onclick="CloseCollectBalance">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Collect Remaining Balance</div>
            <div class="sheet-sub">Add a payment toward this stall's balance for @MonthLabel.</div>

            <div class="sheet-preview">
                <div class="preview-num">@SelectedStall.StallNo</div>
                <div class="preview-info">
                    <div class="preview-name">@SelectedStall.PayorName</div>
                    <div class="preview-detail">Monthly rental · @FormatCurrency(SelectedStall.MonthlyRate)</div>
                </div>
            </div>

            <div class="balance-recap">
                <div class="balance-recap-row"><span>Already paid</span><strong>@FormatCurrency(SelectedStall.AmountPaid)</strong></div>
                <div class="balance-recap-row balance-recap-due"><span>Remaining balance</span><strong>@FormatCurrency(SelectedStall.Balance)</strong></div>
            </div>

            <div class="or-number-wrap">
                <div class="form-label">Amount collected now</div>
                <div class="fish-input-row">
                    <span>₱</span>
                    <input class="form-input" type="number" min="0" step="0.01" max="@SelectedStall.Balance" placeholder="0" @bind="BalanceCollectNow" @bind:event="oninput" />
                </div>
                <div class="form-hint">Up to the remaining balance of @FormatCurrency(SelectedStall.Balance). Paying it in full marks the stall Paid.</div>
            </div>

            <div class="or-number-wrap">
                <div class="form-label">Official receipt no. <span>optional</span></div>
                <input class="form-input mono-input"
                       type="text"
                       inputmode="numeric"
                       maxlength="30"
                       placeholder="000001"
                       @bind="BalanceOrNumber"
                       @bind:event="oninput" />
                <div class="form-hint">Use the pre-numbered OR from the issued receipt.</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(CollectBalanceError))
            {
                <div class="form-error">@CollectBalanceError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseCollectBalance" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmCollectBalanceAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Confirm Payment")
                </button>
            </div>
        </div>
    </div>
}

@if (ShowActivation && ActivationStall is not null)
{
    <div class="sheet-overlay" @onclick="CloseActivation">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Payor Activation Code</div>
            <div class="sheet-sub">Issue a one-time code so this payor can activate their online account.</div>

            <div class="sheet-preview">
                <div class="preview-num">@ActivationStall.StallNo</div>
                <div class="preview-info">
                    <div class="preview-name">@ActivationStall.PayorName</div>
                    <div class="preview-detail">Monthly rental - @FormatCurrency(ActivationStall.MonthlyRate)</div>
                </div>
            </div>

            @if (ActivationResult is null)
            {
                <div class="or-number-wrap">
                    <div class="form-label">Payor's mobile number</div>
                    <input class="form-input mono-input"
                           type="tel"
                           inputmode="numeric"
                           maxlength="20"
                           placeholder="09xx xxx xxxx"
                           @bind="ActivationContact"
                           @bind:event="oninput" />
                    <div class="form-hint">The payor must enter this exact number when activating.</div>
                </div>

                @if (!string.IsNullOrWhiteSpace(ActivationError))
                {
                    <div class="form-error">@ActivationError</div>
                }

                <div class="sheet-btn-row">
                    <button class="btn-cancel" type="button" @onclick="CloseActivation" disabled="@IsGenerating">Cancel</button>
                    <button class="btn-confirm" type="button" @onclick="GenerateActivationAsync" disabled="@IsGenerating">
                        @(IsGenerating ? "Generating..." : "Generate Code")
                    </button>
                </div>
            }
            else
            {
                <div class="activation-code-box">
                    <div class="activation-code-label">Activation code</div>
                    <div class="activation-code-value">@ActivationResult.Code</div>
                    <button class="btn-copy" type="button" @onclick="CopyCodeAsync">@CopyLabel</button>
                </div>
                <div class="activation-meta">
                    <div class="activation-meta-row"><span>For mobile</span><strong>@ActivationResult.ContactNumber</strong></div>
                    <div class="activation-meta-row"><span>Expires</span><strong>@ActivationResult.ExpiresAt.ToLocalTime().ToString("MMM d, yyyy")</strong></div>
                </div>
                <div class="form-hint">
                    Give this code to the payor. They activate at the Payor Portal using this code and the mobile
                    number above. Generating a new code voids this one.
                </div>
                <div class="sheet-btn-row">
                    <button class="btn-confirm" type="button" @onclick="CloseActivation">Done</button>
                </div>
            }
        </div>
    </div>
}

@if (ShowEncodeOr && EncodeStall is not null)
{
    <div class="sheet-overlay" @onclick="CloseEncodeOr">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Encode Official Receipt</div>
            <div class="sheet-sub">This stall was paid online. Enter the OR number you issued for it.</div>

            <div class="sheet-preview">
                <div class="preview-num">@EncodeStall.StallNo</div>
                <div class="preview-info">
                    <div class="preview-name">@EncodeStall.PayorName</div>
                    <div class="preview-detail">Paid online · @FormatCurrency(EncodeStall.MonthlyRate)</div>
                </div>
            </div>

            <div class="or-number-wrap">
                <div class="form-label">Official receipt no.</div>
                <input class="form-input mono-input"
                       type="text"
                       maxlength="50"
                       placeholder="e.g. OR-2026-0301"
                       @bind="EncodeOrInput"
                       @bind:event="oninput" />
                <div class="form-hint">The online payment is already received; this only records the OR.</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(EncodeError))
            {
                <div class="form-error">@EncodeError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseEncodeOr" disabled="@EncodeBusy">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmEncodeOrAsync" disabled="@EncodeBusy">
                    @(EncodeBusy ? "Saving..." : "Save OR")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Facility { get; set; } = string.Empty;

    private FacilityCode FacilityCode;
    private MobileMonthlyCollectionDto? Collection;
    // Stall ids with a locally-queued (not-yet-synced) offline payment for this facility/period.
    private HashSet<Guid> QueuedOfflineStalls = new();
    private bool IsLoading = true;
    private bool IsSaving;
    private string? ErrorMessage;
    private string? SheetError;
    private string SearchQuery = string.Empty;
    private string ActiveFilter = "All";
    private int SelectedYear;
    private int SelectedMonth;
    private bool ShowSheet;
    private bool ShowReceipt;
    private MobileMonthlyStallCollectionDto? SelectedStall;
    private PaymentStatus SelectedStatus = PaymentStatus.Paid;
    private decimal? PartialAmount;
    private string ORNumber = string.Empty;

    // Payor activation-code issuance
    private bool ShowActivation;
    private bool IsGenerating;
    private MobileMonthlyStallCollectionDto? ActivationStall;
    private string ActivationContact = string.Empty;
    private string? ActivationError;
    private StallActivationCodeDto? ActivationResult;
    private string CopyLabel = "Copy";

    // Encode OR for an online payment that is awaiting OR
    private bool ShowEncodeOr;
    private bool EncodeBusy;
    private MobileMonthlyStallCollectionDto? EncodeStall;
    private string EncodeOrInput = string.Empty;
    private string? EncodeError;

    // Online · OR-pending stalls open the Encode-OR sheet (preserves online attribution — uses the
    // dedicated command, not generic record-payment); everything else opens the record-payment sheet.
    private void OnCardTap(MobileMonthlyStallCollectionDto stall)
    {
        // Encoding an OR for an online payment needs the server, so offline we just open the read-only view.
        if (Sync.IsOnline && stall.AwaitingOr && stall.OnlinePaymentTransactionId.HasValue)
            OpenEncodeOr(stall);
        else
            OpenStall(stall);
    }

    private void OpenEncodeOr(MobileMonthlyStallCollectionDto stall)
    {
        EncodeStall = stall;
        EncodeOrInput = string.Empty;
        EncodeError = null;
        ShowEncodeOr = true;
    }

    private void CloseEncodeOr()
    {
        ShowEncodeOr = false;
        EncodeStall = null;
        EncodeError = null;
    }

    private async Task ConfirmEncodeOrAsync()
    {
        if (EncodeStall?.OnlinePaymentTransactionId is not { } txnId) return;

        if (string.IsNullOrWhiteSpace(EncodeOrInput))
        {
            EncodeError = "Enter the OR number.";
            return;
        }

        if (!Sync.IsOnline)
        {
            EncodeError = "You're offline. Encoding the OR for an online payment needs a connection.";
            return;
        }

        EncodeBusy = true;
        try
        {
            var result = await MobileApi.IssueOnlinePaymentOrNumberAsync(txnId, EncodeOrInput.Trim());
            if (result.IsSuccess)
            {
                ShowEncodeOr = false;
                EncodeStall = null;
                await LoadCollectionAsync();
            }
            else
            {
                EncodeError = result.Error ?? "Could not save the OR. It may already be in use.";
            }
        }
        catch
        {
            EncodeError = "Couldn't reach the server. Please check your connection and try again.";
        }
        finally
        {
            EncodeBusy = false;
        }
    }

    private void OpenActivation(MobileMonthlyStallCollectionDto stall)
    {
        if (!Sync.IsOnline)
            return; // activation needs the server to issue a one-time code — locked offline

        ActivationStall = stall;
        ActivationContact = string.Empty;
        ActivationError = null;
        ActivationResult = null;
        CopyLabel = "Copy";
        ShowActivation = true;
    }

    // Activation lives in the stall's detail sheets now (not on the card): close the open sheet, then open it.
    private void OpenActivationFromSheet()
    {
        var stall = SelectedStall;
        ShowSheet = false;
        ShowReceipt = false;
        if (stall is not null) OpenActivation(stall);
    }

    private void CloseActivation()
    {
        ShowActivation = false;
        ActivationStall = null;
        ActivationResult = null;
        ActivationError = null;
    }

    private async Task GenerateActivationAsync()
    {
        if (ActivationStall is null) return;
        ActivationError = null;

        if (!Sync.IsOnline)
        {
            ActivationError = "You're offline. Activation codes can only be generated online.";
            return;
        }

        if (string.IsNullOrWhiteSpace(ActivationContact))
        {
            ActivationError = "Enter the payor's mobile number.";
            return;
        }

        IsGenerating = true;
        try
        {
            var result = await MobileApi.GenerateActivationCodeAsync(
                new GenerateStallActivationCodeCommand(ActivationStall.StallId, ActivationContact.Trim(), null));

            if (result.IsSuccess && result.Value is not null)
                ActivationResult = result.Value;
            else
                ActivationError = result.Error ?? "Could not generate the code. Please try again.";
        }
        catch
        {
            ActivationError = "Couldn't reach the server. Please check your connection and try again.";
        }
        finally
        {
            IsGenerating = false;
        }
    }

    private async Task CopyCodeAsync()
    {
        if (ActivationResult is null) return;
        try
        {
            await JS.InvokeVoidAsync("navigator.clipboard.writeText", ActivationResult.Code);
            CopyLabel = "Copied!";
        }
        catch
        {
            CopyLabel = "Copy failed";
        }
    }

    private readonly string[] FilterOptions = ["All", "Paid", "Partial", "Unpaid"];

    private string FacilityCodeUpper => Facility.ToUpperInvariant();
    private string FacilityTitle => FacilityCodeUpper;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
        }
        catch (HttpRequestException)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        if (!Enum.TryParse(Facility, ignoreCase: true, out FacilityCode))
        {
            Navigation.NavigateTo("/menu", forceLoad: false);
            return;
        }

        var hasAccess = Session.Menu?.Facilities.Any(f => f.Code == FacilityCode && f.IsAvailable) == true;
        if (!hasAccess)
        {
            Navigation.NavigateTo("/menu", forceLoad: false);
            return;
        }

        var today = Session.Menu?.Today ?? DateOnly.FromDateTime(DateTime.Now);
        SelectedYear = today.Year;
        SelectedMonth = today.Month;

        PaymentHub.PaymentReceived += OnOnlinePaymentReceived;

        await LoadCollectionAsync();
    }

    // Realtime: when a payor pays online for a stall in THIS facility/month, refresh so the card flips
    // Unpaid → Paid · Online (awaiting OR) live. The hub event fires off the UI thread — marshal onto it.
    private void OnOnlinePaymentReceived(OnlinePaymentNotification n)
    {
        if (n.BillingYear != SelectedYear || n.BillingMonth != SelectedMonth)
            return;
        if (Collection?.Stalls is null || !Collection.Stalls.Any(s => s.StallId == n.StallId))
            return;

        _ = InvokeAsync(RefreshCollectionSoftlyAsync);
    }

    // A background refresh must NOT tear down the working list: unlike LoadCollectionAsync (initial
    // load) it never flips IsLoading or shows the error screen. It swaps in fresh data only on success;
    // on a transient failure it retries once, then silently keeps the current list (the toast already
    // told the collector a payment came in).
    private async Task RefreshCollectionSoftlyAsync()
    {
        for (var attempt = 0; attempt < 2; attempt++)
        {
            var result = await MobileApi.GetMonthlyCollectionAsync(FacilityCode, SelectedYear, SelectedMonth);
            if (result.IsSuccess && result.Value is not null)
            {
                Collection = result.Value;
                await RefreshQueuedOfflineAsync();
                StateHasChanged();
                return;
            }

            if (attempt == 0)
                await Task.Delay(800);
        }
        // Keep the existing list as-is — no error screen for a non-critical realtime refresh.
    }

    public void Dispose() => PaymentHub.PaymentReceived -= OnOnlinePaymentReceived;

    private async Task LoadCollectionAsync()
    {
        IsLoading = true;
        ErrorMessage = null;
        StateHasChanged();

        try
        {
            var result = await MobileApi.GetMonthlyCollectionAsync(FacilityCode, SelectedYear, SelectedMonth);
            if (!result.IsSuccess || result.Value is null)
            {
                ErrorMessage = result.Error ?? "Unable to load assigned stalls.";
                return;
            }

            Collection = result.Value;
            await RefreshQueuedOfflineAsync();
        }
        catch
        {
            // The HTTP layer throws on a connection failure/timeout; keep the retry path safe and unstuck.
            ErrorMessage = "Unable to connect to the EEMO server. Please check the connection and try again.";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    // Build the set of stalls that already have a locally-queued offline payment for this facility/period,
    // so the card can show "Queued · Offline" instead of a misleading "Unpaid".
    private async Task RefreshQueuedOfflineAsync()
    {
        var pending = await Sync.GetAllAsync();
        QueuedOfflineStalls = pending
            .Where(o => o.Kind == OfflineOperationKind.MonthlyRental
                     && o.StallId is not null
                     && string.Equals(o.FacilityLabel, FacilityCodeUpper, StringComparison.OrdinalIgnoreCase)
                     && o.BusinessDate.Year == SelectedYear && o.BusinessDate.Month == SelectedMonth
                     && o.LocalStatus is PendingLocalStatus.Pending or PendingLocalStatus.Failed)
            .Select(o => o.StallId!.Value)
            .ToHashSet();
    }

    private bool IsQueuedOffline(MobileMonthlyStallCollectionDto stall) => QueuedOfflineStalls.Contains(stall.StallId);

    private IEnumerable<MobileMonthlyStallCollectionDto> FilteredStalls =>
        (Collection?.Stalls ?? Array.Empty<MobileMonthlyStallCollectionDto>())
        .Where(s =>
        {
            var matchesSearch = string.IsNullOrWhiteSpace(SearchQuery)
                || s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
                || s.PayorName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);

            var matchesFilter = ActiveFilter switch
            {
                "Paid" => s.Status == PaymentStatus.Paid,
                "Partial" => s.Status == PaymentStatus.Partial,
                "Unpaid" => s.Status == PaymentStatus.Unpaid,
                _ => true
            };

            return matchesSearch && matchesFilter;
        })
        .OrderBy(s => s.StallNo);

    private string MonthLabel =>
        new DateTime(SelectedYear == 0 ? DateTime.Now.Year : SelectedYear, SelectedMonth == 0 ? DateTime.Now.Month : SelectedMonth, 1)
            .ToString("MMMM yyyy", CultureInfo.InvariantCulture);

    private int PaidPercent =>
        Collection is null || Collection.TotalStalls == 0
            ? 0
            : Math.Clamp((int)Math.Round((decimal)Collection.PaidCount / Collection.TotalStalls * 100m), 0, 100);

    private void GoBack() => Navigation.NavigateTo("/menu", forceLoad: false);

    // Paid/Partial stalls open a receipt (view) with Edit; Unpaid opens the record sheet directly.
    private void OpenStall(MobileMonthlyStallCollectionDto stall)
    {
        SelectedStall = stall;
        if (stall.Status != PaymentStatus.Unpaid)
        {
            SheetError = null;
            ShowReceipt = true;
        }
        else
        {
            OpenSheet(stall);
        }
    }

    private void OpenEditFromReceipt()
    {
        ShowReceipt = false;
        if (SelectedStall is not null) OpenSheet(SelectedStall);
    }

    private void CloseReceipt()
    {
        ShowReceipt = false;
        SelectedStall = null;
    }

    // ── Collect the remaining balance on a partial record ──
    private bool ShowCollectBalance;
    private decimal? BalanceCollectNow;
    private string BalanceOrNumber = string.Empty;
    private string? CollectBalanceError;

    private void OpenCollectBalance()
    {
        if (SelectedStall is null) return;
        ShowReceipt = false;
        BalanceCollectNow = SelectedStall.Balance; // default to clearing the whole balance
        BalanceOrNumber = SelectedStall.ORNumber ?? string.Empty; // carry the existing OR forward, if any
        CollectBalanceError = null;
        ShowCollectBalance = true;
    }

    private void CloseCollectBalance()
    {
        ShowCollectBalance = false;
        BalanceCollectNow = null;
        BalanceOrNumber = string.Empty;
        CollectBalanceError = null;
        SelectedStall = null;
    }

    private async Task ConfirmCollectBalanceAsync()
    {
        if (SelectedStall is null || Collection is null) return;

        var balance = SelectedStall.Balance;
        if (BalanceCollectNow is null or <= 0m)
        {
            CollectBalanceError = "Enter an amount greater than 0.";
            return;
        }
        if (BalanceCollectNow.Value > balance)
        {
            CollectBalanceError = $"Amount can't exceed the remaining balance of {FormatCurrency(balance)}.";
            return;
        }

        // PartialAmount is the ABSOLUTE total paid; add what's collected now. Clearing the balance
        // (or reaching the monthly rate) marks the stall Paid — the domain also auto-upgrades.
        var newTotalPaid = SelectedStall.AmountPaid + BalanceCollectNow.Value;
        var status = newTotalPaid >= SelectedStall.MonthlyRate ? PaymentStatus.Paid : PaymentStatus.Partial;
        var orNumber = !string.IsNullOrWhiteSpace(BalanceOrNumber) ? BalanceOrNumber.Trim() : null;

        IsSaving = true;
        CollectBalanceError = null;

        if (!Sync.IsOnline)
        {
            await Sync.EnqueueAsync(new PendingOperation
            {
                Kind = OfflineOperationKind.MonthlyRental,
                BusinessDate = new DateOnly(SelectedYear, SelectedMonth, 1),
                StallId = SelectedStall.StallId,
                Status = status,
                PartialAmount = status == PaymentStatus.Partial ? newTotalPaid : null,
                ORNumber = orNumber,
                FacilityLabel = FacilityCodeUpper,
                Title = SelectedStall.PayorName,
                Detail = $"No. {SelectedStall.StallNo} · balance",
                Amount = BalanceCollectNow.Value
            });
            QueuedOfflineStalls.Add(SelectedStall.StallId);
            CloseCollectBalance();
            IsSaving = false;
            return;
        }

        var request = new RecordMobileMonthlyCollectionRequest(
            SelectedStall.StallId,
            status,
            status == PaymentStatus.Partial ? newTotalPaid : null,
            orNumber);

        var result = await MobileApi.RecordMonthlyCollectionAsync(request);
        if (!result.IsSuccess)
        {
            CollectBalanceError = result.Error ?? "Unable to save the payment.";
            IsSaving = false;
            return;
        }

        CloseCollectBalance();
        try
        {
            await LoadCollectionAsync();
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void OpenSheet(MobileMonthlyStallCollectionDto stall)
    {
        SelectedStall = stall;
        SelectedStatus = stall.Status == PaymentStatus.Unpaid ? PaymentStatus.Paid : stall.Status;
        PartialAmount = stall.Status == PaymentStatus.Partial ? stall.AmountPaid : null;
        ORNumber = stall.ORNumber ?? string.Empty;
        SheetError = null;
        ShowSheet = true;
    }

    private void SelectStatus(PaymentStatus status)
    {
        SelectedStatus = status;
        SheetError = null;
    }

    private async Task ConfirmAsync()
    {
        if (SelectedStall is null || Collection is null)
            return;

        if (SelectedStatus == PaymentStatus.Partial && (PartialAmount is null or <= 0))
        {
            SheetError = "Enter the partial amount collected (greater than 0).";
            return;
        }

        IsSaving = true;
        SheetError = null;

        // Offline: queue Paid/Partial collections locally; "Unpaid" is a no-money state change needing the server.
        if (!Sync.IsOnline)
        {
            if (SelectedStatus == PaymentStatus.Unpaid)
            {
                SheetError = "You're offline. Marking a stall 'Unpaid' needs a connection.";
                IsSaving = false;
                return;
            }

            await Sync.EnqueueAsync(new PendingOperation
            {
                Kind = OfflineOperationKind.MonthlyRental,
                BusinessDate = new DateOnly(SelectedYear, SelectedMonth, 1),
                StallId = SelectedStall.StallId,
                Status = SelectedStatus,
                PartialAmount = SelectedStatus == PaymentStatus.Partial ? PartialAmount : null,
                ORNumber = !string.IsNullOrWhiteSpace(ORNumber) ? ORNumber.Trim() : null,
                FacilityLabel = FacilityCodeUpper,
                Title = SelectedStall.PayorName,
                Detail = $"No. {SelectedStall.StallNo}",
                Amount = SelectedStatus == PaymentStatus.Partial ? (PartialAmount ?? 0m) : SelectedStall.MonthlyRate
            });

            QueuedOfflineStalls.Add(SelectedStall.StallId); // reflect immediately on the card
            CloseSheet();
            IsSaving = false;
            return;
        }

        var request = new RecordMobileMonthlyCollectionRequest(
            SelectedStall.StallId,
            SelectedStatus,
            SelectedStatus == PaymentStatus.Partial ? PartialAmount : null,
            SelectedStatus != PaymentStatus.Unpaid && !string.IsNullOrWhiteSpace(ORNumber) ? ORNumber.Trim() : null);

        var result = await MobileApi.RecordMonthlyCollectionAsync(request);
        if (!result.IsSuccess)
        {
            SheetError = result.Error ?? "Unable to save the payment.";
            IsSaving = false;
            return;
        }

        CloseSheet();
        try
        {
            await LoadCollectionAsync();
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void CloseSheet()
    {
        ShowSheet = false;
        SelectedStall = null;
        SelectedStatus = PaymentStatus.Paid;
        PartialAmount = null;
        ORNumber = string.Empty;
        SheetError = null;
    }

    private static string FormatCurrency(decimal value) => $"₱{value:N0}";

    // The unpaid (not-yet-collected) state gets the prominent "Collect" action; everything else is view-only.
    private bool IsCollectAction(MobileMonthlyStallCollectionDto stall) =>
        !IsQueuedOffline(stall) && stall.Status == PaymentStatus.Unpaid;

    private string ActionLabel(MobileMonthlyStallCollectionDto stall)
    {
        if (IsQueuedOffline(stall)) return "View";
        if (stall.Status == PaymentStatus.Unpaid) return "Collect";
        if (stall.AwaitingOr && stall.OnlinePaymentTransactionId.HasValue) return "Encode OR";
        return "View Receipt";
    }

    private static string GetBadgeClass(MobileMonthlyStallCollectionDto stall) =>
        stall.Status == PaymentStatus.Paid ? "badge-paid" :
        stall.Status == PaymentStatus.Partial ? "badge-partial" :
        "badge-unpaid";

    // Initials for the card avatar (1–2 letters from the payor's name).
    private static string Initials(string? name)
    {
        if (string.IsNullOrWhiteSpace(name)) return "•";
        var parts = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 1)
            return parts[0].Substring(0, 1).ToUpperInvariant();
        return (parts[0].Substring(0, 1) + parts[^1].Substring(0, 1)).ToUpperInvariant();
    }
}
