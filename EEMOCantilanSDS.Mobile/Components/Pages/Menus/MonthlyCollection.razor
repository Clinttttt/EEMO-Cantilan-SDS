@page "/collect/{Facility}"
@using System.Globalization
@using global::EEMOCantilanSDS.Application.Common.Interface.ApiClients
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Application.Requests.Mobile
@using global::EEMOCantilanSDS.Domain.Enums
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session
@inject IMobileApiClient MobileApi

<div class="page-shell">
    <div class="header">
        <div class="header-eyebrow">Monthly Collections</div>
        <div class="header-row">
            <button class="back-btn" type="button" @onclick="GoBack" aria-label="Back to menu">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
            </button>
            <div class="header-title-block">
                <div class="header-title">@(Collection?.FacilityName ?? FacilityTitle)</div>
                <div class="header-sub">@FacilityCodeUpper - Monthly Stall Rental</div>
            </div>
        </div>
    </div>

    <div class="date-strip">
        <div class="date-strip-left">Collector: <span>@Session.CollectorName</span></div>
        <button class="collection-month-pill" type="button">
            <svg viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            @MonthLabel
        </button>
    </div>

    <div class="content">
        @if (IsLoading)
        {
            <div class="state-card">
                <div class="state-title">Loading collections</div>
                <div class="state-text">Please wait while the assigned stalls are loaded.</div>
            </div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="state-card error">
                <div class="state-title">Unable to load collections</div>
                <div class="state-text">@ErrorMessage</div>
                <button class="primary-action" type="button" @onclick="LoadCollectionAsync">Try Again</button>
            </div>
        }
        else if (Collection is not null)
        {
            <div class="summary-strip">
                <div class="summary-item">
                    <div class="summary-value">@FormatCurrency(Collection.CollectedAmount)</div>
                    <div class="summary-key">Collected</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@Collection.PaidCount</div>
                    <div class="summary-key">Paid</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@(Collection.PartialCount + Collection.UnpaidCount)</div>
                    <div class="summary-key">Pending</div>
                </div>
            </div>

            <div class="month-banner">
                <div class="month-banner-left">
                    <div class="month-banner-label">Collection Period</div>
                    <div class="month-banner-month">@MonthLabel</div>
                    <div class="month-banner-date">Outstanding: @FormatCurrency(Collection.OutstandingAmount)</div>
                </div>
                <div class="month-banner-right">
                    <div class="month-banner-stat">
                        <span class="month-banner-val">@Collection.PaidCount</span>
                        <span class="month-banner-key">of @Collection.TotalStalls paid</span>
                    </div>
                    <div class="month-progress-wrap">
                        <div class="month-progress-fill" style="width:@PaidPercent%"></div>
                    </div>
                </div>
            </div>

            <div class="search-wrap">
                <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8" /><line x1="21" y1="21" x2="16.65" y2="16.65" /></svg>
                <input type="text" placeholder="Search stall no. or name" @bind="SearchQuery" @bind:event="oninput" />
            </div>

            <div class="filter-tabs">
                @foreach (var tab in FilterOptions)
                {
                    <button class="filter-tab @(ActiveFilter == tab ? "active" : "")" type="button" @onclick="() => ActiveFilter = tab">
                        @tab
                    </button>
                }
            </div>

            @if (!FilteredStalls.Any())
            {
                <div class="state-card">
                    <div class="state-title">No matching stalls</div>
                    <div class="state-text">Try another search or filter.</div>
                </div>
            }
            else
            {
                <div class="section-label">@Collection.TotalStalls Occupied Stalls</div>
                @foreach (var stall in FilteredStalls)
                {
                    <button class="stall-row @GetRowClass(stall)" type="button" @onclick="() => OpenSheet(stall)">
                        <div class="stall-info">
                            <div class="stall-main-row">
                                <div class="stall-name">@stall.PayorName</div>
                                <span class="stall-status-pill @GetPillClass(stall)">@stall.Status</span>
                            </div>
                            <div class="stall-meta">
                                <span>No. @stall.StallNo</span>
                                @if (!string.IsNullOrWhiteSpace(stall.AreaLabel))
                                {
                                    <span>@stall.AreaLabel</span>
                                }
                                @if (stall.Status != PaymentStatus.Unpaid && !string.IsNullOrWhiteSpace(stall.ORNumber))
                                {
                                    <span>OR @stall.ORNumber</span>
                                }
                                @if (stall.Status == PaymentStatus.Partial)
                                {
                                    <span>Bal @FormatCurrency(stall.Balance)</span>
                                }
                            </div>
                        </div>
                        <div class="stall-amount-col">
                            <div class="stall-amount">@FormatCurrency(stall.MonthlyRate)</div>
                        </div>
                    </button>
                }
            }
        }
    </div>

    <BottomNav ActiveTab="menu" />
</div>

@if (ShowSheet && SelectedStall is not null)
{
    <div class="sheet-overlay" @onclick="CloseSheet">
        <div class="sheet" @onclick:stopPropagation="true">
            <div class="sheet-handle"></div>
            <div class="sheet-title">Record Monthly Payment</div>
            <div class="sheet-sub">Update this stall's payment status for @MonthLabel.</div>

            <div class="sheet-preview">
                <div class="preview-num">@SelectedStall.StallNo</div>
                <div class="preview-info">
                    <div class="preview-name">@SelectedStall.PayorName</div>
                    <div class="preview-detail">Monthly rental - @FormatCurrency(SelectedStall.MonthlyRate)</div>
                </div>
            </div>

            <button class="status-option @(SelectedStatus == PaymentStatus.Paid ? "status-option-active paid" : "")" type="button" @onclick="() => SelectStatus(PaymentStatus.Paid)">
                <div class="status-option-icon paid-icon-sm">
                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Paid in Full</div>
                    <div class="status-option-sub">Full monthly rental collected - @FormatCurrency(SelectedStall.MonthlyRate)</div>
                </div>
                @if (SelectedStatus == PaymentStatus.Paid)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            <button class="status-option @(SelectedStatus == PaymentStatus.Partial ? "status-option-active partial" : "")" type="button" @onclick="() => SelectStatus(PaymentStatus.Partial)">
                <div class="status-option-icon partial-icon-sm">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><path d="M12 6v6l4 2" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Partial Payment</div>
                    <div class="status-option-sub">Collected less than the full monthly rental.</div>
                </div>
                @if (SelectedStatus == PaymentStatus.Partial)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            @if (SelectedStatus == PaymentStatus.Partial)
            {
                <div class="or-number-wrap">
                    <div class="form-label">Amount collected</div>
                    <div class="fish-input-row">
                        <span>₱</span>
                        <input class="form-input" type="number" min="0" step="0.01" placeholder="0" @bind="PartialAmount" @bind:event="oninput" />
                    </div>
                    <div class="form-hint">Must be greater than 0 and less than @FormatCurrency(SelectedStall.MonthlyRate).</div>
                </div>
            }

            @if (SelectedStatus != PaymentStatus.Unpaid)
            {
                <div class="or-number-wrap">
                    <div class="form-label">Official receipt no. <span>optional</span></div>
                    <input class="form-input mono-input"
                           type="text"
                           inputmode="numeric"
                           maxlength="30"
                           placeholder="000001"
                           @bind="ORNumber"
                           @bind:event="oninput" />
                    <div class="form-hint">Use the pre-numbered OR from the issued receipt.</div>
                </div>
            }

            <button class="status-option @(SelectedStatus == PaymentStatus.Unpaid ? "status-option-active unpaid" : "")" type="button" @onclick="() => SelectStatus(PaymentStatus.Unpaid)">
                <div class="status-option-icon unpaid-icon-sm">
                    <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="15" y1="9" x2="9" y2="15" /><line x1="9" y1="9" x2="15" y2="15" /></svg>
                </div>
                <div class="status-option-info">
                    <div class="status-option-label">Unpaid</div>
                    <div class="status-option-sub">Mark this stall as unpaid for the month.</div>
                </div>
                @if (SelectedStatus == PaymentStatus.Unpaid)
                {
                    <div class="status-option-check">✓</div>
                }
            </button>

            @if (!string.IsNullOrWhiteSpace(SheetError))
            {
                <div class="form-error">@SheetError</div>
            }

            <div class="sheet-btn-row">
                <button class="btn-cancel" type="button" @onclick="CloseSheet" disabled="@IsSaving">Cancel</button>
                <button class="btn-confirm" type="button" @onclick="ConfirmAsync" disabled="@IsSaving">
                    @(IsSaving ? "Saving..." : "Confirm")
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Facility { get; set; } = string.Empty;

    private FacilityCode FacilityCode;
    private MobileMonthlyCollectionDto? Collection;
    private bool IsLoading = true;
    private bool IsSaving;
    private string? ErrorMessage;
    private string? SheetError;
    private string SearchQuery = string.Empty;
    private string ActiveFilter = "All";
    private int SelectedYear;
    private int SelectedMonth;
    private bool ShowSheet;
    private MobileMonthlyStallCollectionDto? SelectedStall;
    private PaymentStatus SelectedStatus = PaymentStatus.Paid;
    private decimal? PartialAmount;
    private string ORNumber = string.Empty;

    private readonly string[] FilterOptions = ["All", "Paid", "Partial", "Unpaid"];

    private string FacilityCodeUpper => Facility.ToUpperInvariant();
    private string FacilityTitle => FacilityCodeUpper;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();
        }
        catch (HttpRequestException)
        {
            Navigation.NavigateTo("/login", forceLoad: false);
            return;
        }

        if (!Enum.TryParse(Facility, ignoreCase: true, out FacilityCode))
        {
            Navigation.NavigateTo("/menu", forceLoad: false);
            return;
        }

        var hasAccess = Session.Menu?.Facilities.Any(f => f.Code == FacilityCode && f.IsAvailable) == true;
        if (!hasAccess)
        {
            Navigation.NavigateTo("/menu", forceLoad: false);
            return;
        }

        var today = Session.Menu?.Today ?? DateOnly.FromDateTime(DateTime.Now);
        SelectedYear = today.Year;
        SelectedMonth = today.Month;

        await LoadCollectionAsync();
    }

    private async Task LoadCollectionAsync()
    {
        IsLoading = true;
        ErrorMessage = null;

        var result = await MobileApi.GetMonthlyCollectionAsync(FacilityCode, SelectedYear, SelectedMonth);
        if (!result.IsSuccess || result.Value is null)
        {
            ErrorMessage = result.Error ?? "Unable to load assigned stalls.";
            IsLoading = false;
            return;
        }

        Collection = result.Value;
        IsLoading = false;
    }

    private IEnumerable<MobileMonthlyStallCollectionDto> FilteredStalls =>
        (Collection?.Stalls ?? Array.Empty<MobileMonthlyStallCollectionDto>())
        .Where(s =>
        {
            var matchesSearch = string.IsNullOrWhiteSpace(SearchQuery)
                || s.StallNo.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase)
                || s.PayorName.Contains(SearchQuery, StringComparison.OrdinalIgnoreCase);

            var matchesFilter = ActiveFilter switch
            {
                "Paid" => s.Status == PaymentStatus.Paid,
                "Partial" => s.Status == PaymentStatus.Partial,
                "Unpaid" => s.Status == PaymentStatus.Unpaid,
                _ => true
            };

            return matchesSearch && matchesFilter;
        })
        .OrderBy(s => s.StallNo);

    private string MonthLabel =>
        new DateTime(SelectedYear == 0 ? DateTime.Now.Year : SelectedYear, SelectedMonth == 0 ? DateTime.Now.Month : SelectedMonth, 1)
            .ToString("MMMM yyyy", CultureInfo.InvariantCulture);

    private int PaidPercent =>
        Collection is null || Collection.TotalStalls == 0
            ? 0
            : Math.Clamp((int)Math.Round((decimal)Collection.PaidCount / Collection.TotalStalls * 100m), 0, 100);

    private void GoBack() => Navigation.NavigateTo("/menu", forceLoad: false);

    private void OpenSheet(MobileMonthlyStallCollectionDto stall)
    {
        SelectedStall = stall;
        SelectedStatus = stall.Status == PaymentStatus.Unpaid ? PaymentStatus.Paid : stall.Status;
        PartialAmount = stall.Status == PaymentStatus.Partial ? stall.AmountPaid : null;
        ORNumber = stall.ORNumber ?? string.Empty;
        SheetError = null;
        ShowSheet = true;
    }

    private void SelectStatus(PaymentStatus status)
    {
        SelectedStatus = status;
        SheetError = null;
    }

    private async Task ConfirmAsync()
    {
        if (SelectedStall is null || Collection is null)
            return;

        if (SelectedStatus == PaymentStatus.Partial && (PartialAmount is null or <= 0))
        {
            SheetError = "Enter the partial amount collected (greater than 0).";
            return;
        }

        IsSaving = true;
        SheetError = null;

        var request = new RecordMobileMonthlyCollectionRequest(
            SelectedStall.StallId,
            SelectedStatus,
            SelectedStatus == PaymentStatus.Partial ? PartialAmount : null,
            SelectedStatus != PaymentStatus.Unpaid && !string.IsNullOrWhiteSpace(ORNumber) ? ORNumber.Trim() : null);

        var result = await MobileApi.RecordMonthlyCollectionAsync(request);
        if (!result.IsSuccess)
        {
            SheetError = result.Error ?? "Unable to save the payment.";
            IsSaving = false;
            return;
        }

        CloseSheet();
        try
        {
            await LoadCollectionAsync();
        }
        finally
        {
            IsSaving = false;
        }
    }

    private void CloseSheet()
    {
        ShowSheet = false;
        SelectedStall = null;
        SelectedStatus = PaymentStatus.Paid;
        PartialAmount = null;
        ORNumber = string.Empty;
        SheetError = null;
    }

    private static string FormatCurrency(decimal value) => $"₱{value:N0}";

    private static string GetRowClass(MobileMonthlyStallCollectionDto stall) =>
        stall.Status == PaymentStatus.Paid ? "paid" :
        stall.Status == PaymentStatus.Partial ? "partial" :
        string.Empty;

    private static string GetPillClass(MobileMonthlyStallCollectionDto stall) =>
        stall.Status == PaymentStatus.Paid ? "pill-paid" :
        stall.Status == PaymentStatus.Partial ? "pill-partial" :
        "pill-unpaid";
}
