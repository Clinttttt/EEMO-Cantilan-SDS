@page "/menu"
@using global::EEMOCantilanSDS.Application.Dtos.Mobile
@using global::EEMOCantilanSDS.Domain.Enums
@inject NavigationManager Navigation
@inject EEMOCantilanSDS.Mobile.Services.MobileSessionService Session

<div class="page-shell">
    <AppHeader CollectorName="@Session.CollectorName" />

    <div class="content">
        @if (IsLoading)
        {
            <div class="menu-state-card">Loading assigned collection areas...</div>
        }
        else if (!string.IsNullOrWhiteSpace(ErrorMessage))
        {
            <div class="menu-state-card error">@ErrorMessage</div>
        }
        else
        {
            <div class="summary-strip">
                <div class="summary-item">
                    <div class="summary-value">₱0</div>
                    <div class="summary-key">Today</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@AssignedFacilities.Count</div>
                    <div class="summary-key">Assigned</div>
                </div>
                <div class="summary-item">
                    <div class="summary-value">@AssignedFacilities.Count(f => f.IsAvailable)</div>
                    <div class="summary-key">Available</div>
                </div>
            </div>

            @if (MarketFacilities.Any())
            {
                <div class="section-label">Market Collections</div>
                @foreach (var facility in MarketFacilities)
                {
                    <div class="menu-card @(facility.IsAvailable ? string.Empty : "disabled")" @onclick="() => OpenFacility(facility)">
                        <div class="card-icon">@((MarkupString)GetFacilityIcon(facility.Code))</div>
                        <div class="card-info">
                            <div class="card-title">@facility.Name</div>
                            <div class="card-sub">@facility.Code - @facility.Description</div>
                        </div>
                        <div class="card-status">@(facility.IsAvailable ? "Open" : "Soon")</div>
                        <div class="card-arrow">›</div>
                    </div>
                }
            }

            @if (OtherFacilities.Any())
            {
                <div class="group-spacer"></div>
                <div class="section-label">Other Assigned Collections</div>
                @foreach (var facility in OtherFacilities)
                {
                    <div class="menu-card disabled">
                        <div class="card-icon">@((MarkupString)GetFacilityIcon(facility.Code))</div>
                        <div class="card-info">
                            <div class="card-title">@facility.Name</div>
                            <div class="card-sub">@facility.Code - @facility.Description</div>
                        </div>
                        <div class="card-status">Soon</div>
                    </div>
                }
            }

            @if (!AssignedFacilities.Any())
            {
                <div class="menu-state-card">
                    No collection facility is assigned to this collector account yet.
                </div>
            }
        }
    </div>

    <BottomNav ActiveTab="menu" />
</div>

@code {
    bool IsLoading = true;
    string ErrorMessage = string.Empty;

    IReadOnlyList<MobileFacilityMenuItemDto> AssignedFacilities =>
        Session.Menu?.AssignedFacilities ?? Array.Empty<MobileFacilityMenuItemDto>();

    IEnumerable<MobileFacilityMenuItemDto> MarketFacilities =>
        AssignedFacilities.Where(f => f.Code is FacilityCode.NPM or FacilityCode.TCC or FacilityCode.NCC or FacilityCode.TPM);

    IEnumerable<MobileFacilityMenuItemDto> OtherFacilities =>
        AssignedFacilities.Except(MarketFacilities);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Session.InitializeAsync();

            if (Session.Menu is null)
            {
                Navigation.NavigateTo("/login", forceLoad: false);
                return;
            }
        }
        catch (HttpRequestException)
        {
            ErrorMessage = "Unable to connect to the EEMO server. Please check the connection and try again.";
        }
        finally
        {
            IsLoading = false;
        }
    }

    void OpenFacility(MobileFacilityMenuItemDto facility)
    {
        if (!facility.IsAvailable)
        {
            return;
        }

        if (facility.Code == FacilityCode.NPM)
        {
            Navigation.NavigateTo("/market", forceLoad: false);
        }
    }

    static string GetFacilityIcon(FacilityCode code) => code switch
    {
        FacilityCode.NPM or FacilityCode.TPM =>
            "<svg viewBox=\"0 0 24 24\"><path d=\"M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z\" /><polyline points=\"9 22 9 12 15 12 15 22\" /></svg>",
        FacilityCode.TCC =>
            "<svg viewBox=\"0 0 24 24\"><rect x=\"2\" y=\"7\" width=\"20\" height=\"14\" rx=\"2\" /><path d=\"M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2\" /></svg>",
        FacilityCode.NCC =>
            "<svg viewBox=\"0 0 24 24\"><path d=\"M3 3h18v18H3zM3 9h18M3 15h18M9 3v18M15 3v18\" /></svg>",
        FacilityCode.SLH =>
            "<svg viewBox=\"0 0 24 24\"><path d=\"M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z\" /></svg>",
        FacilityCode.TRM =>
            "<svg viewBox=\"0 0 24 24\"><rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"1\" /><path d=\"M16 8h4l3 3v5h-7V8z\" /><circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\" /><circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\" /></svg>",
        _ =>
            "<svg viewBox=\"0 0 24 24\"><circle cx=\"12\" cy=\"12\" r=\"10\" /><line x1=\"12\" y1=\"8\" x2=\"12\" y2=\"12\" /><line x1=\"12\" y1=\"16\" x2=\"12.01\" y2=\"16\" /></svg>"
    };
}
