@page "/"
@inject NavigationManager Navigation
@implements IDisposable

<style>
    :root, html, body {
        height: 100%;
        width: 100%;
        overflow: hidden;
        background-color: #0d2137;
    }

    /* ── Splash Shell ── */
    .splash {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        height: 100dvh;
        width: 100%;
        background: radial-gradient(ellipse at 50% 40%, #1e3a5f 0%, #0d2137 65%);
        position: relative;
        overflow: hidden;
    }

    /* ── Subtle background ring decoration ── */
    .splash::before {
        content: '';
        position: absolute;
        width: 420px;
        height: 420px;
        border-radius: 50%;
        border: 1px solid rgba(200,168,75,0.08);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    .splash::after {
        content: '';
        position: absolute;
        width: 560px;
        height: 560px;
        border-radius: 50%;
        border: 1px solid rgba(200,168,75,0.05);
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
    }

    /* ── Gold line top ── */
    .splash-top-line {
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, #c8a84b, #e8cc76, #c8a84b, transparent);
    }

    /* ── Gold line bottom ── */
    .splash-bottom-line {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, #c8a84b, #e8cc76, #c8a84b, transparent);
    }

    /* ── Logo ── */
    .splash-logo-wrap {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        animation: splashFadeIn 0.9s ease forwards;
        opacity: 0;
    }

    @@keyframes splashFadeIn {
        0%   { opacity: 0; transform: translateY(18px) scale(0.95); }
        100% { opacity: 1; transform: translateY(0)    scale(1);    }
    }

    .splash-logo {
        width: 200px;
        height: 200px;
        border-radius: 50%;
        object-fit: cover;
        /* Soft gold glow */
        filter: drop-shadow(0 0 28px rgba(200,168,75,0.35))
                drop-shadow(0 8px 24px rgba(0,0,0,0.45));
    }

    /* ── Text under logo ── */
    .splash-org {
        margin-top: 24px;
        text-align: center;
    }

    .splash-gov {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px;
        font-weight: 500;
        letter-spacing: 3.5px;
        color: #c8a84b;
        text-transform: uppercase;
        margin-bottom: 6px;
    }

    .splash-title {
        font-family: 'EB Garamond', serif;
        font-size: 20px;
        font-weight: 600;
        color: #ffffff;
        line-height: 1.25;
        letter-spacing: 0.3px;
    }

    .splash-sub {
        font-family: 'DM Sans', sans-serif;
        font-size: 10.5px;
        color: rgba(255,255,255,0.4);
        margin-top: 5px;
        letter-spacing: 0.3px;
    }

    /* ── Gold divider ── */
    .splash-divider {
        width: 40px;
        height: 1.5px;
        background: linear-gradient(90deg, transparent, #c8a84b, transparent);
        margin: 16px auto 0;
        border-radius: 1px;
    }

    /* ── Loading dots ── */
    .splash-loader {
        position: absolute;
        bottom: calc(52px + env(safe-area-inset-bottom, 0px));
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        animation: splashFadeIn 1.1s ease 0.3s forwards;
        opacity: 0;
        z-index: 1;
    }

    .loader-label {
        font-family: 'DM Sans', sans-serif;
        font-size: 9px;
        letter-spacing: 2.5px;
        color: rgba(255,255,255,0.25);
        text-transform: uppercase;
    }

    .loader-dots {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .dot {
        width: 5px;
        height: 5px;
        border-radius: 50%;
        background: #c8a84b;
        animation: dotPulse 1.3s ease-in-out infinite;
    }

        .dot:nth-child(1) { animation-delay: 0s;    }
        .dot:nth-child(2) { animation-delay: 0.2s;  }
        .dot:nth-child(3) { animation-delay: 0.4s;  }

    @@keyframes dotPulse {
        0%, 80%, 100% { opacity: 0.2; transform: scale(0.85); }
        40%            { opacity: 1;   transform: scale(1.15); }
    }

    /* ── Version tag ── */
    .splash-version {
        position: absolute;
        bottom: calc(18px + env(safe-area-inset-bottom, 0px));
        font-family: 'DM Sans', sans-serif;
        font-size: 8.5px;
        color: rgba(255,255,255,0.15);
        letter-spacing: 1px;
        z-index: 1;
    }
</style>


<div class="splash">

    <!-- Top + bottom gold accent lines -->
    <div class="splash-top-line"></div>
    <div class="splash-bottom-line"></div>

    <!-- Logo + Text -->
    <div class="splash-logo-wrap">

        <img class="splash-logo"
             src="images/eemo-logov2.png"
             alt="EEMO Collectors Seal" />

        <div class="splash-org">
            <div class="splash-gov">Republic of the Philippines</div>
            <div class="splash-title">
                Economic Enterprise &amp;<br />Management Office
            </div>
            <div class="splash-sub">Municipality of Cantilan, Surigao del Sur</div>
            <div class="splash-divider"></div>
        </div>

    </div>

    <!-- Loading indicator -->
    <div class="splash-loader">
        <div class="loader-dots">
            <div class="dot"></div>
            <div class="dot"></div>
            <div class="dot"></div>
        </div>
        <div class="loader-label">@LoadingText</div>
    </div>

    <!-- Version -->
    <div class="splash-version">EEMO Collectors v1.0</div>

</div>


@code {

    // Loading label — cycles through messages while waiting
    string LoadingText = "Initializing";

    // Sequence: label shown at each step → delay after it (ms)
    readonly (string Label, int Delay)[] Steps = new[]
    {
        ("Initializing",      1000),
        ("Loading data",      1000),
        ("Almost ready",      600),
    };

    private System.Threading.CancellationTokenSource _cts = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        try
        {
            foreach (var (label, delay) in Steps)
            {
                LoadingText = label;
                StateHasChanged();
                await Task.Delay(delay, _cts.Token);
            }

            // Navigate to menu — forceLoad: false = no flicker
            Navigation.NavigateTo("/login", forceLoad: false);
        }
        catch (TaskCanceledException)
        {
            // Component disposed before navigation — safe to ignore
        }
    }

    public void Dispose() => _cts.Cancel();
}
