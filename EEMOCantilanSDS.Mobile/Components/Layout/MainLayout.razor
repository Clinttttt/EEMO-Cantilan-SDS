@inherits LayoutComponentBase



<div class="full-layout">
    @Body
</div>

<style>
    *, html, body {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    html, body {
        height: 100%;
        /* allow the web content to scroll; inner pages will provide the native-like scroller */
        overflow: auto;
        color-scheme: light;
    }

    .full-layout {
        width: 100%;
        /* use dynamic viewport height to avoid mobile address bar issues */
        height: 100dvh;
        display: flex;
        flex-direction: column;
        overflow: visible;
    }
</style>