@* Shared centered load-error state with a retry action.
   Styles live in wwwroot/css/eemo.css (.empty-state*, .retry-btn). *@
<div class="empty-state">
    <div class="empty-icon">
        <svg viewBox="0 0 24 24"><line x1="1" y1="1" x2="23" y2="23" /><path d="M16.72 11.06A10.94 10.94 0 0 1 19 12.55" /><path d="M5 12.55a10.94 10.94 0 0 1 5.17-2.39" /><path d="M10.71 5.05A16 16 0 0 1 22.58 9" /><path d="M1.42 9a15.91 15.91 0 0 1 4.7-2.88" /><path d="M8.53 16.11a6 6 0 0 1 6.95 0" /><line x1="12" y1="20" x2="12.01" y2="20" /></svg>
    </div>
    <div class="empty-title">@Title</div>
    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="empty-sub">@Message</div>
    }
    @if (OnRetry.HasDelegate)
    {
        <button class="retry-btn" type="button" @onclick="OnRetry">@RetryText</button>
    }
</div>

@code {
    /// <summary>Headline, e.g. "Couldn't load records".</summary>
    [Parameter] public string Title { get; set; } = "Something went wrong";

    /// <summary>Optional detail line (typically the server/connection message).</summary>
    [Parameter] public string? Message { get; set; }

    /// <summary>Retry button label.</summary>
    [Parameter] public string RetryText { get; set; } = "Try again";

    /// <summary>Invoked when the retry button is tapped. If unset, the button is hidden.</summary>
    [Parameter] public EventCallback OnRetry { get; set; }
}
