@* ═══════════════════════════════════════════════════════════
   BottomNav.razor  —  Shared EEMO bottom navigation
   Place in: Components/Shared/BottomNav.razor

   USAGE:
     <BottomNav ActiveTab="menu" />
     <BottomNav ActiveTab="records" />
     <BottomNav ActiveTab="reports" />
     <BottomNav ActiveTab="profile" />

   ActiveTab values: "menu" | "records" | "reports" | "profile"
═══════════════════════════════════════════════════════════ *@

@inject NavigationManager Navigation

<div class="bottom-nav">

    <div class="nav-item @(ActiveTab == "menu" ? "active" : "")"
         @onclick='() => GoTo("/menu")'>
        <svg viewBox="0 0 24 24">
            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" />
        </svg>
        <span class="nav-label">Menu</span>
    </div>

    <div class="nav-item @(ActiveTab == "records" ? "active" : "")"
         @onclick='() => GoTo("/records")'>
        <svg viewBox="0 0 24 24">
            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
            <polyline points="14 2 14 8 20 8" />
        </svg>
        <span class="nav-label">Records</span>
    </div>

    <div class="nav-item @(ActiveTab == "reports" ? "active" : "")"
         @onclick='() => GoTo("/reports")'>
        <svg viewBox="0 0 24 24">
            <line x1="18" y1="20" x2="18" y2="10" />
            <line x1="12" y1="20" x2="12" y2="4" />
            <line x1="6" y1="20" x2="6" y2="14" />
        </svg>
        <span class="nav-label">Reports</span>
    </div>

    <div class="nav-item @(ActiveTab == "profile" ? "active" : "")"
         @onclick='() => GoTo("/profile")'>
        <svg viewBox="0 0 24 24">
            <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
            <circle cx="12" cy="7" r="4" />
        </svg>
        <span class="nav-label">Profile</span>
    </div>

</div>

@code {

    /// <summary>Which tab to mark as active.
    /// Values: "menu" | "records" | "reports" | "profile"</summary>
    [Parameter] public string ActiveTab { get; set; } = "menu";

    // Navigation uses forceLoad: false — no flicker, no history stack corruption
    void GoTo(string path) => Navigation.NavigateTo(path, forceLoad: false);
}
